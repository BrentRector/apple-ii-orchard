4660  A9B9              ; ----------------------------------------------------------------------
4661  A9B9              DIRBUF_PTR:
4662  A9B9 00 00                DEFB    "\0\0"
4663  A9BB              ; ----------------------------------------------------------------------
4664  A9BB              ; DPB_PTR -- Pointer to the current drive's Disk Parameter Block (DPB). [RE]
4665  A9BB              ; ----------------------------------------------------------------------
4666  A9BB              DPB_PTR:
4667  A9BB 00 00                DEFB    "\0\0"
4668  A9BD              ; ----------------------------------------------------------------------
4669  A9BD              ; REC_BYTE_OFFSET -- Byte offset of the current record within the host sector (deblocking). [RE]
4670  A9BD              ; ----------------------------------------------------------------------
4671  A9BD              REC_BYTE_OFFSET:
4672  A9BD 00 00                DEFB    "\0\0"
4673  A9BF              ; ----------------------------------------------------------------------
4674  A9BF              ; ALLOC_VEC_PTR -- Pointer to the current drive's allocation vector (ALV). [RE]
4675  A9BF              ; ----------------------------------------------------------------------
4676  A9BF              ALLOC_VEC_PTR:
4677  A9BF 00 00                DEFB    "\0\0"
4678  A9C1              ; ----------------------------------------------------------------------
4679  A9C1              ; DPB_SPT -- DPB field SPT: sectors per track for the current drive. [RE]
4680  A9C1              ; ----------------------------------------------------------------------
4681  A9C1              DPB_SPT:
4682  A9C1 00 00                DEFB    "\0\0"
4683  A9C3              ; ----------------------------------------------------------------------
4684  A9C3              ; DPB_BSH -- DPB field BSH: block shift factor (log2 of records per block). [RE]
4685  A9C3              ; ----------------------------------------------------------------------
4686  A9C3              DPB_BSH:
4687  A9C3 00                   DEFB    "\0"
4688  A9C4              ; ----------------------------------------------------------------------
4689  A9C4              ; DPB_BLM -- DPB field BLM: block mask (records per block minus 1). [RE]
4690  A9C4              ; ----------------------------------------------------------------------
4691  A9C4              DPB_BLM:
4692  A9C4 00                   DEFB    "\0"
4693  A9C5              ; ----------------------------------------------------------------------
4694  A9C5              ; DPB_EXM -- DPB field EXM: extent mask. [RE]
4695  A9C5              ; ----------------------------------------------------------------------
4696  A9C5              DPB_EXM:
4697  A9C5 00                   DEFB    "\0"
4698  A9C6              ; ----------------------------------------------------------------------
4699  A9C6              ; MAX_BLOCK_DSM -- DPB field DSM: highest block number on the drive (disk size in blocks minus 1).
4700  A9C6              ; [RE]
4701  A9C6              ; ----------------------------------------------------------------------
4702  A9C6              MAX_BLOCK_DSM:
4703  A9C6 00 00                DEFB    "\0\0"
4704  A9C8              ; ----------------------------------------------------------------------
4705  A9C8              ; DPB_REC_PTR -- DPB field DRM-related record pointer / directory max entries working cell. [RE]
4706  A9C8              ; ----------------------------------------------------------------------
4707  A9C8              DPB_REC_PTR:
4708  A9C8 00 00                DEFB    "\0\0"
4709  A9CA              ; ----------------------------------------------------------------------

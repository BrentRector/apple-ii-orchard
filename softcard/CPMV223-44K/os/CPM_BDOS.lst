4648  A9B5              ; cache. [RE]
4649  A9B5              ; ----------------------------------------------------------------------
4650  A9B5              DEBLOCK_HSTREC_PTR0:
4651  A9B5 00 00                DEFB    "\0\0"
4652  A9B7              ; ----------------------------------------------------------------------
4653  A9B7              ; DEBLOCK_HSTREC_PTR1 -- Deblocking host-record pointer (high half) for the record/sector buffer
4654  A9B7              ; cache. [RE]
4655  A9B7              ; ----------------------------------------------------------------------
4656  A9B7              DEBLOCK_HSTREC_PTR1:
4657  A9B7 00 00                DEFB    "\0\0"
4658  A9B9              ; ----------------------------------------------------------------------

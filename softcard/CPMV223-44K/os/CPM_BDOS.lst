4637  A9B1              ; ----------------------------------------------------------------------
4638  A9B1              DMA_ADDR:
4639  A9B1 80 00                DEFB    $80,$00
4640  A9B3              ; ----------------------------------------------------------------------
4641  A9B3              ; DPB_WORK_PTR0 -- Scratch pointer used while walking the Disk Parameter Block / allocation vector.
4642  A9B3              ; [RE]
4643  A9B3              ; ----------------------------------------------------------------------
4644  A9B3              DPB_WORK_PTR0:
4645  A9B3 00 00                DEFB    "\0\0"
4646  A9B5              ; ----------------------------------------------------------------------

# file opened: CPM_BDOS.asm
   1  0000              ; ============================================================================
   2  0000              ; Microsoft SoftCard CP/M 2.23 (44K) -- BDOS (Basic Disk Operating System)
   3  0000              ; ----------------------------------------------------------------------------
   4  0000              ; Runtime-addressed (de-skewed): ORG $9C00 (FBASE), runs $9C00-$A9FF. An independent
   5  0000              ; compilation; references the CCP warm-boot entry once (CCP_WBOOT). The 44K system
   6  0000              ; tracks store this sector-interleaved; the disk producer re-applies the skew. See
   7  0000              ; ../../docs/CPM_Skew_Findings.md.
   8  0000              ; ============================================================================
   9  0000
  10  0000                  IFNDEF CPM_LINK
  11  0000                  DEVICE NOSLOT64K
  12  0000                  INCLUDE "cpm22.inc"
# file opened: cpm22.inc
   1+ 0000              ; cpm22.inc -- canonical Digital Research CP/M 2.2 definitions shared by SoftCard
   2+ 0000              ; CP/M sources.  Defined ONCE here and INCLUDEd by each source rather than re-deriving
   3+ 0000              ; magic numbers per file.  EQUs are zero-width, so including this is byte-identical.
   4+ 0000              ; This is the OS/ABI counterpart to apple_softcard.inc (which holds the Apple/SoftCard
   5+ 0000              ; HARDWARE externals); keep the two concerns separate.
   6+ 0000              ;
   7+ 0000              ; Source: CP/M 2.2 Interface Guide / "CP/M Reference Manual" [DOC CPMREF] (in the
   8+ 0000              ; archive at softcard/reference/softcard-cpm-archive/manuals/transcribed/).
   9+ 0000              ;
  10+ 0000              ; NOTE on the base page: $0000 (warm-boot JP) and $0005 (BDOS JP) are implementation
  11+ 0000              ; LABELS inside the BIOS/CCP/BDOS modules but CALL TARGETS in transient programs.  The
  12+ 0000              ; cell EQUs below are for the transient-program (caller) view; an OS module that DEFINES
  13+ 0000              ; these vectors as its own labels should not also pull in this base-page section.
  14+ 0000
  15+ 0000              ; ---- base page (transient-program view) ----------------------------------------
  16+ 0000              WBOOTV      EQU $0000      ; warm-boot vector: JP WBOOT (a CALL/JP $0000 restarts CP/M)
  17+ 0000              IOBYTE_ADDR EQU $0003      ; logical<->physical device map (STAT / fns 7,8)
  18+ 0000              CDISK_ADDR  EQU $0004      ; current drive (low nibble) / user (high nibble)
  19+ 0000              BDOS        EQU $0005      ; BDOS entry vector: CALL BDOS with C=function, DE=arg
  20+ 0000              RST2_VEC    EQU $0010      ; Z-80 RST 2 ($10) restart vector (8 bytes); CP/M leaves it for the app/debugger
  21+ 0000              RST4_VEC    EQU $0020      ; Z-80 RST 4 ($20) restart vector (8 bytes); CP/M leaves it for the app/debugger
  22+ 0000              TFCB        EQU $005C      ; default FCB parsed from the command tail
  23+ 0000              TFCB2       EQU $006C      ; second parsed FCB (overlaps TFCB+16)
  24+ 0000              TBUFF       EQU $0080      ; default DMA buffer (128 B); also the command-tail buffer
  25+ 0000              CMDLINE     EQU $0081      ; command-tail characters (TBUFF+1): $0080 = length, $0081+ = the upper-cased tail
  26+ 0000              TPA         EQU $0100      ; transient program area / load address
  27+ 0000
  28+ 0000              ; ---- BDOS function numbers (register C) ----------------------------------------
  29+ 0000              P_TERMCPM   EQU 0          ; system reset (return to CCP)
  30+ 0000              C_READ      EQU 1          ; console input (echoed) -> A
  31+ 0000              C_WRITE     EQU 2          ; console output (E = char)
  32+ 0000              A_READ      EQU 3          ; reader (AUX) input -> A
  33+ 0000              A_WRITE     EQU 4          ; punch (AUX) output (E = char)
  34+ 0000              L_WRITE     EQU 5          ; list (printer) output (E = char)
  35+ 0000              C_RAWIO     EQU 6          ; direct console I/O (E=$FF read / else write)
  36+ 0000              A_STATIN    EQU 7          ; get IOBYTE -> A
  37+ 0000              A_STATOUT   EQU 8          ; set IOBYTE (E = value)
  38+ 0000              C_WRITESTR  EQU 9          ; print '$'-terminated string (DE -> string)
  39+ 0000              C_READSTR   EQU 10         ; buffered console line input (DE -> buffer)
  40+ 0000              C_STAT      EQU 11         ; console status -> A (0 = none ready)
  41+ 0000              S_BDOSVER   EQU 12         ; return BDOS version -> HL
  42+ 0000              DRV_ALLRESET EQU 13        ; reset disk system
  43+ 0000              DRV_SET     EQU 14         ; select drive (E = 0=A..15=P)
  44+ 0000              F_OPEN      EQU 15         ; open file (DE -> FCB)
  45+ 0000              F_CLOSE     EQU 16         ; close file (DE -> FCB)
  46+ 0000              F_SFIRST    EQU 17         ; search for first (DE -> FCB)
  47+ 0000              F_SNEXT     EQU 18         ; search for next
  48+ 0000              F_DELETE    EQU 19         ; delete file (DE -> FCB)
  49+ 0000              F_READ      EQU 20         ; read sequential (DE -> FCB)
  50+ 0000              F_WRITE     EQU 21         ; write sequential (DE -> FCB)
  51+ 0000              F_MAKE      EQU 22         ; create file (DE -> FCB)
  52+ 0000              F_RENAME    EQU 23         ; rename file (DE -> FCB)
  53+ 0000              DRV_LOGINVEC EQU 24        ; return login vector -> HL
  54+ 0000              DRV_GET     EQU 25         ; return current drive -> A
  55+ 0000              F_DMAOFF    EQU 26         ; set DMA address (DE)
  56+ 0000              DRV_ALLOCVEC EQU 27        ; return allocation vector -> HL
  57+ 0000              DRV_SETRO   EQU 28         ; write-protect current drive
  58+ 0000              DRV_ROVEC   EQU 29         ; return read-only vector -> HL
  59+ 0000              F_ATTRIB    EQU 30         ; set file attributes (DE -> FCB)
  60+ 0000              DRV_DPB     EQU 31         ; return DPB address -> HL
  61+ 0000              F_USERNUM   EQU 32         ; get/set user number (E=$FF get / else set)
  62+ 0000              F_READRAND  EQU 33         ; read random (DE -> FCB)
  63+ 0000              F_WRITERAND EQU 34         ; write random (DE -> FCB)
  64+ 0000              F_SIZE      EQU 35         ; compute file size (DE -> FCB)
  65+ 0000              F_RANDREC   EQU 36         ; set random record (DE -> FCB)
  66+ 0000              DRV_RESET   EQU 37         ; reset drives (DE = drive vector)
  67+ 0000              F_WRITEZF   EQU 40         ; write random with zero fill (DE -> FCB)
  68+ 0000
  69+ 0000              ; ---- FCB field offsets (from the start of a 36-byte FCB) ------------------------
  70+ 0000              FCB_DR      EQU 0          ; drive code (0 = default, 1..16 = A..P)
  71+ 0000              FCB_F       EQU 1          ; filename (8 bytes, space-padded)
  72+ 0000              FCB_T       EQU 9          ; filetype (3 bytes; hi bits = R/O, SYS, archive)
  73+ 0000              FCB_EX      EQU 12         ; current extent
  74+ 0000              FCB_S1      EQU 13         ; reserved
  75+ 0000              FCB_S2      EQU 14         ; reserved (extent high)
  76+ 0000              FCB_RC      EQU 15         ; record count for the current extent (0..128)
  77+ 0000              FCB_CR      EQU 32         ; current record within the extent
  78+ 0000              FCB_R0      EQU 33         ; random record number, low byte
  79+ 0000              FCB_R1      EQU 34         ; random record number, middle byte
  80+ 0000              FCB_R2      EQU 35         ; random record number, high byte (overflow)
  81+ 0000
# file closed: cpm22.inc
  13  0000                  INCLUDE "cpm_system_223.inc"
# file opened: cpm_system_223.inc
   1+ 0000              ; ============================================================================
   2+ 0000              ; cpm_system_223.inc -- CP/M 2.23 (44K) cross-module system contract
   3+ 0000              ; ----------------------------------------------------------------------------
   4+ 0000              ; The de-skewed 2.23-44K system image is TWO independent compilations -- the CCP
   5+ 0000              ; ($9300-$9BFF) and the BDOS ($9C00-$A9FF) -- decoded at their true RUNTIME
   6+ 0000              ; addresses (see ../docs/CPM_Skew_Findings.md). On the correctly-addressed source
   7+ 0000              ; the two are almost decoupled: the CCP calls the BDOS only through the page-zero
   8+ 0000              ; $0005 ABI (cpm22.inc :: BDOS), and the ONLY direct cross-module symbols are the
   9+ 0000              ; module bases + the warm-boot re-entry below. Defined ONCE here, INCLUDEd by both
  10+ 0000              ; (never duplicated -- feedback_no_duplicate_symbol_definitions).
  11+ 0000              ; ============================================================================
  12+ 0000
  13+ 0000              CCP_BASE   EQU $9300      ; CCP cold entry (the BIOS cold/warm boot lands here)
  14+ 0000              CCP_WBOOT  EQU $9B06      ; CCP warm-boot re-entry the BDOS returns through
  15+ 0000              BDOS_FBASE EQU $9C00      ; FBASE: BDOS image base (6-byte serial + JP entry)
  16+ 0000
# file closed: cpm_system_223.inc
  14  0000                  ORG $9C00
  15  9C00                  ENDIF
  16  9C00 BD 16 00 01          DEFB    $BD,$16,$00,$01,$4D,$40
  16  9C04 4D 40
  17  9C06              ; ----------------------------------------------------------------------
  18  9C06              ; BDOS_ENTRY -- the BDOS=$0005-vector landing point (FBASE+6); jumps to the function dispatcher.
  19  9C06              ;   In: C = BDOS function number, DE = info address (or single-byte arg in E) -- the standard $0005
  20  9C06              ;       call ABI.
  21  9C06              ;   Out: jumps to BDOS_DISPATCH; never returns here (the handler RETs through the common BDOS exit).
  22  9C06              ;   Clobbers: none of its own (single JP).
  23  9C06              ;   Algorithm: OBSERVED -- one JP BDOS_DISPATCH. The page-zero $0005 jump-vector targets this
  24  9C06              ;              address ($9C06), so every BDOS call enters here. [RE]
  25  9C06              ; ----------------------------------------------------------------------
  26  9C06              BDOS_ENTRY:
  27  9C06 C3 11 9C             JP BDOS_DISPATCH
  28  9C09              ; ----------------------------------------------------------------------
  29  9C09              ; BDOS_ERR_VECTORS -- DATA: first entry of a 4-word table of BDOS disk-error reporter addresses.
  30  9C09              ;   In: a caller does LD HL,<one of these 4 word slots> then falls into the reporter helper at
  31  9C09              ;       BDOS_VECTOR_JUMP ($9F4A), which does LD E,(HL)/INC HL/LD D,(HL)/EX DE,HL/JP (HL).
  32  9C09              ;   Out: this slot's word is the run address of the Bad-Sector (permanent disk) error reporter.
  33  9C09              ;   Clobbers: n/a (data).
  34  9C09              ;   Algorithm: OBSERVED -- two DATA bytes ($99 $9C) forming the Bad-Sector reporter address;
  35  9C09              ;              mis-decoded as SBC A,C / SBC A,H. The four reporters print 'Bdos Err On d:' then a
  36  9C09              ;              '$'-terminated cause string ('Bad Sector'/'Select'/'R/O'/'File R/O'). [RE]
  37  9C09              ; ----------------------------------------------------------------------
  38  9C09              BDOS_ERR_VECTORS:
  39  9C09 99                   SBC A,C
  40  9C0A 9C                   SBC A,H
  41  9C0B              ; ----------------------------------------------------------------------
  42  9C0B              ; BDOS_ERRVEC_SELECT -- DATA: word for the Select-error reporter in the BDOS error-vector table.
  43  9C0B              ;   In: n/a (data; loaded into HL by the helper front-end at BDOS_ERR_SELECT ($9F47) before
  44  9C0B              ;       falling into the $9F4A reporter dispatch).
  45  9C0B              ;   Out: n/a (the word here is the run address of the 'Select' error reporter; prints then
  46  9C0B              ;        warm-boots).
  47  9C0B              ;   Clobbers: n/a (data).
  48  9C0B              ;   Algorithm: OBSERVED -- two DATA bytes ($A5 $9C) forming the Select-error reporter address;
  49  9C0B              ;              mis-decoded as AND L / SBC A,H. [RE]
  50  9C0B              ; ----------------------------------------------------------------------
  51  9C0B              BDOS_ERRVEC_SELECT:
  52  9C0B A5                   AND L
  53  9C0C 9C                   SBC A,H
  54  9C0D              ; ----------------------------------------------------------------------
  55  9C0D              ; BDOS_ERRVEC_RODISK -- DATA: word for the R/O-disk error reporter in the BDOS error-vector table.
  56  9C0D              ;   In: n/a (data; loaded into HL by the caller reached when a write is attempted to a R/O-flagged
  57  9C0D              ;       drive).
  58  9C0D              ;   Out: n/a (the word here is the run address of the reporter that prints 'R/O').
  59  9C0D              ;   Clobbers: n/a (data).
  60  9C0D              ;   Algorithm: OBSERVED -- two DATA bytes ($AB $9C) forming the R/O-disk reporter address;
  61  9C0D              ;              mis-decoded as XOR E / SBC A,H. Exact CP/M error sub-class UNKNOWN; cause string
  62  9C0D              ;              'R/O'. [RE]
  63  9C0D              ; ----------------------------------------------------------------------
  64  9C0D              BDOS_ERRVEC_RODISK:
  65  9C0D AB                   XOR E
  66  9C0E 9C                   SBC A,H
  67  9C0F              ; ----------------------------------------------------------------------
  68  9C0F              ; BDOS_ERRVEC_FILERO -- DATA: word for the File-R/O error reporter in the BDOS error-vector table.
  69  9C0F              ;   In: n/a (data; loaded into HL by the caller reached on a write to a read-only file).
  70  9C0F              ;   Out: n/a (the word here is the run address of the reporter that prints 'File R/O').
  71  9C0F              ;   Clobbers: n/a (data).
  72  9C0F              ;   Algorithm: OBSERVED -- two DATA bytes ($B1 $9C) forming the File-R/O reporter address;
  73  9C0F              ;              mis-decoded as OR C / SBC A,H. Last of the 4 error-vector words; BDOS_DISPATCH
  74  9C0F              ;              follows. [RE]
  75  9C0F              ; ----------------------------------------------------------------------
  76  9C0F              BDOS_ERRVEC_FILERO:
  77  9C0F B1                   OR C
  78  9C10 9C                   SBC A,H
  79  9C11              ; ----------------------------------------------------------------------
  80  9C11              ; BDOS_DISPATCH -- the CP/M 2.2 FDOS dispatcher: set up the BDOS frame and vector to the handler.
  81  9C11              ;   In: C = BDOS function number (valid 0..40); DE = info address (single-byte arg also in E);
  82  9C11              ;       caller SP live.
  83  9C11              ;   Out: control transfers (JP (HL)) to the selected handler with HL = caller info-address; on
  84  9C11              ;        out-of-range C (>= 41) it RETs straight to the just-pushed common exit (default 0 result).
  85  9C11              ;   Clobbers: A, BC, DE, HL, SP (switches to the private BDOS stack).
  86  9C11              ;   Algorithm: OBSERVED -- save caller DE into BDOS_PARAM_PTR; copy low byte E into the
  87  9C11              ;              drive/byte-arg
  88  9C11              ;              cell; default BDOS_RETVAL to 0; capture caller SP into BDOS_SAVED_SP and switch SP to
  89  9C11              ;              BDOS_STACK_TOP; clear two per-call state cells; push the common BDOS exit ($A974) so
  90  9C11              ;              every handler RETs through it; range-check A(=C) against $29 (41) -- CP $29 / RET NC
  91  9C11              ;              returns when A >= 41. Then move byte-arg E into C, index BDOS_DISPATCH_TBL by 2*A
  92  9C11              ;              (two ADD HL,DE), fetch the handler word into DE, reload the saved info-address into
  93  9C11              ;              HL,
  94  9C11              ;              EX DE,HL, JP (HL). Static-indexed: function N selects table entry N. [RE]
  95  9C11              ; ----------------------------------------------------------------------
  96  9C11              BDOS_DISPATCH:
  97  9C11 EB                   EX DE,HL
  98  9C12 22 43 9F             LD (BDOS_PARAM_PTR),HL
  99  9C15 EB                   EX DE,HL
 100  9C16 7B                   LD A,E
 101  9C17 32 D6 A9             LD (DRV_SELECT_ARG),A
 102  9C1A 21 00 00             LD HL,$0000
 103  9C1D 22 45 9F             LD (BDOS_RETVAL),HL
 104  9C20 39                   ADD HL,SP
 105  9C21 22 0F 9F             LD (BDOS_SAVED_SP),HL
 106  9C24 31 41 9F             LD SP,BDOS_STACK_TOP
 107  9C27 AF                   XOR A
 108  9C28 32 E0 A9             LD (DRV_SAVED_FCB_BYTE),A
 109  9C2B 32 DE A9             LD (DRV_RESTORE_FLAG),A
 110  9C2E 21 74 A9             LD HL,FCB_AUTO_DRIVE_RESTORE
 111  9C31 E5                   PUSH HL
 112  9C32 79                   LD A,C
 113  9C33 FE 29                CP $29
 114  9C35 D0                   RET NC
 115  9C36 4B                   LD C,E
 116  9C37 21 47 9C             LD HL,BDOS_DISPATCH_TBL
 117  9C3A 5F                   LD E,A
 118  9C3B 16 00                LD D,$00
 119  9C3D 19                   ADD HL,DE
 120  9C3E 19                   ADD HL,DE
 121  9C3F 5E                   LD E,(HL)
 122  9C40 23                   INC HL
 123  9C41 56                   LD D,(HL)
 124  9C42 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
 125  9C45 EB                   EX DE,HL
 126  9C46 E9                   JP (HL)
 127  9C47              ; ----------------------------------------------------------------------
 128  9C47              ; BDOS_DISPATCH_TBL -- 41-entry BDOS function dispatch table (one handler address per fn 0..40).
 129  9C47              ;   In: indexed by 2*A (the function number) in BDOS_DISPATCH.
 130  9C47              ;   Out: the selected word is fetched and entered via JP (HL).
 131  9C47              ;   Clobbers: n/a (data).
 132  9C47              ;   Algorithm: OBSERVED -- a table of 16-bit handler run addresses, verified function-for-function
 133  9C47              ;              against the 2.20-44K twin (same order). In-image handlers ($9Cxx-$A8xx) render as
 134  9C47              ;              labels; BIOS-vector slots target $FAxx (2.23 BIOS variable page = Apple $0A00) where
 135  9C47              ;              2.20-44K uses $AAxx. Functions 4..11 sit in the DEFB run at $9C4F. Functions 0-36
 136  9C47              ;              ($00-$24) are the standard CP/M 2.2 set; slots 37-40 are SoftCard extensions
 137  9C47              ;              (37 = drive-login mask, 38/39 = RET no-op at $9F04, 40 = Write Random Zero Fill).
 138  9C47              ;              [RE]
 139  9C47              ;   Order (fn: target): 0 SysReset $FA03; 1 C_READ F_CONIN_H; 2 C_WRITE F_CONOUT_H; 3 A_READ
 140  9C47              ;     F_READERIN_H; 4 A_WRITE $FA12; 5 L_WRITE $FA0F; 6 C_RAWIO F_DIRECTIO_H; 7 A_STATIN F_GETIOB_H;
 141  9C47              ;     8 A_STATOUT F_SETIOB_H; 9 C_WRITESTR F_PRINTSTR_H; 10 C_READSTR F_READCONBUF_H; 11 C_STAT
 142  9C47              ;     F_CONSTAT_H; 12-40 = the file/drive ops (handlers above $A0F7, decoded in the rest of the
 143  9C47              ;     file). [RE]
 144  9C47              ; ----------------------------------------------------------------------
 145  9C47              BDOS_DISPATCH_TBL:
 146  9C47 03 FA                DEFW    $FA03
 147  9C49 C8 9E                DEFW    F_CONIN_H
 148  9C4B 90 9D                DEFW    F_CONOUT_H
 149  9C4D CE 9E                DEFW    F_READERIN_H
 150  9C4F 12 FA 0F FA          DEFB    $12,$FA,$0F,$FA,$D4,$9E,$ED,$9E,$F3,$9E,$F8,$9E,$E1,$9D,$FE,$9E
 150  9C53 D4 9E ED 9E
 150  9C57 F3 9E F8 9E
 150  9C5B E1 9D FE 9E
 151  9C5F 7E A8                DEFW    S_BDOSVER_H
 152  9C61 83 A8                DEFW    DRV_ALLRESET_H
 153  9C63 45 A8                DEFW    DRV_SET_H
 154  9C65 9C A8                DEFW    F_OPEN_H
 155  9C67 A5 A8                DEFW    F_CLOSE_H
 156  9C69 AB A8                DEFW    F_SFIRST_H
 157  9C6B C8 A8                DEFW    F_SNEXT_H
 158  9C6D D7 A8                DEFW    F_DELETE_H
 159  9C6F E0 A8                DEFW    F_READ_H
 160  9C71 E6 A8                DEFW    F_WRITE_H
 161  9C73 EC A8                DEFW    F_MAKE_H
 162  9C75 F5 A8                DEFW    F_RENAME_H
 163  9C77 FE A8                DEFW    DRV_LOGINVEC_H
 164  9C79 04 A9                DEFW    DRV_GET_H
 165  9C7B 0A A9                DEFW    F_DMAOFF_H
 166  9C7D 11 A9                DEFW    DRV_ALLOCVEC_H
 167  9C7F 2C A1                DEFW    DRV_SETRO_H
 168  9C81 17 A9                DEFW    DRV_ROVEC_H
 169  9C83 1D A9                DEFW    F_ATTRIB_H
 170  9C85 26 A9                DEFW    DRV_DPB_H
 171  9C87 2D A9                DEFW    F_USERNUM_H
 172  9C89 41 A9                DEFW    F_READRAND_H
 173  9C8B 47 A9                DEFW    F_WRITERAND_H
 174  9C8D 4D A9                DEFW    F_SIZE_H
 175  9C8F 0E A8                DEFW    F_RANDREC_H
 176  9C91 53 A9                DEFW    DRV_RESET_H
 177  9C93 04 9F                DEFW    $9F04
 178  9C95 04 9F                DEFW    $9F04
 179  9C97 9B A9                DEFW    F_WRITEZF_H
 180  9C99 21 CA                DEFW    $CA21
 181  9C9B 9C CD                DEFW    $CD9C
 182  9C9D E5 9C                DEFW    BDOS_ERR_PRINT
 183  9C9F FE 03                DEFW    $03FE
 184  9CA1 CA 00                DEFW    $00CA
 185  9CA3 00 C9                DEFW    $C900
 186  9CA5 21 D5                DEFW    $D521
 187  9CA7 9C C3                DEFW    $C39C
 188  9CA9 B4 9C 21 E1          DEFB    $B4,$9C,$21,$E1,$9C,$C3,$B4,$9C,$21,$DC,$9C,$CD,$E5,$9C,$C3,$00
 188  9CAD 9C C3 B4 9C
 188  9CB1 21 DC 9C CD
 188  9CB5 E5 9C C3 00
 189  9CB9 00                   DEFB    "\0"
 190  9CBA              ; ----------------------------------------------------------------------
 191  9CBA              ; BDOS_ERR_MSG_HEAD -- '$'-terminated head of the BDOS error banner: 'Bdos Err On '.
 192  9CBA              ;   [RE] Printed by BDOS_ERR_PRINT; the drive letter is patched into the byte that follows.
 193  9CBA              ; ----------------------------------------------------------------------
 194  9CBA              BDOS_ERR_MSG_HEAD:
 195  9CBA 42 64 6F 73          DEFB    "Bdos Err On "           ; string
 195  9CBE 20 45 72 72
 195  9CC2 20 4F 6E 20
 196  9CC6              ; ----------------------------------------------------------------------
 197  9CC6              ; BDOS_ERR_MSG_DRIVE -- drive-letter slot plus the four '$'-delimited error reasons.
 198  9CC6              ;   Layout: 1 patched drive-letter byte, then ' : $', 'Bad Sector$', 'Select$', 'File R/O$'.
 199  9CC6              ;   [RE] BDOS_ERR_PRINT overwrites the first byte with 'A'+drive, then prints from here; the
 200  9CC6              ;   selected
 201  9CC6              ;        reason string (at +4 / +15 / +22) is pointed to by HL on entry to the trap.
 202  9CC6              ; ----------------------------------------------------------------------
 203  9CC6              BDOS_ERR_MSG_DRIVE:
 204  9CC6 20 3A 20 24          DEFB    " : $Bad Sector$Select$File R/O$" ; string
 204  9CCA 42 61 64 20
 204  9CCE 53 65 63 74
 204  9CD2 6F 72 24 53
 204  9CD6 65 6C 65 63
 204  9CDA 74 24 46 69
 204  9CDE 6C 65 20 52
 204  9CE2 2F 4F 24
 205  9CE5              ; ----------------------------------------------------------------------
 206  9CE5              ; BDOS_ERR_PRINT -- print the 'Bdos Err On d: <reason>' banner to the console.
 207  9CE5              ;   In: HL = pointer to the trailing reason string ('$'-terminated); BDOS_CUR_DRIVE = drive index.
 208  9CE5              ;   Out: banner echoed via the console-output path; the entry HL is consumed (PUSH/POP).
 209  9CE5              ;   Clobbers: AF, BC, HL.
 210  9CE5              ;   Algorithm: save the reason pointer (PUSH HL); print CR/LF (CON_CRLF); form drive letter
 211  9CE5              ;              'A'+BDOS_CUR_DRIVE and patch it into BDOS_ERR_MSG_DRIVE; print the fixed head via BC;
 212  9CE5              ;              then POP the reason pointer into BC and print it, each through CON_PRINT_STR.
 213  9CE5              ;   [RE] Standard CP/M 2.2 BDOS error reporter.
 214  9CE5              ; ----------------------------------------------------------------------
 215  9CE5              BDOS_ERR_PRINT:
 216  9CE5 E5                   PUSH HL
 217  9CE6 CD C9 9D             CALL CON_CRLF
 218  9CE9                      ; Current drive index (0=A) from BDOS_CUR_DRIVE
 219  9CE9 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
 220  9CEC                      ; Convert drive index to a letter 'A'+n
 221  9CEC C6 41                ADD A,$41
 222  9CEE 32 C6 9C             LD (BDOS_ERR_MSG_DRIVE),A
 223  9CF1                      ; Point BC at the fixed head 'Bdos Err On '
 224  9CF1 01 BA 9C             LD BC,BDOS_ERR_MSG_HEAD
 225  9CF4 CD D3 9D             CALL CON_PRINT_STR
 226  9CF7 C1                   POP BC
 227  9CF8 CD D3 9D             CALL CON_PRINT_STR
 228  9CFB              ; ----------------------------------------------------------------------
 229  9CFB              ; CON_GETC_OR_RAW -- return the 1-char type-ahead if present, else read raw console input.
 230  9CFB              ;   In: CON_PENDING_CHAR = pending look-ahead char (0 if none).
 231  9CFB              ;   Out: A = next console character; CON_PENDING_CHAR cleared if it supplied the byte.
 232  9CFB              ;   Clobbers: AF, HL.
 233  9CFB              ;   Algorithm: if CON_PENDING_CHAR nonzero, consume and return it; otherwise call the BIOS
 234  9CFB              ;              console-input vector ($FA09, the 2.23 BIOS variable page) for a fresh key.
 235  9CFB              ;   [RE] Single-byte console un-get buffer used by the line editor and CONIN.
 236  9CFB              ; ----------------------------------------------------------------------
 237  9CFB              CON_GETC_OR_RAW:
 238  9CFB 21 0E 9F             LD HL,CON_PENDING_CHAR
 239  9CFE 7E                   LD A,(HL)
 240  9CFF 36 00                LD (HL),$00
 241  9D01 B7                   OR A
 242  9D02 C0                   RET NZ
 243  9D03                      ; BIOS CONIN vector (2.23 BIOS variable page $FA00 = Apple low RAM $0A00)
 244  9D03 C3 09 FA             JP $FA09
 245  9D06              ; ----------------------------------------------------------------------
 246  9D06              ; F_CONIN_RAW -- read one console char, echoing it unless it is a control char.
 247  9D06              ;   In: none.  Out: A = character read (7-bit not masked here).  Clobbers: AF, BC, HL.
 248  9D06              ;   Algorithm: fetch a char (CON_GETC_OR_RAW); if it is a handled control (IS_CTRL_CHAR sets carry)
 249  9D06              ;              skip echo; otherwise echo via F_CONOUT_H, preserving the char.
 250  9D06              ;   [RE] Backs BDOS function 1 (Console Input with echo).
 251  9D06              ; ----------------------------------------------------------------------
 252  9D06              F_CONIN_RAW:
 253  9D06 CD FB 9C             CALL CON_GETC_OR_RAW
 254  9D09 CD 14 9D             CALL IS_CTRL_CHAR
 255  9D0C D8                   RET C
 256  9D0D F5                   PUSH AF
 257  9D0E 4F                   LD C,A
 258  9D0F CD 90 9D             CALL F_CONOUT_H
 259  9D12 F1                   POP AF
 260  9D13 C9                   RET
 261  9D14              ; ----------------------------------------------------------------------
 262  9D14              ; IS_CTRL_CHAR -- classify a char as a special/control code for echo suppression.
 263  9D14              ;   In: A = character.
 264  9D14              ;   Out: Z set if A is CR/LF/TAB/BS; CARRY reflects A<' ' from the final CP $20 (carry set => below
 265  9D14              ;        space, i.e. an unhandled control char).
 266  9D14              ;   Clobbers: AF.
 267  9D14              ;   Algorithm: compare A against CR(0D), LF(0A), TAB(09), BS(08) returning Z on a hit; else fall
 268  9D14              ;              through to CP ' ' so carry tells printable-vs-control. [RE]
 269  9D14              ; ----------------------------------------------------------------------
 270  9D14              IS_CTRL_CHAR:
 271  9D14 FE 0D                CP $0D
 272  9D16 C8                   RET Z
 273  9D17 FE 0A                CP $0A
 274  9D19 C8                   RET Z
 275  9D1A FE 09                CP $09
 276  9D1C C8                   RET Z
 277  9D1D FE 08                CP $08
 278  9D1F C8                   RET Z
 279  9D20 FE 20                CP $20
 280  9D22 C9                   RET
 281  9D23              ; ----------------------------------------------------------------------
 282  9D23              ; CON_POLL_STATUS -- console-status poll that also traps Ctrl-S/Ctrl-C while idle.
 283  9D23              ;   In: CON_PENDING_CHAR = type-ahead char (nonzero => a key is already pending).
 284  9D23              ;   Out: A = 1 if a character is ready, 0 if not.
 285  9D23              ;   Clobbers: AF.
 286  9D23              ;   Algorithm: if a char is already buffered, report ready; else ask the BIOS console status vector
 287  9D23              ;              ($FA06). If a key is down, peek it ($FA09): Ctrl-S (13h) stalls (then Ctrl-C
 288  9D23              ;              warm-boots
 289  9D23              ;              via JP 0); any other key is stashed in CON_PENDING_CHAR and reported ready.
 290  9D23              ;   [RE] Backs the BDOS console-status / flow-control behaviour.
 291  9D23              ; ----------------------------------------------------------------------
 292  9D23              CON_POLL_STATUS:
 293  9D23 3A 0E 9F             LD A,(CON_PENDING_CHAR)
 294  9D26 B7                   OR A
 295  9D27 C2 45 9D             JP NZ,CON_STATUS_READY
 296  9D2A                      ; BIOS console-status vector ($FA00 BIOS variable page = Apple $0A00)
 297  9D2A CD 06 FA             CALL $FA06
 298  9D2D E6 01                AND $01
 299  9D2F C8                   RET Z
 300  9D30                      ; Peek the pending key via the BIOS CONIN vector
 301  9D30 CD 09 FA             CALL $FA09
 302  9D33 FE 13                CP $13
 303  9D35 C2 42 9D             JP NZ,CON_POLL_STASH
 304  9D38                      ; After Ctrl-S, read the resume/abort key (Ctrl-C warm-boots)
 305  9D38 CD 09 FA             CALL $FA09
 306  9D3B FE 03                CP $03
 307  9D3D CA 00 00             JP Z,$0000
 308  9D40 AF                   XOR A
 309  9D41 C9                   RET
 310  9D42              ; ----------------------------------------------------------------------
 311  9D42              ; CON_POLL_STASH -- stash the just-read key as type-ahead and report 'ready'.
 312  9D42              ;   In: A = key character to hold.  Out: A = 1 (ready).  Clobbers: none beyond A.
 313  9D42              ;   Algorithm: store A into CON_PENDING_CHAR, then fall into the A:=1 tail (CON_STATUS_READY). [RE]
 314  9D42              ; ----------------------------------------------------------------------
 315  9D42              CON_POLL_STASH:
 316  9D42 32 0E 9F             LD (CON_PENDING_CHAR),A
 317  9D45              ; ----------------------------------------------------------------------
 318  9D45              ; CON_STATUS_READY -- return A=1, the 'character is ready' status result.
 319  9D45              ;   In: none.  Out: A=1.  Clobbers: A.  [RE] Shared tail of CON_POLL_STATUS.
 320  9D45              ; ----------------------------------------------------------------------
 321  9D45              CON_STATUS_READY:
 322  9D45 3E 01                LD A,$01
 323  9D47 C9                   RET
 324  9D48              ; ----------------------------------------------------------------------
 325  9D48              ; CON_PUT_COL -- output one char to the console, tracking column and honouring Ctrl-S.
 326  9D48              ;   In: C = character to print.
 327  9D48              ;   Out: char sent to console (and to the list device if echo flag set); CON_COL updated for
 328  9D48              ;        printables; BS/LF adjust it.
 329  9D48              ;   Clobbers: AF, HL (BC preserved across the BIOS calls).
 330  9D48              ;   Algorithm: unless the redisplay-suppress flag (CON_SAVED_COL) is set, poll for Ctrl-S/Ctrl-C
 331  9D48              ;              then
 332  9D48              ;              send C to the BIOS conout vector ($FA0C) and, if CON_LIST_ECHO is set, to the list
 333  9D48              ;              vector ($FA0F). Then update the column: DEL(7F) leaves it; printable >=' '
 334  9D48              ;              increments;
 335  9D48              ;              BS decrements; LF zeroes it. [RE] Core char output + column bookkeeping.
 336  9D48              ; ----------------------------------------------------------------------
 337  9D48              CON_PUT_COL:
 338  9D48 3A 0A 9F             LD A,(CON_SAVED_COL)
 339  9D4B B7                   OR A
 340  9D4C C2 62 9D             JP NZ,CON_TRACK_COL
 341  9D4F C5                   PUSH BC
 342  9D50 CD 23 9D             CALL CON_POLL_STATUS
 343  9D53 C1                   POP BC
 344  9D54 C5                   PUSH BC
 345  9D55                      ; BIOS console-output vector ($FA00 BIOS variable page)
 346  9D55 CD 0C FA             CALL $FA0C
 347  9D58 C1                   POP BC
 348  9D59 C5                   PUSH BC
 349  9D5A 3A 0D 9F             LD A,(CON_LIST_ECHO)
 350  9D5D B7                   OR A
 351  9D5E                      ; BIOS list-output vector when printer echo (CON_LIST_ECHO) is set
 352  9D5E C4 0F FA             CALL NZ,$FA0F
 353  9D61 C1                   POP BC
 354  9D62              ; ----------------------------------------------------------------------
 355  9D62              ; CON_TRACK_COL -- update the output column counter for the char just sent.
 356  9D62              ;   In: C = the char emitted; CON_COL = current column.
 357  9D62              ;   Out: CON_COL adjusted (DEL no-op, printable +1, BS -1 if nonzero, LF -> 0).
 358  9D62              ;   Clobbers: AF, HL.
 359  9D62              ;   Algorithm: DEL(7F) -> return; >=' ' -> increment; control chars -> if column already 0 return;
 360  9D62              ;              BS(08) -> decrement; LF(0A) -> zero the column. [RE]
 361  9D62              ; ----------------------------------------------------------------------
 362  9D62              CON_TRACK_COL:
 363  9D62 79                   LD A,C
 364  9D63 21 0C 9F             LD HL,CON_COL
 365  9D66 FE 7F                CP $7F
 366  9D68 C8                   RET Z
 367  9D69 34                   INC (HL)
 368  9D6A FE 20                CP $20
 369  9D6C D0                   RET NC
 370  9D6D 35                   DEC (HL)
 371  9D6E 7E                   LD A,(HL)
 372  9D6F B7                   OR A
 373  9D70 C8                   RET Z
 374  9D71 79                   LD A,C
 375  9D72 FE 08                CP $08
 376  9D74 C2 79 9D             JP NZ,CON_TRACK_COL_LF
 377  9D77 35                   DEC (HL)
 378  9D78 C9                   RET
 379  9D79              ; ----------------------------------------------------------------------
 380  9D79              ; CON_TRACK_COL_LF -- handle the line-feed case of column tracking.
 381  9D79              ;   In: A = the control char; HL -> column cell.  Out: column zeroed if A was LF; else unchanged.
 382  9D79              ;   Clobbers: AF.  [RE] LF tail of CON_TRACK_COL.
 383  9D79              ; ----------------------------------------------------------------------
 384  9D79              CON_TRACK_COL_LF:
 385  9D79 FE 0A                CP $0A
 386  9D7B C0                   RET NZ
 387  9D7C 36 00                LD (HL),$00
 388  9D7E C9                   RET
 389  9D7F              ; ----------------------------------------------------------------------
 390  9D7F              ; CON_PUT_VISIBLE -- output a char, expanding non-tab control codes as '^X'.
 391  9D7F              ;   In: C = character.  Out: char(s) sent via CON_PUT_COL; TAB handled by F_CONOUT_H expansion.
 392  9D7F              ;   Clobbers: AF.
 393  9D7F              ;   Algorithm: if the char is a handled control (IS_CTRL_CHAR, carry clear) print it normally
 394  9D7F              ;              through
 395  9D7F              ;              F_CONOUT_H; otherwise emit '^' then the char OR'd with 40h, so e.g. Ctrl-A shows as
 396  9D7F              ;              '^A'.
 397  9D7F              ;   [RE] Visible-control echo used by the line editor's buffer redisplay.
 398  9D7F              ; ----------------------------------------------------------------------
 399  9D7F              CON_PUT_VISIBLE:
 400  9D7F 79                   LD A,C
 401  9D80 CD 14 9D             CALL IS_CTRL_CHAR
 402  9D83 D2 90 9D             JP NC,F_CONOUT_H
 403  9D86 F5                   PUSH AF
 404  9D87 0E 5E                LD C,$5E
 405  9D89 CD 48 9D             CALL CON_PUT_COL
 406  9D8C F1                   POP AF
 407  9D8D F6 40                OR $40
 408  9D8F 4F                   LD C,A
 409  9D90              ; ----------------------------------------------------------------------
 410  9D90              ; F_CONOUT_H -- BDOS console-output handler (function 2) with tab expansion.
 411  9D90              ;   In: C = character to print.  Out: character emitted; TAB expands to spaces to the next 8-column
 412  9D90              ;       stop.
 413  9D90              ;   Clobbers: AF.
 414  9D90              ;   Algorithm: if C != TAB(09) just print it via CON_PUT_COL; if TAB, emit spaces through
 415  9D90              ;              CON_PUT_COL
 416  9D90              ;              until CON_COL is a multiple of 8. [RE] BDOS function 2 (Console Output).
 417  9D90              ; ----------------------------------------------------------------------
 418  9D90              F_CONOUT_H:
 419  9D90 79                   LD A,C
 420  9D91 FE 09                CP $09
 421  9D93 C2 48 9D             JP NZ,CON_PUT_COL
 422  9D96              ; ----------------------------------------------------------------------
 423  9D96              ; CONOUT_TAB_FILL -- emit spaces until the column reaches the next 8-stop (tab expand).
 424  9D96              ;   In: CON_COL = current column.  Out: spaces printed until (column & 7)==0.  Clobbers: AF, C.
 425  9D96              ;   Algorithm: output a space via CON_PUT_COL, re-read the column, loop while low 3 bits are
 426  9D96              ;              nonzero.
 427  9D96              ;   [RE] Tab-expansion loop of F_CONOUT_H.
 428  9D96              ; ----------------------------------------------------------------------
 429  9D96              CONOUT_TAB_FILL:
 430  9D96 0E 20                LD C,$20
 431  9D98 CD 48 9D             CALL CON_PUT_COL
 432  9D9B 3A 0C 9F             LD A,(CON_COL)
 433  9D9E E6 07                AND $07
 434  9DA0 C2 96 9D             JP NZ,CONOUT_TAB_FILL
 435  9DA3 C9                   RET
 436  9DA4              ; ----------------------------------------------------------------------
 437  9DA4              ; CON_BACKSPACE -- erase the last echoed character (BS, space, BS).
 438  9DA4              ;   In: none.  Out: cursor moved left one cell, char blanked on screen.  Clobbers: AF, C.
 439  9DA4              ;   Algorithm: emit BS (via CON_BS_OUT), then space, then BS again through the BIOS conout vector
 440  9DA4              ;              ($FA0C) so the previous glyph is overwritten with a blank. [RE]
 441  9DA4              ; ----------------------------------------------------------------------
 442  9DA4              CON_BACKSPACE:
 443  9DA4 CD AC 9D             CALL CON_BS_OUT
 444  9DA7 0E 20                LD C,$20
 445  9DA9                      ; BIOS conout vector: print the blanking space ($FA00 BIOS variable page)
 446  9DA9 CD 0C FA             CALL $FA0C
 447  9DAC              ; ----------------------------------------------------------------------
 448  9DAC              ; CON_BS_OUT -- send a single backspace (08) to the console.
 449  9DAC              ;   In: none.  Out: BS emitted via the BIOS conout vector ($FA0C).  Clobbers: C.
 450  9DAC              ;   [RE] Tail-call helper; also used as the leading BS of CON_BACKSPACE.
 451  9DAC              ; ----------------------------------------------------------------------
 452  9DAC              CON_BS_OUT:
 453  9DAC 0E 08                LD C,$08
 454  9DAE                      ; BIOS conout vector (tail call), $FA00 BIOS variable page
 455  9DAE C3 0C FA             JP $FA0C
 456  9DB1              ; ----------------------------------------------------------------------
 457  9DB1              ; CON_RETYPE_LINE -- echo '#' + CR/LF and reprint the current edit buffer (Ctrl-R / Ctrl-U).
 458  9DB1              ;   In: CON_COL = total chars in the line; the edit buffer follows BDOS_PARAM_PTR's pointer.
 459  9DB1              ;   Out: a fresh copy of the typed line shown on a new line.  Clobbers: AF, C, HL.
 460  9DB1              ;   Algorithm: print '#', CR/LF (CON_CRLF), then loop re-emitting characters with CON_PUT_COL until
 461  9DB1              ;              the echoed count CON_LINE_START_COL reaches CON_COL. [RE]
 462  9DB1              ; ----------------------------------------------------------------------
 463  9DB1              CON_RETYPE_LINE:
 464  9DB1 0E 23                LD C,$23
 465  9DB3 CD 48 9D             CALL CON_PUT_COL
 466  9DB6 CD C9 9D             CALL CON_CRLF
 467  9DB9              ; ----------------------------------------------------------------------
 468  9DB9              ; CON_RETYPE_LOOP -- reprint buffered characters until the column matches the count.
 469  9DB9              ;   In: CON_LINE_START_COL = chars already re-echoed; CON_COL = target count.
 470  9DB9              ;   Out: remaining buffered chars emitted as spaces (placeholder re-echo).  Clobbers: AF, C, HL.
 471  9DB9              ;   Algorithm: while CON_COL >= the running CON_LINE_START_COL counter is false, emit a space via
 472  9DB9              ;              CON_PUT_COL and loop. [RE] Re-echo loop of CON_RETYPE_LINE.
 473  9DB9              ;   [?] The compared cells are the editor's column vs echoed-count; exact pairing UNKNOWN beyond
 474  9DB9              ;       'advance until equal'.
 475  9DB9              ; ----------------------------------------------------------------------
 476  9DB9              CON_RETYPE_LOOP:
 477  9DB9 3A 0C 9F             LD A,(CON_COL)
 478  9DBC 21 0B 9F             LD HL,CON_LINE_START_COL
 479  9DBF BE                   CP (HL)
 480  9DC0 D0                   RET NC
 481  9DC1 0E 20                LD C,$20
 482  9DC3 CD 48 9D             CALL CON_PUT_COL
 483  9DC6 C3 B9 9D             JP CON_RETYPE_LOOP
 484  9DC9              ; ----------------------------------------------------------------------
 485  9DC9              ; CON_CRLF -- output a carriage-return / line-feed pair to the console.
 486  9DC9              ;   In: none.  Out: CR then LF emitted; column reset by the LF.  Clobbers: AF, C.
 487  9DC9              ;   Algorithm: CON_PUT_COL with CR(0D), then tail-call CON_PUT_COL with LF(0A). [RE]
 488  9DC9              ; ----------------------------------------------------------------------
 489  9DC9              CON_CRLF:
 490  9DC9 0E 0D                LD C,$0D
 491  9DCB CD 48 9D             CALL CON_PUT_COL
 492  9DCE 0E 0A                LD C,$0A
 493  9DD0 C3 48 9D             JP CON_PUT_COL
 494  9DD3              ; ----------------------------------------------------------------------
 495  9DD3              ; CON_PRINT_STR -- print a '$'-terminated string to the console.
 496  9DD3              ;   In: BC = pointer to the string; terminated by '$' (24h).
 497  9DD3              ;   Out: each char emitted via F_CONOUT_H until '$' is reached.  Clobbers: AF, BC, C.
 498  9DD3              ;   Algorithm: load (BC); if '$' return; else advance BC, output the char through F_CONOUT_H
 499  9DD3              ;              (preserving BC), and loop. [RE] Backs BDOS function 9 and the error printer.
 500  9DD3              ; ----------------------------------------------------------------------
 501  9DD3              CON_PRINT_STR:
 502  9DD3 0A                   LD A,(BC)
 503  9DD4 FE 24                CP $24
 504  9DD6 C8                   RET Z
 505  9DD7 03                   INC BC
 506  9DD8 C5                   PUSH BC
 507  9DD9 4F                   LD C,A
 508  9DDA CD 90 9D             CALL F_CONOUT_H
 509  9DDD C1                   POP BC
 510  9DDE C3 D3 9D             JP CON_PRINT_STR
 511  9DE1              ; ----------------------------------------------------------------------
 512  9DE1              ; F_READCONBUF_H -- BDOS buffered console line input (function 10) with editing.
 513  9DE1              ;   In: BDOS_PARAM_PTR -> the read buffer (byte0 = max length, byte1 = returned count, data...).
 514  9DE1              ;   Out: the buffer filled with the edited line; byte1 set to the char count.  Clobbers: AF, BC, DE,
 515  9DE1              ;        HL.
 516  9DE1              ;   Algorithm: seed the echoed-count from the current column; read chars one at a time
 517  9DE1              ;              (CON_GETC_OR_RAW, masked to 7 bits) and dispatch the editing controls: CR/LF
 518  9DE1              ;              terminate;
 519  9DE1              ;              BS/DEL delete; Ctrl-E new line; Ctrl-P printer toggle; Ctrl-X erase line; Ctrl-U
 520  9DE1              ;              abandon
 521  9DE1              ;              (#); Ctrl-R retype; other chars stored. Terminates by writing the count and CR.
 522  9DE1              ;   [RE] Classic CP/M 2.2 line editor (Read Console Buffer).
 523  9DE1              ; ----------------------------------------------------------------------
 524  9DE1              F_READCONBUF_H:
 525  9DE1 3A 0C 9F             LD A,(CON_COL)
 526  9DE4 32 0B 9F             LD (CON_LINE_START_COL),A
 527  9DE7 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
 528  9DEA 4E                   LD C,(HL)
 529  9DEB 23                   INC HL
 530  9DEC E5                   PUSH HL
 531  9DED 06 00                LD B,$00
 532  9DEF              ; ----------------------------------------------------------------------
 533  9DEF              ; READBUF_NEXT -- top of the line-editor read loop: save state and fetch a char.
 534  9DEF              ;   In: B = count so far, HL -> buffer position.
 535  9DEF              ;   Out: falls into READBUF_GETC with BC/HL preserved on the stack.  Clobbers: stack.
 536  9DEF              ;   [RE] Per-keystroke loop head of F_READCONBUF_H.
 537  9DEF              ; ----------------------------------------------------------------------
 538  9DEF              READBUF_NEXT:
 539  9DEF C5                   PUSH BC
 540  9DF0 E5                   PUSH HL
 541  9DF1              ; ----------------------------------------------------------------------
 542  9DF1              ; READBUF_GETC -- read and classify the next edit character.
 543  9DF1              ;   In: stacked BC/HL = saved count and buffer pointer.
 544  9DF1              ;   Out: A = 7-bit char; control codes dispatched to the appropriate editor handler.  Clobbers: AF,
 545  9DF1              ;        BC, HL.
 546  9DF1              ;   Algorithm: CON_GETC_OR_RAW, mask to 7 bits, restore BC/HL, then chain CP/JP tests: CR/LF ->
 547  9DF1              ;              finish;
 548  9DF1              ;              BS -> delete; remaining tests fall through to the DEL/control handlers.
 549  9DF1              ;   [RE] Keystroke dispatcher inside F_READCONBUF_H.
 550  9DF1              ; ----------------------------------------------------------------------
 551  9DF1              READBUF_GETC:
 552  9DF1 CD FB 9C             CALL CON_GETC_OR_RAW
 553  9DF4 E6 7F                AND $7F
 554  9DF6 E1                   POP HL
 555  9DF7 C1                   POP BC
 556  9DF8 FE 0D                CP $0D
 557  9DFA CA C1 9E             JP Z,READBUF_DONE
 558  9DFD FE 0A                CP $0A
 559  9DFF CA C1 9E             JP Z,READBUF_DONE
 560  9E02 FE 08                CP $08
 561  9E04 C2 16 9E             JP NZ,READBUF_DEL
 562  9E07 78                   LD A,B
 563  9E08 B7                   OR A
 564  9E09 CA EF 9D             JP Z,READBUF_NEXT
 565  9E0C 05                   DEC B
 566  9E0D 3A 0C 9F             LD A,(CON_COL)
 567  9E10 32 0A 9F             LD (CON_SAVED_COL),A
 568  9E13 C3 70 9E             JP READBUF_REDISPLAY
 569  9E16              ; ----------------------------------------------------------------------
 570  9E16              ; READBUF_DEL -- handle DEL (7F) as a destructive rubout of the previous char.
 571  9E16              ;   In: A = char (7F), B = count, HL -> buffer position.
 572  9E16              ;   Out: if buffer nonempty, last char fetched for re-echo and pointer/count backed up; empty buffer
 573  9E16              ;        just re-loops.  Clobbers: AF, B, HL.  [RE] DELETE key path of the line editor.
 574  9E16              ; ----------------------------------------------------------------------
 575  9E16              READBUF_DEL:
 576  9E16 FE 7F                CP $7F
 577  9E18 C2 26 9E             JP NZ,READBUF_CTRL_E
 578  9E1B 78                   LD A,B
 579  9E1C B7                   OR A
 580  9E1D CA EF 9D             JP Z,READBUF_NEXT
 581  9E20 7E                   LD A,(HL)
 582  9E21 05                   DEC B
 583  9E22 2B                   DEC HL
 584  9E23 C3 A9 9E             JP READBUF_STORE_ECHO
 585  9E26              ; ----------------------------------------------------------------------
 586  9E26              ; READBUF_CTRL_E -- handle Ctrl-E (05): physical CR/LF without ending the line.
 587  9E26              ;   In: A = char, BC/HL = editor state.  Out: cursor moved to a new line, echoed-count reset;
 588  9E26              ;       editing continues.
 589  9E26              ;   Clobbers: AF.
 590  9E26              ;   Algorithm: on Ctrl-E print CR/LF (CON_CRLF), zero CON_LINE_START_COL, and resume reading;
 591  9E26              ;              otherwise
 592  9E26              ;              fall through to the next control test. [RE]
 593  9E26              ; ----------------------------------------------------------------------
 594  9E26              READBUF_CTRL_E:
 595  9E26 FE 05                CP $05
 596  9E28 C2 37 9E             JP NZ,READBUF_CTRL_P
 597  9E2B C5                   PUSH BC
 598  9E2C E5                   PUSH HL
 599  9E2D CD C9 9D             CALL CON_CRLF
 600  9E30 AF                   XOR A
 601  9E31 32 0B 9F             LD (CON_LINE_START_COL),A
 602  9E34 C3 F1 9D             JP READBUF_GETC
 603  9E37              ; ----------------------------------------------------------------------
 604  9E37              ; READBUF_CTRL_P -- handle Ctrl-P (10): toggle the printer (list-device) echo flag.
 605  9E37              ;   In: A = char.  Out: CON_LIST_ECHO flipped between 0 and 1; editing continues.  Clobbers: AF, HL.
 606  9E37              ;   Algorithm: on Ctrl-P compute 1 - CON_LIST_ECHO to toggle the printer-echo flag, then loop;
 607  9E37              ;              otherwise
 608  9E37              ;              fall through to the Ctrl-X test. [RE]
 609  9E37              ; ----------------------------------------------------------------------
 610  9E37              READBUF_CTRL_P:
 611  9E37 FE 10                CP $10
 612  9E39 C2 48 9E             JP NZ,READBUF_CTRL_X
 613  9E3C E5                   PUSH HL
 614  9E3D 21 0D 9F             LD HL,CON_LIST_ECHO
 615  9E40 3E 01                LD A,$01
 616  9E42 96                   SUB (HL)
 617  9E43 77                   LD (HL),A
 618  9E44 E1                   POP HL
 619  9E45 C3 EF 9D             JP READBUF_NEXT
 620  9E48              ; ----------------------------------------------------------------------
 621  9E48              ; READBUF_CTRL_X -- handle Ctrl-X (18): erase the whole input line.
 622  9E48              ;   In: A = char; CON_COL = column; CON_LINE_START_COL = start column.
 623  9E48              ;   Out: all echoed chars backspaced away and the buffer emptied; editing restarts.  Clobbers: AF,
 624  9E48              ;        HL.
 625  9E48              ;   Algorithm: on Ctrl-X loop CON_BACKSPACE while the column exceeds the line-start, then restart
 626  9E48              ;              the
 627  9E48              ;              read with an empty buffer; else fall to the Ctrl-U test. [RE]
 628  9E48              ; ----------------------------------------------------------------------
 629  9E48              READBUF_CTRL_X:
 630  9E48 FE 18                CP $18
 631  9E4A C2 5F 9E             JP NZ,READBUF_CTRL_U
 632  9E4D E1                   POP HL
 633  9E4E              ; ----------------------------------------------------------------------
 634  9E4E              ; READBUF_ERASE_LOOP -- backspace-erase characters back to the line start.
 635  9E4E              ;   In: CON_LINE_START_COL = start column, CON_COL = current column.
 636  9E4E              ;   Out: console column reduced to the start; chars visually erased.  Clobbers: AF, HL.
 637  9E4E              ;   Algorithm: while current column > start column, decrement it and CON_BACKSPACE. [RE]
 638  9E4E              ; ----------------------------------------------------------------------
 639  9E4E              READBUF_ERASE_LOOP:
 640  9E4E 3A 0B 9F             LD A,(CON_LINE_START_COL)
 641  9E51 21 0C 9F             LD HL,CON_COL
 642  9E54 BE                   CP (HL)
 643  9E55 D2 E1 9D             JP NC,F_READCONBUF_H
 644  9E58 35                   DEC (HL)
 645  9E59 CD A4 9D             CALL CON_BACKSPACE
 646  9E5C C3 4E 9E             JP READBUF_ERASE_LOOP
 647  9E5F              ; ----------------------------------------------------------------------
 648  9E5F              ; READBUF_CTRL_U -- handle Ctrl-U (15): abandon the line, show '#', restart.
 649  9E5F              ;   In: A = char.  Out: '#' printed, fresh line started, buffer reset.  Clobbers: AF, HL.
 650  9E5F              ;   Algorithm: on Ctrl-U mark the abandoned line (CON_RETYPE_LINE prints '#'+CRLF) and restart the
 651  9E5F              ;              read;
 652  9E5F              ;              otherwise fall to the Ctrl-R test. [RE]
 653  9E5F              ; ----------------------------------------------------------------------
 654  9E5F              READBUF_CTRL_U:
 655  9E5F FE 15                CP $15
 656  9E61 C2 6B 9E             JP NZ,READBUF_CTRL_R
 657  9E64 CD B1 9D             CALL CON_RETYPE_LINE
 658  9E67 E1                   POP HL
 659  9E68 C3 E1 9D             JP F_READCONBUF_H
 660  9E6B              ; ----------------------------------------------------------------------
 661  9E6B              ; READBUF_CTRL_R -- handle Ctrl-R (12): retype the current line, else store the char.
 662  9E6B              ;   In: A = char, B = count, HL -> buffer.
 663  9E6B              ;   Out: Ctrl-R reprints the buffer; any other char falls into the store path.  Clobbers: AF.
 664  9E6B              ;   Algorithm: if char != Ctrl-R, jump to the store path (READBUF_STORE); on Ctrl-R fall into the
 665  9E6B              ;              retype-and-redisplay sequence. [RE]
 666  9E6B              ; ----------------------------------------------------------------------
 667  9E6B              READBUF_CTRL_R:
 668  9E6B FE 12                CP $12
 669  9E6D C2 A6 9E             JP NZ,READBUF_STORE
 670  9E70              ; ----------------------------------------------------------------------
 671  9E70              ; READBUF_REDISPLAY -- reprint the buffered line after a retype/delete.
 672  9E70              ;   In: B = char count; buffer on stack (HL).
 673  9E70              ;   Out: '#'/CRLF emitted then each buffered char re-echoed via CON_PUT_VISIBLE.  Clobbers: AF, BC,
 674  9E70              ;        HL.
 675  9E70              ;   Algorithm: CON_RETYPE_LINE for the marker, then walk the buffer re-echoing each stored char with
 676  9E70              ;              CON_PUT_VISIBLE (so controls show as '^X'). [RE] Used by Ctrl-R and after a
 677  9E70              ;              backspace.
 678  9E70              ; ----------------------------------------------------------------------
 679  9E70              READBUF_REDISPLAY:
 680  9E70 C5                   PUSH BC
 681  9E71 CD B1 9D             CALL CON_RETYPE_LINE
 682  9E74 C1                   POP BC
 683  9E75 E1                   POP HL
 684  9E76 E5                   PUSH HL
 685  9E77 C5                   PUSH BC
 686  9E78              ; ----------------------------------------------------------------------
 687  9E78              ; READBUF_REDISPLAY_LOOP -- re-echo each buffered character.
 688  9E78              ;   In: B = remaining count, HL -> buffer position.
 689  9E78              ;   Out: every buffered char emitted via CON_PUT_VISIBLE.  Clobbers: AF, BC, C, HL.
 690  9E78              ;   Algorithm: while B != 0, advance HL, load the char, CON_PUT_VISIBLE it, decrement B; on
 691  9E78              ;              exhaustion
 692  9E78              ;              fall into the post-redisplay column fixup (READBUF_REPOS). [RE]
 693  9E78              ; ----------------------------------------------------------------------
 694  9E78              READBUF_REDISPLAY_LOOP:
 695  9E78 78                   LD A,B
 696  9E79 B7                   OR A
 697  9E7A CA 8A 9E             JP Z,READBUF_REPOS
 698  9E7D 23                   INC HL
 699  9E7E 4E                   LD C,(HL)
 700  9E7F 05                   DEC B
 701  9E80 C5                   PUSH BC
 702  9E81 E5                   PUSH HL
 703  9E82 CD 7F 9D             CALL CON_PUT_VISIBLE
 704  9E85 E1                   POP HL
 705  9E86 C1                   POP BC
 706  9E87 C3 78 9E             JP READBUF_REDISPLAY_LOOP
 707  9E8A              ; ----------------------------------------------------------------------
 708  9E8A              ; READBUF_REPOS -- after redisplay, backspace the cursor to the edit position.
 709  9E8A              ;   In: CON_SAVED_COL = saved column to restore to, CON_COL = current column.
 710  9E8A              ;   Out: cursor moved back so further typing continues at the right spot.  Clobbers: AF, HL.
 711  9E8A              ;   Algorithm: if no saved position (CON_SAVED_COL==0) resume reading; else compute how far past the
 712  9E8A              ;              target the cursor is (CON_SAVED_COL := saved - column) and fall into
 713  9E8A              ;              READBUF_REPOS_LOOP.
 714  9E8A              ;   [RE] Cursor-reposition step after a Ctrl-R / delete redisplay.
 715  9E8A              ;   [?] Any stale auto-name prefix is a skew artifact -- this is console line-editor code, NOT
 716  9E8A              ;       directory traversal.
 717  9E8A              ; ----------------------------------------------------------------------
 718  9E8A              READBUF_REPOS:
 719  9E8A E5                   PUSH HL
 720  9E8B 3A 0A 9F             LD A,(CON_SAVED_COL)
 721  9E8E B7                   OR A
 722  9E8F CA F1 9D             JP Z,READBUF_GETC
 723  9E92 21 0C 9F             LD HL,CON_COL
 724  9E95 96                   SUB (HL)
 725  9E96 32 0A 9F             LD (CON_SAVED_COL),A
 726  9E99              ; ----------------------------------------------------------------------
 727  9E99              ; READBUF_REPOS_LOOP -- backspace the cursor by the computed cell count.
 728  9E99              ;   In: CON_SAVED_COL = number of cells to back up.
 729  9E99              ;   Out: cursor repositioned; loop ends and the editor reads the next char.  Clobbers: AF, HL.
 730  9E99              ;   Algorithm: CON_BACKSPACE, decrement CON_SAVED_COL, repeat until zero, then resume input. [RE]
 731  9E99              ; ----------------------------------------------------------------------
 732  9E99              READBUF_REPOS_LOOP:
 733  9E99 CD A4 9D             CALL CON_BACKSPACE
 734  9E9C 21 0A 9F             LD HL,CON_SAVED_COL
 735  9E9F 35                   DEC (HL)
 736  9EA0 C2 99 9E             JP NZ,READBUF_REPOS_LOOP
 737  9EA3 C3 F1 9D             JP READBUF_GETC
 738  9EA6              ; ----------------------------------------------------------------------
 739  9EA6              ; READBUF_STORE -- store an ordinary character into the input buffer.
 740  9EA6              ;   In: A = char to store, B = count, HL -> next buffer slot.
 741  9EA6              ;   Out: char written, count incremented; falls into the echo/limit check.  Clobbers: AF, B, HL.
 742  9EA6              ;   Algorithm: write the char at ++HL, bump B, then fall into READBUF_STORE_ECHO which echoes it and
 743  9EA6              ;              checks the buffer-full limit.
 744  9EA6              ;   [?] Any stale auto-name is a skew mislabel -- this is the line editor's character-store path,
 745  9EA6              ;   NOT
 746  9EA6              ;       an FCB/directory compare.
 747  9EA6              ; ----------------------------------------------------------------------
 748  9EA6              READBUF_STORE:
 749  9EA6 23                   INC HL
 750  9EA7 77                   LD (HL),A
 751  9EA8 04                   INC B
 752  9EA9              ; ----------------------------------------------------------------------
 753  9EA9              ; READBUF_STORE_ECHO -- echo the stored char and enforce the buffer length limit.
 754  9EA9              ;   In: A = char, B = count, C = buffer max length.
 755  9EA9              ;   Out: char echoed; if count reached the max (or hit a hard limit) the line is terminated,
 756  9EA9              ;        otherwise
 757  9EA9              ;        reading continues.  Clobbers: AF, BC, HL.
 758  9EA9              ;   Algorithm: echo via CON_PUT_VISIBLE; reload the buffer max; if the max byte is 1 (degenerate)
 759  9EA9              ;              terminate immediately; if count == max terminate, else loop. [RE]
 760  9EA9              ;   [?] The CP $03 then CP $01 sequence tests the buffer-descriptor max byte; exact degenerate-case
 761  9EA9              ;       semantics beyond 'terminate when full' are UNKNOWN.
 762  9EA9              ; ----------------------------------------------------------------------
 763  9EA9              READBUF_STORE_ECHO:
 764  9EA9 C5                   PUSH BC
 765  9EAA E5                   PUSH HL
 766  9EAB 4F                   LD C,A
 767  9EAC CD 7F 9D             CALL CON_PUT_VISIBLE
 768  9EAF E1                   POP HL
 769  9EB0 C1                   POP BC
 770  9EB1 7E                   LD A,(HL)
 771  9EB2 FE 03                CP $03
 772  9EB4 78                   LD A,B
 773  9EB5 C2 BD 9E             JP NZ,READBUF_LIMIT
 774  9EB8 FE 01                CP $01
 775  9EBA CA 00 00             JP Z,$0000
 776  9EBD              ; ----------------------------------------------------------------------
 777  9EBD              ; READBUF_LIMIT -- compare the count to the buffer max and continue or finish.
 778  9EBD              ;   In: A = count (B), C = buffer maximum length.
 779  9EBD              ;   Out: if count < max keep reading, else fall into the line-terminate path.  Clobbers: AF.
 780  9EBD              ;   Algorithm: CP C; if count < max (carry) loop back to READBUF_NEXT, else finish. [RE]
 781  9EBD              ; ----------------------------------------------------------------------
 782  9EBD              READBUF_LIMIT:
 783  9EBD B9                   CP C
 784  9EBE DA EF 9D             JP C,READBUF_NEXT
 785  9EC1              ; ----------------------------------------------------------------------
 786  9EC1              ; READBUF_DONE -- finish the input line: store the count and emit a CR.
 787  9EC1              ;   In: stacked HL -> buffer count byte; B = final character count.
 788  9EC1              ;   Out: count written into the buffer; CR echoed; returns to the BDOS caller.  Clobbers: AF, C, HL.
 789  9EC1              ;   Algorithm: pop the buffer pointer, store B as the returned char count, then output CR via
 790  9EC1              ;              CON_PUT_COL
 791  9EC1              ;              (tail call) to close the input line. [RE] Reached on CR/LF/buffer-full.
 792  9EC1              ; ----------------------------------------------------------------------
 793  9EC1              READBUF_DONE:
 794  9EC1 E1                   POP HL
 795  9EC2 70                   LD (HL),B
 796  9EC3 0E 0D                LD C,$0D
 797  9EC5 C3 48 9D             JP CON_PUT_COL
 798  9EC8              ; ----------------------------------------------------------------------
 799  9EC8              ; F_CONIN_H -- BDOS function 1 handler: console input with echo, returned in A.
 800  9EC8              ;   In: none.  Out: BDOS result (BDOS_RETVAL) = char read.  Clobbers: AF, BC, HL.
 801  9EC8              ;   Algorithm: read+echo via F_CONIN_RAW, then store the char as the BDOS return value.
 802  9EC8              ;   [RE] Dispatch-table entry for function 1.
 803  9EC8              ; ----------------------------------------------------------------------
 804  9EC8              F_CONIN_H:
 805  9EC8 CD 06 9D             CALL F_CONIN_RAW
 806  9ECB C3 01 9F             JP BDOS_RET_RESULT
 807  9ECE              ; ----------------------------------------------------------------------
 808  9ECE              ; F_READERIN_H -- BDOS function 3 handler: read from the reader (AUX/RDR) device.
 809  9ECE              ;   In: none.  Out: BDOS result (BDOS_RETVAL) = byte from the BIOS reader vector.  Clobbers: AF.
 810  9ECE              ;   Algorithm: call the BIOS reader-input vector ($FA15), store the byte as the result.
 811  9ECE              ;   [RE] Dispatch entry for function 3 (Reader Input).
 812  9ECE              ; ----------------------------------------------------------------------
 813  9ECE              F_READERIN_H:
 814  9ECE                      ; BIOS reader-input vector ($FA00 BIOS variable page = Apple $0A00)
 815  9ECE CD 15 FA             CALL $FA15
 816  9ED1 C3 01 9F             JP BDOS_RET_RESULT
 817  9ED4              ; ----------------------------------------------------------------------
 818  9ED4              ; F_DIRECTIO_H -- BDOS function 6 handler: direct console I/O.
 819  9ED4              ;   In: C = subfunction (FF = input/status, FE = status only, else = output char).
 820  9ED4              ;   Out: input/status results returned via BDOS_RET_RESULT; output sent to console.  Clobbers: AF.
 821  9ED4              ;   Algorithm: C==FF -> direct input branch; C==FE -> raw BIOS console-status ($FA06); otherwise
 822  9ED4              ;              treat
 823  9ED4              ;              C as a character and send it to the BIOS conout ($FA0C), bypassing the editor and
 824  9ED4              ;              flow
 825  9ED4              ;              control. [RE] Dispatch entry for function 6 (Direct Console I/O).
 826  9ED4              ; ----------------------------------------------------------------------
 827  9ED4              F_DIRECTIO_H:
 828  9ED4 79                   LD A,C
 829  9ED5 3C                   INC A
 830  9ED6 CA E0 9E             JP Z,DIRECTIO_INPUT
 831  9ED9 3C                   INC A
 832  9EDA                      ; FE subfunction -> raw BIOS console-status ($FA00 BIOS variable page)
 833  9EDA CA 06 FA             JP Z,$FA06
 834  9EDD                      ; Else output C directly via BIOS conout ($FA00 BIOS variable page)
 835  9EDD C3 0C FA             JP $FA0C
 836  9EE0              ; ----------------------------------------------------------------------
 837  9EE0              ; DIRECTIO_INPUT -- direct console input subfunction of function 6.
 838  9EE0              ;   In: none.  Out: BDOS result = char if one is ready, else 0; no echo, no flow control.  Clobbers:
 839  9EE0              ;       AF.
 840  9EE0              ;   Algorithm: poll raw BIOS console status ($FA06); if no key, return 0; if a key is ready, read it
 841  9EE0              ;              raw
 842  9EE0              ;              ($FA09) and store as the result. [RE]
 843  9EE0              ;   [?] Any stale auto-name prefix is a skew artifact -- this is direct console input, NOT an
 844  9EE0              ;   FCB/directory routine.
 845  9EE0              ; ----------------------------------------------------------------------
 846  9EE0              DIRECTIO_INPUT:
 847  9EE0                      ; Raw BIOS console-status vector ($FA00 BIOS variable page)
 848  9EE0 CD 06 FA             CALL $FA06
 849  9EE3 B7                   OR A
 850  9EE4 CA 91 A9             JP Z,BDOS_RETURN_RESULT
 851  9EE7                      ; Read the key raw, no echo (BIOS CONIN vector, $FA00 page)
 852  9EE7 CD 09 FA             CALL $FA09
 853  9EEA C3 01 9F             JP BDOS_RET_RESULT
 854  9EED              ; ----------------------------------------------------------------------
 855  9EED              ; F_GETIOB_H -- BDOS function 7 handler: get the I/O byte (IOBYTE).
 856  9EED              ;   In: none.  Out: BDOS result = the IOBYTE at fixed address 0003.  Clobbers: AF.
 857  9EED              ;   Algorithm: load (0003) and return it as the result. [RE] Dispatch entry for function 7.
 858  9EED              ; ----------------------------------------------------------------------
 859  9EED              F_GETIOB_H:
 860  9EED 3A 03 00             LD A,($0003)
 861  9EF0 C3 01 9F             JP BDOS_RET_RESULT
 862  9EF3              ; ----------------------------------------------------------------------
 863  9EF3              ; F_SETIOB_H -- BDOS function 8 handler: set the I/O byte (IOBYTE).
 864  9EF3              ;   In: C = new IOBYTE value.  Out: (0003) = C.  Clobbers: HL.
 865  9EF3              ;   Algorithm: store C into the fixed IOBYTE cell at 0003 and return. [RE] Dispatch entry for
 866  9EF3              ;              function 8.
 867  9EF3              ; ----------------------------------------------------------------------
 868  9EF3              F_SETIOB_H:
 869  9EF3 21 03 00             LD HL,$0003
 870  9EF6 71                   LD (HL),C
 871  9EF7 C9                   RET
 872  9EF8              ; ----------------------------------------------------------------------
 873  9EF8              ; F_PRINTSTR_H -- BDOS function 9 handler: print a '$'-terminated string.
 874  9EF8              ;   In: DE = pointer to the string.  Out: string echoed to the console up to the '$'.  Clobbers: AF,
 875  9EF8              ;       BC.
 876  9EF8              ;   Algorithm: move DE into BC and tail-call CON_PRINT_STR. [RE] Dispatch entry for function 9.
 877  9EF8              ; ----------------------------------------------------------------------
 878  9EF8              F_PRINTSTR_H:
 879  9EF8 EB                   EX DE,HL
 880  9EF9 4D                   LD C,L
 881  9EFA 44                   LD B,H
 882  9EFB C3 D3 9D             JP CON_PRINT_STR
 883  9EFE              ; ----------------------------------------------------------------------
 884  9EFE              ; F_CONSTAT_H -- BDOS function 11 handler: get console status.
 885  9EFE              ;   In: none.  Out: BDOS result = 1 if a console char is ready, else 0.  Clobbers: AF.
 886  9EFE              ;   Algorithm: CON_POLL_STATUS to test readiness (handling Ctrl-S/Ctrl-C), then fall into
 887  9EFE              ;              BDOS_RET_RESULT to store the 0/1 status. [RE] Dispatch entry for function 11.
 888  9EFE              ; ----------------------------------------------------------------------
 889  9EFE              F_CONSTAT_H:
 890  9EFE CD 23 9D             CALL CON_POLL_STATUS
 891  9F01              ; ----------------------------------------------------------------------
 892  9F01              ; BDOS_RET_RESULT -- store A as the BDOS function return value and return.
 893  9F01              ;   In: A = result byte.  Out: BDOS_RETVAL (BDOS return cell) = A.  Clobbers: none beyond the cell.
 894  9F01              ;   Algorithm: write A to the return-value cell; common tail of many handlers. The bare RET at $9F04
 895  9F01              ;              (the next byte) is the dispatch-table target for fns 38/39 (the 2.20 twin names that
 896  9F01              ;              RET
 897  9F01              ;              'BDOS_RET_NOP'). [RE] The BDOS result sink read by BDOS_DISPATCH on exit.
 898  9F01              ; ----------------------------------------------------------------------
 899  9F01              BDOS_RET_RESULT:
 900  9F01 32 45 9F             LD (BDOS_RETVAL),A
 901  9F04 C9                   RET
 902  9F05              ; ----------------------------------------------------------------------
 903  9F05              ; BDOS_RET_ONE -- set the BDOS return value to 1 and exit.
 904  9F05              ;   In: none.  Out: BDOS result (BDOS_RETVAL) = 1.  Clobbers: AF.
 905  9F05              ;   Algorithm: load A=1 and join BDOS_RET_RESULT. [RE] Used by handlers reporting a fixed 1.
 906  9F05              ; ----------------------------------------------------------------------
 907  9F05              BDOS_RET_ONE:
 908  9F05 3E 01                LD A,$01
 909  9F07 C3 01 9F             JP BDOS_RET_RESULT
 910  9F0A              ; ----------------------------------------------------------------------
 911  9F0A              ; CON_SAVED_COL -- saved cursor column for line-editor redisplay/reposition.
 912  9F0A              ;   Also doubles as a 'suppress status-poll/echo' flag inside CON_PUT_COL.
 913  9F0A              ;   [RE] BDOS console state byte; zero when not repositioning.
 914  9F0A              ; ----------------------------------------------------------------------
 915  9F0A              CON_SAVED_COL:
 916  9F0A 00                   DEFB    "\0"
 917  9F0B              ; ----------------------------------------------------------------------
 918  9F0B              ; CON_LINE_START_COL -- column at the start of the current input line (echoed-count base).
 919  9F0B              ;   [RE] Used by the line editor to know how far back Ctrl-X / DEL may erase.
 920  9F0B              ; ----------------------------------------------------------------------
 921  9F0B              CON_LINE_START_COL:
 922  9F0B 00                   DEFB    "\0"
 923  9F0C              ; ----------------------------------------------------------------------
 924  9F0C              ; CON_COL -- current console output column counter.
 925  9F0C              ;   [RE] Incremented per printable char, reset by LF; drives tab expansion and editing.
 926  9F0C              ; ----------------------------------------------------------------------
 927  9F0C              CON_COL:
 928  9F0C 00                   DEFB    "\0"
 929  9F0D              ; ----------------------------------------------------------------------
 930  9F0D              ; CON_LIST_ECHO -- printer (list device) echo flag; nonzero => mirror console output.
 931  9F0D              ;   [RE] Toggled by the line editor's Ctrl-P.
 932  9F0D              ; ----------------------------------------------------------------------
 933  9F0D              CON_LIST_ECHO:
 934  9F0D 00                   DEFB    "\0"
 935  9F0E              ; ----------------------------------------------------------------------
 936  9F0E              ; CON_PENDING_CHAR -- 1-byte console type-ahead / un-get buffer (0 = empty).
 937  9F0E              ;   [RE] Filled by CON_POLL_STATUS, consumed by CON_GETC_OR_RAW.
 938  9F0E              ; ----------------------------------------------------------------------
 939  9F0E              CON_PENDING_CHAR:
 940  9F0E 00                   DEFB    "\0"
 941  9F0F              ; ----------------------------------------------------------------------
 942  9F0F              ; BDOS_SAVED_SP -- caller's stack pointer saved on BDOS entry (then BDOS-local stack slack).
 943  9F0F              ;   [RE] BDOS_DISPATCH saves SP here and switches to the BDOS-local stack; restored on exit. The
 944  9F0F              ;        trailing DEFS reserves the BDOS local stack space below BDOS_STACK_TOP.
 945  9F0F              ; ----------------------------------------------------------------------
 946  9F0F              BDOS_SAVED_SP:
 947  9F0F 00 00 00...          DEFS    50, $00                  ; fill
 948  9F41              ; ----------------------------------------------------------------------
 949  9F41              ; BDOS_STACK_TOP -- top of the BDOS private stack (SP loaded here on entry).
 950  9F41              ;   [RE] BDOS_DISPATCH does LD SP,BDOS_STACK_TOP before dispatching a function.
 951  9F41              ; ----------------------------------------------------------------------
 952  9F41              BDOS_STACK_TOP:
 953  9F41 00                   DEFB    "\0"
 954  9F42              ; ----------------------------------------------------------------------
 955  9F42              ; BDOS_CUR_DRIVE -- current selected drive index (0=A) for error reporting and disk ops.
 956  9F42              ;   [RE] Used to form the error-banner drive letter and as the drive arg in random-record / DPB
 957  9F42              ;   setup.
 958  9F42              ; ----------------------------------------------------------------------
 959  9F42              BDOS_CUR_DRIVE:
 960  9F42 00                   DEFB    "\0"
 961  9F43              ; ----------------------------------------------------------------------
 962  9F43              ; BDOS_PARAM_PTR -- saved DE parameter pointer from the BDOS call (FCB / DMA / buffer).
 963  9F43              ;   [RE] BDOS_DISPATCH stashes the incoming DE here; consumers reload it as the operand pointer.
 964  9F43              ;   16-bit cell.
 965  9F43              ; ----------------------------------------------------------------------
 966  9F43              BDOS_PARAM_PTR:
 967  9F43 00 00                DEFB    "\0\0"
 968  9F45              ; ----------------------------------------------------------------------
 969  9F45              ; BDOS_RETVAL -- BDOS function return value (16-bit: low byte = A result, high = B).
 970  9F45              ;   [RE] Cleared on entry; written by BDOS_RET_RESULT; read back by the dispatcher's exit.
 971  9F45              ; ----------------------------------------------------------------------
 972  9F45              BDOS_RETVAL:
 973  9F45 00 00                DEFB    "\0\0"
 974  9F47              ; ----------------------------------------------------------------------
 975  9F47              ; BDOS_ERR_SELECT -- enter the BDOS disk-error handler via the error-vector table.
 976  9F47              ;   In: none (uses the fixed error-vector list at BDOS_ERR_VECTORS).
 977  9F47              ;   Out: transfers to the indexed error routine (does not return normally).  Clobbers: HL, DE.
 978  9F47              ;   Algorithm: point HL at the error-vector table entry (BDOS_ERRVEC_SELECT) and fall into the
 979  9F47              ;              dispatch-by-pointer tail BDOS_VECTOR_JUMP. [RE] One of the BDOS_ERR_VECTORS entry
 980  9F47              ;              points.
 981  9F47              ;   [?] Exact reason-code mapping is encoded by which vector slot the caller chose.
 982  9F47              ; ----------------------------------------------------------------------
 983  9F47              BDOS_ERR_SELECT:
 984  9F47 21 0B 9C             LD HL,BDOS_ERRVEC_SELECT
 985  9F4A              ; ----------------------------------------------------------------------
 986  9F4A              ; BDOS_VECTOR_JUMP -- jump through a 2-byte pointer pointed to by HL.
 987  9F4A              ;   In: HL -> a little-endian routine pointer.  Out: control transferred to (HL); does not return
 988  9F4A              ;       here.
 989  9F4A              ;   Clobbers: DE, HL.
 990  9F4A              ;   Algorithm: load DE from (HL), EX DE,HL, JP (HL) -- an indirect call/jump. [RE] Shared
 991  9F4A              ;              indirect-dispatch
 992  9F4A              ;              tail used by the BDOS error/random-record paths.
 993  9F4A              ; ----------------------------------------------------------------------
 994  9F4A              BDOS_VECTOR_JUMP:
 995  9F4A 5E                   LD E,(HL)
 996  9F4B 23                   INC HL
 997  9F4C 56                   LD D,(HL)
 998  9F4D EB                   EX DE,HL
 999  9F4E E9                   JP (HL)
1000  9F4F              ; ----------------------------------------------------------------------
1001  9F4F              ; BLOCK_COPY_INCC -- copy (C+1) bytes from (DE) to (HL); pre-increment entry.
1002  9F4F              ;   In: C = count-1, DE = source, HL = destination.  Out: bytes copied; DE/HL advanced past the
1003  9F4F              ;       block.

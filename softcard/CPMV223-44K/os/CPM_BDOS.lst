4631  A9AF              ; read-only. [RE]
4632  A9AF              ; ----------------------------------------------------------------------
4633  A9AF              DRV_SELECT_VECTOR:
4634  A9AF 00 00                DEFB    "\0\0"
4635  A9B1              ; ----------------------------------------------------------------------

4716  A9CC              ; ----------------------------------------------------------------------
4717  A9CC              REC_SCAN_PTR:
4718  A9CC 00 00                DEFB    "\0\0"
4719  A9CE              ; ----------------------------------------------------------------------
4720  A9CE              ; DPB_OFF -- DPB field OFF: track offset (number of reserved system tracks). [RE]
4721  A9CE              ; ----------------------------------------------------------------------
4722  A9CE              DPB_OFF:
4723  A9CE 00 00                DEFB    "\0\0"
4724  A9D0              ; ----------------------------------------------------------------------
4725  A9D0              ; DPB_XLT_PTR -- Pointer to the current drive's sector-translation (skew) table (XLT). [RE]
4726  A9D0              ; ----------------------------------------------------------------------
4727  A9D0              DPB_XLT_PTR:
4728  A9D0 00 00                DEFB    "\0\0"
4729  A9D2              ; ----------------------------------------------------------------------
4730  A9D2              ; DIR_DIRTY_FLAG -- Directory-changed flag ($FF = a directory record needs flushing). [RE]
4731  A9D2              ; ----------------------------------------------------------------------
4732  A9D2              DIR_DIRTY_FLAG:
4733  A9D2 00                   DEFB    "\0"
4734  A9D3              ; ----------------------------------------------------------------------
4735  A9D3              ; RW_DIRECTION_FLAG -- Read/write direction flag for the current record op ($FF = read, else write).
4736  A9D3              ; [RE]
4737  A9D3              ; ----------------------------------------------------------------------
4738  A9D3              RW_DIRECTION_FLAG:
4739  A9D3 00                   DEFB    "\0"
4740  A9D4              ; ----------------------------------------------------------------------
4741  A9D4              ; DIR_MATCH_FLAG -- Directory-search match flag / result ($FF when no entry matched). [RE]
4742  A9D4              ; ----------------------------------------------------------------------
4743  A9D4              DIR_MATCH_FLAG:
4744  A9D4 00                   DEFB    "\0"
4745  A9D5              ; ----------------------------------------------------------------------

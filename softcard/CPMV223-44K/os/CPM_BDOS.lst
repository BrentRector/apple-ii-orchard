1295  A0F7              ; ----------------------------------------------------------------------
1296  A0F7              ; DIR_CHECKSUM -- compute the 128-byte additive checksum of the directory buffer.
1297  A0F7              ;   In: DIRBUF_PTR -> 128-byte directory sector buffer.
1298  A0F7              ;   Out: A = 8-bit sum of the 128 bytes.  Clobbers: A,C,HL.
1299  A0F7              ;   Algorithm: C=$80 count, HL=DIRBUF_PTR, A=0; loop ADD A,(HL)/INC HL/DEC C until C==0.
1300  A0F7              ;   [RE] canonical CP/M directory-checksum routine (detects media swap). [DOC CP/M 2.2 ALG]
1301  A0F7              ; ----------------------------------------------------------------------
1302  A0F7              DIR_CHECKSUM:
1303  A0F7 0E 80                LD C,$80
1304  A0F9 2A B9 A9             LD HL,(DIRBUF_PTR)
1305  A0FC AF                   XOR A
1306  A0FD              ; ----------------------------------------------------------------------
1307  A0FD              ; DIR_CHECKSUM_LOOP -- accumulate the 8-bit additive checksum over the 128-byte directory buffer.
1308  A0FD              ; [RE]
1309  A0FD              ; ----------------------------------------------------------------------
1310  A0FD              DIR_CHECKSUM_LOOP:
1311  A0FD 86                   ADD A,(HL)
1312  A0FE 23                   INC HL
1313  A0FF 0D                   DEC C
1314  A100 C2 FD A0             JP NZ,DIR_CHECKSUM_LOOP
1315  A103 C9                   RET
1316  A104              ; ----------------------------------------------------------------------
1317  A104              ; SHL_HL_C -- logical-shift HL left by C bit positions.
1318  A104              ;   In: HL = value; C = shift count (0 leaves HL unchanged).
1319  A104              ;   Out: HL <<= C.  Clobbers: C,HL (C decremented to 0).
1320  A104              ;   Algorithm: INC C / loop { DEC C; ret if zero; ADD HL,HL }.
1321  A104              ;   [RE] generic unsigned left-shift helper (e.g. building a 1<<n drive-bit mask).
1322  A104              ; ----------------------------------------------------------------------
1323  A104              SHL_HL_C:
1324  A104 0C                   INC C
1325  A105              ; ----------------------------------------------------------------------
1326  A105              ; SHL_HL_C_LOOP -- one ADD HL,HL per remaining shift count in C. [RE]
1327  A105              ; ----------------------------------------------------------------------
1328  A105              SHL_HL_C_LOOP:
1329  A105 0D                   DEC C
1330  A106 C8                   RET Z
1331  A107 29                   ADD HL,HL
1332  A108 C3 05 A1             JP SHL_HL_C_LOOP
1333  A10B              ; ----------------------------------------------------------------------
1334  A10B              ; DRIVE_BIT_OR_INTO_VECTOR -- OR the current drive's single-bit mask into a 16-bit vector.
1335  A10B              ;   In: BC = existing 16-bit vector (preserved); BDOS_CUR_DRIVE = current drive (0-based).
1336  A10B              ;       (HL on entry is IGNORED; it is overwritten with $0001.)
1337  A10B              ;   Out: HL = BC OR (1 << current_drive).  Clobbers: A,HL (BC saved/restored).
1338  A10B              ;   Algorithm: PUSH BC; C=current drive; HL=1; SHL_HL_C to form 1<<drive; POP BC; L=C OR L, H=B OR
1339  A10B              ;              H.
1340  A10B              ;   [RE] sets the current drive's bit in whatever vector the caller passes in BC (R/O and login
1341  A10B              ;   setters). [?]
1342  A10B              ; ----------------------------------------------------------------------
1343  A10B              DRIVE_BIT_OR_INTO_VECTOR:
1344  A10B C5                   PUSH BC
1345  A10C 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
1346  A10F 4F                   LD C,A
1347  A110 21 01 00             LD HL,$0001
1348  A113 CD 04 A1             CALL SHL_HL_C
1349  A116 C1                   POP BC
1350  A117 79                   LD A,C
1351  A118 B5                   OR L
1352  A119 6F                   LD L,A
1353  A11A 78                   LD A,B
1354  A11B B4                   OR H
1355  A11C 67                   LD H,A
1356  A11D C9                   RET
1357  A11E              ; ----------------------------------------------------------------------
1358  A11E              ; DRIVE_BIT_TEST -- test whether the current drive's bit is set in the read-only drive vector.
1359  A11E              ;   In: the 16-bit R/O vector at DRV_LOGIN_VECTOR (cell mislabeled DRV_LOGIN_VECTOR; it is the
1360  A11E              ;       read-only vector
1361  A11E              ;       set by the Write-Protect-Disk handler DRV_SETRO_H); BDOS_CUR_DRIVE = drive.
1362  A11E              ;   Out: A = 1 if the current drive's R/O bit is set, else 0; Z reflects the result.  Clobbers:
1363  A11E              ;        A,C,HL.
1364  A11E              ;   Algorithm: load the vector, shift right by the drive number to bring its bit to bit 0, AND $01.
1365  A11E              ;   [RE] CHECK_DRIVE_READONLY raises the R/O error when this bit is set, proving the vector is the
1366  A11E              ;        read-only vector, not the login vector. [?] cell-name fix deferred.
1367  A11E              ; ----------------------------------------------------------------------
1368  A11E              DRIVE_BIT_TEST:
1369  A11E 2A AD A9             LD HL,(DRV_LOGIN_VECTOR)
1370  A121 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
1371  A124 4F                   LD C,A
1372  A125 CD EA A0             CALL DRV_INSTALL_RWTS_10
1373  A128 7D                   LD A,L
1374  A129 E6 01                AND $01
1375  A12B C9                   RET
1376  A12C              ; ----------------------------------------------------------------------
1377  A12C              ; DRV_SETRO_H -- BDOS function 28 (Write Protect Disk): set the current drive's R/O bit.
1378  A12C              ;   In: the R/O drive vector at DRV_LOGIN_VECTOR; BDOS_CUR_DRIVE = current drive; DPB_REC_PTR (a
1379  A12C              ;       directory
1380  A12C              ;       record-count limit); DPB_WORK_PTR0 -> a 16-bit working cell.
1381  A12C              ;   Out: the R/O vector has the current drive's bit set; the word at [DPB_WORK_PTR0] = DPB_REC_PTR +
1382  A12C              ;        1.
1383  A12C              ;   Clobbers: A,BC,DE,HL.
1384  A12C              ;   Algorithm: load the R/O vector into BC, set the current-drive bit via DRIVE_BIT_OR_INTO_VECTOR,
1385  A12C              ;       store it back; then store (DPB_REC_PTR + 1) into the cell pointed to by DPB_WORK_PTR0.
1386  A12C              ;   [RE] this is the fn-28 entry in the dispatch table, confirming Write-Protect-Disk. [?] reason
1387  A12C              ;   for
1388  A12C              ;        caching DPB_REC_PTR+1 UNKNOWN.
1389  A12C              ; ----------------------------------------------------------------------
1390  A12C              DRV_SETRO_H:
1391  A12C 21 AD A9             LD HL,DRV_LOGIN_VECTOR
1392  A12F 4E                   LD C,(HL)
1393  A130 23                   INC HL
1394  A131 46                   LD B,(HL)
1395  A132 CD 0B A1             CALL DRIVE_BIT_OR_INTO_VECTOR
1396  A135                      ; store the R/O drive vector back with the current drive's bit set
1397  A135 22 AD A9             LD (DRV_LOGIN_VECTOR),HL
1398  A138 2A C8 A9             LD HL,(DPB_REC_PTR)
1399  A13B 23                   INC HL
1400  A13C EB                   EX DE,HL
1401  A13D 2A B3 A9             LD HL,(DPB_WORK_PTR0)
1402  A140 73                   LD (HL),E
1403  A141 23                   INC HL
1404  A142 72                   LD (HL),D
1405  A143 C9                   RET
1406  A144              ; ----------------------------------------------------------------------
1407  A144              ; FCB_RO_FLAG_TEST -- raise the file-R/O error if the matched directory entry is read-only.
1408  A144              ;   In: DIRBUF_PTR / DEBLOCK_BYTE_OFF locate the matched directory entry (via
1409  A144              ;       FCB_BUF_PTR_ADD_OFFSET).
1410  A144              ;   Out: returns normally if writable; otherwise jumps to the BDOS error vector (no return).
1411  A144              ;        Clobbers: A,DE,HL.
1412  A144              ;   Algorithm: point at the entry, advance to byte +9 (the first type byte t1', whose bit 7 is the
1413  A144              ;              R/O
1414  A144              ;       attribute), RLA to shift bit 7 into carry; RET NC if clear, else load the file-R/O error
1415  A144              ;       vector
1416  A144              ;       (BDOS_ERRVEC_FILERO) and dispatch via BDOS_VECTOR_JUMP.
1417  A144              ;   [RE] CP/M file R/O attribute = bit 7 of directory-entry byte 9 (t1'). [DOC CP/M 2.2 FCB]
1418  A144              ; ----------------------------------------------------------------------
1419  A144              FCB_RO_FLAG_TEST:
1420  A144 CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
1421  A147              ; ----------------------------------------------------------------------
1422  A147              ; CHECK_DIRENT_READONLY_INNER -- inner entry of FCB_RO_FLAG_TEST (HL already on the directory
1423  A147              ; entry). [RE]
1424  A147              ; ----------------------------------------------------------------------
1425  A147              CHECK_DIRENT_READONLY_INNER:
1426  A147                      ; advance to directory-entry byte +9 (type byte t1'; bit 7 = R/O attribute)
1427  A147 11 09 00             LD DE,$0009
1428  A14A 19                   ADD HL,DE
1429  A14B 7E                   LD A,(HL)
1430  A14C 17                   RLA
1431  A14D D0                   RET NC
1432  A14E 21 0F 9C             LD HL,BDOS_ERRVEC_FILERO
1433  A151 C3 4A 9F             JP BDOS_VECTOR_JUMP
1434  A154              ; ----------------------------------------------------------------------
1435  A154              ; CHECK_DRIVE_READONLY -- raise the disk-R/O error if the current drive is write-protected.
1436  A154              ;   In: the current drive context (DRIVE_BIT_TEST reads the R/O drive vector).
1437  A154              ;   Out: returns if writable; otherwise jumps to the BDOS error vector (no return).  Clobbers:
1438  A154              ;        A,C,HL.
1439  A154              ;   Algorithm: CALL DRIVE_BIT_TEST; RET Z if clear (writable), else load the disk-R/O error vector
1440  A154              ;       (BDOS_ERRVEC_RODISK) and dispatch via BDOS_VECTOR_JUMP.
1441  A154              ;   [RE] guards writes against a write-protected disk. [?]
1442  A154              ; ----------------------------------------------------------------------
1443  A154              CHECK_DRIVE_READONLY:
1444  A154 CD 1E A1             CALL DRIVE_BIT_TEST
1445  A157 C8                   RET Z
1446  A158 21 0D 9C             LD HL,BDOS_ERRVEC_RODISK
1447  A15B C3 4A 9F             JP BDOS_VECTOR_JUMP
1448  A15E              ; ----------------------------------------------------------------------
1449  A15E              ; FCB_BUF_PTR_ADD_OFFSET -- compute a pointer to the matched directory entry inside the directory
1450  A15E              ; buffer.
1451  A15E              ;   In: DIRBUF_PTR -> directory sector buffer; DEBLOCK_BYTE_OFF = byte offset of the entry.
1452  A15E              ;   Out: HL = DIRBUF_PTR + DEBLOCK_BYTE_OFF.  Clobbers: A,HL.
1453  A15E              ;   Algorithm: load the buffer base, load the 8-bit entry offset, add it to L with carry into H.
1454  A15E              ;   [RE] locates the directory entry just matched by a BDOS directory search. [?]
1455  A15E              ; ----------------------------------------------------------------------
1456  A15E              FCB_BUF_PTR_ADD_OFFSET:
1457  A15E 2A B9 A9             LD HL,(DIRBUF_PTR)
1458  A161 3A E9 A9             LD A,(DEBLOCK_BYTE_OFF)
1459  A164              ; ----------------------------------------------------------------------
1460  A164              ; DIRENT_PTR_ADD -- add the 8-bit directory-entry offset in A to HL (carry into H). [RE]
1461  A164              ; ----------------------------------------------------------------------
1462  A164              DIRENT_PTR_ADD:
1463  A164 85                   ADD A,L
1464  A165 6F                   LD L,A
1465  A166 D0                   RET NC
1466  A167 24                   INC H
1467  A168 C9                   RET
1468  A169              ; ----------------------------------------------------------------------
1469  A169              ; FCB_GET_S2 -- point HL at FCB byte 14 (the S2 / extent-high field) of the current FCB.
1470  A169              ;   In: BDOS_PARAM_PTR (CURFCB_PTR) = current FCB pointer.
1471  A169              ;   Out: HL = [CURFCB_PTR] + $000E (FCB+14, the S2 byte); A = its current value.  Clobbers: A,DE,HL.
1472  A169              ;   Algorithm: HL = base + $0E, read (HL) into A.
1473  A169              ;   [RE] FCB byte 14 = S2 (extent-high / module count) per CP/M 2.2 FCB layout. [DOC CP/M 2.2 FCB]
1474  A169              ; ----------------------------------------------------------------------
1475  A169              FCB_GET_S2:
1476  A169 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
1477  A16C 11 0E 00             LD DE,$000E
1478  A16F 19                   ADD HL,DE
1479  A170 7E                   LD A,(HL)
1480  A171 C9                   RET
1481  A172              ; ----------------------------------------------------------------------
1482  A172              ; CLEAR_FCB_S2 -- zero the S2 (byte 14) field of the current FCB.
1483  A172              ;   In: the current FCB (via FCB_GET_S2).  Out: FCB byte 14 = 0.  Clobbers: A,DE,HL.
1484  A172              ;   Algorithm: get the S2 pointer, store 0.
1485  A172              ;   [RE] resets the extent-high/S2 field. [DOC CP/M 2.2 FCB]
1486  A172              ; ----------------------------------------------------------------------
1487  A172              CLEAR_FCB_S2:
1488  A172 CD 69 A1             CALL FCB_GET_S2
1489  A175 36 00                LD (HL),$00
1490  A177 C9                   RET
1491  A178              ; ----------------------------------------------------------------------
1492  A178              ; MARK_FCB_S2_HIGHBIT -- set bit 7 of the FCB S2 (byte 14) field.
1493  A178              ;   In: the current FCB (via FCB_GET_S2, which also returns A = the current S2 value).
1494  A178              ;   Out: FCB byte 14 |= $80.  Clobbers: A,DE,HL.
1495  A178              ;   Algorithm: get the S2 pointer (A = current S2), OR $80, store back.
1496  A178              ;   [RE] in CP/M 2.2 the high bit of S2 flags the FCB as written / needing a directory update at
1497  A178              ;   close.
1498  A178              ;        [DOC CP/M 2.2 FCB]
1499  A178              ; ----------------------------------------------------------------------
1500  A178              MARK_FCB_S2_HIGHBIT:
1501  A178 CD 69 A1             CALL FCB_GET_S2
1502  A17B F6 80                OR $80
1503  A17D 77                   LD (HL),A
1504  A17E C9                   RET
1505  A17F              ; ----------------------------------------------------------------------
1506  A17F              ; CMP_CURREC_VS_WORKPTR -- compare the current record number against the working record cell.
1507  A17F              ;   In: CUR_RECORD = 16-bit current record; DPB_WORK_PTR0 -> a 16-bit working record value.
1508  A17F              ;   Out: HL = address of the working value's high byte; flags = (CUR_RECORD - working value);
1509  A17F              ;        CARRY SET when CUR_RECORD < the working value.  Clobbers: A,DE,HL.
1510  A17F              ;   Algorithm: DE = CUR_RECORD, HL = (DPB_WORK_PTR0); subtract low byte then high byte, leaving HL
1511  A17F              ;              on
1512  A17F              ;       the high byte; no value is stored.
1513  A17F              ;   [RE] RECPTR_INC_STORE uses this: on NC it bumps and stores CUR_RECORD+1, extending the
1514  A17F              ;   high-water count. [?]
1515  A17F              ; ----------------------------------------------------------------------
1516  A17F              CMP_CURREC_VS_WORKPTR:
1517  A17F 2A EA A9             LD HL,(CUR_RECORD)
1518  A182 EB                   EX DE,HL
1519  A183 2A B3 A9             LD HL,(DPB_WORK_PTR0)
1520  A186 7B                   LD A,E
1521  A187 96                   SUB (HL)
1522  A188 23                   INC HL
1523  A189 7A                   LD A,D
1524  A18A 9E                   SBC A,(HL)
1525  A18B C9                   RET
1526  A18C              ; ----------------------------------------------------------------------
1527  A18C              ; RECPTR_INC_STORE -- if the current record is at/past the stored high-water count, bump it one
1528  A18C              ; past.
1529  A18C              ;   In: CUR_RECORD = record just processed; DPB_WORK_PTR0 -> a 16-bit record-count cell.
1530  A18C              ;   Out: if CUR_RECORD >= cell, cell := CUR_RECORD+1; else unchanged. DE = CUR_RECORD(+1 if
1531  A18C              ;        updated); HL in cell.
1532  A18C              ;   Clobbers: A,DE,HL,flags.
1533  A18C              ;   Algorithm: CMP_CURREC_VS_WORKPTR; RET C (CUR_RECORD < count, leave it); else DE:=CUR_RECORD+1
1534  A18C              ;              and write
1535  A18C              ;       it HIGH byte first (LD (HL),D), DEC HL, then LOW byte (LD (HL),E).
1536  A18C              ;   [RE] classic CP/M 2.2 extent record-count bump; keeps the FCB high-water one past the last
1537  A18C              ;   accessed.
1538  A18C              ; ----------------------------------------------------------------------
1539  A18C              RECPTR_INC_STORE:
1540  A18C CD 7F A1             CALL CMP_CURREC_VS_WORKPTR
1541  A18F D8                   RET C
1542  A190 13                   INC DE
1543  A191 72                   LD (HL),D
1544  A192 2B                   DEC HL
1545  A193 73                   LD (HL),E
1546  A194 C9                   RET
1547  A195              ; ----------------------------------------------------------------------
1548  A195              ; SUB16_DE_HL -- 16-bit subtract HL := DE - HL.
1549  A195              ;   In: DE = minuend, HL = subtrahend.
1550  A195              ;   Out: HL = DE - HL; carry set on borrow (DE < HL unsigned); A holds the high-byte result.
1551  A195              ;   Clobbers: A,HL,flags. DE preserved.
1552  A195              ;   Algorithm: low bytes (E - L) -> L, then high bytes with borrow (D - H) -> H.
1553  A195              ;   [RE] general BDOS 16-bit compare/difference helper used by the record scan and seek logic.
1554  A195              ; ----------------------------------------------------------------------
1555  A195              SUB16_DE_HL:
1556  A195 7B                   LD A,E
1557  A196 95                   SUB L
1558  A197 6F                   LD L,A
1559  A198 7A                   LD A,D
1560  A199 9C                   SBC A,H
1561  A19A 67                   LD H,A
1562  A19B C9                   RET
1563  A19C              ; ----------------------------------------------------------------------
1564  A19C              ; RECORD_SCAN_INIT -- enter the directory-record scan in store mode (write A into the located byte).
1565  A19C              ;   In: see RECORD_SCAN_BODY.  Out: see RECORD_SCAN_BODY.  Clobbers: A,BC,DE,HL,flags.
1566  A19C              ;   Algorithm: set C=$FF so the INC C inside RECORD_SCAN_BODY wraps to 0 (Z) and takes the store
1567  A19C              ;              branch
1568  A19C              ;       (FCB_STORE_A_ORPHAN), then fall through into RECORD_SCAN_BODY.
1569  A19C              ;   [RE] thin mode-selecting entry to the shared directory-record scan.
1570  A19C              ; ----------------------------------------------------------------------
1571  A19C              RECORD_SCAN_INIT:
1572  A19C 0E FF                LD C,$FF
1573  A19E              ; ----------------------------------------------------------------------
1574  A19E              ; RECORD_SCAN_BODY -- scan to the target byte in the cached directory record, then store or compare
1575  A19E              ; A there.
1576  A19E              ;   In: C = mode (INC C wraps to 0 => store mode, else compare); REC_CACHE = record cursor;
1577  A19E              ;       REC_SCAN_PTR =
1578  A19E              ;       scan limit; REC_BYTE_OFFSET = byte offset; A = byte to store/compare; DIRBUF holds the
1579  A19E              ;       loaded record.
1580  A19E              ;   Out: store mode writes A (FCB_STORE_A_ORPHAN). Compare: Z on match; if no match and CUR_RECORD
1581  A19E              ;        is past the
1582  A19E              ;        stored count it flags the drive R/O (DRV_SETRO_H). NC if REC_CACHE-REC_SCAN_PTR did not
1583  A19E              ;        borrow.
1584  A19E              ;   Clobbers: A,BC,DE,HL,flags.
1585  A19E              ;   Algorithm: DE:=REC_CACHE, HL:=REC_SCAN_PTR; SUB16_DE_HL; RET NC if no borrow. Else DIR_CHECKSUM,
1586  A19E              ;              add
1587  A19E              ;       REC_BYTE_OFFSET to REC_CACHE to address the target byte. INC C: if it wrapped to 0, store A;
1588  A19E              ;       else CP (HL),
1589  A19E              ;       RET Z on match; on mismatch CMP_CURREC_VS_WORKPTR; RET NC if within count, else DRV_SETRO_H.
1590  A19E              ;   [RE] heart of the directory record scan/checksum loop in the BDOS deblocking layer.
1591  A19E              ; ----------------------------------------------------------------------
1592  A19E              RECORD_SCAN_BODY:
1593  A19E 2A EC A9             LD HL,(REC_CACHE)
1594  A1A1 EB                   EX DE,HL
1595  A1A2 2A CC A9             LD HL,(REC_SCAN_PTR)
1596  A1A5 CD 95 A1             CALL SUB16_DE_HL
1597  A1A8 D0                   RET NC
1598  A1A9 C5                   PUSH BC
1599  A1AA CD F7 A0             CALL DIR_CHECKSUM
1600  A1AD 2A BD A9             LD HL,(REC_BYTE_OFFSET)
1601  A1B0 EB                   EX DE,HL
1602  A1B1 2A EC A9             LD HL,(REC_CACHE)
1603  A1B4 19                   ADD HL,DE
1604  A1B5 C1                   POP BC
1605  A1B6 0C                   INC C
1606  A1B7 CA C4 A1             JP Z,FCB_STORE_A_ORPHAN
1607  A1BA BE                   CP (HL)
1608  A1BB C8                   RET Z
1609  A1BC CD 7F A1             CALL CMP_CURREC_VS_WORKPTR
1610  A1BF D0                   RET NC
1611  A1C0 CD 2C A1             CALL DRV_SETRO_H
1612  A1C3 C9                   RET
1613  A1C4              ; ----------------------------------------------------------------------
1614  A1C4              ; FCB_STORE_A_ORPHAN -- store the accumulator into the directory byte addressed by HL (scan
1615  A1C4              ; store-mode tail).
1616  A1C4              ;   In: HL -> target directory byte; A = value to store.  Out: (HL) = A.  Clobbers: none (memory
1617  A1C4              ;       only).
1618  A1C4              ;   Algorithm: LD (HL),A; RET.
1619  A1C4              ;   [RE] store-mode terminator branched to from RECORD_SCAN_BODY when INC C wrapped to 0.
1620  A1C4              ; ----------------------------------------------------------------------
1621  A1C4              FCB_STORE_A_ORPHAN:
1622  A1C4 77                   LD (HL),A
1623  A1C5 C9                   RET
1624  A1C6              ; ----------------------------------------------------------------------
1625  A1C6              ; DIR_RECORD_WRITE -- checksum-verify then write the directory buffer to disk as a record, and
1626  A1C6              ; refresh the user buffer.
1627  A1C6              ;   In: directory buffer (DIRBUF) and the BDOS deblock state set up by the caller.
1628  A1C6              ;   Out: the record is written to disk (with the R/O-on-tamper check); user DMA restored; errors
1629  A1C6              ;        raised via
1630  A1C6              ;        DISK_WRITE_CHECKED.  Clobbers: A,BC,DE,HL,flags.
1631  A1C6              ;   Algorithm: RECORD_SCAN_INIT runs the scan in store mode (re-checksums DIRBUF and sets the drive
1632  A1C6              ;              R/O on a
1633  A1C6              ;       tamper mismatch). SET_DMA_TO_DISK_BUF aims the BIOS DMA at DIRBUF; C=1 selects the directory
1634  A1C6              ;       write type;
1635  A1C6              ;       DISK_WRITE_CHECKED issues the BIOS WRITE and raises on error; JP RESTORE_USER_DMA restores
1636  A1C6              ;       the user DMA.
1637  A1C6              ;   [RE] directory-record write path; C=1 is the CP/M deblock directory-write code.
1638  A1C6              ; ----------------------------------------------------------------------
1639  A1C6              DIR_RECORD_WRITE:
1640  A1C6 CD 9C A1             CALL RECORD_SCAN_INIT
1641  A1C9 CD E0 A1             CALL SET_DMA_TO_DISK_BUF
1642  A1CC 0E 01                LD C,$01
1643  A1CE CD B8 9F             CALL DISK_WRITE_CHECKED
1644  A1D1 C3 DA A1             JP RESTORE_USER_DMA
1645  A1D4              ; ----------------------------------------------------------------------
1646  A1D4              ; DIR_RECORD_READ -- read a directory record from disk into the directory buffer, then restore the
1647  A1D4              ; user DMA.
1648  A1D4              ;   In: BDOS deblock state set up by the caller.
1649  A1D4              ;   Out: DIRBUF filled from disk; user DMA restored; errors raised via DISK_READ_CHECKED.  Clobbers:
1650  A1D4              ;        A,BC,DE,HL,flags.
1651  A1D4              ;   Algorithm: SET_DMA_TO_DISK_BUF, DISK_READ_CHECKED (BIOS READ + error check), then fall through
1652  A1D4              ;              into
1653  A1D4              ;       RESTORE_USER_DMA.
1654  A1D4              ;   [RE] directory-record read path; pairs with DIR_RECORD_WRITE.
1655  A1D4              ; ----------------------------------------------------------------------
1656  A1D4              DIR_RECORD_READ:
1657  A1D4 CD E0 A1             CALL SET_DMA_TO_DISK_BUF
1658  A1D7 CD B2 9F             CALL DISK_READ_CHECKED
1659  A1DA              ; ----------------------------------------------------------------------
1660  A1DA              ; RESTORE_USER_DMA -- restore the BIOS DMA address to the user's DMA buffer.
1661  A1DA              ;   In: DMA_ADDR cell holds the user DMA address.
1662  A1DA              ;   Out: BIOS DMA set to (DMA_ADDR) via the BIOS SETDMA vector.  Clobbers: BC,HL,flags.
1663  A1DA              ;   Algorithm: HL := address of the DMA_ADDR cell, then JP SET_DMA_FROM_CELL.
1664  A1DA              ;   [RE] used after directory I/O to put DMA back to the application buffer.
1665  A1DA              ; ----------------------------------------------------------------------
1666  A1DA              RESTORE_USER_DMA:
1667  A1DA 21 B1 A9             LD HL,DMA_ADDR
1668  A1DD C3 E3 A1             JP SET_DMA_FROM_CELL
1669  A1E0              ; ----------------------------------------------------------------------
1670  A1E0              ; SET_DMA_TO_DISK_BUF -- point the BIOS DMA at the directory/disk buffer (DIRBUF).
1671  A1E0              ;   In: DIRBUF_PTR cell holds the directory buffer address.
1672  A1E0              ;   Out: BIOS DMA set to (DIRBUF_PTR) via the BIOS SETDMA vector.  Clobbers: BC,HL,flags.
1673  A1E0              ;   Algorithm: HL := address of the DIRBUF_PTR cell, fall into SET_DMA_FROM_CELL.
1674  A1E0              ;   [RE] companion to RESTORE_USER_DMA; aims I/O at the OS directory buffer.
1675  A1E0              ; ----------------------------------------------------------------------
1676  A1E0              SET_DMA_TO_DISK_BUF:
1677  A1E0 21 B9 A9             LD HL,DIRBUF_PTR
1678  A1E3              ; ----------------------------------------------------------------------
1679  A1E3              ; SET_DMA_FROM_CELL -- load a DMA address from a 16-bit cell and hand it to the BIOS SETDMA vector.
1680  A1E3              ;   In: HL -> a 2-byte little-endian DMA address cell.
1681  A1E3              ;   Out: BIOS DMA set to (HL); tail-jumps into the BIOS SETDMA jump vector.  Clobbers: BC,HL.
1682  A1E3              ;   Algorithm: C := (HL), INC HL, B := (HL); JP $FA24 (BIOS SETDMA entry in the 2.23 BDOS->BIOS
1683  A1E3              ;              jump-vector page).
1684  A1E3              ;   [RE] shared tail of SET_DMA_TO_DISK_BUF and RESTORE_USER_DMA. 2.23 BIOS jump table is at Z-80
1685  A1E3              ;   $FA00
1686  A1E3              ;        (= Apple $0A00 low RAM); the 2.20 twin uses $AA24 here. [DOC
1687  A1E3              ;        feedback_softcard_z80_high_addr_is_low_apple_ram]
1688  A1E3              ; ----------------------------------------------------------------------
1689  A1E3              SET_DMA_FROM_CELL:
1690  A1E3 4E                   LD C,(HL)
1691  A1E4 23                   INC HL
1692  A1E5 46                   LD B,(HL)
1693  A1E6 C3 24 FA             JP $FA24
1694  A1E9              ; ----------------------------------------------------------------------
1695  A1E9              ; DISK_BUF_MOVE -- copy the 128-byte directory buffer into the user DMA buffer.
1696  A1E9              ;   In: DIRBUF_PTR -> source (directory buffer); DMA_ADDR -> destination (user DMA).
1697  A1E9              ;   Out: 128 bytes copied DIRBUF -> user DMA.  Clobbers: A,BC,DE,HL,flags.
1698  A1E9              ;   Algorithm: DE := (DIRBUF_PTR), HL := (DMA_ADDR), C := $80 (128), JP the byte-copy loop.
1699  A1E9              ;   [RE] deblock read-back: surfaces a directory-sector record to the application buffer.
1700  A1E9              ; ----------------------------------------------------------------------
1701  A1E9              DISK_BUF_MOVE:
1702  A1E9 2A B9 A9             LD HL,(DIRBUF_PTR)
1703  A1EC EB                   EX DE,HL
1704  A1ED 2A B1 A9             LD HL,(DMA_ADDR)
1705  A1F0 0E 80                LD C,$80
1706  A1F2 C3 4F 9F             JP BLOCK_COPY_INCC
1707  A1F5              ; ----------------------------------------------------------------------
1708  A1F5              ; CUR_RECORD_BYTES_EQUAL -- test whether the low and high bytes of the 16-bit CUR_RECORD cell are
1709  A1F5              ; equal.
1710  A1F5              ;   In: CUR_RECORD = a 16-bit cell (CUR_RECORD low, CUR_RECORD_HI high).
1711  A1F5              ;   Out: if the two bytes differ, NZ with A = the low byte; if equal, A = low byte + 1.  Clobbers:
1712  A1F5              ;        A,HL,flags.
1713  A1F5              ;   Algorithm: HL -> low byte; A := (HL); INC HL; CP (HL); RET NZ if they differ; else INC A and
1714  A1F5              ;              RET.
1715  A1F5              ;   [RE] deblock helper comparing the two halves of CUR_RECORD; called widely. The exact role of the
1716  A1F5              ;        equal/INC result is UNKNOWN from these bytes alone (callers consume A / the Z flag).
1717  A1F5              ; ----------------------------------------------------------------------
1718  A1F5              CUR_RECORD_BYTES_EQUAL:
1719  A1F5 21 EA A9             LD HL,CUR_RECORD
1720  A1F8 7E                   LD A,(HL)
1721  A1F9 23                   INC HL
1722  A1FA BE                   CP (HL)
1723  A1FB C0                   RET NZ
1724  A1FC 3C                   INC A
1725  A1FD C9                   RET
1726  A1FE              ; ----------------------------------------------------------------------
1727  A1FE              ; INVALIDATE_CUR_RECORD -- mark the cached record pointer invalid (CUR_RECORD := $FFFF).
1728  A1FE              ;   In: none.  Out: CUR_RECORD cell = $FFFF.  Clobbers: HL.
1729  A1FE              ;   Algorithm: HL := $FFFF; store to CUR_RECORD; RET.
1730  A1FE              ;   [RE] forces the next deblock access to reload, since $FFFF can never equal a real record number.
1731  A1FE              ; ----------------------------------------------------------------------
1732  A1FE              INVALIDATE_CUR_RECORD:
1733  A1FE 21 FF FF             LD HL,$FFFF
1734  A201 22 EA A9             LD (CUR_RECORD),HL
1735  A204 C9                   RET
1736  A205              ; ----------------------------------------------------------------------
1737  A205              ; DIR_READ_NEXT -- advance the directory record pointer and read the next directory record.
1738  A205              ;   In: CUR_RECORD = last directory record index processed; DPB_REC_PTR = total directory records on
1739  A205              ;       this drive.
1740  A205              ;   Out: CY/A per DIR_RECORD_DEBLOCK if a record remains; CUR_RECORD invalidated ($FFFF) at end of
1741  A205              ;        directory.
1742  A205              ;   Clobbers: A,DE,HL,flags.
1743  A205              ;   Algorithm: increment CUR_RECORD; if it has not passed DPB_REC_PTR, fall through to
1744  A205              ;              DIR_RECORD_DEBLOCK to
1745  A205              ;       position on the next 32-byte entry; else mark end-of-directory via INVALIDATE_CUR_RECORD.
1746  A205              ;   [RE] canonical CP/M 2.2 read-next-directory-entry sequencer.
1747  A205              ; ----------------------------------------------------------------------
1748  A205              DIR_READ_NEXT:
1749  A205 2A C8 A9             LD HL,(DPB_REC_PTR)
1750  A208 EB                   EX DE,HL
1751  A209 2A EA A9             LD HL,(CUR_RECORD)
1752  A20C                      ; CUR_RECORD += 1 (advance to the next directory record)
1753  A20C 23                   INC HL
1754  A20D 22 EA A9             LD (CUR_RECORD),HL
1755  A210 CD 95 A1             CALL SUB16_DE_HL
1756  A213 D2 19 A2             JP NC,DIR_RECORD_DEBLOCK
1757  A216 C3 FE A1             JP INVALIDATE_CUR_RECORD
1758  A219              ; ----------------------------------------------------------------------
1759  A219              ; DIR_RECORD_DEBLOCK -- position on the current 32-byte directory entry within its 128-byte record,
1760  A219              ; reading from disk on a boundary.
1761  A219              ;   In: CUR_RECORD = current directory record index.
1762  A219              ;   Out: DEBLOCK_BYTE_OFF = byte offset (0/32/64/96) of this entry in the buffer; on a fresh record
1763  A219              ;        the record
1764  A219              ;        has been read into the disk buffer.  Clobbers: A,BC,DE,HL,flags.
1765  A219              ;   Algorithm: offset = (CUR_RECORD & 3) << 5; store it; if non-zero the entry is already buffered
1766  A219              ;              so return;
1767  A219              ;       on a boundary (offset 0) compute the absolute disk record and read it into DIRBUF.
1768  A219              ;   [RE] CP/M packs four 32-byte directory entries per 128-byte record; this is the BDOS deblocking
1769  A219              ;   step.
1770  A219              ; ----------------------------------------------------------------------
1771  A219              DIR_RECORD_DEBLOCK:
1772  A219 3A EA A9             LD A,(CUR_RECORD)
1773  A21C E6 03                AND $03
1774  A21E 06 05                LD B,$05
1775  A220              ; ----------------------------------------------------------------------
1776  A220              ; DIR_DEBLOCK_SHIFT -- (record & 3) << 5 to form the 32-byte entry offset within the 128-byte
1777  A220              ; record. [RE]
1778  A220              ; ----------------------------------------------------------------------
1779  A220              DIR_DEBLOCK_SHIFT:
1780  A220 87                   ADD A,A
1781  A221 05                   DEC B
1782  A222 C2 20 A2             JP NZ,DIR_DEBLOCK_SHIFT
1783  A225 32 E9 A9             LD (DEBLOCK_BYTE_OFF),A
1784  A228 B7                   OR A
1785  A229 C0                   RET NZ
1786  A22A C5                   PUSH BC
1787  A22B CD C3 9F             CALL REC_DIV4_SETUP
1788  A22E CD D4 A1             CALL DIR_RECORD_READ
1789  A231 C1                   POP BC
1790  A232 C3 9E A1             JP RECORD_SCAN_BODY
1791  A235              ; ----------------------------------------------------------------------
1792  A235              ; ALLOC_BIT_GET -- fetch the allocation-vector bit for a given disk block, returning it in carry.
1793  A235              ;   In: BC = block (group) number.
1794  A235              ;   Out: carry/high bit of A = current allocation state; A = the allocation byte rotated so the
1795  A235              ;        wanted bit is
1796  A235              ;        in the MSB; HL = address of that byte in the allocation vector; D = E = bit index.
1797  A235              ;        Clobbers: A,BC,DE,HL,flags.
1798  A235              ;   Algorithm: D=E=(block & 7)+1 = 1-based bit index (rotate count); byte index = block >> 3; add to
1799  A235              ;              ALLOC_VEC_PTR;
1800  A235              ;       load the byte and rotate left by the bit index so the selected bit lands in carry/MSB.
1801  A235              ;   [RE] canonical CP/M 2.2 getmod: read one allocation bit from the bit-vector.
1802  A235              ; ----------------------------------------------------------------------
1803  A235              ALLOC_BIT_GET:
1804  A235 79                   LD A,C
1805  A236 E6 07                AND $07
1806  A238 3C                   INC A
1807  A239 5F                   LD E,A
1808  A23A 57                   LD D,A
1809  A23B 79                   LD A,C
1810  A23C 0F                   RRCA
1811  A23D 0F                   RRCA
1812  A23E 0F                   RRCA
1813  A23F E6 1F                AND $1F
1814  A241 4F                   LD C,A
1815  A242 78                   LD A,B
1816  A243 87                   ADD A,A
1817  A244 87                   ADD A,A
1818  A245 87                   ADD A,A
1819  A246 87                   ADD A,A
1820  A247 87                   ADD A,A
1821  A248 B1                   OR C
1822  A249 4F                   LD C,A
1823  A24A 78                   LD A,B
1824  A24B 0F                   RRCA
1825  A24C 0F                   RRCA
1826  A24D 0F                   RRCA
1827  A24E E6 1F                AND $1F
1828  A250 47                   LD B,A
1829  A251 2A BF A9             LD HL,(ALLOC_VEC_PTR)
1830  A254 09                   ADD HL,BC
1831  A255 7E                   LD A,(HL)
1832  A256              ; ----------------------------------------------------------------------
1833  A256              ; ALLOC_BIT_ROTATE -- rotate the allocation byte left D=bit-index times to land the wanted bit in
1834  A256              ; the MSB. [RE]
1835  A256              ; ----------------------------------------------------------------------
1836  A256              ALLOC_BIT_ROTATE:
1837  A256 07                   RLCA
1838  A257 1D                   DEC E
1839  A258 C2 56 A2             JP NZ,ALLOC_BIT_ROTATE
1840  A25B C9                   RET
1841  A25C              ; ----------------------------------------------------------------------
1842  A25C              ; ALLOC_BIT_SET -- mark a disk block as allocated in the allocation vector.
1843  A25C              ;   In: BC = block (group) number.  Out: the allocation byte for that block is updated in place with
1844  A25C              ;       its bit forced to 1.
1845  A25C              ;   Clobbers: A,BC,DE,HL,flags.
1846  A25C              ;   Algorithm: ALLOC_BIT_GET reads the byte (left-rotated so the bit is in the MSB) and returns the
1847  A25C              ;              bit index in D;
1848  A25C              ;       clear the rotated LSB and OR in 1 to set the target bit; rotate right D times to restore
1849  A25C              ;       alignment; store back.
1850  A25C              ;   [RE] canonical CP/M 2.2 setmod: set one allocation bit in the bit-vector.
1851  A25C              ; ----------------------------------------------------------------------
1852  A25C              ALLOC_BIT_SET:
1853  A25C D5                   PUSH DE
1854  A25D CD 35 A2             CALL ALLOC_BIT_GET
1855  A260 E6 FE                AND $FE
1856  A262 C1                   POP BC
1857  A263 B1                   OR C
1858  A264              ; ----------------------------------------------------------------------
1859  A264              ; ALLOC_BIT_RESTORE -- rotate the allocation byte right D times to restore alignment, then store it
1860  A264              ; back. [RE]
1861  A264              ; ----------------------------------------------------------------------
1862  A264              ALLOC_BIT_RESTORE:
1863  A264 0F                   RRCA
1864  A265 15                   DEC D
1865  A266 C2 64 A2             JP NZ,ALLOC_BIT_RESTORE
1866  A269 77                   LD (HL),A
1867  A26A C9                   RET
1868  A26B              ; ----------------------------------------------------------------------
1869  A26B              ; ALLOC_FROM_FCB -- mark every disk block referenced by a directory entry's block map as allocated.
1870  A26B              ;   In: DEBLOCK_BYTE_OFF positions HL on the current 32-byte directory entry; BLOCK_WIDTH_FLAG
1871  A26B              ;       selects 8-bit
1872  A26B              ;       (non-zero, DSM<256) vs 16-bit (zero) block numbers; entry holds a 16-byte block map at
1873  A26B              ;       offset $10.
1874  A26B              ;   Out: the allocation vector has every non-zero, in-range block of this entry marked used.
1875  A26B              ;        Clobbers: A,BC,DE,HL,flags.
1876  A26B              ;   Algorithm: point HL at the block map (entry+$10); iterate 16 (8-bit) or 8 (16-bit) pointers;
1877  A26B              ;              read each block
1878  A26B              ;       number; if non-zero and <= MAX_BLOCK_DSM, mark it allocated via ALLOC_BIT_SET.
1879  A26B              ;   [RE] canonical CP/M 2.2 directory-entry allocation-map application used when rebuilding the
1880  A26B              ;   allocation vector.
1881  A26B              ; ----------------------------------------------------------------------
1882  A26B              ALLOC_FROM_FCB:
1883  A26B CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
1884  A26E                      ; point HL at the 16-byte block map at directory-entry offset $10
1885  A26E 11 10 00             LD DE,$0010
1886  A271 19                   ADD HL,DE
1887  A272 C5                   PUSH BC
1888  A273 0E 11                LD C,$11
1889  A275              ; ----------------------------------------------------------------------
1890  A275              ; ALLOC_FROM_FCB_LOOP -- per block-map slot: dispatch 8-bit vs 16-bit block-number handling. [RE]
1891  A275              ; ----------------------------------------------------------------------
1892  A275              ALLOC_FROM_FCB_LOOP:
1893  A275 D1                   POP DE
1894  A276 0D                   DEC C
1895  A277 C8                   RET Z
1896  A278 D5                   PUSH DE
1897  A279 3A DD A9             LD A,(BLOCK_WIDTH_FLAG)
1898  A27C B7                   OR A
1899  A27D CA 88 A2             JP Z,ALLOC_FROM_FCB_WIDE
1900  A280 C5                   PUSH BC
1901  A281 E5                   PUSH HL
1902  A282 4E                   LD C,(HL)
1903  A283 06 00                LD B,$00
1904  A285 C3 8E A2             JP ALLOC_FROM_FCB_CHECK
1905  A288              ; ----------------------------------------------------------------------
1906  A288              ; ALLOC_FROM_FCB_WIDE -- 8-bit block path: load a single block byte into BC. [RE]
1907  A288              ; ----------------------------------------------------------------------
1908  A288              ALLOC_FROM_FCB_WIDE:
1909  A288 0D                   DEC C
1910  A289 C5                   PUSH BC
1911  A28A 4E                   LD C,(HL)
1912  A28B 23                   INC HL
1913  A28C 46                   LD B,(HL)
1914  A28D E5                   PUSH HL
1915  A28E              ; ----------------------------------------------------------------------
1916  A28E              ; ALLOC_FROM_FCB_CHECK -- mark the block used if it is non-zero and within MAX_BLOCK_DSM. [RE]
1917  A28E              ; ----------------------------------------------------------------------
1918  A28E              ALLOC_FROM_FCB_CHECK:
1919  A28E 79                   LD A,C
1920  A28F B0                   OR B
1921  A290 CA 9D A2             JP Z,ALLOC_FROM_FCB_NEXT
1922  A293 2A C6 A9             LD HL,(MAX_BLOCK_DSM)
1923  A296 7D                   LD A,L
1924  A297 91                   SUB C
1925  A298 7C                   LD A,H
1926  A299 98                   SBC A,B
1927  A29A D4 5C A2             CALL NC,ALLOC_BIT_SET
1928  A29D              ; ----------------------------------------------------------------------
1929  A29D              ; ALLOC_FROM_FCB_NEXT -- advance to the next block-map slot and loop. [RE]
1930  A29D              ; ----------------------------------------------------------------------
1931  A29D              ALLOC_FROM_FCB_NEXT:
1932  A29D E1                   POP HL
1933  A29E 23                   INC HL
1934  A29F C1                   POP BC
1935  A2A0 C3 75 A2             JP ALLOC_FROM_FCB_LOOP
1936  A2A3              ; ----------------------------------------------------------------------
1937  A2A3              ; ALLOC_VECTOR_BUILD -- rebuild the drive's allocation bit-vector by scanning the entire directory.
1938  A2A3              ;   In: selected drive's DPB fields (MAX_BLOCK_DSM, directory-reserved-blocks word at ALLOC_END_PTR,
1939  A2A3              ;       ALLOC_VEC_PTR).
1940  A2A3              ;   Out: allocation vector fully populated: reserved directory blocks plus every block referenced by
1941  A2A3              ;        a non-deleted
1942  A2A3              ;        directory entry are marked used.  Clobbers: A,BC,DE,HL,flags.
1943  A2A3              ;   Algorithm: zero the allocation vector across its whole length ((DSM+1)/8 bytes); seed the
1944  A2A3              ;              reserved directory
1945  A2A3              ;       blocks; reset the scan workspace to read from the start; for each entry skip deleted ($E5)
1946  A2A3              ;       ones, run a
1947  A2A3              ;       special-entry check against the BDOS default-FCB byte / '$' name byte, and ALLOC_FROM_FCB to
1948  A2A3              ;       mark its blocks;
1949  A2A3              ;       advance until the directory is exhausted.
1950  A2A3              ;   [RE] canonical CP/M 2.2 drive-init allocation-vector builder, invoked on drive selection /
1951  A2A3              ;   reset.
1952  A2A3              ;   [?] the compare against (BDOS_STACK_TOP) then the $24 ('$') name-byte test and (BDOS_RETVAL)
1953  A2A3              ;   store is a special-entry path;
1954  A2A3              ;       its exact intent is UNKNOWN.
1955  A2A3              ; ----------------------------------------------------------------------
1956  A2A3              ALLOC_VECTOR_BUILD:
1957  A2A3 2A C6 A9             LD HL,(MAX_BLOCK_DSM)
1958  A2A6 0E 03                LD C,$03
1959  A2A8 CD EA A0             CALL DRV_INSTALL_RWTS_10
1960  A2AB 23                   INC HL
1961  A2AC 44                   LD B,H
1962  A2AD 4D                   LD C,L
1963  A2AE 2A BF A9             LD HL,(ALLOC_VEC_PTR)
1964  A2B1              ; ----------------------------------------------------------------------
1965  A2B1              ; ALLOC_VECTOR_CLEAR_LOOP -- zero the allocation vector across its full (DSM+1)/8 byte length. [RE]
1966  A2B1              ; ----------------------------------------------------------------------
1967  A2B1              ALLOC_VECTOR_CLEAR_LOOP:
1968  A2B1 36 00                LD (HL),$00
1969  A2B3 23                   INC HL
1970  A2B4 0B                   DEC BC
1971  A2B5 78                   LD A,B
1972  A2B6 B1                   OR C
1973  A2B7 C2 B1 A2             JP NZ,ALLOC_VECTOR_CLEAR_LOOP
1974  A2BA 2A CA A9             LD HL,(ALLOC_END_PTR)
1975  A2BD EB                   EX DE,HL
1976  A2BE 2A BF A9             LD HL,(ALLOC_VEC_PTR)
1977  A2C1 73                   LD (HL),E
1978  A2C2 23                   INC HL
1979  A2C3 72                   LD (HL),D
1980  A2C4 CD A1 9F             CALL DISK_HOME_CLEAR_SCAN
1981  A2C7 2A B3 A9             LD HL,(DPB_WORK_PTR0)
1982  A2CA 36 03                LD (HL),$03
1983  A2CC 23                   INC HL
1984  A2CD 36 00                LD (HL),$00
1985  A2CF CD FE A1             CALL INVALIDATE_CUR_RECORD
1986  A2D2              ; ----------------------------------------------------------------------
1987  A2D2              ; ALLOC_VECTOR_SCAN_LOOP -- read each directory entry, skipping erased ($E5) ones, applying the
1988  A2D2              ; special-entry check. [RE]
1989  A2D2              ; ----------------------------------------------------------------------
1990  A2D2              ALLOC_VECTOR_SCAN_LOOP:
1991  A2D2 0E FF                LD C,$FF
1992  A2D4 CD 05 A2             CALL DIR_READ_NEXT
1993  A2D7 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
1994  A2DA C8                   RET Z
1995  A2DB CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
1996  A2DE 3E E5                LD A,$E5
1997  A2E0 BE                   CP (HL)
1998  A2E1 CA D2 A2             JP Z,ALLOC_VECTOR_SCAN_LOOP
1999  A2E4 3A 41 9F             LD A,(BDOS_STACK_TOP)
2000  A2E7 BE                   CP (HL)
2001  A2E8 C2 F6 A2             JP NZ,ALLOC_VECTOR_SCAN_MARK
2002  A2EB 23                   INC HL
2003  A2EC 7E                   LD A,(HL)
2004  A2ED                      ; compare the name byte against '$' for the special-entry path [?]
2005  A2ED D6 24                SUB $24
2006  A2EF C2 F6 A2             JP NZ,ALLOC_VECTOR_SCAN_MARK
2007  A2F2 3D                   DEC A
2008  A2F3 32 45 9F             LD (BDOS_RETVAL),A
2009  A2F6              ; ----------------------------------------------------------------------
2010  A2F6              ; ALLOC_VECTOR_SCAN_MARK -- mark this entry's blocks used (ALLOC_FROM_FCB) and advance the scan.
2011  A2F6              ; [RE]
2012  A2F6              ; ----------------------------------------------------------------------
2013  A2F6              ALLOC_VECTOR_SCAN_MARK:
2014  A2F6 0E 01                LD C,$01
2015  A2F8 CD 6B A2             CALL ALLOC_FROM_FCB
2016  A2FB CD 8C A1             CALL RECPTR_INC_STORE
2017  A2FE C3 D2 A2             JP ALLOC_VECTOR_SCAN_LOOP
2018  A301              ; ----------------------------------------------------------------------
2019  A301              ; DIR_RETURN_MATCH_FLAG -- return the saved directory-search match status as the BDOS result.
2020  A301              ;   In: DIR_MATCH_FLAG (DIR_MATCH_FLAG) holds the last directory scan result ($FF=no match, else the
2021  A301              ;       0..3 entry index).
2022  A301              ;   Out: A = DIR_MATCH_FLAG; stored to the BDOS result byte (BDOS_RETVAL) via the common
2023  A301              ;        result-store path.  Clobbers: A.
2024  A301              ;   Algorithm: load the cached search-match flag and tail-jump into the common result store.
2025  A301              ;   [RE] common return tail of F_DELETE_HND / F_RENAME_HND / F_ATTRIB_HND.
2026  A301              ; ----------------------------------------------------------------------
2027  A301              DIR_RETURN_MATCH_FLAG:
2028  A301 3A D4 A9             LD A,(DIR_MATCH_FLAG)
2029  A304 C3 01 9F             JP BDOS_RET_RESULT
2030  A307              ; ----------------------------------------------------------------------
2031  A307              ; FCB_EXTENT_COMPARE -- compare two FCB extent bytes under the drive's extent mask.
2032  A307              ;   In: C = one extent byte; A = the other extent byte; EXTENT_MASK (DPB_EXM) = DPB EXM.
2033  A307              ;   Out: A,flags = ((A & ~mask) - (C & ~mask)) & $1F; Z set when the high extent fields match.
2034  A307              ;        Clobbers: A (BC/AF saved+restored).
2035  A307              ;   Algorithm: complement EXM, AND it into both extent bytes (dropping the masked low bits),
2036  A307              ;              subtract, keep five
2037  A307              ;       bits, and test for equality.
2038  A307              ;   [RE]
2039  A307              ; ----------------------------------------------------------------------
2040  A307              FCB_EXTENT_COMPARE:
2041  A307 C5                   PUSH BC
2042  A308 F5                   PUSH AF
2043  A309 3A C5 A9             LD A,(DPB_EXM)
2044  A30C 2F                   CPL
2045  A30D 47                   LD B,A
2046  A30E 79                   LD A,C
2047  A30F A0                   AND B
2048  A310 4F                   LD C,A
2049  A311 F1                   POP AF
2050  A312 A0                   AND B
2051  A313 91                   SUB C
2052  A314                      ; keep five extent bits for the masked extent comparison
2053  A314 E6 1F                AND $1F
2054  A316 C1                   POP BC
2055  A317 C9                   RET
2056  A318              ; ----------------------------------------------------------------------
2057  A318              ; DIR_SEARCH_FIRST -- begin a directory scan for the current FCB, comparing C bytes per entry.
2058  A318              ;   In: C = number of FCB bytes to match ($0C=name+type, $0F=incl. extent); FCB pointer in
2059  A318              ;       CURFCB_PTR (BDOS_PARAM_PTR).
2060  A318              ;   Out: falls through into BDOS_DIR_SCAN_NEXT, which returns the within-record entry index 0..3 or
2061  A318              ;        $FF.
2062  A318              ;   Clobbers: A,B,C,D,E,H,L,flags.
2063  A318              ;   Algorithm: set DIR_MATCH_FLAG=$FF, store the compare length (DIR_CMP_LEN) and search-FCB pointer
2064  A318              ;              (DIR_FCB_PTR), reset
2065  A318              ;       the record counter to -1 (INVALIDATE_CUR_RECORD), rewind/clear the scan state, then run the
2066  A318              ;       first pass.
2067  A318              ;   [RE]
2068  A318              ; ----------------------------------------------------------------------
2069  A318              DIR_SEARCH_FIRST:
2070  A318 3E FF                LD A,$FF
2071  A31A 32 D4 A9             LD (DIR_MATCH_FLAG),A
2072  A31D 21 D8 A9             LD HL,DIR_CMP_LEN
2073  A320 71                   LD (HL),C
2074  A321 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2075  A324 22 D9 A9             LD (DIR_FCB_PTR),HL
2076  A327 CD FE A1             CALL INVALIDATE_CUR_RECORD
2077  A32A CD A1 9F             CALL DISK_HOME_CLEAR_SCAN
2078  A32D              ; ----------------------------------------------------------------------
2079  A32D              ; BDOS_DIR_SCAN_NEXT -- advance through directory entries until one matches the search FCB.
2080  A32D              ;   In: search-FCB pointer in DIR_FCB_PTR (DIR_FCB_PTR); compare length in DIR_CMP_LEN
2081  A32D              ;       (DIR_CMP_LEN).
2082  A32D              ;   Out: A = matching entry index (0..3) on success (DIR_MATCH_FOUND); not-found via DIR_NO_MATCH
2083  A32D              ;        ($FF result).
2084  A32D              ;   Clobbers: A,B,C,D,E,H,L,flags.
2085  A32D              ;   Algorithm: step to the next directory record (DIR_READ_NEXT); if the counter passed the
2086  A32D              ;              directory limit ->
2087  A32D              ;       not found; otherwise treat erased ($E5) entries specially and bound-check
2088  A32D              ;       (CMP_CURREC_VS_WORKPTR), then
2089  A32D              ;       fall into the per-entry compare; on full match -> DIR_MATCH_FOUND, else loop to the next
2090  A32D              ;       entry/record.
2091  A32D              ;   [RE] standard CP/M 2.2 directory search-next with '?' wildcards.
2092  A32D              ; ----------------------------------------------------------------------
2093  A32D              BDOS_DIR_SCAN_NEXT:
2094  A32D 0E 00                LD C,$00
2095  A32F CD 05 A2             CALL DIR_READ_NEXT
2096  A332 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2097  A335 CA 94 A3             JP Z,DIR_NO_MATCH
2098  A338 2A D9 A9             LD HL,(DIR_FCB_PTR)
2099  A33B EB                   EX DE,HL
2100  A33C 1A                   LD A,(DE)
2101  A33D FE E5                CP $E5
2102  A33F CA 4A A3             JP Z,BDOS_DIR_SCAN_NEXT_CMP
2103  A342 D5                   PUSH DE
2104  A343 CD 7F A1             CALL CMP_CURREC_VS_WORKPTR
2105  A346 D1                   POP DE
2106  A347 D2 94 A3             JP NC,DIR_NO_MATCH
2107  A34A              ; ----------------------------------------------------------------------
2108  A34A              ; BDOS_DIR_SCAN_NEXT_CMP -- set up the per-entry compare loop for BDOS_DIR_SCAN_NEXT.
2109  A34A              ;   In: DE -> directory entry; FCB bytes via FCB_BUF_PTR_ADD_OFFSET; DIR_CMP_LEN (DIR_CMP_LEN) bytes
2110  A34A              ;       to compare.
2111  A34A              ;   Out: B=0 (index), C=compare count; falls into DIR_CMP_BYTE_LOOP.  Clobbers: A,B,C,H,L,flags.
2112  A34A              ;   Algorithm: point HL at the FCB bytes, load the compare length into C, zero the byte index B,
2113  A34A              ;              enter the loop.
2114  A34A              ;   [RE]
2115  A34A              ; ----------------------------------------------------------------------
2116  A34A              BDOS_DIR_SCAN_NEXT_CMP:
2117  A34A CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2118  A34D 3A D8 A9             LD A,(DIR_CMP_LEN)
2119  A350 4F                   LD C,A
2120  A351 06 00                LD B,$00
2121  A353              ; ----------------------------------------------------------------------
2122  A353              ; DIR_CMP_BYTE_LOOP -- compare one FCB byte against the directory entry, honoring wildcards.
2123  A353              ;   In: C = bytes remaining; B = byte index; DE -> entry byte; HL -> FCB byte.
2124  A353              ;   Out: count exhausted -> DIR_MATCH_FOUND; mismatch -> restart BDOS_DIR_SCAN_NEXT; else step via
2125  A353              ;        DIR_CMP_ADVANCE.
2126  A353              ;   Clobbers: A,flags (DE,HL,B,C advanced by DIR_CMP_ADVANCE).
2127  A353              ;   Algorithm: count==0 ends the entry as a match; entry byte '?' ($3F) is a wildcard; index 13
2128  A353              ;              ($0D, S1) is
2129  A353              ;       skipped; index 12 ($0C) is the extent field (DIR_CMP_EXTENT); otherwise the two bytes must
2130  A353              ;       match in the
2131  A353              ;       low 7 bits.
2132  A353              ;   [RE]
2133  A353              ; ----------------------------------------------------------------------
2134  A353              DIR_CMP_BYTE_LOOP:
2135  A353 79                   LD A,C
2136  A354 B7                   OR A
2137  A355 CA 83 A3             JP Z,DIR_MATCH_FOUND
2138  A358 1A                   LD A,(DE)
2139  A359 FE 3F                CP $3F
2140  A35B CA 7C A3             JP Z,DIR_CMP_ADVANCE
2141  A35E 78                   LD A,B
2142  A35F FE 0D                CP $0D
2143  A361 CA 7C A3             JP Z,DIR_CMP_ADVANCE
2144  A364 FE 0C                CP $0C
2145  A366 1A                   LD A,(DE)
2146  A367 CA 73 A3             JP Z,DIR_CMP_EXTENT
2147  A36A 96                   SUB (HL)
2148  A36B E6 7F                AND $7F
2149  A36D C2 2D A3             JP NZ,BDOS_DIR_SCAN_NEXT
2150  A370 C3 7C A3             JP DIR_CMP_ADVANCE
2151  A373              ; ----------------------------------------------------------------------
2152  A373              ; DIR_CMP_EXTENT -- compare the extent byte during the directory match.
2153  A373              ;   In: HL -> FCB extent byte; A = entry extent byte; B/C preserved across the call.
2154  A373              ;   Out: equal -> DIR_CMP_ADVANCE; unequal -> restart BDOS_DIR_SCAN_NEXT.  Clobbers: A,flags (BC
2155  A373              ;        saved+restored).
2156  A373              ;   Algorithm: load the FCB extent byte into C, FCB_EXTENT_COMPARE on the entry extent (A) and the
2157  A373              ;              FCB extent
2158  A373              ;       under EXM; Z continues, NZ rejects this entry.
2159  A373              ;   [RE]
2160  A373              ; ----------------------------------------------------------------------
2161  A373              DIR_CMP_EXTENT:
2162  A373 C5                   PUSH BC
2163  A374 4E                   LD C,(HL)
2164  A375 CD 07 A3             CALL FCB_EXTENT_COMPARE
2165  A378 C1                   POP BC
2166  A379 C2 2D A3             JP NZ,BDOS_DIR_SCAN_NEXT
2167  A37C              ; ----------------------------------------------------------------------
2168  A37C              ; DIR_CMP_ADVANCE -- step to the next byte of the entry/FCB compare.
2169  A37C              ;   In: DE -> entry byte, HL -> FCB byte, B = index, C = count remaining.
2170  A37C              ;   Out: DE,HL incremented; B incremented; C decremented; loops back to DIR_CMP_BYTE_LOOP.
2171  A37C              ;        Clobbers: B,C,D,E,H,L.
2172  A37C              ;   Algorithm: advance both pointers, bump the index, drop the count, re-enter the byte loop.
2173  A37C              ;   [RE]
2174  A37C              ; ----------------------------------------------------------------------
2175  A37C              DIR_CMP_ADVANCE:
2176  A37C 13                   INC DE
2177  A37D 23                   INC HL
2178  A37E 04                   INC B
2179  A37F 0D                   DEC C
2180  A380 C3 53 A3             JP DIR_CMP_BYTE_LOOP
2181  A383              ; ----------------------------------------------------------------------
2182  A383              ; DIR_MATCH_FOUND -- record a successful directory match and return its index.
2183  A383              ;   In: CUR_RECORD (CUR_RECORD) = current directory record number.
2184  A383              ;   Out: BDOS result byte (BDOS_RETVAL) = record & 3 (entry index 0..3); DIR_MATCH_FLAG cleared to 0
2185  A383              ;        if still negative.
2186  A383              ;   Clobbers: A,H,L,flags.
2187  A383              ;   Algorithm: compute the within-record entry index (record mod 4) into the result byte; if
2188  A383              ;              DIR_MATCH_FLAG still
2189  A383              ;       has its sign bit set (=$FF, not yet matched), zero it to mark 'matched'.
2190  A383              ;   [RE]
2191  A383              ; ----------------------------------------------------------------------
2192  A383              DIR_MATCH_FOUND:
2193  A383 3A EA A9             LD A,(CUR_RECORD)
2194  A386 E6 03                AND $03
2195  A388 32 45 9F             LD (BDOS_RETVAL),A
2196  A38B 21 D4 A9             LD HL,DIR_MATCH_FLAG
2197  A38E 7E                   LD A,(HL)
2198  A38F 17                   RLA
2199  A390 D0                   RET NC
2200  A391 AF                   XOR A
2201  A392 77                   LD (HL),A
2202  A393 C9                   RET
2203  A394              ; ----------------------------------------------------------------------
2204  A394              ; DIR_NO_MATCH -- terminate a directory scan with 'not found'.
2205  A394              ;   In: none.  Out: BDOS result byte (BDOS_RETVAL) = $FF; record counter reset to -1.  Clobbers:
2206  A394              ;       A,H,L,flags.
2207  A394              ;   Algorithm: INVALIDATE_CUR_RECORD, then store $FF as the BDOS result.
2208  A394              ;   [RE]
2209  A394              ; ----------------------------------------------------------------------
2210  A394              DIR_NO_MATCH:
2211  A394 CD FE A1             CALL INVALIDATE_CUR_RECORD
2212  A397 3E FF                LD A,$FF
2213  A399 C3 01 9F             JP BDOS_RET_RESULT
2214  A39C              ; ----------------------------------------------------------------------
2215  A39C              ; F_DELETE_HND -- delete every directory entry matching the FCB (BDOS function 19).
2216  A39C              ;   In: CURFCB_PTR (BDOS_PARAM_PTR) -> FCB (may contain '?' wildcards). Reached from the dispatcher
2217  A39C              ;       fn 19.
2218  A39C              ;   Out: matching directory entries marked erased ($E5) and written back; result via the search
2219  A39C              ;        tail.
2220  A39C              ;   Clobbers: A,B,C,D,E,H,L,flags.
2221  A39C              ;   Algorithm: log in the drive (CHECK_DRIVE_READONLY), DIR_SEARCH_FIRST on 12 FCB bytes
2222  A39C              ;              (name+type), then fall
2223  A39C              ;       into F_DELETE_LOOP to erase each match.
2224  A39C              ;   [RE] CP/M 2.2 F_DELETE.
2225  A39C              ; ----------------------------------------------------------------------
2226  A39C              F_DELETE_HND:
2227  A39C CD 54 A1             CALL CHECK_DRIVE_READONLY
2228  A39F                      ; compare 12 bytes (name+type) when searching for entries to delete
2229  A39F 0E 0C                LD C,$0C
2230  A3A1 CD 18 A3             CALL DIR_SEARCH_FIRST
2231  A3A4              ; ----------------------------------------------------------------------
2232  A3A4              ; F_DELETE_LOOP -- erase-and-write each matching directory entry, then search the next.
2233  A3A4              ;   In: a pending search result from DIR_SEARCH_FIRST / NEXT.  Out: returns when no further matches
2234  A3A4              ;       remain.
2235  A3A4              ;   Clobbers: A,B,C,D,E,H,L,flags.
2236  A3A4              ;   Algorithm: stop when CUR_RECORD_BYTES_EQUAL reports no match; reject if read-only
2237  A3A4              ;              (FCB_RO_FLAG_TEST); point at
2238  A3A4              ;       the matched entry, set its first byte to $E5, clear the entry's allocation map
2239  A3A4              ;       (ALLOC_FROM_FCB), write the
2240  A3A4              ;       directory record (DIR_RECORD_WRITE), search-next, repeat.
2241  A3A4              ;   [RE]
2242  A3A4              ; ----------------------------------------------------------------------
2243  A3A4              F_DELETE_LOOP:
2244  A3A4 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2245  A3A7 C8                   RET Z
2246  A3A8 CD 44 A1             CALL FCB_RO_FLAG_TEST
2247  A3AB CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2248  A3AE 36 E5                LD (HL),$E5
2249  A3B0 0E 00                LD C,$00
2250  A3B2 CD 6B A2             CALL ALLOC_FROM_FCB
2251  A3B5 CD C6 A1             CALL DIR_RECORD_WRITE
2252  A3B8 CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
2253  A3BB C3 A4 A3             JP F_DELETE_LOOP
2254  A3BE              ; ----------------------------------------------------------------------
2255  A3BE              ; ALLOC_GET_BLOCK -- find/allocate a disk block near a starting block, marking it used.
2256  A3BE              ;   In: BC = starting block number (passed by the write core when extending a file).
2257  A3BE              ;   Out: HL = the block number actually claimed (0 if none free); its allocation-vector bit set.
2258  A3BE              ;        Clobbers: A,B,C,D,E,H,L,flags.
2259  A3BE              ;   Algorithm: copy the start block to DE, scan downward then upward testing each block's allocation
2260  A3BE              ;              bit
2261  A3BE              ;       (ALLOC_BIT_GET), bounded by MAX_BLOCK_DSM; mark the chosen block used (ALLOC_BIT_RESTORE)
2262  A3BE              ;       and return it,
2263  A3BE              ;       or 0 when no block can be allocated.
2264  A3BE              ;   [RE] allocation-vector block search/allocate.
2265  A3BE              ; ----------------------------------------------------------------------
2266  A3BE              ALLOC_GET_BLOCK:
2267  A3BE 50                   LD D,B
2268  A3BF 59                   LD E,C
2269  A3C0              ; ----------------------------------------------------------------------
2270  A3C0              ; ALLOC_SCAN_DOWN -- scan downward for an in-use block in the run.
2271  A3C0              ;   In: BC = block counter; DE = candidate block; allocation vector via ALLOC_BIT_GET.
2272  A3C0              ;   Out: on an in-use block -> ALLOC_MARK_DONE; otherwise falls into ALLOC_SCAN_UP.  Clobbers:
2273  A3C0              ;        A,B,C,D,E,flags.
2274  A3C0              ;   Algorithm: while BC != 0, decrement, test the block's bit; if set (in use), finish; else keep
2275  A3C0              ;              scanning down.
2276  A3C0              ;   [RE]
2277  A3C0              ; ----------------------------------------------------------------------
2278  A3C0              ALLOC_SCAN_DOWN:
2279  A3C0 79                   LD A,C
2280  A3C1 B0                   OR B
2281  A3C2 CA D1 A3             JP Z,ALLOC_SCAN_UP
2282  A3C5 0B                   DEC BC
2283  A3C6 D5                   PUSH DE
2284  A3C7 C5                   PUSH BC
2285  A3C8 CD 35 A2             CALL ALLOC_BIT_GET
2286  A3CB 1F                   RRA
2287  A3CC D2 EC A3             JP NC,ALLOC_MARK_DONE
2288  A3CF C1                   POP BC
2289  A3D0 D1                   POP DE
2290  A3D1              ; ----------------------------------------------------------------------
2291  A3D1              ; ALLOC_SCAN_UP -- scan upward (toward MAX_BLOCK_DSM) for an in-use block.
2292  A3D1              ;   In: DE = candidate block; MAX_BLOCK_DSM (MAX_BLOCK_DSM) = highest block number on the drive.
2293  A3D1              ;   Out: at/past the disk limit -> ALLOC_SCAN_FINISH; on an in-use block -> ALLOC_MARK_DONE.
2294  A3D1              ;        Clobbers: A,B,C,D,E,H,L,flags.
2295  A3D1              ;   Algorithm: compare DE against DSM; if past it, stop; else increment and test the next block's
2296  A3D1              ;              bit (ALLOC_BIT_GET),
2297  A3D1              ;       looping back to the downward scan.
2298  A3D1              ;   [RE]
2299  A3D1              ; ----------------------------------------------------------------------
2300  A3D1              ALLOC_SCAN_UP:
2301  A3D1 2A C6 A9             LD HL,(MAX_BLOCK_DSM)
2302  A3D4 7B                   LD A,E
2303  A3D5 95                   SUB L
2304  A3D6 7A                   LD A,D
2305  A3D7 9C                   SBC A,H
2306  A3D8 D2 F4 A3             JP NC,ALLOC_SCAN_FINISH
2307  A3DB 13                   INC DE
2308  A3DC C5                   PUSH BC
2309  A3DD D5                   PUSH DE
2310  A3DE 42                   LD B,D
2311  A3DF 4B                   LD C,E
2312  A3E0 CD 35 A2             CALL ALLOC_BIT_GET
2313  A3E3 1F                   RRA
2314  A3E4 D2 EC A3             JP NC,ALLOC_MARK_DONE
2315  A3E7 D1                   POP DE
2316  A3E8 C1                   POP BC
2317  A3E9 C3 C0 A3             JP ALLOC_SCAN_DOWN
2318  A3EC              ; ----------------------------------------------------------------------
2319  A3EC              ; ALLOC_MARK_DONE -- set the chosen block's allocation bit and return it.
2320  A3EC              ;   In: A = the block's current allocation byte (rotated by the scan); the block number tracked by
2321  A3EC              ;       ALLOC_BIT_RESTORE.
2322  A3EC              ;   Out: allocation vector updated; HL/DE restored from the stack; returns to ALLOC_GET_BLOCK's
2323  A3EC              ;        caller.  Clobbers: A,H,L,D,E,flags.
2324  A3EC              ;   Algorithm: rotate the in-use bit back into place, force it set (INC A), write it through
2325  A3EC              ;              ALLOC_BIT_RESTORE,
2326  A3EC              ;       restore the saved registers, and return.
2327  A3EC              ;   [RE]
2328  A3EC              ; ----------------------------------------------------------------------
2329  A3EC              ALLOC_MARK_DONE:
2330  A3EC 17                   RLA
2331  A3ED 3C                   INC A
2332  A3EE CD 64 A2             CALL ALLOC_BIT_RESTORE
2333  A3F1 E1                   POP HL
2334  A3F2 D1                   POP DE
2335  A3F3 C9                   RET
2336  A3F4              ; ----------------------------------------------------------------------
2337  A3F4              ; ALLOC_SCAN_FINISH -- end the block scan when the disk limit is reached.
2338  A3F4              ;   In: BC = remaining block counter; DE = candidate block.
2339  A3F4              ;   Out: if blocks remain -> back to ALLOC_SCAN_DOWN; else HL=0 (no block) and return.  Clobbers:
2340  A3F4              ;        A,H,L,flags.
2341  A3F4              ;   Algorithm: if the counter is non-zero, resume the downward scan; otherwise return zero (no
2342  A3F4              ;              allocatable block).
2343  A3F4              ;   [RE]
2344  A3F4              ; ----------------------------------------------------------------------
2345  A3F4              ALLOC_SCAN_FINISH:
2346  A3F4 79                   LD A,C
2347  A3F5 B0                   OR B
2348  A3F6 C2 C0 A3             JP NZ,ALLOC_SCAN_DOWN
2349  A3F9 21 00 00             LD HL,$0000
2350  A3FC C9                   RET
2351  A3FD              ; ----------------------------------------------------------------------
2352  A3FD              ; FCB_WRITE_DIR_ENTRY -- copy the whole 32-byte FCB image into the matched directory entry and write
2353  A3FD              ; it.
2354  A3FD              ;   In: CURFCB_PTR (BDOS_PARAM_PTR) -> FCB; sets C=0 (FCB offset 0), E=$20 (32 bytes).
2355  A3FD              ;   Out: directory record holding this entry written back to disk.  Clobbers: A,B,C,D,E,H,L,flags.
2356  A3FD              ;   Algorithm: set up a full-32-byte copy at FCB offset 0 and fall into FCB_COPY_TO_DIR.
2357  A3FD              ;   [RE]
2358  A3FD              ; ----------------------------------------------------------------------
2359  A3FD              FCB_WRITE_DIR_ENTRY:
2360  A3FD 0E 00                LD C,$00
2361  A3FF 1E 20                LD E,$20
2362  A401              ; ----------------------------------------------------------------------
2363  A401              ; FCB_COPY_TO_DIR -- copy E FCB bytes (from offset C) into the matched directory entry.
2364  A401              ;   In: C = FCB byte offset; E = byte count; CURFCB_PTR (BDOS_PARAM_PTR) -> FCB; current matched dir
2365  A401              ;       entry.
2366  A401              ;   Out: directory buffer updated, then the record written via FCB_FLUSH_DIR.  Clobbers:
2367  A401              ;        A,B,C,D,E,H,L,flags.
2368  A401              ;   Algorithm: form a source pointer at FCB+C, point HL at the directory entry slot
2369  A401              ;              (FCB_BUF_PTR_ADD_OFFSET),
2370  A401              ;       block-copy E bytes, then fall into FCB_FLUSH_DIR to commit the record.
2371  A401              ;   [RE]
2372  A401              ; ----------------------------------------------------------------------
2373  A401              FCB_COPY_TO_DIR:
2374  A401 D5                   PUSH DE
2375  A402 06 00                LD B,$00
2376  A404 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2377  A407 09                   ADD HL,BC
2378  A408 EB                   EX DE,HL
2379  A409 CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2380  A40C C1                   POP BC
2381  A40D CD 4F 9F             CALL BLOCK_COPY_INCC
2382  A410              ; ----------------------------------------------------------------------
2383  A410              ; FCB_FLUSH_DIR -- position to the directory record and write it back.
2384  A410              ;   In: current directory record state from the preceding match.  Out: the directory record written
2385  A410              ;       to disk.
2386  A410              ;   Clobbers: A,B,C,D,E,H,L,flags.
2387  A410              ;   Algorithm: run the directory record-position helper (DIR_RECORD_DEBLOCK setup) then tail-jump to
2388  A410              ;              DIR_RECORD_WRITE.
2389  A410              ;   [RE]
2390  A410              ; ----------------------------------------------------------------------
2391  A410              FCB_FLUSH_DIR:
2392  A410 CD C3 9F             CALL REC_DIV4_SETUP
2393  A413 C3 C6 A1             JP DIR_RECORD_WRITE
2394  A416              ; ----------------------------------------------------------------------
2395  A416              ; F_RENAME_HND -- rename a file: replace matching directory entries with the new name (BDOS fn 23).
2396  A416              ;   In: CURFCB_PTR (BDOS_PARAM_PTR) -> FCB whose bytes 0..15 are the old name and bytes 16..31 the
2397  A416              ;       new name. Dispatcher fn 23.
2398  A416              ;   Out: every matching directory entry rewritten with the new name; read-only entries rejected.
2399  A416              ;        Clobbers: A,B,C,D,E,H,L,flags.
2400  A416              ;   Algorithm: log in the drive, DIR_SEARCH_FIRST on 12 bytes of the old name, copy the FCB drive
2401  A416              ;              byte (offset 0)
2402  A416              ;       into the new-name half (offset 16) so both target the same drive, then run F_RENAME_LOOP
2403  A416              ;       over each match.
2404  A416              ;   [RE] CP/M 2.2 F_RENAME.
2405  A416              ; ----------------------------------------------------------------------
2406  A416              F_RENAME_HND:
2407  A416 CD 54 A1             CALL CHECK_DRIVE_READONLY
2408  A419 0E 0C                LD C,$0C
2409  A41B CD 18 A3             CALL DIR_SEARCH_FIRST
2410  A41E 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2411  A421 7E                   LD A,(HL)
2412  A422 11 10 00             LD DE,$0010
2413  A425 19                   ADD HL,DE
2414  A426 77                   LD (HL),A
2415  A427              ; ----------------------------------------------------------------------
2416  A427              ; F_RENAME_LOOP -- rewrite each matched entry with the new name and write it back.
2417  A427              ;   In: a pending search result.  Out: returns when no more matches.  Clobbers: A,B,C,D,E,H,L,flags.
2418  A427              ;   Algorithm: stop on no-match; reject read-only files; copy 12 bytes from FCB offset 16 (new
2419  A427              ;              name+type) into the
2420  A427              ;       entry at offset 0 (FCB_COPY_TO_DIR); write the directory record; search-next; repeat.
2421  A427              ;   [RE]
2422  A427              ; ----------------------------------------------------------------------
2423  A427              F_RENAME_LOOP:
2424  A427 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2425  A42A C8                   RET Z
2426  A42B CD 44 A1             CALL FCB_RO_FLAG_TEST
2427  A42E 0E 10                LD C,$10
2428  A430 1E 0C                LD E,$0C
2429  A432 CD 01 A4             CALL FCB_COPY_TO_DIR
2430  A435 CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
2431  A438 C3 27 A4             JP F_RENAME_LOOP
2432  A43B              ; ----------------------------------------------------------------------
2433  A43B              ; F_ATTRIB_HND -- set file attributes from the FCB into matching directory entries (BDOS fn 30).
2434  A43B              ;   In: CURFCB_PTR (BDOS_PARAM_PTR) -> FCB carrying the attribute high bits in the name/type bytes.
2435  A43B              ;       Dispatcher fn 30.
2436  A43B              ;   Out: every matching directory entry's first 12 bytes rewritten with the FCB's attribute bits.
2437  A43B              ;        Clobbers: A,B,C,D,E,H,L,flags.
2438  A43B              ;   Algorithm: DIR_SEARCH_FIRST on 12 bytes, then F_ATTRIB_LOOP to copy the 12 name/type bytes (with
2439  A43B              ;              attribute high
2440  A43B              ;       bits) from FCB offset 0 into each matched entry and write the record.
2441  A43B              ;   [RE] CP/M 2.2 F_ATTRIB.
2442  A43B              ; ----------------------------------------------------------------------
2443  A43B              F_ATTRIB_HND:
2444  A43B 0E 0C                LD C,$0C
2445  A43D CD 18 A3             CALL DIR_SEARCH_FIRST
2446  A440              ; ----------------------------------------------------------------------
2447  A440              ; F_ATTRIB_LOOP -- write the FCB's attribute bytes into each matched entry.
2448  A440              ;   In: a pending search result.  Out: returns when no more matches.  Clobbers: A,B,C,D,E,H,L,flags.
2449  A440              ;   Algorithm: stop on no-match; copy 12 bytes from FCB offset 0 (name/type with attribute bits)
2450  A440              ;              into the entry
2451  A440              ;       (FCB_COPY_TO_DIR); flush the directory record; search-next; repeat.
2452  A440              ;   [RE]
2453  A440              ; ----------------------------------------------------------------------
2454  A440              F_ATTRIB_LOOP:
2455  A440 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2456  A443 C8                   RET Z
2457  A444 0E 00                LD C,$00
2458  A446 1E 0C                LD E,$0C
2459  A448 CD 01 A4             CALL FCB_COPY_TO_DIR
2460  A44B CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
2461  A44E C3 40 A4             JP F_ATTRIB_LOOP
2462  A451              ; ----------------------------------------------------------------------
2463  A451              ; FCB_OPEN_SEARCH -- search-first for the FCB's extent and merge the directory entry into the FCB.
2464  A451              ;   In: CURFCB_PTR (BDOS_PARAM_PTR) -> FCB. Core of F_OPEN (dispatcher fn 15) and the random-record
2465  A451              ;       extent-positioning path.
2466  A451              ;   Out: on match, the matched entry is merged into the FCB (record-count fields filled,
2467  A451              ;        FILE_SIZE_FROM_EXTENT);
2468  A451              ;        on no match returns Z with no merge.  Clobbers: A,B,C,D,E,H,L,flags.
2469  A451              ;   Algorithm: DIR_SEARCH_FIRST on 15 bytes (name+type+extent); if not found return Z; otherwise
2470  A451              ;              fall through into
2471  A451              ;       FILE_SIZE_FROM_EXTENT to copy the entry into the FCB and set the record count.
2472  A451              ;   [RE] CP/M 2.2 F_OPEN core / extent locate-and-merge.
2473  A451              ; ----------------------------------------------------------------------
2474  A451              FCB_OPEN_SEARCH:
2475  A451                      ; compare 15 bytes (name+type+extent) for the open/extent search
2476  A451 0E 0F                LD C,$0F
2477  A453 CD 18 A3             CALL DIR_SEARCH_FIRST
2478  A456 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2479  A459 C8                   RET Z
2480  A45A              ; ----------------------------------------------------------------------
2481  A45A              ; FILE_SIZE_FROM_EXTENT -- merge a matched directory entry into the FCB and update its record count.
2482  A45A              ;   In: HL -> matched directory entry; CURFCB_PTR (BDOS_PARAM_PTR) -> the user FCB.
2483  A45A              ;   Out: the 32-byte entry copied into the FCB image; the FCB's record-count byte (offset 15)
2484  A45A              ;        updated per this extent.
2485  A45A              ;   Clobbers: A,B,C,D,E,H,L,flags.
2486  A45A              ;   Algorithm: save the entry's first byte, copy the 32 directory bytes into the FCB image, set the
2487  A45A              ;              S2 'written'
2488  A45A              ;       flag (MARK_FCB_S2_HIGHBIT), then read offset 12 = EX (extent number) into C and offset 15 =
2489  A45A              ;       RC (record
2490  A45A              ;       count) into B, and choose the new offset-15 value ($00 if this extent is below the current
2491  A45A              ;       one, RC if equal,
2492  A45A              ;       $80 if above) and store it.  Used by both F_OPEN (FCB_OPEN_SEARCH) and F_SIZE.
2493  A45A              ;   [RE]
2494  A45A              ; ----------------------------------------------------------------------
2495  A45A              FILE_SIZE_FROM_EXTENT:
2496  A45A CD A6 A0             CALL DRV_INSTALL_RWTS_1
2497  A45D 7E                   LD A,(HL)
2498  A45E F5                   PUSH AF
2499  A45F E5                   PUSH HL
2500  A460 CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2501  A463 EB                   EX DE,HL
2502  A464 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2503  A467 0E 20                LD C,$20
2504  A469 D5                   PUSH DE
2505  A46A CD 4F 9F             CALL BLOCK_COPY_INCC
2506  A46D CD 78 A1             CALL MARK_FCB_S2_HIGHBIT
2507  A470 D1                   POP DE
2508  A471 21 0C 00             LD HL,$000C
2509  A474 19                   ADD HL,DE
2510  A475 4E                   LD C,(HL)
2511  A476 21 0F 00             LD HL,$000F
2512  A479 19                   ADD HL,DE
2513  A47A 46                   LD B,(HL)
2514  A47B E1                   POP HL
2515  A47C F1                   POP AF
2516  A47D 77                   LD (HL),A
2517  A47E 79                   LD A,C
2518  A47F BE                   CP (HL)
2519  A480 78                   LD A,B
2520  A481 CA 8B A4             JP Z,FILE_SIZE_STORE
2521  A484 3E 00                LD A,$00
2522  A486 DA 8B A4             JP C,FILE_SIZE_STORE
2523  A489 3E 80                LD A,$80
2524  A48B              ; ----------------------------------------------------------------------
2525  A48B              ; FILE_SIZE_STORE -- write the computed record value into the FCB record-count field.
2526  A48B              ;   In: A = computed value ($00/$80/extent RC); CURFCB_PTR (BDOS_PARAM_PTR) -> FCB.  Out: FCB offset
2527  A48B              ;       15 (RC) = A.  Clobbers: D,E,H,L.
2528  A48B              ;   Algorithm: index the FCB to offset 15 and store the record-count byte.
2529  A48B              ;   [RE]
2530  A48B              ; ----------------------------------------------------------------------
2531  A48B              FILE_SIZE_STORE:
2532  A48B 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2533  A48E 11 0F 00             LD DE,$000F
2534  A491 19                   ADD HL,DE
2535  A492 77                   LD (HL),A
2536  A493 C9                   RET
2537  A494              ; ----------------------------------------------------------------------
2538  A494              ; FCB_WORD_FILL_IF_ZERO -- copy a 16-bit word from (DE) to (HL) only when (HL) is currently zero.
2539  A494              ;   In: HL -> destination word; DE -> source word.
2540  A494              ;   Out: if the destination word was 0, it is overwritten with the source word; DE,HL preserved.
2541  A494              ;        Clobbers: A,flags.
2542  A494              ;   Algorithm: OR the two destination bytes; if non-zero return unchanged; otherwise copy both
2543  A494              ;              source bytes across,
2544  A494              ;       restoring DE/HL to their entry values.
2545  A494              ;   [RE] allocation-word merge helper used during F_CLOSE_HND.
2546  A494              ; ----------------------------------------------------------------------
2547  A494              FCB_WORD_FILL_IF_ZERO:
2548  A494 7E                   LD A,(HL)
2549  A495 23                   INC HL
2550  A496 B6                   OR (HL)
2551  A497 2B                   DEC HL
2552  A498 C0                   RET NZ
2553  A499 1A                   LD A,(DE)
2554  A49A 77                   LD (HL),A
2555  A49B 13                   INC DE
2556  A49C 23                   INC HL
2557  A49D 1A                   LD A,(DE)
2558  A49E 77                   LD (HL),A
2559  A49F 1B                   DEC DE
2560  A4A0 2B                   DEC HL
2561  A4A1 C9                   RET
2562  A4A2              ; ----------------------------------------------------------------------
2563  A4A2              ; F_CLOSE_HND -- close a file: merge the in-memory FCB into its directory entry (BDOS fn 16).
2564  A4A2              ;   In: CURFCB_PTR (BDOS_PARAM_PTR) -> FCB. Dispatcher fn 16; also used internally to flush an
2565  A4A2              ;       extent.
2566  A4A2              ;   Out: directory entry updated with this FCB's allocation map / record count; result byte set.
2567  A4A2              ;        Clobbers: A,B,C,D,E,H,L,flags.
2568  A4A2              ;   Algorithm: zero the result byte and record state, verify the drive is selected (DRIVE_BIT_TEST)
2569  A4A2              ;              and the FCB S2
2570  A4A2              ;       high bit is clear; DIR_SEARCH_FIRST on the extent (15 bytes); if found, merge the FCB's
2571  A4A2              ;       16-byte allocation
2572  A4A2              ;       map into the entry (filling zero words via FCB_WORD_FILL_IF_ZERO, keeping the larger record
2573  A4A2              ;       count) then flush.
2574  A4A2              ;   [RE] CP/M 2.2 F_CLOSE.
2575  A4A2              ; ----------------------------------------------------------------------
2576  A4A2              F_CLOSE_HND:
2577  A4A2 AF                   XOR A
2578  A4A3 32 45 9F             LD (BDOS_RETVAL),A
2579  A4A6 32 EA A9             LD (CUR_RECORD),A
2580  A4A9 32 EB A9             LD (CUR_RECORD_HI),A
2581  A4AC CD 1E A1             CALL DRIVE_BIT_TEST
2582  A4AF C0                   RET NZ
2583  A4B0 CD 69 A1             CALL FCB_GET_S2
2584  A4B3 E6 80                AND $80
2585  A4B5 C0                   RET NZ
2586  A4B6 0E 0F                LD C,$0F
2587  A4B8 CD 18 A3             CALL DIR_SEARCH_FIRST
2588  A4BB CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2589  A4BE C8                   RET Z
2590  A4BF 01 10 00             LD BC,$0010
2591  A4C2 CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2592  A4C5 09                   ADD HL,BC
2593  A4C6 EB                   EX DE,HL
2594  A4C7 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2595  A4CA 09                   ADD HL,BC
2596  A4CB 0E 10                LD C,$10
2597  A4CD              ; ----------------------------------------------------------------------
2598  A4CD              ; FCB_MERGE_MAP_LOOP -- merge the FCB allocation map slot-by-slot into the directory entry.
2599  A4CD              ;   In: HL -> entry allocation slot; DE -> FCB allocation slot; C = slots remaining (16).
2600  A4CD              ;   Out: merged allocation map; jumps to FCB_MERGE_DIFF on an 8-bit conflict, else continues.
2601  A4CD              ;        Clobbers: A,B,C,D,E,H,L,flags.
2602  A4CD              ;   Algorithm: per slot, if BLOCK_WIDTH_FLAG selects 16-bit block numbers go word-wise
2603  A4CD              ;              (FCB_MERGE_WORD); else handle
2604  A4CD              ;       an 8-bit block: when the entry slot is zero take the FCB's block, then fall into the byte
2605  A4CD              ;       reconciliation.
2606  A4CD              ;   [RE]
2607  A4CD              ; ----------------------------------------------------------------------
2608  A4CD              FCB_MERGE_MAP_LOOP:
2609  A4CD 3A DD A9             LD A,(BLOCK_WIDTH_FLAG)
2610  A4D0 B7                   OR A
2611  A4D1 CA E8 A4             JP Z,FCB_MERGE_WORD
2612  A4D4 7E                   LD A,(HL)
2613  A4D5 B7                   OR A
2614  A4D6 1A                   LD A,(DE)
2615  A4D7 C2 DB A4             JP NZ,FCB_MERGE_BYTE_CHECK
2616  A4DA 77                   LD (HL),A
2617  A4DB              ; ----------------------------------------------------------------------
2618  A4DB              ; FCB_MERGE_BYTE_CHECK -- reconcile one 8-bit allocation slot between FCB and entry.
2619  A4DB              ;   In: A = FCB block byte; HL -> entry block byte; DE -> FCB block byte.
2620  A4DB              ;   Out: FCB block non-zero -> FCB_MERGE_DIFF (compare); else copy entry block into the FCB, then
2621  A4DB              ;        compare.  Clobbers: A,flags.
2622  A4DB              ;   Algorithm: if the FCB block byte is non-zero, jump to the compare; otherwise mirror the entry
2623  A4DB              ;              block byte into
2624  A4DB              ;       the FCB so both agree, then fall into the compare.
2625  A4DB              ;   [RE]
2626  A4DB              ; ----------------------------------------------------------------------
2627  A4DB              FCB_MERGE_BYTE_CHECK:
2628  A4DB B7                   OR A
2629  A4DC C2 E1 A4             JP NZ,FCB_MERGE_DIFF
2630  A4DF 7E                   LD A,(HL)
2631  A4E0 12                   LD (DE),A
2632  A4E1              ; ----------------------------------------------------------------------
2633  A4E1              ; FCB_MERGE_DIFF -- detect a block-map disagreement between FCB and directory entry.
2634  A4E1              ;   In: A = FCB block byte; HL -> entry block byte.
2635  A4E1              ;   Out: if they differ, FCB_DEC_RESULT flags the conflict; else continue (FCB_MERGE_NEXT).
2636  A4E1              ;        Clobbers: A,flags.
2637  A4E1              ;   Algorithm: compare the FCB block byte with the entry's; unequal records an error via
2638  A4E1              ;              FCB_DEC_RESULT, otherwise
2639  A4E1              ;       advance to the next slot.
2640  A4E1              ;   [RE]
2641  A4E1              ; ----------------------------------------------------------------------
2642  A4E1              FCB_MERGE_DIFF:
2643  A4E1 BE                   CP (HL)
2644  A4E2 C2 1F A5             JP NZ,FCB_DEC_RESULT
2645  A4E5 C3 FD A4             JP FCB_MERGE_NEXT
2646  A4E8              ; ----------------------------------------------------------------------
2647  A4E8              ; FCB_MERGE_WORD -- merge/compare a 16-bit allocation word for double-byte-block drives.
2648  A4E8              ;   In: HL -> entry word; DE -> FCB word.
2649  A4E8              ;   Out: zero words filled across both directions; on a true word mismatch -> FCB_DEC_RESULT.
2650  A4E8              ;        Clobbers: A,D,E,H,L,flags.
2651  A4E8              ;   Algorithm: fill the entry word from the FCB if it was zero, fill the FCB word from the entry if
2652  A4E8              ;              it was zero
2653  A4E8              ;       (FCB_WORD_FILL_IF_ZERO both ways, EX DE,HL between), then compare the two 16-bit values
2654  A4E8              ;       byte-by-byte and
2655  A4E8              ;       flag a conflict on inequality.
2656  A4E8              ;   [RE]
2657  A4E8              ; ----------------------------------------------------------------------
2658  A4E8              FCB_MERGE_WORD:
2659  A4E8 CD 94 A4             CALL FCB_WORD_FILL_IF_ZERO
2660  A4EB EB                   EX DE,HL
2661  A4EC CD 94 A4             CALL FCB_WORD_FILL_IF_ZERO
2662  A4EF EB                   EX DE,HL
2663  A4F0 1A                   LD A,(DE)
2664  A4F1 BE                   CP (HL)
2665  A4F2 C2 1F A5             JP NZ,FCB_DEC_RESULT
2666  A4F5 13                   INC DE
2667  A4F6 23                   INC HL
2668  A4F7 1A                   LD A,(DE)
2669  A4F8 BE                   CP (HL)
2670  A4F9 C2 1F A5             JP NZ,FCB_DEC_RESULT
2671  A4FC 0D                   DEC C
2672  A4FD              ; ----------------------------------------------------------------------
2673  A4FD              ; FCB_MERGE_NEXT -- step to the next allocation slot, then finalize the record count.
2674  A4FD              ;   In: DE,HL -> current FCB/entry block bytes; C = slot count remaining.
2675  A4FD              ;   Out: loops to FCB_MERGE_MAP_LOOP until C reaches 0, then reconciles the record-count field and
2676  A4FD              ;        continues to FCB_MERGE_FINISH.
2677  A4FD              ;   Clobbers: A,B,C,D,E,H,L,flags.
2678  A4FD              ;   Algorithm: advance both pointers, decrement the count; while slots remain re-enter the merge
2679  A4FD              ;              loop; when done
2680  A4FD              ;       back up by 20 bytes ($FFEC) to the record-count field and keep the larger of the FCB/entry
2681  A4FD              ;       counts (and the
2682  A4FD              ;       matching S2/extent bytes), then fall into FCB_MERGE_FINISH.
2683  A4FD              ;   [RE]
2684  A4FD              ; ----------------------------------------------------------------------
2685  A4FD              FCB_MERGE_NEXT:
2686  A4FD 13                   INC DE
2687  A4FE 23                   INC HL
2688  A4FF 0D                   DEC C
2689  A500 C2 CD A4             JP NZ,FCB_MERGE_MAP_LOOP
2690  A503 01 EC FF             LD BC,$FFEC
2691  A506 09                   ADD HL,BC
2692  A507 EB                   EX DE,HL
2693  A508 09                   ADD HL,BC
2694  A509 1A                   LD A,(DE)
2695  A50A BE                   CP (HL)
2696  A50B DA 17 A5             JP C,FCB_MERGE_FINISH
2697  A50E 77                   LD (HL),A
2698  A50F 01 03 00             LD BC,$0003
2699  A512 09                   ADD HL,BC
2700  A513 EB                   EX DE,HL
2701  A514 09                   ADD HL,BC
2702  A515 7E                   LD A,(HL)
2703  A516 12                   LD (DE),A
2704  A517              ; ----------------------------------------------------------------------
2705  A517              ; FCB_MERGE_FINISH -- mark the merged entry dirty and flush the directory record.
2706  A517              ;   In: merged directory entry in the buffer.  Out: dir-changed flag (DIR_DIRTY_FLAG) = $FF;
2707  A517              ;       directory record written via FCB_FLUSH_DIR.
2708  A517              ;   Clobbers: A,H,L,flags.
2709  A517              ;   Algorithm: set the 'directory changed' flag and tail-jump to FCB_FLUSH_DIR to commit the record
2710  A517              ;              to disk.
2711  A517              ;   [RE]
2712  A517              ; ----------------------------------------------------------------------
2713  A517              FCB_MERGE_FINISH:
2714  A517 3E FF                LD A,$FF
2715  A519 32 D2 A9             LD (DIR_DIRTY_FLAG),A
2716  A51C C3 10 A4             JP FCB_FLUSH_DIR
2717  A51F              ; ----------------------------------------------------------------------
2718  A51F              ; FCB_DEC_RESULT -- record a directory-merge conflict by decrementing the result byte.
2719  A51F              ;   In: none (operates on the BDOS result byte BDOS_RETVAL).  Out: result byte decremented (toward
2720  A51F              ;       the $FF error code).
2721  A51F              ;   Clobbers: H,L,flags.
2722  A51F              ;   Algorithm: point at the result byte and decrement it in place to signal the close/merge
2723  A51F              ;              mismatch.
2724  A51F              ;   [RE]
2725  A51F              ; ----------------------------------------------------------------------
2726  A51F              FCB_DEC_RESULT:
2727  A51F 21 45 9F             LD HL,BDOS_RETVAL
2728  A522 35                   DEC (HL)
2729  A523 C9                   RET
2730  A524              ; ----------------------------------------------------------------------
2731  A524              ; DIR_MAKE_ENTRY -- find a free directory slot and create a new (empty) entry for the FCB.
2732  A524              ;   In: CURFCB_PTR (BDOS_PARAM_PTR) -> FCB. Core of F_MAKE (dispatcher fn 22).
2733  A524              ;   Out: a free directory slot located and initialized for this file; returns Z if no slot is free.
2734  A524              ;        Clobbers: A,B,C,D,E,H,L,flags.
2735  A524              ;   Algorithm: log in the drive, temporarily redirect the FCB pointer to a scratch FCB
2736  A524              ;              (EMPTY_DIR_FCB) and DIR_SEARCH_FIRST
2737  A524              ;       in mode 1 for an empty ($E5) slot, restore the FCB pointer; on success zero 17 bytes of the
2738  A524              ;       entry's
2739  A524              ;       record/allocation area (from offset 15), clear the S1 byte (offset 13), advance the record
2740  A524              ;       pointer
2741  A524              ;       (RECPTR_INC_STORE), write the new entry (FCB_WRITE_DIR_ENTRY), and set the FCB S2 'written'
2742  A524              ;       flag.
2743  A524              ;   [RE] make-directory-entry helper.
2744  A524              ; ----------------------------------------------------------------------
2745  A524              DIR_MAKE_ENTRY:
2746  A524 CD 54 A1             CALL CHECK_DRIVE_READONLY
2747  A527 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2748  A52A E5                   PUSH HL
2749  A52B 21 AC A9             LD HL,EMPTY_DIR_FCB
2750  A52E 22 43 9F             LD (BDOS_PARAM_PTR),HL
2751  A531 0E 01                LD C,$01
2752  A533 CD 18 A3             CALL DIR_SEARCH_FIRST
2753  A536 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2754  A539 E1                   POP HL
2755  A53A 22 43 9F             LD (BDOS_PARAM_PTR),HL
2756  A53D C8                   RET Z
2757  A53E EB                   EX DE,HL
2758  A53F 21 0F 00             LD HL,$000F
2759  A542 19                   ADD HL,DE
2760  A543 0E 11                LD C,$11
2761  A545 AF                   XOR A
2762  A546              ; ----------------------------------------------------------------------
2763  A546              ; DIR_ZERO_ALLOC -- store-zero / INC HL / DEC C loop clearing the new entry's record/allocation
2764  A546              ; bytes. [RE]
2765  A546              ; ----------------------------------------------------------------------
2766  A546              DIR_ZERO_ALLOC:
2767  A546 77                   LD (HL),A
2768  A547 23                   INC HL
2769  A548 0D                   DEC C
2770  A549 C2 46 A5             JP NZ,DIR_ZERO_ALLOC
2771  A54C 21 0D 00             LD HL,$000D
2772  A54F 19                   ADD HL,DE
2773  A550 77                   LD (HL),A
2774  A551 CD 8C A1             CALL RECPTR_INC_STORE
2775  A554 CD FD A3             CALL FCB_WRITE_DIR_ENTRY
2776  A557 C3 78 A1             JP MARK_FCB_S2_HIGHBIT
2777  A55A              ; ----------------------------------------------------------------------
2778  A55A              ; FCB_ADVANCE_RECORD -- advance the FCB to the next record/extent for sequential write.
2779  A55A              ;   In: CURFCB_PTR ($9F43) -> open FCB.
2780  A55A              ;   Out: FCB current-record / extent fields stepped; new extent opened or created as needed.
2781  A55A              ;   Clobbers: A,B,C,D,E,H,L,flags
2782  A55A              ;   Algorithm: clear the dir-changed flag, flush the current extent (F_CLOSE_HND via F_CLOSE_HND),
2783  A55A              ;              bump the
2784  A55A              ;              FCB current-record byte (offset 12) and wrap it mod 32; on wrap go open the next
2785  A55A              ;              extent (FCB_NEXT_EXTENT); otherwise check the extent mask (EXM at $A9C5) and the
2786  A55A              ;              dir-changed flag to decide between re-opening the current extent or merging the
2787  A55A              ;              just-flushed one.
2788  A55A              ;   [RE] sequential-write record/extent advance
2789  A55A              ; ----------------------------------------------------------------------
2790  A55A              FCB_ADVANCE_RECORD:
2791  A55A AF                   XOR A
2792  A55B                      ; clear the directory-changed flag
2793  A55B 32 D2 A9             LD (DIR_DIRTY_FLAG),A
2794  A55E                      ; close/flush the current extent first
2795  A55E CD A2 A4             CALL F_CLOSE_HND
2796  A561 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2797  A564 C8                   RET Z
2798  A565 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2799  A568                      ; FCB offset 12 = current-record byte
2800  A568 01 0C 00             LD BC,$000C
2801  A56B 09                   ADD HL,BC
2802  A56C 7E                   LD A,(HL)
2803  A56D 3C                   INC A
2804  A56E                      ; wrap the current record mod 32 (128 records/extent)
2805  A56E E6 1F                AND $1F
2806  A570 77                   LD (HL),A
2807  A571                      ; record wrapped -> move to the next extent
2808  A571 CA 83 A5             JP Z,FCB_NEXT_EXTENT
2809  A574 47                   LD B,A
2810  A575                      ; load the extent mask (EXM)
2811  A575 3A C5 A9             LD A,(DPB_EXM)
2812  A578 A0                   AND B
2813  A579 21 D2 A9             LD HL,DIR_DIRTY_FLAG
2814  A57C A6                   AND (HL)
2815  A57D CA 8E A5             JP Z,FCB_OPEN_NEXT_EXTENT
2816  A580 C3 AC A5             JP FCB_MERGE_FOUND_EXTENT
2817  A583              ; ----------------------------------------------------------------------
2818  A583              ; FCB_NEXT_EXTENT -- step the FCB to the next extent when the record count wraps.
2819  A583              ;   In: HL -> FCB current-record byte; FCB extent fields follow.
2820  A583              ;   Out: extent byte (offset 14) incremented; low-nibble rollover branches to finish.
2821  A583              ;   Clobbers: A,B,C,H,L,flags
2822  A583              ;   Algorithm: advance HL by 2 to the extent byte (offset 14), increment it; if its low nibble is
2823  A583              ;              now zero a module of extents has rolled over and control goes to DISK_FINISH_OK;
2824  A583              ;              otherwise fall into the open-next-extent path.
2825  A583              ;   [RE]
2826  A583              ; ----------------------------------------------------------------------
2827  A583              FCB_NEXT_EXTENT:
2828  A583                      ; step from record byte (12) to the extent byte (14)
2829  A583 01 02 00             LD BC,$0002
2830  A586 09                   ADD HL,BC
2831  A587                      ; advance to the next extent
2832  A587 34                   INC (HL)
2833  A588 7E                   LD A,(HL)
2834  A589                      ; low nibble = extent within the current entry group
2835  A589 E6 0F                AND $0F
2836  A58B                      ; extent group rolled over -> finish
2837  A58B CA B6 A5             JP Z,DISK_FINISH_OK
2838  A58E              ; ----------------------------------------------------------------------
2839  A58E              ; FCB_OPEN_NEXT_EXTENT -- search the directory for the FCB's next extent, creating it if absent.
2840  A58E              ;   In: CURFCB_PTR ($9F43) -> FCB positioned at the next extent; the read/write direction flag in
2841  A58E              ;       $A9D3.
2842  A58E              ;   Out: the extent opened (merged into the FCB) or a new entry created; result set.
2843  A58E              ;   Clobbers: A,B,C,D,E,H,L,flags
2844  A58E              ;   Algorithm: search-first on 15 bytes for the extent; if found go merge it
2845  A58E              ;              (FCB_MERGE_FOUND_EXTENT); else, when the direction flag is not $FF (i.e. a write),
2846  A58E              ;              make a new directory entry (DIR_MAKE_ENTRY); on a read (or no free slot) take the
2847  A58E              ;              disk-finish/error path.
2848  A58E              ;   [RE]
2849  A58E              ; ----------------------------------------------------------------------
2850  A58E              FCB_OPEN_NEXT_EXTENT:
2851  A58E                      ; search on 15 bytes (name+type+extent)
2852  A58E 0E 0F                LD C,$0F
2853  A590                      ; search-first for the next extent
2854  A590 CD 18 A3             CALL DIR_SEARCH_FIRST
2855  A593 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2856  A596                      ; extent exists -> merge it into the FCB
2857  A596 C2 AC A5             JP NZ,FCB_MERGE_FOUND_EXTENT
2858  A599 3A D3 A9             LD A,(RW_DIRECTION_FLAG)
2859  A59C 3C                   INC A
2860  A59D CA B6 A5             JP Z,DISK_FINISH_OK
2861  A5A0                      ; no extent -> make a new directory entry
2862  A5A0 CD 24 A5             CALL DIR_MAKE_ENTRY
2863  A5A3 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2864  A5A6 CA B6 A5             JP Z,DISK_FINISH_OK
2865  A5A9 C3 AF A5             JP FCB_FINISH_NEW_EXTENT
2866  A5AC              ; ----------------------------------------------------------------------
2867  A5AC              ; FCB_MERGE_FOUND_EXTENT -- merge a located directory extent back into the FCB.
2868  A5AC              ;   In: a successful search result for the extent; CURFCB_PTR ($9F43) -> FCB.
2869  A5AC              ;   Out: FCB's record/size fields updated from the entry; then falls into FCB_FINISH_NEW_EXTENT
2870  A5AC              ;        (refresh fields, return 0).
2871  A5AC              ;   Clobbers: A,B,C,D,E,H,L,flags
2872  A5AC              ;   Algorithm: merge the matched extent into the FCB (FILE_SIZE_FROM_EXTENT), then fall through into
2873  A5AC              ;              FCB_FINISH_NEW_EXTENT which refreshes the working fields and returns success.
2874  A5AC              ;   [RE]
2875  A5AC              ; ----------------------------------------------------------------------
2876  A5AC              FCB_MERGE_FOUND_EXTENT:
2877  A5AC                      ; FCB_FINISH_NEW_EXTENT
2878  A5AC                      ; merge the matched extent and set the FCB record count, then fall into
2879  A5AC CD 5A A4             CALL FILE_SIZE_FROM_EXTENT
2880  A5AF              ; ----------------------------------------------------------------------
2881  A5AF              ; FCB_FINISH_NEW_EXTENT -- finish opening a newly created extent and return OK.
2882  A5AF              ;   In: a new directory entry just made for the FCB.
2883  A5AF              ;   Out: FCB working fields refreshed; BDOS result = 0.
2884  A5AF              ;   Clobbers: A,B,C,D,E,H,L,flags
2885  A5AF              ;   Algorithm: refresh the FCB drive/extent fields (DRV_INSTALL_RWTS_3) and return success (0).
2886  A5AF              ;   [RE]
2887  A5AF              ; ----------------------------------------------------------------------
2888  A5AF              FCB_FINISH_NEW_EXTENT:
2889  A5AF                      ; refresh the FCB drive/extent working fields
2890  A5AF CD BB A0             CALL DRV_INSTALL_RWTS_3
2891  A5B2 AF                   XOR A
2892  A5B3                      ; return success (0)
2893  A5B3 C3 01 9F             JP BDOS_RET_RESULT
2894  A5B6              ; ----------------------------------------------------------------------
2895  A5B6              ; DISK_FINISH_OK -- finalize the BDOS result and set the FCB written flag.
2896  A5B6              ;   In: directory/record operation just completed.
2897  A5B6              ;   Out: BDOS result finalized (BDOS_RET_ONE); FCB S2 'written' bit set.
2898  A5B6              ;   Clobbers: A,H,L,flags
2899  A5B6              ;   Algorithm: run the common result-finalizer (BDOS_RET_ONE) then tail-jump to MARK_FCB_S2_HIGHBIT
2900  A5B6              ;              to set the FCB S2 high bit (mark written) and return.
2901  A5B6              ;   [RE]
2902  A5B6              ; ----------------------------------------------------------------------
2903  A5B6              DISK_FINISH_OK:
2904  A5B6                      ; finalize the BDOS result for the operation
2905  A5B6 CD 05 9F             CALL BDOS_RET_ONE
2906  A5B9                      ; set the FCB S2 'written' flag and return
2907  A5B9 C3 78 A1             JP MARK_FCB_S2_HIGHBIT
2908  A5BC              ; ----------------------------------------------------------------------
2909  A5BC              ; FILE_READ_SEQ -- sequential read of one record into the DMA buffer (BDOS fn 20).
2910  A5BC              ;   In: CURFCB_PTR ($9F43) -> open FCB. Reached from F_READ_H (dispatch fn 20).
2911  A5BC              ;   Out: requested record read; BDOS result reflects success/EOF.
2912  A5BC              ;   Clobbers: A,B,C,D,E,H,L,flags
2913  A5BC              ;   Algorithm: set the sequential/random mode flag $A9D5=1 (1 = sequential; the random-read path
2914  A5BC              ;              BDOS_SEEK_NOREAD sets it 0) then fall into the shared read core (FILE_READ_RECORD).
2915  A5BC              ;   [RE] CP/M 2.2 sequential read entry
2916  A5BC              ; ----------------------------------------------------------------------
2917  A5BC              FILE_READ_SEQ:
2918  A5BC                      ; mode = 1 (sequential read)
2919  A5BC 3E 01                LD A,$01
2920  A5BE                      ; store the sequential/random mode flag (1=sequential)
2921  A5BE 32 D5 A9             LD (WRITE_TYPE_FLAG),A
2922  A5C1              ; ----------------------------------------------------------------------
2923  A5C1              ; FILE_READ_RECORD -- read the FCB's current record into the DMA buffer (shared read core).
2924  A5C1              ;   In: CURFCB_PTR ($9F43) -> open FCB; record/extent fields set. Shared by sequential
2925  A5C1              ;       (FILE_READ_SEQ) and random read.
2926  A5C1              ;   Out: the record's sector read and de-blocked to the DMA address; result = 0/error.
2927  A5C1              ;   Clobbers: A,B,C,D,E,H,L,flags
2928  A5C1              ;   Algorithm: set the direction flag $A9D3=$FF (read), refresh the FCB working fields, compare the
2929  A5C1              ;              current record ($A9E3) against the extent's record count ($A9E1); if at the $80
2930  A5C1              ;              boundary advance to the next extent (FCB_ADVANCE_RECORD), else translate the record
2931  A5C1              ;              to a physical sector and read it.
2932  A5C1              ;   [RE] CP/M 2.2 read core
2933  A5C1              ; ----------------------------------------------------------------------
2934  A5C1              FILE_READ_RECORD:
2935  A5C1                      ; direction = read
2936  A5C1 3E FF                LD A,$FF
2937  A5C3                      ; store the read/write direction flag ($FF=read)
2938  A5C3 32 D3 A9             LD (RW_DIRECTION_FLAG),A
2939  A5C6                      ; refresh the FCB drive/extent working fields
2940  A5C6 CD BB A0             CALL DRV_INSTALL_RWTS_3
2941  A5C9 3A E3 A9             LD A,(FCB_CURREC)
2942  A5CC 21 E1 A9             LD HL,FCB_RECCOUNT
2943  A5CF BE                   CP (HL)
2944  A5D0 DA E6 A5             JP C,FILE_READ_DO_SECTOR
2945  A5D3                      ; record at the $80 boundary = extent boundary / EOF
2946  A5D3 FE 80                CP $80
2947  A5D5 C2 FB A5             JP NZ,FILE_READ_ERROR
2948  A5D8 CD 5A A5             CALL FCB_ADVANCE_RECORD
2949  A5DB AF                   XOR A
2950  A5DC 32 E3 A9             LD (FCB_CURREC),A
2951  A5DF 3A 45 9F             LD A,(BDOS_RETVAL)
2952  A5E2 B7                   OR A
2953  A5E3 C2 FB A5             JP NZ,FILE_READ_ERROR
2954  A5E6              ; ----------------------------------------------------------------------
2955  A5E6              ; FILE_READ_DO_SECTOR -- translate the record to a sector and read it into the DMA buffer.
2956  A5E6              ;   In: FCB working fields set; record within the current extent.
2957  A5E6              ;   Out: the physical sector read and de-blocked into the DMA address.
2958  A5E6              ;   Clobbers: A,B,C,D,E,H,L,flags
2959  A5E6              ;   Algorithm: compute block/sector/track from the record (DISK_STORE_SEC_TRK_14/16/17); if no block
2960  A5E6              ;              is allocated take the read-error path; otherwise read the sector through the
2961  A5E6              ;              deblocking buffer and return via the BIOS read tail (DRV_INSTALL_RWTS_6).
2962  A5E6              ;   [RE]
2963  A5E6              ; ----------------------------------------------------------------------
2964  A5E6              FILE_READ_DO_SECTOR:
2965  A5E6                      ; compute the block number for this record
2966  A5E6 CD 77 A0             CALL DISK_STORE_SEC_TRK_14
2967  A5E9 CD 84 A0             CALL DISK_STORE_SEC_TRK_16
2968  A5EC                      ; no allocated block -> read error / unwritten
2969  A5EC CA FB A5             JP Z,FILE_READ_ERROR
2970  A5EF                      ; compute the physical sector/track
2971  A5EF CD 8A A0             CALL DISK_STORE_SEC_TRK_17
2972  A5F2 CD D1 9F             CALL RECORD_TO_TRACK
2973  A5F5 CD B2 9F             CALL DISK_READ_CHECKED
2974  A5F8                      ; perform the BIOS sector read and return
2975  A5F8 C3 D2 A0             JP DRV_INSTALL_RWTS_6
2976  A5FB              ; ----------------------------------------------------------------------
2977  A5FB              ; FILE_READ_ERROR -- return a read error / unwritten-record result.
2978  A5FB              ;   In: none.
2979  A5FB              ;   Out: BDOS result set to the error code via BDOS_RET_ONE.
2980  A5FB              ;   Clobbers: A,flags
2981  A5FB              ;   Algorithm: tail-jump to the common error-result setter.
2982  A5FB              ;   [RE]
2983  A5FB              ; ----------------------------------------------------------------------
2984  A5FB              FILE_READ_ERROR:
2985  A5FB                      ; return the BDOS read error code
2986  A5FB C3 05 9F             JP BDOS_RET_ONE
2987  A5FE              ; ----------------------------------------------------------------------
2988  A5FE              ; FILE_WRITE_SEQ -- sequential write of one record from the DMA buffer (BDOS fn 21).
2989  A5FE              ;   In: CURFCB_PTR ($9F43) -> FCB; DMA buffer holds the record. Reached from F_WRITE_H (dispatch fn
2990  A5FE              ;       21).
2991  A5FE              ;   Out: enters the write core; record written, blocks allocated as needed; result set.
2992  A5FE              ;   Clobbers: A,B,C,D,E,H,L,flags
2993  A5FE              ;   Algorithm: set the sequential/random mode flag $A9D5=1 (1 = sequential) then fall into the
2994  A5FE              ;              shared write core (at $A603, which clears the direction flag, logs in, allocates a
2995  A5FE              ;              block when the record is new, translates to a sector, and writes).
2996  A5FE              ;   [RE] CP/M 2.2 sequential write entry
2997  A5FE              ; ----------------------------------------------------------------------
2998  A5FE              FILE_WRITE_SEQ:
2999  A5FE                      ; mode = 1 (sequential write)
3000  A5FE 3E 01                LD A,$01
3001  A600                      ; store the sequential/random mode flag (1=sequential)
3002  A600 32 D5 A9             LD (WRITE_TYPE_FLAG),A
3003  A603              ; ----------------------------------------------------------------------
3004  A603              ; BDOS_WRITE -- BDOS WRITE primitive (CP/M 2.2 fn 21 F_WRITE / fn 34 F_WRITERAND / fn 40 F_WRITEZF
3005  A603              ; target). Write the current record of the open file, allocating and deblocking disk blocks as
3006  A603              ; needed.
3007  A603              ;   In: CURFCB (BDOS_PARAM_PTR) -> active FCB; the BDOS work cells for current-record (FCB_CURREC) /
3008  A603              ;       record-count (FCB_RECCOUNT) have been primed from the FCB by DRV_INSTALL_RWTS_3; DMA holds
3009  A603              ;       the
3010  A603              ;       caller's record; WRITE_TYPE_FLAG = write type (1 = sequential, 2 = random); BDOS_RETVAL =
3011  A603              ;       seek
3012  A603              ;       create/extend mode flag.
3013  A603              ;   Out: A = BDOS return code (0 = OK, 2 = disk full); status returned through BDOS_RET_RESULT; FCB
3014  A603              ;        allocation map / record count updated; host sector written. (OBSERVED: only the disk-full=2
3015  A603              ;        path is taken here; other error codes come from sub-routines.)
3016  A603              ;   Clobbers: A, BC, DE, HL, flags.
3017  A603              ;   Algorithm: clear the directory-update flag (RW_DIRECTION_FLAG); fetch the current record index
3018  A603              ;              and reject
3019  A603              ;              it if >= 128 (extent full). Compute the FCB allocation-map SLOT for this record and
3020  A603              ;              read the block number already stored there: if it is non-zero the block is already
3021  A603              ;              allocated, so branch straight to the write phase. If it is zero, recompute the slot
3022  A603              ;              index, fetch the block stored in the PREVIOUS slot as an allocation hint, then call
3023  A603              ;              the disk-map allocator (ALLOC_GET_BLOCK) to grab a fresh block. Store the (new or
3024  A603              ;              existing) block number into the FCB allocation slot, then perform the physical write
3025  A603              ;              and update the extent record count. Mirrors the standard CP/M 2.2 BDOS write routine.
3026  A603              ;              [RE]
3027  A603              ; ----------------------------------------------------------------------
3028  A603              BDOS_WRITE:
3029  A603                      ; Clear the directory-update-needed flag (RW_DIRECTION_FLAG) before starting this write.
3030  A603 3E 00                LD A,$00
3031  A605 32 D3 A9             LD (RW_DIRECTION_FLAG),A
3032  A608                      ; Drive read-only / select check (raises a BDOS error overlay if the drive is not writable).
3033  A608 CD 54 A1             CALL CHECK_DRIVE_READONLY
3034  A60B                      ; HL = pointer to the active FCB (CURFCB).
3035  A60B 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3036  A60E CD 47 A1             CALL CHECK_DIRENT_READONLY_INNER
3037  A611 CD BB A0             CALL DRV_INSTALL_RWTS_3
3038  A614                      ; Load the current record number within the extent (primed from the FCB).
3039  A614 3A E3 A9             LD A,(FCB_CURREC)
3040  A617                      ; Record index 128 means the extent is full -> cannot write, report error.
3041  A617 FE 80                CP $80
3042  A619                      ; Extent full / index out of range: bail to the BDOS error path.
3043  A619 D2 05 9F             JP NC,BDOS_RET_ONE
3044  A61C CD 77 A0             CALL DISK_STORE_SEC_TRK_14
3045  A61F CD 84 A0             CALL DISK_STORE_SEC_TRK_16
3046  A622                      ; allocated.
3047  A622                      ; C = 0: existing-block write mode (no zero-fill); used only if the block is already
3048  A622 0E 00                LD C,$00
3049  A624                      ; phase.
3050  A624                      ; Block already allocated (slot held a non-zero block) -> skip allocation, go to the write
3051  A624 C2 6E A6             JP NZ,BDOS_WRITE_PHASE
3052  A627                      ; disk block).
3053  A627                      ; Recompute the FCB allocation-map slot index for the current record (A = slot index, NOT a
3054  A627 CD 3E A0             CALL DISK_STORE_SEC_TRK_6
3055  A62A                      ; Save the allocation-slot index for use when storing the new block number.
3056  A62A 32 D7 A9             LD (ALLOC_SLOT_INDEX),A
3057  A62D 01 00 00             LD BC,$0000
3058  A630 B7                   OR A
3059  A631                      ; Slot index 0 (first slot) -> skip the previous-slot fetch; go allocate a fresh block.
3060  A631 CA 3B A6             JP Z,BDOS_WRITE_ALLOCBLK
3061  A634 4F                   LD C,A
3062  A635 0B                   DEC BC
3063  A636                      ; -> HL.
3064  A636                      ; Fetch the block stored in the PREVIOUS slot (BC = slot-1) as the allocation starting hint
3065  A636 CD 5E A0             CALL DISK_STORE_SEC_TRK_10
3066  A639 44                   LD B,H
3067  A63A 4D                   LD C,L
3068  A63B              ; ----------------------------------------------------------------------
3069  A63B              ; BDOS_WRITE_ALLOCBLK -- allocate a fresh data block from the disk allocation vector, or return
3070  A63B              ; 'disk full'.
3071  A63B              ;   In: BC = allocation hint (block from the previous slot, or 0); CURFCB context valid.
3072  A63B              ;   Out: on success HL = newly allocated block number and control falls into BDOS_WRITE_STOREBLK; on
3073  A63B              ;        no free block, returns A=2 (disk full) via BDOS_RET_RESULT.
3074  A63B              ;   Clobbers: A, BC, DE, HL, flags.
3075  A63B              ;   Algorithm: call the disk-map allocator ALLOC_GET_BLOCK, which scans the drive allocation bitmap
3076  A63B              ;              (up to MAX_BLOCK_DSM), marks a free block in use and returns HL = its block number
3077  A63B              ;              (HL = 0 when the disk is full). If HL is zero, set A=2 and return the disk-full
3078  A63B              ;              status; otherwise fall through to record the new block in the FCB. [RE]
3079  A63B              ; ----------------------------------------------------------------------
3080  A63B              BDOS_WRITE_ALLOCBLK:
3081  A63B                      ; full).
3082  A63B                      ; Allocate a fresh block from the drive allocation bitmap; HL = new block number (0 = disk
3083  A63B CD BE A3             CALL ALLOC_GET_BLOCK
3084  A63E 7D                   LD A,L
3085  A63F                      ; Test HL for zero (no free block was found).
3086  A63F B4                   OR H
3087  A640                      ; Non-zero block: proceed to record it in the FCB.
3088  A640 C2 48 A6             JP NZ,BDOS_WRITE_STOREBLK
3089  A643                      ; A = 2: disk-full return code.
3090  A643 3E 02                LD A,$02
3091  A645                      ; Return disk-full status to the caller.
3092  A645 C3 01 9F             JP BDOS_RET_RESULT
3093  A648              ; ----------------------------------------------------------------------
3094  A648              ; BDOS_WRITE_STOREBLK -- store the (new or existing) block number into the FCB allocation slot for
3095  A648              ; the current record.
3096  A648              ;   In: HL = block number; CURFCB (BDOS_PARAM_PTR) = active FCB; ALLOC_SLOT_INDEX = allocation-slot
3097  A648              ;       index
3098  A648              ;       within the extent; BLOCK_WIDTH_FLAG selects 1-byte vs 2-byte block entries.
3099  A648              ;   Out: FCB allocation map updated with the block number at the computed slot.
3100  A648              ;   Clobbers: A, BC, DE, HL, flags.
3101  A648              ;   Algorithm: save the block number to CUR_BLOCK_NUMBER (for the write phase) into DE; point HL at
3102  A648              ;              the FCB
3103  A648              ;              allocation map (FCB+16); read the slot index. If BLOCK_WIDTH_FLAG selects 8-bit
3104  A648              ;              blocks, add the slot index to HL (via DIRENT_PTR_ADD) and store one byte; otherwise
3105  A648              ;              jump to the 16-bit store path. [RE]
3106  A648              ; ----------------------------------------------------------------------
3107  A648              BDOS_WRITE_STOREBLK:
3108  A648                      ; Save the block number for the write phase (host record/sector base).
3109  A648 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
3110  A64B EB                   EX DE,HL
3111  A64C 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3112  A64F                      ; Offset 16 = start of the allocation/disk-map area inside the FCB.
3113  A64F 01 10 00             LD BC,$0010
3114  A652 09                   ADD HL,BC
3115  A653                      ; Test whether the drive uses 8-bit (small disk) or 16-bit block numbers.
3116  A653 3A DD A9             LD A,(BLOCK_WIDTH_FLAG)
3117  A656 B7                   OR A
3118  A657                      ; A = allocation-slot index within the FCB extent.
3119  A657 3A D7 A9             LD A,(ALLOC_SLOT_INDEX)
3120  A65A                      ; 16-bit-block-number drive: store the block number as a 2-byte entry.
3121  A65A CA 64 A6             JP Z,BDOS_WRITE_STOREBLK16
3122  A65D                      ; Add the slot index to HL = address of the single-byte slot inside the FCB map.
3123  A65D CD 64 A1             CALL DIRENT_PTR_ADD
3124  A660                      ; Store the low byte (8-bit block number) into the FCB slot.
3125  A660 73                   LD (HL),E
3126  A661 C3 6C A6             JP BDOS_WRITE_NEWBLK
3127  A664              ; ----------------------------------------------------------------------
3128  A664              ; BDOS_WRITE_STOREBLK16 -- store a 16-bit block number into the FCB allocation map (large-disk
3129  A664              ; format).
3130  A664              ;   In: HL = FCB allocation-map base (FCB+16); A = slot index; DE = block number.
3131  A664              ;   Out: the 2-byte block number written at FCB+16 + slot*2 (low byte then high byte).
3132  A664              ;   Clobbers: A, BC, HL, flags.
3133  A664              ;   Algorithm: extend the slot index to BC, add it to HL twice (slot*2 byte offset), then store DE
3134  A664              ;              low/high. Falls through to the write phase. [RE]
3135  A664              ; ----------------------------------------------------------------------
3136  A664              BDOS_WRITE_STOREBLK16:
3137  A664                      ; BC = slot index.
3138  A664 4F                   LD C,A
3139  A665 06 00                LD B,$00
3140  A667                      ; Add slot index twice (this is the first add) => byte offset = slot*2 for 16-bit entries.
3141  A667 09                   ADD HL,BC
3142  A668 09                   ADD HL,BC
3143  A669                      ; Store block-number low byte.
3144  A669 73                   LD (HL),E
3145  A66A 23                   INC HL
3146  A66B                      ; Store block-number high byte.
3147  A66B 72                   LD (HL),D
3148  A66C              ; ----------------------------------------------------------------------
3149  A66C              ; BDOS_WRITE_NEWBLK -- mark this write as 'new block, must zero-fill' before the write phase.
3150  A66C              ;   In: control reaches here after a freshly allocated block was recorded in the FCB.
3151  A66C              ;   Out: C = 2, signalling the write phase to zero-fill the unwritten records of the new block.
3152  A66C              ;   Clobbers: C.
3153  A66C              ;   Algorithm: set C=2 (new-block write mode) and fall into the write phase. [RE]
3154  A66C              ; ----------------------------------------------------------------------
3155  A66C              BDOS_WRITE_NEWBLK:
3156  A66C                      ; C = 2: new-block write mode (the block was just allocated, zero-fill it).
3157  A66C 0E 02                LD C,$02
3158  A66E              ; ----------------------------------------------------------------------
3159  A66E              ; BDOS_WRITE_PHASE -- perform the physical write of the current record, honoring the
3160  A66E              ; deblocking/new-block mode.
3161  A66E              ;   In: C = write mode (0 = existing block, 2 = new block); CURFCB context valid; DMA holds the
3162  A66E              ;       caller's record; BDOS_RETVAL = seek create/extend mode flag (00 / FF); WRITE_TYPE_FLAG =
3163  A66E              ;       BDOS write
3164  A66E              ;       type (1 = sequential, 2 = random).
3165  A66E              ;   Out: host sector updated on disk; control merges into the post-write record-count update;
3166  A66E              ;        returns early if the create/extend flag is set.
3167  A66E              ;   Clobbers: A, BC, DE, HL, flags.
3168  A66E              ;   Algorithm: load BDOS_RETVAL; if it is non-zero (a create/extend was flagged) return so the
3169  A66E              ;              caller can handle it. Otherwise save the mode, compute the host record/sector
3170  A66E              ;              (DISK_STORE_SEC_TRK_17), and branch on write type: random data writes (type 2) go
3171  A66E              ;              directly; sequential writes of a fresh block (mode 2) first zero-fill the
3172  A66E              ;              directory/work buffer and write its records up to the host-sector boundary.
3173  A66E              ;              (OBSERVED: BDOS_RETVAL is the same cell the seek code sets to its phase value;
3174  A66E              ;              calling it a 'host-buffer' flag is not supported -- it is the seek/create mode cell.)
3175  A66E              ;              [RE]
3176  A66E              ; ----------------------------------------------------------------------
3177  A66E              BDOS_WRITE_PHASE:
3178  A66E                      ; pending).
3179  A66E                      ; Load the seek create/extend mode flag (BDOS_RETVAL; 00 = normal, FF = create/extend
3180  A66E 3A 45 9F             LD A,(BDOS_RETVAL)
3181  A671 B7                   OR A
3182  A672                      ; Create/extend flagged (BDOS_RETVAL != 0) -> return to the caller without writing here.
3183  A672 C0                   RET NZ
3184  A673                      ; Preserve the write-mode byte (C) across the sector computation.
3185  A673 C5                   PUSH BC
3186  A674                      ; Compute the host physical record index/sector for the current logical record.
3187  A674 CD 8A A0             CALL DISK_STORE_SEC_TRK_17
3188  A677                      ; Load the BDOS write type (1 = sequential, 2 = random).
3189  A677 3A D5 A9             LD A,(WRITE_TYPE_FLAG)
3190  A67A 3D                   DEC A
3191  A67B 3D                   DEC A
3192  A67C                      ; Write type != 2 (sequential) -> may need the new-block zero-fill path.
3193  A67C C2 BB A6             JP NZ,BDOS_WRITE_DOWRITE
3194  A67F C1                   POP BC
3195  A680 C5                   PUSH BC
3196  A681                      ; A = write mode (was the block freshly allocated?).
3197  A681 79                   LD A,C
3198  A682 3D                   DEC A
3199  A683 3D                   DEC A
3200  A684                      ; Existing block (mode != 2): write directly, no zero-fill.
3201  A684 C2 BB A6             JP NZ,BDOS_WRITE_DOWRITE
3202  A687 E5                   PUSH HL
3203  A688                      ; HL = directory/work buffer to be zero-filled before the new-block write.
3204  A688 2A B9 A9             LD HL,(DIRBUF_PTR)
3205  A68B                      ; D = 0: byte counter for the 128-byte fill loop.
3206  A68B 57                   LD D,A
3207  A68C              ; ----------------------------------------------------------------------
3208  A68C              ; BDOS_WRITE_ZEROFILL -- zero-fill one 128-byte record buffer for a freshly allocated block.
3209  A68C              ;   In: HL = buffer start; A = 0 (fill value); D = 0 (loop counter).
3210  A68C              ;   Out: 128 bytes from HL cleared to 0; HL advanced past the buffer.
3211  A68C              ;   Clobbers: A(=0), D, HL, flags.
3212  A68C              ;   Algorithm: store 0, advance HL, INC D and loop while the sign flag stays clear (D < 128), i.e.
3213  A68C              ;              128 iterations (0..127). Clears the work buffer before writing fresh records into a
3214  A68C              ;              new block. [RE]
3215  A68C              ; ----------------------------------------------------------------------
3216  A68C              BDOS_WRITE_ZEROFILL:
3217  A68C                      ; Store 0 into the buffer byte.
3218  A68C 77                   LD (HL),A
3219  A68D 23                   INC HL
3220  A68E                      ; Advance the 0..127 fill counter.
3221  A68E 14                   INC D
3222  A68F                      ; Loop while D < 128 (sign clear): fill all 128 record bytes.
3223  A68F F2 8C A6             JP P,BDOS_WRITE_ZEROFILL
3224  A692                      ; Point the DMA at the deblocking/host buffer for the fill writes.
3225  A692 CD E0 A1             CALL SET_DMA_TO_DISK_BUF
3226  A695                      ; HL = base host record index for this block's fill.
3227  A695 2A E7 A9             LD HL,(BLOCK_BASE_RECORD)
3228  A698 0E 02                LD C,$02
3229  A69A              ; ----------------------------------------------------------------------
3230  A69A              ; BDOS_WRITE_FILLLOOP -- write the zero-filled records of a new block up to the host-sector
3231  A69A              ; boundary.
3232  A69A              ;   In: HL = current host record index; C = 2 (mode); deblock DMA already pointed at the fill
3233  A69A              ;       buffer.
3234  A69A              ;   Out: the records spanning the host sector written; loops until the record index crosses the
3235  A69A              ;        host-sector mask boundary.
3236  A69A              ;   Clobbers: A, BC, HL, flags.
3237  A69A              ;   Algorithm: save the record index (CUR_BLOCK_NUMBER), translate/seek the host sector
3238  A69A              ;              (RECORD_TO_TRACK),
3239  A69A              ;              write it (DISK_WRITE_CHECKED), reload the index and mask it with the
3240  A69A              ;              records-per-host-sector mask (DPB_BLM); INC the index and loop until the masked value
3241  A69A              ;              differs (host-sector boundary reached). Then restore the saved record index and
3242  A69A              ;              finalize via RESTORE_USER_DMA. [RE]
3243  A69A              ; ----------------------------------------------------------------------
3244  A69A              BDOS_WRITE_FILLLOOP:
3245  A69A                      ; Save the working host-record index.
3246  A69A 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
3247  A69D C5                   PUSH BC
3248  A69E                      ; Translate/seek the host track+sector for this record.
3249  A69E CD D1 9F             CALL RECORD_TO_TRACK
3250  A6A1 C1                   POP BC
3251  A6A2                      ; Write the (zeroed) record to the host sector via the BIOS R/W call.
3252  A6A2 CD B8 9F             CALL DISK_WRITE_CHECKED
3253  A6A5 2A E5 A9             LD HL,(CUR_BLOCK_NUMBER)
3254  A6A8 0E 00                LD C,$00
3255  A6AA                      ; Load the records-per-host-sector mask.
3256  A6AA 3A C4 A9             LD A,(DPB_BLM)
3257  A6AD 47                   LD B,A
3258  A6AE                      ; Mask the record index to its position within the host sector.
3259  A6AE A5                   AND L
3260  A6AF                      ; Compare against the host-sector base value (still inside this host sector?).
3261  A6AF B8                   CP B
3262  A6B0 23                   INC HL
3263  A6B1                      ; Loop while still within the same host sector (fill all its records).
3264  A6B1 C2 9A A6             JP NZ,BDOS_WRITE_FILLLOOP
3265  A6B4 E1                   POP HL
3266  A6B5 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
3267  A6B8                      ; Restore the caller DMA and finalize the new-block fill.
3268  A6B8 CD DA A1             CALL RESTORE_USER_DMA
3269  A6BB              ; ----------------------------------------------------------------------
3270  A6BB              ; BDOS_WRITE_DOWRITE -- write the caller's current record to its host sector and bump the extent
3271  A6BB              ; record count.
3272  A6BB              ;   In: stack holds the mode byte; CURFCB context valid; DMA = caller record.
3273  A6BB              ;   Out: record written; FCB current-record-count cell (FCB_RECCOUNT) advanced when this record
3274  A6BB              ;        extends
3275  A6BB              ;        the extent; C=2 if the count grew; falls into the S2/extent-overflow update.
3276  A6BB              ;   Clobbers: A, BC, DE, HL, flags.
3277  A6BB              ;   Algorithm: translate/seek (RECORD_TO_TRACK) and write (DISK_WRITE_CHECKED) the record; compare
3278  A6BB              ;              the just-written record index (FCB_CURREC) against the extent's stored record count
3279  A6BB              ;              (FCB_RECCOUNT); if it is a new high-water record, store and increment the count and
3280  A6BB              ;              set C=2
3281  A6BB              ;              (extent grew). [RE]
3282  A6BB              ; ----------------------------------------------------------------------
3283  A6BB              BDOS_WRITE_DOWRITE:
3284  A6BB                      ; Translate/seek the host track+sector for the current record.
3285  A6BB CD D1 9F             CALL RECORD_TO_TRACK
3286  A6BE C1                   POP BC
3287  A6BF C5                   PUSH BC
3288  A6C0                      ; Write the caller's record to the host sector via the BIOS R/W call.
3289  A6C0 CD B8 9F             CALL DISK_WRITE_CHECKED
3290  A6C3 C1                   POP BC
3291  A6C4                      ; A = the record index just written within the extent.
3292  A6C4 3A E3 A9             LD A,(FCB_CURREC)
3293  A6C7                      ; HL -> the extent's current record-count cell (FCB_RECCOUNT).
3294  A6C7 21 E1 A9             LD HL,FCB_RECCOUNT
3295  A6CA                      ; Is the written record beyond the current record count?
3296  A6CA BE                   CP (HL)
3297  A6CB                      ; Record is within the existing count -> no count update needed.
3298  A6CB DA D2 A6             JP C,BDOS_WRITE_S2UPDATE
3299  A6CE                      ; Extent grew: store the new record index as the count...
3300  A6CE 77                   LD (HL),A
3301  A6CF                      ; ...and bump it (count = index + 1).
3302  A6CF 34                   INC (HL)
3303  A6D0                      ; C = 2: signal the extent record count was extended.
3304  A6D0 0E 02                LD C,$02
3305  A6D2              ; ----------------------------------------------------------------------
3306  A6D2              ; BDOS_WRITE_S2UPDATE -- refresh the FCB S2 byte and, at end-of-extent, advance the FCB to the next
3307  A6D2              ; extent.
3308  A6D2              ;   In: A = current record/extent state; CURFCB context valid; WRITE_TYPE_FLAG = write type.
3309  A6D2              ;   Out: FCB S2 byte stored with its high bit cleared; on extent rollover (record index 0x7F with
3310  A6D2              ;        sequential write) the record count is written back and the FCB moves to the next extent;
3311  A6D2              ;        otherwise takes the common return.
3312  A6D2              ;   Clobbers: A, BC, HL, flags.
3313  A6D2              ;   Algorithm: (two leading NOPs are padding). Fetch the FCB S2 byte (FCB_GET_S2), clear its high
3314  A6D2              ;              bit and store it back. If the just-written record was the last in the extent (0x7F)
3315  A6D2              ;              AND this is a sequential write (WRITE_TYPE_FLAG == 1), copy the working record count
3316  A6D2              ;              back into
3317  A6D2              ;              the FCB (DRV_INSTALL_RWTS_6) and advance to the next extent (FCB_ADVANCE_RECORD); if
3318  A6D2              ;              no host buffer write is pending, reset the current-record cell; else take the common
3319  A6D2              ;              return. (OBSERVED: the LD HL,$A6DF (S2-check site) at entry is immediately
3320  A6D2              ;              overwritten by FCB_GET_S2
3321  A6D2              ;              -- it loads no value that is used.) [RE]
3322  A6D2              ; VERSION DELTA: in 2.23 the two leading bytes are DEC C / DEC C (C: $02 -> $00), not the 2.20 NOP /
3323  A6D2              ; NOP padding; see the spec flag for $A6D2.
3324  A6D2              ; ----------------------------------------------------------------------
3325  A6D2              BDOS_WRITE_S2UPDATE:
3326  A6D2 0D                   DEC C
3327  A6D3 0D                   DEC C
3328  A6D4                      ; Vestigial load of the local S2-check site ($A6DF) -- HL is immediately overwritten by
3329  A6D4                      ; FCB_GET_S2 below; value unused. (2.20 loads CCP_ENTRY=$9400 here; 2.23 loads $A6DF.)
3330  A6D4 21 DF A6             LD HL,BDOS_WRITE_S2CHECK
3331  A6D7 F5                   PUSH AF
3332  A6D8                      ; HL -> the FCB S2 (extent-module) byte; A = its value.
3333  A6D8 CD 69 A1             CALL FCB_GET_S2
3334  A6DB                      ; Clear the high (modified/in-use) bit of the S2 byte.
3335  A6DB E6 7F                AND $7F
3336  A6DD                      ; Store the updated S2 byte back into the FCB.
3337  A6DD 77                   LD (HL),A
3338  A6DE F1                   POP AF
3339  A6DF              ; ----------------------------------------------------------------------
3340  A6DF              ; BDOS_WRITE_S2CHECK -- extent-end test inside the S2 update: was the just-written record the
3341  A6DF              ; last of the extent (index $7F)?
3342  A6DF              ;   In: A = the just-written record index; WRITE_TYPE_FLAG = write type.
3343  A6DF              ;   Out: if not at $7F, or not a sequential write, take the common write return (BDOS_WRITE_RET);
3344  A6DF              ;        otherwise roll the FCB forward to the next extent.
3345  A6DF              ;   Clobbers: A, HL, flags.
3346  A6DF              ;   Algorithm: CP $7F; on no-match return. Else load WRITE_TYPE_FLAG; only type 1 (sequential)
3347  A6DF              ;              rolls the extent (copy the record count back, FCB_ADVANCE_RECORD, reset the
3348  A6DF              ;              current-record cell). [RE]
3349  A6DF              ;   NOTE: in 2.23 this site is also the target of the vestigial LD HL,$A6DF in
3350  A6DF              ;   BDOS_WRITE_S2UPDATE (HL is overwritten by FCB_GET_S2; the value is unused).
3351  A6DF              ; ----------------------------------------------------------------------
3352  A6DF              BDOS_WRITE_S2CHECK:
3353  A6DF FE 7F                CP $7F
3354  A6E1 C2 00 A7             JP NZ,BDOS_WRITE_RET
3355  A6E4 3A D5 A9             LD A,(WRITE_TYPE_FLAG)
3356  A6E7 FE 01                CP $01
3357  A6E9 C2 00 A7             JP NZ,BDOS_WRITE_RET
3358  A6EC CD D2 A0             CALL DRV_INSTALL_RWTS_6
3359  A6EF CD 5A A5             CALL FCB_ADVANCE_RECORD
3360  A6F2 21 45 9F             LD HL,BDOS_RETVAL
3361  A6F5 7E                   LD A,(HL)
3362  A6F6 B7                   OR A
3363  A6F7 C2 FE A6             JP NZ,BDOS_WRITE_RESETREC
3364  A6FA 3D                   DEC A
3365  A6FB 32 E3 A9             LD (FCB_CURREC),A
3366  A6FE              ; ----------------------------------------------------------------------
3367  A6FE              ; BDOS_WRITE_RESETREC -- clear the seek/create-mode flag cell after an extent rollover.
3368  A6FE              ;   In: HL -> the BDOS_RETVAL flag cell.
3369  A6FE              ;   Out: that flag cell cleared to 0.
3370  A6FE              ;   Clobbers: (memory only).
3371  A6FE              ;   Algorithm: store 0 through HL to reset the BDOS_RETVAL flag, then fall into the common return.
3372  A6FE              ;              [RE]
3373  A6FE              ; ----------------------------------------------------------------------
3374  A6FE              BDOS_WRITE_RESETREC:
3375  A6FE                      ; Clear the BDOS_RETVAL seek/create-mode flag for the new extent.
3376  A6FE 36 00                LD (HL),$00
3377  A700              ; ----------------------------------------------------------------------
3378  A700              ; BDOS_WRITE_RET -- common exit of the WRITE primitive.
3379  A700              ;   In: write completed (or no further action needed).
3380  A700              ;   Out: tail-jumps to DRV_INSTALL_RWTS_6, which copies the working record/count back into the FCB
3381  A700              ;        and returns to the BDOS dispatcher.
3382  A700              ;   Clobbers: per the tail routine.
3383  A700              ;   Algorithm: tail-jump to the record-count writeback routine. [RE]
3384  A700              ; ----------------------------------------------------------------------
3385  A700              BDOS_WRITE_RET:
3386  A700                      ; Copy the working record/count back into the FCB and return via the shared tail.
3387  A700 C3 D2 A0             JP DRV_INSTALL_RWTS_6
3388  A703              ; ----------------------------------------------------------------------
3389  A703              ; BDOS_SEEK_NOREAD -- SEEK entry that clears the write-type cell, then computes/positions the target
3390  A703              ; extent.
3391  A703              ;   In: CURFCB (BDOS_PARAM_PTR) valid.
3392  A703              ;   Out: as for BDOS_SEEK_COMPUTE below.
3393  A703              ;   Clobbers: A, BC, DE, HL, flags.
3394  A703              ;   Algorithm: clear the write-type cell (WRITE_TYPE_FLAG = 0), then fall straight into
3395  A703              ;              BDOS_SEEK_COMPUTE.
3396  A703              ;              (OBSERVED: this entry is used by the random read/write callers
3397  A703              ;              FCB_EXTENT_TO_TRKSEC_8/9 after they set C; BDOS_SEEK_NOREAD itself does not consume C
3398  A703              ;              -- it is merely preserved on the stack across the seek and used by the caller
3399  A703              ;              afterward.) [RE]
3400  A703              ; ----------------------------------------------------------------------
3401  A703              BDOS_SEEK_NOREAD:
3402  A703 AF                   XOR A
3403  A704                      ; Write type = 0 (cleared before the seek).
3404  A704 32 D5 A9             LD (WRITE_TYPE_FLAG),A
3405  A707              ; ----------------------------------------------------------------------
3406  A707              ; BDOS_SEEK_COMPUTE -- compute the target extent/record from the FCB random-record field (R0/R1/R2)
3407  A707              ; and seek the directory to it.
3408  A707              ;   In: CURFCB (BDOS_PARAM_PTR) -> FCB whose random-record bytes (FCB+33..35 = R0/R1/R2) hold the
3409  A707              ;       desired record; BDOS_RETVAL = create/extend mode flag.
3410  A707              ;   Out: B = target S2 (module), C = target extent-within-entry; if the FCB is already positioned
3411  A707              ;        there, returns OK (A=0) via BDOS_RET_RESULT; else repositions the directory; on R2 != 0
3412  A707              ;        returns record-out-of-range. (OBSERVED: BC is also just preserved on the stack for the
3413  A707              ;        calling read/write routine.)
3414  A707              ;   Clobbers: A, BC, DE, HL, flags.
3415  A707              ;   Algorithm: read R0 and combine with R1 into the 16-bit record number. record-within-extent = R0
3416  A707              ;              & 0x7F; extent = ((R1 << 1) | R0.bit7) & 0x1F (C); S2/module = R1 >> 4 (B). If R2
3417  A707              ;              (high random byte) is non-zero the record is out of range -> abort with phase code 6.
3418  A707              ;              Otherwise compare target extent (C vs FCB+12) and S2 (B vs FCB+14): if both already
3419  A707              ;              match, fall through with no positioning; else reposition the directory to the target
3420  A707              ;              extent. Mirrors the standard CP/M 2.2 BDOS random seek. [RE]
3421  A707              ; ----------------------------------------------------------------------
3422  A707              BDOS_SEEK_COMPUTE:
3423  A707 C5                   PUSH BC
3424  A708                      ; HL = pointer to the active FCB (CURFCB).
3425  A708 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3426  A70B EB                   EX DE,HL
3427  A70C                      ; Offset 33 (0x21) = FCB random-record field R0; HL = FCB+33 after ADD HL,DE.
3428  A70C 21 21 00             LD HL,$0021
3429  A70F 19                   ADD HL,DE
3430  A710 7E                   LD A,(HL)
3431  A711                      ; Record-within-extent = R0 bits 0..6 (0..127).
3432  A711 E6 7F                AND $7F
3433  A713 F5                   PUSH AF
3434  A714 7E                   LD A,(HL)
3435  A715                      ; Rotate R0 bit7 into carry (combined with R1 below for the extent number).
3436  A715 17                   RLA
3437  A716 23                   INC HL
3438  A717 7E                   LD A,(HL)
3439  A718                      ; Rotate R1 left, picking up R0.bit7 from carry: forms (R1 << 1) | R0.bit7.
3440  A718 17                   RLA
3441  A719                      ; Low 5 bits = extent number within the directory entry.
3442  A719 E6 1F                AND $1F
3443  A71B                      ; C = target extent (low part).
3444  A71B 4F                   LD C,A
3445  A71C 7E                   LD A,(HL)
3446  A71D 1F                   RRA
3447  A71E 1F                   RRA
3448  A71F 1F                   RRA
3449  A720 1F                   RRA
3450  A721                      ; Keep R1's high nibble = S2 / extent-module count.
3451  A721 E6 0F                AND $0F
3452  A723                      ; B = target S2 (extent module) value (R1 >> 4).
3453  A723 47                   LD B,A
3454  A724 F1                   POP AF
3455  A725 23                   INC HL
3456  A726 6E                   LD L,(HL)
3457  A727 2C                   INC L
3458  A728 2D                   DEC L
3459  A729                      ; Preset L = seek phase code 6 (the random-record overflow result).
3460  A729 2E 06                LD L,$06
3461  A72B                      ; R2 (high random-record byte) non-zero -> record number out of range, abort the seek.
3462  A72B C2 8B A7             JP NZ,RANDREC_POS_RET
3463  A72E 21 20 00             LD HL,$0020
3464  A731 19                   ADD HL,DE
3465  A732 77                   LD (HL),A
3466  A733                      ; Offset 12 = FCB extent (EX) byte.
3467  A733 21 0C 00             LD HL,$000C
3468  A736 19                   ADD HL,DE
3469  A737 79                   LD A,C
3470  A738                      ; Compare target extent (C) against the FCB's current extent.
3471  A738 96                   SUB (HL)
3472  A739                      ; Extent differs -> must reposition the directory to the new extent.
3473  A739 C2 47 A7             JP NZ,BDOS_SEEK_REPOSITION
3474  A73C                      ; Offset 14 = FCB S2 (module) byte.
3475  A73C 21 0E 00             LD HL,$000E
3476  A73F 19                   ADD HL,DE
3477  A740 78                   LD A,B
3478  A741                      ; Compare target S2 (B) against the FCB's current S2.
3479  A741 96                   SUB (HL)
3480  A742 E6 7F                AND $7F
3481  A744                      ; Extent and S2 both already current -> nothing to seek, return OK.
3482  A744 CA 7F A7             JP Z,BDOS_SEEK_DONE
3483  A747              ; ----------------------------------------------------------------------
3484  A747              ; BDOS_SEEK_REPOSITION -- close the current extent and open/seek the directory to the requested
3485  A747              ; extent.
3486  A747              ;   In: B = target S2, C = target extent; DE -> FCB; BDOS_RETVAL = create/extend mode flag (0xFF =
3487  A747              ;       create on miss).
3488  A747              ;   Out: FCB extent (EX, +12) and S2 (+14) set to the target; directory positioned at the matching
3489  A747              ;        extent; a phase code is left in L (stored into BDOS_RETVAL at the seek tail); on success
3490  A747              ;        falls into BDOS_SEEK_DONE.
3491  A747              ;   Clobbers: A, BC, DE, HL, flags.
3492  A747              ;   Algorithm: close/flush the currently open extent (F_CLOSE_HND clears the host-buffer/seek
3493  A747              ;              cache).
3494  A747              ;              Set phase=3; if BDOS_RETVAL == 0xFF (create mode; INC A gives 0 / Z) take the
3495  A747              ;              extent-allocate path. Otherwise store the new EX (+12) and S2 (+14) into the FCB and
3496  A747              ;              open the matching directory entry (FCB_OPEN_SEARCH). Re-test BDOS_RETVAL (phase 4):
3497  A747              ;              on create, probe the next extent; read the directory record (DIR_MAKE_ENTRY); re-test
3498  A747              ;              (phase 5); then drop into BDOS_SEEK_DONE. [RE]
3499  A747              ; ----------------------------------------------------------------------
3500  A747              BDOS_SEEK_REPOSITION:
3501  A747 C5                   PUSH BC
3502  A748 D5                   PUSH DE
3503  A749                      ; repositioning.
3504  A749                      ; Close the currently open extent (clears the host-buffer/seek cache cells) before
3505  A749 CD A2 A4             CALL F_CLOSE_HND
3506  A74C D1                   POP DE
3507  A74D C1                   POP BC
3508  A74E                      ; Seek phase code 3 (extent-allocate path).
3509  A74E 2E 03                LD L,$03
3510  A750                      ; Load the create/extend mode flag.
3511  A750 3A 45 9F             LD A,(BDOS_RETVAL)
3512  A753                      ; Test for the 0xFF 'create/allocate on miss' value (INC -> 0 / sets Z).
3513  A753 3C                   INC A
3514  A754                      ; Create/allocate mode -> take the extent-allocate path.
3515  A754 CA 84 A7             JP Z,FCB_EXTENT_TO_TRKSEC_7
3516  A757                      ; Offset 12 = FCB extent (EX) byte.
3517  A757 21 0C 00             LD HL,$000C
3518  A75A 19                   ADD HL,DE
3519  A75B                      ; Store the new target extent into the FCB.
3520  A75B 71                   LD (HL),C
3521  A75C                      ; Offset 14 = FCB S2 byte.
3522  A75C 21 0E 00             LD HL,$000E
3523  A75F 19                   ADD HL,DE
3524  A760                      ; Store the new target S2 (module) into the FCB.
3525  A760 70                   LD (HL),B
3526  A761                      ; Search/open the directory entry for the new extent.
3527  A761 CD 51 A4             CALL FCB_OPEN_SEARCH
3528  A764 3A 45 9F             LD A,(BDOS_RETVAL)
3529  A767 3C                   INC A
3530  A768 C2 7F A7             JP NZ,BDOS_SEEK_DONE
3531  A76B C1                   POP BC
3532  A76C C5                   PUSH BC
3533  A76D                      ; Seek phase code 4.
3534  A76D 2E 04                LD L,$04
3535  A76F                      ; Bump the extent for the next-extent create probe.
3536  A76F 0C                   INC C
3537  A770                      ; Create path: allocate/init the new extent.
3538  A770 CA 84 A7             JP Z,FCB_EXTENT_TO_TRKSEC_7
3539  A773                      ; Read the directory record for the new extent into the scratch buffer.
3540  A773 CD 24 A5             CALL DIR_MAKE_ENTRY
3541  A776                      ; Seek phase code 5.
3542  A776 2E 05                LD L,$05
3543  A778 3A 45 9F             LD A,(BDOS_RETVAL)
3544  A77B 3C                   INC A
3545  A77C                      ; Create path: finalize the new extent.
3546  A77C CA 84 A7             JP Z,FCB_EXTENT_TO_TRKSEC_7
3547  A77F              ; ----------------------------------------------------------------------
3548  A77F              ; BDOS_SEEK_DONE -- successful SEEK exit: restore registers and return OK.
3549  A77F              ;   In: target extent/record now current in the FCB.
3550  A77F              ;   Out: A = 0 (seek OK) returned via BDOS_RET_RESULT; the BC saved at SEEK entry restored.
3551  A77F              ;   Clobbers: A, BC.
3552  A77F              ;   Algorithm: pop the saved BC, set A=0 and return the success status through the BDOS result tail.
3553  A77F              ;              [RE]
3554  A77F              ; ----------------------------------------------------------------------
3555  A77F              BDOS_SEEK_DONE:
3556  A77F                      ; Restore the caller's BC saved at SEEK entry.
3557  A77F C1                   POP BC
3558  A780                      ; A = 0: seek successful.
3559  A780 AF                   XOR A
3560  A781                      ; Return the seek result (0 = OK) to the caller.
3561  A781 C3 01 9F             JP BDOS_RET_RESULT
3562  A784              ; ----------------------------------------------------------------------
3563  A784              ; RANDREC_POS_FAIL -- error tail of the random-record positioning code (BDOS_SEEK_COMPUTE): mark the
3564  A784              ; extent invalid and report.
3565  A784              ;   In: L = error/return code to publish (set by the caller, e.g. 6 = 'random record out of range',
3566  A784              ;       3, 4, 5); one BC frame still pushed by BDOS_SEEK_COMPUTE; BDOS_PARAM_PTR = current FCB
3567  A784              ;       pointer.
3568  A784              ;   Out: FCB S2 byte (offset $0E) forced to $C0; BDOS_RETVAL result cell loaded with L; tail-jumps
3569  A784              ;        via RANDREC_POS_RET to MARK_FCB_S2_HIGHBIT, which then ORs $80 into S2 and returns.
3570  A784              ;   Clobbers: A, HL, BC (popped).
3571  A784              ;   Algorithm: PUSH HL; fetch &FCB.S2 via FCB_GET_S2 and store $C0 into it; POP HL; fall through
3572  A784              ;              into RANDREC_POS_RET, which POPs the BC frame, copies L into the result cell, and JPs
3573  A784              ;              MARK_FCB_S2_HIGHBIT.
3574  A784              ;   [RE] Reached from several points in BDOS_SEEK_COMPUTE when the random record cannot be
3575  A784              ;   positioned (out of range, or a read-mode request that would have to extend the file). Setting S2
3576  A784              ;   to $C0 marks the extent so the file is treated as unwritten/at-EOF; the published L code is the
3577  A784              ;   BDOS error returned to the caller.
3578  A784              ; ----------------------------------------------------------------------
3579  A784              FCB_EXTENT_TO_TRKSEC_7:
3580  A784 E5                   PUSH HL
3581  A785                      ; HL := &FCB.S2 (offset $0E of the current FCB)
3582  A785 CD 69 A1             CALL FCB_GET_S2
3583  A788                      ; S2 := $C0: high bit set (extent marked invalid/unwritten) + zero the module count [RE]
3584  A788 36 C0                LD (HL),$C0
3585  A78A E1                   POP HL
3586  A78B              ; ----------------------------------------------------------------------
3587  A78B              ; RANDREC_POS_RET -- common exit for BDOS_SEEK_COMPUTE: discard the saved BC frame, publish the L
3588  A78B              ; result code, finalize via MARK_FCB_S2_HIGHBIT.
3589  A78B              ;   In: L = result/return code; one BC frame still pushed on the stack from BDOS_SEEK_COMPUTE's
3590  A78B              ;       entry PUSH BC.
3591  A78B              ;   Out: BDOS_RETVAL result cell = L; control transfers to MARK_FCB_S2_HIGHBIT (sets FCB S2 high
3592  A78B              ;        bit, returns to the BDOS dispatcher).
3593  A78B              ;   Clobbers: A, BC (popped).
3594  A78B              ;   Algorithm: POP BC to discard the saved register pair; A := L; store A into the BDOS_RETVAL
3595  A78B              ;              result cell; JP MARK_FCB_S2_HIGHBIT.
3596  A78B              ;   [RE] Entered by fall-through from RANDREC_POS_FAIL and directly (JP NZ from $A72B) when the
3597  A78B              ;   addressed extent differs from the open one. MARK_FCB_S2_HIGHBIT ORs $80 into the FCB S2 byte
3598  A78B              ;   before returning.
3599  A78B              ; ----------------------------------------------------------------------
3600  A78B              RANDREC_POS_RET:
3601  A78B                      ; discard the BC frame pushed on entry to BDOS_SEEK_COMPUTE
3602  A78B C1                   POP BC
3603  A78C 7D                   LD A,L
3604  A78D                      ; publish the return/error code in the BDOS result cell
3605  A78D 32 45 9F             LD (BDOS_RETVAL),A
3606  A790                      ; set FCB S2 high bit, then return to caller
3607  A790 C3 78 A1             JP MARK_FCB_S2_HIGHBIT
3608  A793              ; ----------------------------------------------------------------------
3609  A793              ; F_READRAND_BODY -- BDOS function 33 (Read Random) worker: position the FCB from its random record,
3610  A793              ; then read that record.
3611  A793              ;   In: BDOS_PARAM_PTR = current FCB pointer (random-record field r0/r1/r2 set by the caller);
3612  A793              ;       reached from F_READRAND_H after FCB_AUTO_DRIVE_SELECT.
3613  A793              ;   Out: read result stored in the BDOS result cell (BDOS_RETVAL) by the called read routine; Z from
3614  A793              ;        positioning governs whether the read runs.
3615  A793              ;   Clobbers: A, BC, DE, HL.
3616  A793              ;   Algorithm: C := $FF (read mode = do NOT extend the file); CALL BDOS_SEEK_NOREAD
3617  A793              ;              (BDOS_SEEK_COMPUTE) to convert the random record into extent + current-record fields;
3618  A793              ;              if positioning succeeded (Z), CALL FILE_READ_RECORD to read the addressed record;
3619  A793              ;              RET.
3620  A793              ;   [RE][DOC CP/M 2.2 BDOS fn 33] C=$FF is consumed inside BDOS_SEEK_COMPUTE: when positioning would
3621  A793              ;   require extending the file, INC C on $FF sets Z and diverts to the error tail, so a read past
3622  A793              ;   EOF fails instead of allocating. The conditional CALL Z performs the sector read only when
3623  A793              ;   positioning succeeded (Z).
3624  A793              ; ----------------------------------------------------------------------
3625  A793              FCB_EXTENT_TO_TRKSEC_8:
3626  A793                      ; path)
3627  A793                      ; C := $FF: read mode -- positioning must NOT extend/allocate (INC C->Z triggers the fail
3628  A793 0E FF                LD C,$FF
3629  A795                      ; BDOS_SEEK_COMPUTE: convert random record (r0/r1/r2) into extent + cr; Z on success
3630  A795 CD 03 A7             CALL BDOS_SEEK_NOREAD
3631  A798                      ; if positioned OK, read the addressed record
3632  A798 CC C1 A5             CALL Z,FILE_READ_RECORD
3633  A79B C9                   RET
3634  A79C              ; ----------------------------------------------------------------------
3635  A79C              ; F_WRITERAND_BODY -- BDOS function 34 (Write Random) worker: position the FCB from its random
3636  A79C              ; record, then write that record.
3637  A79C              ;   In: BDOS_PARAM_PTR = current FCB pointer (random-record field set by the caller); reached from
3638  A79C              ;       F_WRITERAND_H after FCB_AUTO_DRIVE_SELECT.
3639  A79C              ;   Out: write result stored in the BDOS result cell (BDOS_RETVAL) by the called write routine; Z
3640  A79C              ;        from positioning governs whether the write runs.
3641  A79C              ;   Clobbers: A, BC, DE, HL.
3642  A79C              ;   Algorithm: C := $00 (write mode = allocate/extend as needed); CALL BDOS_SEEK_NOREAD
3643  A79C              ;              (BDOS_SEEK_COMPUTE) to set extent + current-record from the random record; if
3644  A79C              ;              positioning succeeded (Z), CALL BDOS_WRITE to write the record; RET.
3645  A79C              ;   [RE][DOC CP/M 2.2 BDOS fn 34] C=$00 is consumed inside BDOS_SEEK_COMPUTE: INC C on $00 yields
3646  A79C              ;   $01 (NZ), so the extend path is taken rather than the error tail, allowing a new extent/block to
3647  A79C              ;   be allocated. The conditional CALL Z writes the record only when positioning succeeded (Z).
3648  A79C              ; ----------------------------------------------------------------------
3649  A79C              FCB_EXTENT_TO_TRKSEC_9:
3650  A79C                      ; C := $00: write mode -- positioning may allocate/extend the file (INC C->$01 NZ, no fail)
3651  A79C 0E 00                LD C,$00
3652  A79E                      ; BDOS_SEEK_COMPUTE: convert random record into extent + cr; Z on success
3653  A79E CD 03 A7             CALL BDOS_SEEK_NOREAD
3654  A7A1                      ; if positioned OK, write the addressed record
3655  A7A1 CC 03 A6             CALL Z,BDOS_WRITE
3656  A7A4 C9                   RET
3657  A7A5              ; ----------------------------------------------------------------------
3658  A7A5              ; FCB_RECNUM_FROM_FIELDS -- compute the 24-bit absolute record number from an FCB's record byte plus
3659  A7A5              ; its extent (ex) and S2 fields.
3660  A7A5              ;   In: HL = base pointer to the FCB (or directory entry); DE = byte offset within it of the low
3661  A7A5              ;       record byte to read (e.g. $20 = cr for Set Random Record, $0F for the per-extent record
3662  A7A5              ;       count in Compute File Size).
3663  A7A5              ;   Out: C = low byte, B = mid byte, A = high byte of the record number; A AND $01 leaves Z/NZ on
3664  A7A5              ;        the result's low bit for callers; HL, DE clobbered.
3665  A7A5              ;   Clobbers: A, BC, HL, DE, flags.
3666  A7A5              ;   Algorithm: EX DE,HL so HL=offset, DE=FCB base; ADD HL,DE -> &FCB+offset; C := that byte, B := 0.
3667  A7A5              ;              Read the extent byte (offset $0C): RRCA then AND $80 puts its bit0 into bit7, add to
3668  A7A5              ;              C (carry into B) -- the *128 contribution; RRCA/AND $0F of the same extent byte adds
3669  A7A5              ;              the extent's high nibble into B. Read S2 (offset $0E): shift left 4 (ADD A,A x4), add
3670  A7A5              ;              into B to form the high bits; final AND $01 sets Z/NZ on the low bit of the
3671  A7A5              ;              accumulated value.
3672  A7A5              ;   [RE] Builds the linear absolute record index (record + ex*128 + S2*...) that CP/M 2.2 uses to
3673  A7A5              ;   map directory extents onto a flat record space; shared by Set Random Record (fn 36) and Compute
3674  A7A5              ;   File Size (fn 35).
3675  A7A5              ; ----------------------------------------------------------------------
3676  A7A5              FCB_ALLOC_PREP:
3677  A7A5                      ; HL := caller offset; DE := FCB base pointer
3678  A7A5 EB                   EX DE,HL
3679  A7A6                      ; HL := &FCB + offset (the low record byte)
3680  A7A6 19                   ADD HL,DE
3681  A7A7                      ; C := low record bits from that byte
3682  A7A7 4E                   LD C,(HL)
3683  A7A8 06 00                LD B,$00
3684  A7AA                      ; offset $0C = FCB extent (ex) byte
3685  A7AA 21 0C 00             LD HL,$000C
3686  A7AD 19                   ADD HL,DE
3687  A7AE 7E                   LD A,(HL)
3688  A7AF 0F                   RRCA
3689  A7B0                      ; extent bit0 -> record bit7 (the ex*128 contribution)
3690  A7B0 E6 80                AND $80
3691  A7B2 81                   ADD A,C
3692  A7B3 4F                   LD C,A
3693  A7B4 3E 00                LD A,$00
3694  A7B6 88                   ADC A,B
3695  A7B7 47                   LD B,A
3696  A7B8 7E                   LD A,(HL)
3697  A7B9 0F                   RRCA
3698  A7BA E6 0F                AND $0F
3699  A7BC 80                   ADD A,B
3700  A7BD 47                   LD B,A
3701  A7BE                      ; offset $0E = FCB S2 byte (extent-high / module)
3702  A7BE 21 0E 00             LD HL,$000E
3703  A7C1 19                   ADD HL,DE
3704  A7C2 7E                   LD A,(HL)
3705  A7C3                      ; first of four ADD A,A: shift S2 left to form the high record bits
3706  A7C3 87                   ADD A,A
3707  A7C4 87                   ADD A,A
3708  A7C5 87                   ADD A,A
3709  A7C6 87                   ADD A,A
3710  A7C7 F5                   PUSH AF
3711  A7C8 80                   ADD A,B
3712  A7C9 47                   LD B,A
3713  A7CA F5                   PUSH AF
3714  A7CB E1                   POP HL
3715  A7CC 7D                   LD A,L
3716  A7CD E1                   POP HL
3717  A7CE B5                   OR L
3718  A7CF                      ; set Z/NZ on the low bit of the result for callers
3719  A7CF E6 01                AND $01
3720  A7D1 C9                   RET
3721  A7D2              ; ----------------------------------------------------------------------
3722  A7D2              ; F_COMPSIZE_BODY -- BDOS function 35 (Compute File Size) worker: scan the directory and write the
3723  A7D2              ; max record number into r0/r1/r2.
3724  A7D2              ;   In: BDOS_PARAM_PTR = current FCB pointer; reached from F_SIZE_H after FCB_AUTO_DRIVE_SELECT.
3725  A7D2              ;   Out: FCB random-record bytes r0/r1/r2 (offsets $21-$23) set to the file's record count (one past
3726  A7D2              ;        the highest record across all matching directory extents).
3727  A7D2              ;   Clobbers: A, BC, DE, HL.
3728  A7D2              ;   Algorithm: C := $0C and CALL DIR_SEARCH_FIRST to begin a directory search masked over the first
3729  A7D2              ;              12 FCB bytes (drive+name+type; the extent byte is NOT matched). Point HL at FCB+$21
3730  A7D2              ;              and zero the three random-record bytes (D is 0 from LD DE,$0021). Then loop over
3731  A7D2              ;              every matching directory entry (falls into COMPSIZE_SCAN_LOOP): for each, compute its
3732  A7D2              ;              record number via FCB_RECNUM_FROM_FIELDS at offset $0F and keep the running maximum
3733  A7D2              ;              in r0/r1/r2; when the search exhausts, the largest record number remains stored.
3734  A7D2              ;   [RE][DOC CP/M 2.2 BDOS fn 35] Result is a record count (next free record), one past the highest
3735  A7D2              ;   used record; the loop mirrors the canonical 'scan directory, max(extent record number)'
3736  A7D2              ;   algorithm.
3737  A7D2              ; ----------------------------------------------------------------------
3738  A7D2              FCB_ALLOC_BLOCK_NUM_2:
3739  A7D2                      ; mask = first $0C (12) FCB bytes: drive+name+type (extent NOT compared) when scanning
3740  A7D2 0E 0C                LD C,$0C
3741  A7D4                      ; begin a masked directory search over those 12 bytes
3742  A7D4 CD 18 A3             CALL DIR_SEARCH_FIRST
3743  A7D7 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3744  A7DA                      ; offset $21 = FCB random-record field r0 (D=0 used to zero the bytes)
3745  A7DA 11 21 00             LD DE,$0021
3746  A7DD 19                   ADD HL,DE
3747  A7DE E5                   PUSH HL
3748  A7DF                      ; r0 := 0 (zero the 3-byte running maximum)
3749  A7DF 72                   LD (HL),D
3750  A7E0 23                   INC HL
3751  A7E1                      ; r1 := 0
3752  A7E1 72                   LD (HL),D
3753  A7E2 23                   INC HL
3754  A7E3                      ; r2 := 0
3755  A7E3 72                   LD (HL),D
3756  A7E4              ; ----------------------------------------------------------------------
3757  A7E4              ; COMPSIZE_SCAN_LOOP -- per-directory-entry step of Compute File Size: fold each extent's record
3758  A7E4              ; number into the running max.
3759  A7E4              ;   In: stack top = pointer to the FCB random-record max (r0/r1/r2); a masked directory search is in
3760  A7E4              ;       progress.
3761  A7E4              ;   Out: on directory exhaustion, exits via COMPSIZE_DONE (pop, return); otherwise updates the
3762  A7E4              ;        3-byte max in place and continues.
3763  A7E4              ;   Clobbers: A, BC, DE, HL.
3764  A7E4              ;   Algorithm: CALL CUR_RECORD_BYTES_EQUAL to test whether the search is exhausted; if so (Z) JP
3765  A7E4              ;              COMPSIZE_DONE. Else CALL FCB_BUF_PTR_ADD_OFFSET to point at this entry in the
3766  A7E4              ;              directory buffer, then FCB_ALLOC_PREP at offset $0F to get the candidate record
3767  A7E4              ;              number in C(lo)/B(mid)/A(hi). Reload &r0 (POP/PUSH HL), 24-bit subtract candidate -
3768  A7E4              ;              stored (SUB / SBC / SBC over r0,r1,r2); if candidate < stored (carry), JP
3769  A7E4              ;              COMPSIZE_NEXT keeping the stored max; otherwise overwrite r2,r1,r0 with the
3770  A7E4              ;              candidate; fall into COMPSIZE_NEXT.
3771  A7E4              ;   [RE] Implements a running max over directory extents; the 24-bit subtract decides whether this
3772  A7E4              ;   extent extends the file further than any seen so far.
3773  A7E4              ; ----------------------------------------------------------------------
3774  A7E4              COMPSIZE_SCAN_LOOP:
3775  A7E4                      ; test whether the directory search is exhausted; Z = no more entries
3776  A7E4 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3777  A7E7                      ; search exhausted -> finish (pop saved ptr and return)
3778  A7E7 CA 0C A8             JP Z,COMPSIZE_DONE
3779  A7EA                      ; HL := directory buffer + this entry's byte offset
3780  A7EA CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
3781  A7ED                      ; offset $0F = the entry's record-count byte for FCB_RECNUM_FROM_FIELDS
3782  A7ED 11 0F 00             LD DE,$000F
3783  A7F0                      ; candidate record number -> C(lo)/B(mid)/A(hi)
3784  A7F0 CD A5 A7             CALL FCB_ALLOC_PREP
3785  A7F3 E1                   POP HL
3786  A7F4 E5                   PUSH HL
3787  A7F5 5F                   LD E,A
3788  A7F6                      ; begin 24-bit compare: candidate - stored max over r0/r1/r2
3789  A7F6 79                   LD A,C
3790  A7F7 96                   SUB (HL)
3791  A7F8 23                   INC HL
3792  A7F9 78                   LD A,B
3793  A7FA 9E                   SBC A,(HL)
3794  A7FB 23                   INC HL
3795  A7FC 7B                   LD A,E
3796  A7FD 9E                   SBC A,(HL)
3797  A7FE                      ; candidate < stored max -> keep stored max, skip the store
3798  A7FE DA 06 A8             JP C,COMPSIZE_NEXT
3799  A801                      ; candidate >= max: store new high byte (r2)
3800  A801 73                   LD (HL),E
3801  A802 2B                   DEC HL
3802  A803                      ; store new mid byte (r1)
3803  A803 70                   LD (HL),B
3804  A804 2B                   DEC HL
3805  A805                      ; store new low byte (r0)
3806  A805 71                   LD (HL),C
3807  A806              ; ----------------------------------------------------------------------
3808  A806              ; COMPSIZE_NEXT -- Compute File Size loop continuation: advance the directory search and re-enter
3809  A806              ; the scan loop.
3810  A806              ;   In: directory search state live; stack top = pointer to the running r0/r1/r2 maximum.
3811  A806              ;   Out: re-enters COMPSIZE_SCAN_LOOP (COMPSIZE_SCAN_LOOP) after advancing to the next directory
3812  A806              ;        entry.
3813  A806              ;   Clobbers: A, BC, DE, HL.
3814  A806              ;   Algorithm: CALL BDOS_DIR_SCAN_NEXT to advance the masked directory search by one entry; JP
3815  A806              ;              COMPSIZE_SCAN_LOOP.
3816  A806              ;   [RE] Joined both from the 'candidate < max' early path and after a store; BDOS_DIR_SCAN_NEXT
3817  A806              ;   performs the next directory read/match.
3818  A806              ; ----------------------------------------------------------------------
3819  A806              COMPSIZE_NEXT:
3820  A806                      ; advance the masked directory search to the next matching entry
3821  A806 CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
3822  A809                      ; loop back to fold the next extent into the max
3823  A809 C3 E4 A7             JP COMPSIZE_SCAN_LOOP
3824  A80C              ; ----------------------------------------------------------------------
3825  A80C              ; COMPSIZE_DONE -- Compute File Size exit: discard the saved max pointer and return.
3826  A80C              ;   In: stack top = pointer to the FCB r0/r1/r2 max (already written in place).
3827  A80C              ;   Out: returns to the F_SIZE_H caller; FCB random-record field holds the computed file size.
3828  A80C              ;   Clobbers: HL.
3829  A80C              ;   Algorithm: POP HL to balance the PUSH HL done in FCB_ALLOC_BLOCK_NUM_2 before the scan; RET.
3830  A80C              ;   [RE] Sole loop exit, reached when the directory search is exhausted.
3831  A80C              ; ----------------------------------------------------------------------
3832  A80C              COMPSIZE_DONE:
3833  A80C                      ; balance the saved r0/r1/r2 pointer pushed before the scan loop
3834  A80C E1                   POP HL
3835  A80D C9                   RET
3836  A80E              ; ----------------------------------------------------------------------
3837  A80E              ; F_RANDREC_H -- BDOS function 36 (Set Random Record): compute the random-record field of the
3838  A80E              ; current FCB from its sequential position.
3839  A80E              ;   In: current FCB pointer in BDOS cell BDOS_PARAM_PTR (the FCB whose sequential extent/cr fields
3840  A80E              ;       are to be converted).
3841  A80E              ;   Out: bytes r0/r1/r2 (FCB offsets $21..$23) written with the 24-bit record number derived from
3842  A80E              ;        the FCB's extent and current-record fields.
3843  A80E              ;   Clobbers: A, BC, DE, HL.
3844  A80E              ;   Algorithm: call FCB_ALLOC_PREP with HL=FCB base and DE=$0020, which folds the cr (current-record
3845  A80E              ;              at FCB+$20), the extent number and the extent-high bit into a record count returned
3846  A80E              ;              in C (low) / B (high) / A (overflow), and leaves DE = the FCB base pointer; then form
3847  A80E              ;              HL = FCB+$0021 (DE + $0021) and store C,B,A into FCB[$21],[$22],[$23].
3848  A80E              ;   [RE] verified against canonical CP/M 2.2 Set Random Record (dispatch fn 36 at $9C8F);
3849  A80E              ;   FCB_ALLOC_PREP is the standard extent->record-count fold.
3850  A80E              ; ----------------------------------------------------------------------
3851  A80E              F_RANDREC_H:
3852  A80E                      ; HL = pointer to the current FCB (the file whose sequential position we are converting)
3853  A80E 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3854  A811                      ; base
3855  A811                      ; DE = $20: FCB_ALLOC_PREP reads the cr/extent region at FCB+$20 and returns DE = the FCB
3856  A811 11 20 00             LD DE,$0020
3857  A814                      ; overflow; returns DE = FCB base
3858  A814                      ; fold cr + extent# + extent-high bit into a 24-bit record number -> C low, B high, A
3859  A814 CD A5 A7             CALL FCB_ALLOC_PREP
3860  A817                      ; field r0,r1,r2
3861  A817                      ; HL = $0021; the next ADD HL,DE makes HL = FCB + $21, the start of the 3-byte random-record
3862  A817 21 21 00             LD HL,$0021
3863  A81A 19                   ADD HL,DE
3864  A81B                      ; store r0 (record number, low byte)
3865  A81B 71                   LD (HL),C
3866  A81C 23                   INC HL
3867  A81D                      ; store r1 (record number, high byte)
3868  A81D 70                   LD (HL),B
3869  A81E 23                   INC HL
3870  A81F                      ; store r2 (record number overflow / random-record overflow byte)
3871  A81F 77                   LD (HL),A
3872  A820 C9                   RET
3873  A821              ; ----------------------------------------------------------------------
3874  A821              ; DRV_INSTALL_RWTS_17 -- Select-disk / log-in worker: ensure the drive in BDOS_CUR_DRIVE is logged
3875  A821              ; in, and rebuild its allocation vector if it was not.
3876  A821              ;   In: BDOS_CUR_DRIVE = requested (current) drive number 0..15; DRV_SELECT_VECTOR = working
3877  A821              ;       login/select
3878  A821              ;       vector.
3879  A821              ;   Out: if the drive was newly logged in, its directory is scanned (BDOS_ERR_SELECT) and its
3880  A821              ;        allocation vector rebuilt (CMD_EXEC_65); DRV_SELECT_VECTOR updated with the drive's login
3881  A821              ;        bit.
3882  A821              ;   Clobbers: A, BC, DE, HL.
3883  A821              ;   Algorithm: load the working login vector DRV_SELECT_VECTOR; build a single-bit mask for the
3884  A821              ;              requested drive
3885  A821              ;              (DRV_INSTALL_RWTS_10 shifts); test (BDOS_RANDREC_3) whether the drive's DPB is
3886  A821              ;              already established; if not yet logged in (Z) call BDOS_ERR_SELECT to log it in /
3887  A821              ;              scan its directory; if the login bit was already set (RRA -> carry) just return;
3888  A821              ;              otherwise OR this drive's bit into DRV_SELECT_VECTOR (CMD_EXEC_12), store it, and
3889  A821              ;              fall into
3890  A821              ;              CMD_EXEC_65 to (re)build the allocation vector.
3891  A821              ;   [RE] the standard CP/M 2.2 select-disk login path reached from DRV_SET (fn 14) and DRV_ALLRESET
3892  A821              ;   (fn 13). [?] the A=L / RRA already-logged-in test is inferred from the surrounding flow, not
3893  A821              ;   proven from these bytes alone.
3894  A821              ; ----------------------------------------------------------------------
3895  A821              DRV_INSTALL_RWTS_17:
3896  A821                      ; HL = working login/select vector
3897  A821 2A AF A9             LD HL,(DRV_SELECT_VECTOR)
3898  A824                      ; A = requested drive number
3899  A824 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
3900  A827 4F                   LD C,A
3901  A828                      ; shift to form the single-bit drive mask for this drive
3902  A828 CD EA A0             CALL DRV_INSTALL_RWTS_10
3903  A82B E5                   PUSH HL
3904  A82C EB                   EX DE,HL
3905  A82D                      ; establish/test the drive's DPB; sets Z if the drive needs logging in
3906  A82D CD 59 9F             CALL BDOS_RANDREC_3
3907  A830 E1                   POP HL
3908  A831                      ; drive not yet logged in: run the disk log-in / directory scan
3909  A831 CC 47 9F             CALL Z,BDOS_ERR_SELECT
3910  A834 7D                   LD A,L
3911  A835                      ; bit set
3912  A835                      ; rotate bit 0 of the drive mask into carry: carry set => this drive already had its login
3913  A835 1F                   RRA
3914  A836                      ; already logged in: nothing more to do
3915  A836 D8                   RET C
3916  A837 2A AF A9             LD HL,(DRV_SELECT_VECTOR)
3917  A83A 4D                   LD C,L
3918  A83B 44                   LD B,H
3919  A83C                      ; OR this drive's bit into the working login vector
3920  A83C CD 0B A1             CALL DRIVE_BIT_OR_INTO_VECTOR
3921  A83F                      ; store the updated working login vector
3922  A83F 22 AF A9             LD (DRV_SELECT_VECTOR),HL
3923  A842                      ; tail into rebuild-allocation-vector for the freshly logged-in drive
3924  A842 C3 A3 A2             JP ALLOC_VECTOR_BUILD
3925  A845              ; ----------------------------------------------------------------------
3926  A845              ; DRV_SET_H -- BDOS function 14 (Select Disk): make the drive in DRV_SELECT_ARG the current drive.
3927  A845              ;   In: DRV_SELECT_ARG = desired drive number; BDOS_CUR_DRIVE = current drive number.
3928  A845              ;   Out: if the drive changed, BDOS_CUR_DRIVE is updated and the drive is logged in / allocation
3929  A845              ;        vector rebuilt (via DRV_INSTALL_RWTS_17); otherwise no-op.
3930  A845              ;   Clobbers: A, HL (and whatever DRV_INSTALL_RWTS_17 clobbers).
3931  A845              ;   Algorithm: compare desired drive (DRV_SELECT_ARG) with current (BDOS_CUR_DRIVE); if equal
3932  A845              ;              return; else
3933  A845              ;              store the new current drive and jump to the select/log-in worker.
3934  A845              ;   [RE] dispatch fn 14 at $9C63; matches canonical CP/M 2.2 Select Disk.
3935  A845              ; ----------------------------------------------------------------------
3936  A845              DRV_SET_H:
3937  A845                      ; A = requested drive number
3938  A845 3A D6 A9             LD A,(DRV_SELECT_ARG)
3939  A848                      ; HL -> current-drive cell
3940  A848 21 42 9F             LD HL,BDOS_CUR_DRIVE
3941  A84B                      ; already the current drive?
3942  A84B BE                   CP (HL)
3943  A84C                      ; yes: nothing to do
3944  A84C C8                   RET Z
3945  A84D                      ; set the new current drive
3946  A84D 77                   LD (HL),A
3947  A84E                      ; log it in / rebuild its allocation vector
3948  A84E C3 21 A8             JP DRV_INSTALL_RWTS_17
3949  A851              ; ----------------------------------------------------------------------
3950  A851              ; FCB_AUTO_DRIVE_SELECT -- common file-operation preamble: honor the drive prefix in the caller's
3951  A851              ; FCB, temporarily selecting that drive.
3952  A851              ;   In: BDOS_PARAM_PTR = pointer to the caller's FCB (byte 0 = drive prefix, 0=default else
3953  A851              ;       drive+1); BDOS_CUR_DRIVE = current drive; BDOS_STACK_TOP = current user number.
3954  A851              ;   Out: if the FCB names an explicit drive, that drive is selected (DRV_SELECT_ARG set, DRV_SET_H
3955  A851              ;        called)
3956  A851              ;        and the prior drive is saved in the restore cells (DRV_RESTORE_FLAG flag=$FF,
3957  A851              ;        DRV_SAVED_DRIVE=saved drive,
3958  A851              ;        DRV_SAVED_FCB_BYTE=saved FCB drive byte); the FCB's drive byte is rewritten to OR in the
3959  A851              ;        current user
3960  A851              ;        number.
3961  A851              ;   Clobbers: A, HL.
3962  A851              ;   Algorithm: set restore-pending flag DRV_RESTORE_FLAG=$FF; read FCB byte0, mask $1F and DEC to
3963  A851              ;              get drive
3964  A851              ;              index into DRV_SELECT_ARG; if >=$1E (no explicit drive / out of range) skip the
3965  A851              ;              switch; else
3966  A851              ;              save current drive (BDOS_CUR_DRIVE->DRV_SAVED_DRIVE) and original FCB byte
3967  A851              ;              (->DRV_SAVED_FCB_BYTE), strip
3968  A851              ;              the drive prefix bits ($E0 mask) from FCB byte0, and select the requested drive via
3969  A851              ;              DRV_SET_H; finally OR the current user number (BDOS_STACK_TOP) into FCB byte0.
3970  A851              ;   [RE] this is the auto-disk-select / FCB drive-prefix handler that nearly every file BDOS call
3971  A851              ;   funnels through; the matching restore is FCB_AUTO_DRIVE_RESTORE. The old auto-label
3972  A851              ;   'FCB_AUTO_DRIVE_SELECT' is a misnomer (it does not seek tracks).
3973  A851              ; ----------------------------------------------------------------------
3974  A851              FCB_AUTO_DRIVE_SELECT:
3975  A851                      ; mark 'a temporary drive switch is pending' so the epilogue restores it
3976  A851 3E FF                LD A,$FF
3977  A853                      ; store the restore-pending flag
3978  A853 32 DE A9             LD (DRV_RESTORE_FLAG),A
3979  A856                      ; HL -> caller's FCB; (HL) = drive-prefix byte
3980  A856 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3981  A859 7E                   LD A,(HL)
3982  A85A                      ; isolate the drive-prefix field of FCB byte 0
3983  A85A E6 1F                AND $1F
3984  A85C                      ; convert prefix (1..16) to drive index (0..15); $00 (default) wraps to $FF
3985  A85C 3D                   DEC A
3986  A85D                      ; record the drive this FCB asks for
3987  A85D 32 D6 A9             LD (DRV_SELECT_ARG),A
3988  A860                      ; no explicit drive (default => $FF) or out of range?
3989  A860 FE 1E                CP $1E
3990  A862                      ; yes: skip the drive switch, just merge the user number
3991  A862 D2 75 A8             JP NC,FCB_MERGE_USER
3992  A865 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
3993  A868                      ; save the current drive so the epilogue can restore it
3994  A868 32 DF A9             LD (DRV_SAVED_DRIVE),A
3995  A86B 7E                   LD A,(HL)
3996  A86C                      ; save the original FCB drive-prefix byte for restore
3997  A86C 32 E0 A9             LD (DRV_SAVED_FCB_BYTE),A
3998  A86F                      ; clear the drive-prefix bits, leaving the high flag bits of FCB byte0
3999  A86F E6 E0                AND $E0
4000  A871 77                   LD (HL),A
4001  A872                      ; temporarily select the drive named by the FCB
4002  A872 CD 45 A8             CALL DRV_SET_H
4003  A875              ; ----------------------------------------------------------------------
4004  A875              ; FCB_MERGE_USER -- tail of FCB_AUTO_DRIVE_SELECT: OR the current user number into the FCB's drive
4005  A875              ; byte.
4006  A875              ;   In: BDOS_STACK_TOP = current user number; BDOS_PARAM_PTR = pointer to the FCB.
4007  A875              ;   Out: FCB byte0 |= current user number.
4008  A875              ;   Clobbers: A, HL.
4009  A875              ;   Algorithm: load user number, OR with FCB byte0, store back.
4010  A875              ;   [RE] shared exit of the auto-disk-select preamble.
4011  A875              ; ----------------------------------------------------------------------
4012  A875              FCB_MERGE_USER:
4013  A875                      ; A = current user number
4014  A875 3A 41 9F             LD A,(BDOS_STACK_TOP)
4015  A878 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4016  A87B                      ; merge the user number into the FCB's drive/flags byte
4017  A87B B6                   OR (HL)
4018  A87C                      ; write it back
4019  A87C 77                   LD (HL),A
4020  A87D C9                   RET
4021  A87E              ; ----------------------------------------------------------------------
4022  A87E              ; S_BDOSVER_H -- BDOS function 12 (Return Version Number): report CP/M 2.2.
4023  A87E              ;   In: none.
4024  A87E              ;   Out: low byte of the BDOS result set to $22 (= version 2.2) via BDOS_RET_RESULT, which writes
4025  A87E              ;        only BDOS_RETVAL (the result low byte / register A).
4026  A87E              ;   Clobbers: A.
4027  A87E              ;   Algorithm: load $22 and store it as the low byte of the BDOS return result. (The result high
4028  A87E              ;              byte is not written here; in canonical CP/M 2.2 the version word is $00$22, but this
4029  A87E              ;              routine sets only the low byte.)
4030  A87E              ;   [RE] dispatch fn 12 at $9C5F; $22 = CP/M 2.2 per the canonical version code.
4031  A87E              ; ----------------------------------------------------------------------
4032  A87E              S_BDOSVER_H:
4033  A87E                      ; version code $22 = CP/M 2.2
4034  A87E 3E 22                LD A,$22
4035  A880                      ; return it as the BDOS result low byte
4036  A880 C3 01 9F             JP BDOS_RET_RESULT
4037  A883              ; ----------------------------------------------------------------------
4038  A883              ; DRV_ALLRESET_H -- BDOS function 13 (Reset Disk System): return CP/M to its initial disk state.
4039  A883              ;   In: none.
4040  A883              ;   Out: login vector and working login/select vector cleared; current drive forced to A: (0); DMA
4041  A883              ;        address reset to TBUFF ($0080); drive A logged in fresh.
4042  A883              ;   Clobbers: A, HL (and DRV_INSTALL_RWTS_17 / RESTORE_USER_DMA clobbers).
4043  A883              ;   Algorithm: zero DRV_LOGIN_VECTOR and DRV_SELECT_VECTOR; set current drive BDOS_CUR_DRIVE=0; set
4044  A883              ;              DMA_ADDR=$0080 (TBUFF); call RESTORE_USER_DMA (set the live BIOS DMA / reset disk
4045  A883              ;              buffering); jump to DRV_INSTALL_RWTS_17 to log in drive A.
4046  A883              ;   [RE] dispatch fn 13 at $9C61; matches canonical CP/M 2.2 Reset Disk System.
4047  A883              ; ----------------------------------------------------------------------
4048  A883              DRV_ALLRESET_H:
4049  A883 21 00 00             LD HL,$0000
4050  A886                      ; clear the master logged-in drive bitmap
4051  A886 22 AD A9             LD (DRV_LOGIN_VECTOR),HL
4052  A889                      ; clear the working login/select vector
4053  A889 22 AF A9             LD (DRV_SELECT_VECTOR),HL
4054  A88C AF                   XOR A
4055  A88D                      ; force current drive back to A: (0)
4056  A88D 32 42 9F             LD (BDOS_CUR_DRIVE),A
4057  A890                      ; TBUFF ($0080) = default DMA address
4058  A890 21 80 00             LD HL,$0080
4059  A893                      ; reset the DMA address to TBUFF
4060  A893 22 B1 A9             LD (DMA_ADDR),HL
4061  A896                      ; push the reset DMA address through to disk buffering / BIOS
4062  A896 CD DA A1             CALL RESTORE_USER_DMA
4063  A899                      ; log in drive A from a clean state
4064  A899 C3 21 A8             JP DRV_INSTALL_RWTS_17
4065  A89C              ; ----------------------------------------------------------------------
4066  A89C              ; F_OPEN_H -- BDOS function 15 (Open File): open the file named by the FCB.
4067  A89C              ;   In: BDOS_PARAM_PTR = pointer to the caller's FCB.
4068  A89C              ;   Out: directory match result returned via FCB_OPEN_SEARCH (the search/open result path); FCB
4069  A89C              ;        filled in from the matching directory entry on success, $FF if not found.
4070  A89C              ;   Clobbers: A, BC, DE, HL.
4071  A89C              ;   Algorithm: CLEAR_FCB_S2 prepares/clears the open scratch state; FCB_AUTO_DRIVE_SELECT honors the
4072  A89C              ;              FCB drive prefix; jump into the open/search-and-fill path (FCB_OPEN_SEARCH).
4073  A89C              ;   [RE] dispatch fn 15 at $9C65; canonical CP/M 2.2 Open File.
4074  A89C              ; ----------------------------------------------------------------------
4075  A89C              F_OPEN_H:
4076  A89C                      ; prepare directory/open scratch state for this FCB
4077  A89C CD 72 A1             CALL CLEAR_FCB_S2
4078  A89F                      ; auto-select the FCB's drive prefix
4079  A89F CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4080  A8A2                      ; search the directory and fill the FCB (open path)
4081  A8A2 C3 51 A4             JP FCB_OPEN_SEARCH
4082  A8A5              ; ----------------------------------------------------------------------
4083  A8A5              ; F_CLOSE_H -- BDOS function 16 (Close File): write the FCB back to its directory entry.
4084  A8A5              ;   In: BDOS_PARAM_PTR = pointer to the caller's FCB (must be open).
4085  A8A5              ;   Out: directory entry updated; result returned via F_CLOSE_HND path ($FF / dir-code).
4086  A8A5              ;   Clobbers: A, BC, DE, HL.
4087  A8A5              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the FCB drive prefix; jump into the close
4088  A8A5              ;              (rewrite-directory) path.
4089  A8A5              ;   [RE] dispatch fn 16 at $9C67; canonical CP/M 2.2 Close File.
4090  A8A5              ; ----------------------------------------------------------------------
4091  A8A5              F_CLOSE_H:
4092  A8A5                      ; auto-select the FCB's drive prefix
4093  A8A5 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4094  A8A8                      ; rewrite the directory entry and return the close result
4095  A8A8 C3 A2 A4             JP F_CLOSE_HND
4096  A8AB              ; ----------------------------------------------------------------------
4097  A8AB              ; F_SFIRST_H -- BDOS function 17 (Search for First): find the first directory entry matching the
4098  A8AB              ; FCB.
4099  A8AB              ;   In: DE = pointer to the search FCB (the BDOS dispatcher has also saved DE in BDOS_PARAM_PTR).
4100  A8AB              ;       FCB byte0 = $3F ('?') means 'match every entry' (ambiguous all-entries scan).
4101  A8AB              ;   Out: directory match copied to the DMA buffer; result (0..3 = dir position, or $FF none) via
4102  A8AB              ;        DISK_BUF_MOVE.
4103  A8AB              ;   Clobbers: A, BC, DE, HL.
4104  A8AB              ;   Algorithm: C=0 (default match length); fetch FCB byte0 (HL<-DE); if byte0==$3F do an unqualified
4105  A8AB              ;              all-entries scan (C left 0); else compute HL=FCB+$0C via DRV_INSTALL_RWTS_1 and test
4106  A8AB              ;              the extent byte FCB[$0C] -- if it is not '?' prepare scratch (CLEAR_FCB_S2) -- then
4107  A8AB              ;              auto-select drive and set C=$0F (15-byte name+type+extent match); fall into
4108  A8AB              ;              DIR_SEARCH_AND_COPY to run the directory search and copy the hit to the DMA buffer.
4109  A8AB              ;   [RE] dispatch fn 17 at $9C69; canonical CP/M 2.2 Search First; $3F is the '?' all-match marker.
4110  A8AB              ;   DRV_INSTALL_RWTS_1 only computes the FCB+$0C pointer (it does not save the search FCB).
4111  A8AB              ; ----------------------------------------------------------------------
4112  A8AB              F_SFIRST_H:
4113  A8AB                      ; search match length 0 (default name+type compare)
4114  A8AB 0E 00                LD C,$00
4115  A8AD EB                   EX DE,HL
4116  A8AE                      ; fetch FCB byte0 (drive/wildcard marker)
4117  A8AE 7E                   LD A,(HL)
4118  A8AF                      ; $3F ('?') in byte0 => match every directory entry
4119  A8AF FE 3F                CP $3F
4120  A8B1                      ; all-entries scan: go straight to the directory search
4121  A8B1 CA C2 A8             JP Z,DIR_SEARCH_AND_COPY
4122  A8B4                      ; HL = FCB + $0C (pointer to the extent byte); does NOT save the search FCB
4123  A8B4 CD A6 A0             CALL DRV_INSTALL_RWTS_1
4124  A8B7 7E                   LD A,(HL)
4125  A8B8                      ; is the extent byte FCB[$0C] the '?' wildcard (match all extents)?
4126  A8B8 FE 3F                CP $3F
4127  A8BA                      ; extent not wildcard: prepare directory scratch state
4128  A8BA C4 72 A1             CALL NZ,CLEAR_FCB_S2
4129  A8BD                      ; auto-select the FCB's drive prefix
4130  A8BD CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4131  A8C0                      ; match 15 bytes (name+type+extent) for a qualified search
4132  A8C0 0E 0F                LD C,$0F
4133  A8C2              ; ----------------------------------------------------------------------
4134  A8C2              ; DIR_SEARCH_AND_COPY -- run the directory scan and copy the matched entry to the DMA buffer.
4135  A8C2              ;   In: C = number of bytes to compare in the directory match; search FCB already established by
4136  A8C2              ;       F_SFIRST_H.
4137  A8C2              ;   Out: matching directory record moved to the DMA buffer; A = directory position (0..3) or $FF if
4138  A8C2              ;        none.
4139  A8C2              ;   Clobbers: A, BC, DE, HL.
4140  A8C2              ;   Algorithm: DIR_SEARCH_FIRST performs the directory search with the C-byte mask; tail into
4141  A8C2              ;              DISK_BUF_MOVE to copy the located directory entry into the user's DMA buffer and
4142  A8C2              ;              return the result code.
4143  A8C2              ;   [RE] shared search tail for fn 17 (Search First) and fn 18 (Search Next).
4144  A8C2              ; ----------------------------------------------------------------------
4145  A8C2              DIR_SEARCH_AND_COPY:
4146  A8C2                      ; scan the directory comparing C bytes against the search FCB
4147  A8C2 CD 18 A3             CALL DIR_SEARCH_FIRST
4148  A8C5                      ; copy the matched directory entry to the DMA buffer, return its position
4149  A8C5 C3 E9 A1             JP DISK_BUF_MOVE
4150  A8C8              ; ----------------------------------------------------------------------
4151  A8C8              ; F_SNEXT_H -- BDOS function 18 (Search for Next): continue a directory search begun by Search
4152  A8C8              ; First.
4153  A8C8              ;   In: search state saved in DIR_FCB_PTR (the search FCB pointer stored by the directory-search
4154  A8C8              ;       core
4155  A8C8              ;       DIR_SEARCH_FIRST at $A324).
4156  A8C8              ;   Out: next matching directory record copied to the DMA buffer; A = position (0..3) or $FF if no
4157  A8C8              ;        more.
4158  A8C8              ;   Clobbers: A, BC, DE, HL.
4159  A8C8              ;   Algorithm: restore the saved search FCB pointer (DIR_FCB_PTR -> BDOS_PARAM_PTR); auto-select its
4160  A8C8              ;              drive; BDOS_DIR_SCAN_NEXT advances the directory scan from the saved position; tail
4161  A8C8              ;              into DISK_BUF_MOVE to deliver the hit.
4162  A8C8              ;   [RE] dispatch fn 18 at $9C6B; canonical CP/M 2.2 Search Next; DIR_FCB_PTR holds the in-progress
4163  A8C8              ;   search FCB.
4164  A8C8              ; ----------------------------------------------------------------------
4165  A8C8              F_SNEXT_H:
4166  A8C8                      ; restore the saved Search-First FCB pointer
4167  A8C8 2A D9 A9             LD HL,(DIR_FCB_PTR)
4168  A8CB                      ; make it the active FCB for this scan step
4169  A8CB 22 43 9F             LD (BDOS_PARAM_PTR),HL
4170  A8CE                      ; auto-select the FCB's drive prefix
4171  A8CE CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4172  A8D1                      ; advance the directory search from the last matched entry
4173  A8D1 CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
4174  A8D4                      ; copy the next matched entry to the DMA buffer, return its position
4175  A8D4 C3 E9 A1             JP DISK_BUF_MOVE
4176  A8D7              ; ----------------------------------------------------------------------
4177  A8D7              ; F_DELETE_H -- BDOS function 19 (Delete File): erase all directory entries matching the FCB.
4178  A8D7              ;   In: BDOS_PARAM_PTR = pointer to the (possibly ambiguous) FCB.
4179  A8D7              ;   Out: matching directory entries marked deleted ($E5) and their allocation freed; result via
4180  A8D7              ;        DIR_RETURN_MATCH_FLAG ($FF if none / dir code).
4181  A8D7              ;   Clobbers: A, BC, DE, HL.
4182  A8D7              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; F_DELETE_HND scans and erases each
4183  A8D7              ;              matching directory entry (releasing its blocks); tail into the
4184  A8D7              ;              directory-update/result path DIR_RETURN_MATCH_FLAG.
4185  A8D7              ;   [RE] dispatch fn 19 at $9C6D; canonical CP/M 2.2 Delete File.
4186  A8D7              ; ----------------------------------------------------------------------
4187  A8D7              F_DELETE_H:
4188  A8D7                      ; auto-select the FCB's drive prefix
4189  A8D7 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4190  A8DA                      ; erase every matching directory entry and free its blocks
4191  A8DA CD 9C A3             CALL F_DELETE_HND
4192  A8DD                      ; flush the directory and return the result code
4193  A8DD C3 01 A3             JP DIR_RETURN_MATCH_FLAG
4194  A8E0              ; ----------------------------------------------------------------------
4195  A8E0              ; F_READ_H -- BDOS function 20 (Read Sequential): read the next 128-byte record of the open file.
4196  A8E0              ;   In: BDOS_PARAM_PTR = pointer to an open FCB positioned at the next sequential record.
4197  A8E0              ;   Out: one record read into the DMA buffer; A = 0 on success or a nonzero read-error/EOF code; the
4198  A8E0              ;        FCB's sequential position advanced.
4199  A8E0              ;   Clobbers: A, BC, DE, HL.
4200  A8E0              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the sequential read core
4201  A8E0              ;              (FILE_READ_SEQ).
4202  A8E0              ;   [RE] dispatch fn 20 at $9C6F; canonical CP/M 2.2 Read Sequential.
4203  A8E0              ; ----------------------------------------------------------------------
4204  A8E0              F_READ_H:
4205  A8E0                      ; auto-select the FCB's drive prefix
4206  A8E0 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4207  A8E3                      ; read the next sequential record into the DMA buffer
4208  A8E3 C3 BC A5             JP FILE_READ_SEQ
4209  A8E6              ; ----------------------------------------------------------------------
4210  A8E6              ; F_WRITE_H -- BDOS function 21 (Write Sequential): write the next 128-byte record to the open file.
4211  A8E6              ;   In: BDOS_PARAM_PTR = pointer to an open FCB; DMA buffer holds the record to write.
4212  A8E6              ;   Out: one record written; A = 0 on success or a nonzero error code (disk full / R/O); FCB
4213  A8E6              ;        position advanced, allocation extended as needed.
4214  A8E6              ;   Clobbers: A, BC, DE, HL.
4215  A8E6              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the write core
4216  A8E6              ;              (FILE_WRITE_SEQ sets the write-mode flag for a normal sequential write).
4217  A8E6              ;   [RE] dispatch fn 21 at $9C71; canonical CP/M 2.2 Write Sequential; the write core distinguishes
4218  A8E6              ;   normal vs zero-fill write modes.
4219  A8E6              ; ----------------------------------------------------------------------
4220  A8E6              F_WRITE_H:
4221  A8E6                      ; auto-select the FCB's drive prefix
4222  A8E6 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4223  A8E9                      ; set the (normal) write mode and write the next sequential record
4224  A8E9 C3 FE A5             JP FILE_WRITE_SEQ
4225  A8EC              ; ----------------------------------------------------------------------
4226  A8EC              ; F_MAKE_H -- BDOS function 22 (Make File): create a new directory entry for the FCB.
4227  A8EC              ;   In: BDOS_PARAM_PTR = pointer to the FCB naming the file to create.
4228  A8EC              ;   Out: a fresh, empty directory entry allocated and the FCB opened against it; A = dir position or
4229  A8EC              ;        $FF if the directory is full.
4230  A8EC              ;   Clobbers: A, BC, DE, HL.
4231  A8EC              ;   Algorithm: CLEAR_FCB_S2 prepares the create scratch state; FCB_AUTO_DRIVE_SELECT honors the
4232  A8EC              ;              drive prefix; jump into the make-directory-entry core (DIR_MAKE_ENTRY).
4233  A8EC              ;   [RE] dispatch fn 22 at $9C73; canonical CP/M 2.2 Make File.
4234  A8EC              ; ----------------------------------------------------------------------
4235  A8EC              F_MAKE_H:
4236  A8EC                      ; prepare directory create scratch state
4237  A8EC CD 72 A1             CALL CLEAR_FCB_S2
4238  A8EF                      ; auto-select the FCB's drive prefix
4239  A8EF CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4240  A8F2                      ; allocate and initialize a new directory entry for the file
4241  A8F2 C3 24 A5             JP DIR_MAKE_ENTRY
4242  A8F5              ; ----------------------------------------------------------------------
4243  A8F5              ; F_RENAME_H -- BDOS function 23 (Rename File): change a file's name in its directory entries.
4244  A8F5              ;   In: BDOS_PARAM_PTR = pointer to an FCB whose first 12 bytes hold the old name and bytes $10..
4245  A8F5              ;       hold the new name.
4246  A8F5              ;   Out: every matching directory entry's name field rewritten to the new name; result via
4247  A8F5              ;        DIR_RETURN_MATCH_FLAG.
4248  A8F5              ;   Clobbers: A, BC, DE, HL.
4249  A8F5              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; F_RENAME_HND walks the directory
4250  A8F5              ;              rewriting
4251  A8F5              ;              matched entries to the new name; tail into the directory-update/result path
4252  A8F5              ;              DIR_RETURN_MATCH_FLAG.
4253  A8F5              ;   [RE] dispatch fn 23 at $9C75; canonical CP/M 2.2 Rename File.
4254  A8F5              ; ----------------------------------------------------------------------
4255  A8F5              F_RENAME_H:
4256  A8F5                      ; auto-select the FCB's drive prefix
4257  A8F5 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4258  A8F8                      ; rewrite every matching directory entry to the new name
4259  A8F8 CD 16 A4             CALL F_RENAME_HND
4260  A8FB                      ; flush the directory and return the result code
4261  A8FB C3 01 A3             JP DIR_RETURN_MATCH_FLAG
4262  A8FE              ; ----------------------------------------------------------------------
4263  A8FE              ; DRV_LOGINVEC_H -- BDOS function 24 (Return Login Vector): report which drives are logged in.
4264  A8FE              ;   In: DRV_SELECT_VECTOR = working login/select vector (bit d = drive d logged in).
4265  A8FE              ;   Out: BDOS result HL = the login vector (returned via the common result-store
4266  A8FE              ;        BDOS_RET_RESULT_HL).
4267  A8FE              ;   Clobbers: HL.
4268  A8FE              ;   Algorithm: load the working login vector and store it as the 16-bit BDOS result.
4269  A8FE              ;   [RE] dispatch fn 24 at $9C77; canonical CP/M 2.2 Return Login Vector.
4270  A8FE              ; ----------------------------------------------------------------------
4271  A8FE              DRV_LOGINVEC_H:
4272  A8FE                      ; HL = login vector (one bit per logged-in drive)
4273  A8FE 2A AF A9             LD HL,(DRV_SELECT_VECTOR)
4274  A901                      ; store HL as the 16-bit BDOS result
4275  A901 C3 29 A9             JP BDOS_RET_RESULT_HL
4276  A904              ; ----------------------------------------------------------------------
4277  A904              ; DRV_GET_H -- BDOS function 25 (Return Current Disk): report the current default drive.
4278  A904              ;   In: BDOS_CUR_DRIVE = current drive number.
4279  A904              ;   Out: BDOS result A = current drive (0=A:).
4280  A904              ;   Clobbers: A.
4281  A904              ;   Algorithm: load the current-drive cell and return it as the BDOS result.
4282  A904              ;   [RE] dispatch fn 25 at $9C79; canonical CP/M 2.2 Return Current Disk.
4283  A904              ; ----------------------------------------------------------------------
4284  A904              DRV_GET_H:
4285  A904                      ; A = current drive number
4286  A904 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
4287  A907                      ; return it as the BDOS result
4288  A907 C3 01 9F             JP BDOS_RET_RESULT
4289  A90A              ; ----------------------------------------------------------------------
4290  A90A              ; F_DMAOFF_H -- BDOS function 26 (Set DMA Address): set the disk read/write buffer address.
4291  A90A              ;   In: DE = new DMA (disk transfer) address supplied by the caller.
4292  A90A              ;   Out: DMA_ADDR set to DE and pushed through to the BIOS disk-buffering layer.
4293  A90A              ;   Clobbers: A, HL (and RESTORE_USER_DMA clobbers).
4294  A90A              ;   Algorithm: move DE into HL, store at DMA_ADDR, jump to RESTORE_USER_DMA to apply it to the live
4295  A90A              ;              disk buffering / BIOS SETDMA.
4296  A90A              ;   [RE] dispatch fn 26 at $9C7B; canonical CP/M 2.2 Set DMA Address.
4297  A90A              ; ----------------------------------------------------------------------
4298  A90A              F_DMAOFF_H:
4299  A90A                      ; HL = caller's requested DMA address
4300  A90A EB                   EX DE,HL
4301  A90B                      ; record the new DMA address
4302  A90B 22 B1 A9             LD (DMA_ADDR),HL
4303  A90E                      ; apply the DMA address to disk buffering / BIOS
4304  A90E C3 DA A1             JP RESTORE_USER_DMA
4305  A911              ; ----------------------------------------------------------------------
4306  A911              ; DRV_ALLOCVEC_H -- BDOS function 27 (Return Allocation Vector address).
4307  A911              ;   In: ALLOC_VEC_PTR = base address of the current drive's allocation (block-in-use) bit vector.
4308  A911              ;   Out: BDOS result HL = the allocation vector address.
4309  A911              ;   Clobbers: HL.
4310  A911              ;   Algorithm: load the allocation-vector pointer and store it as the 16-bit BDOS result.
4311  A911              ;   [RE] dispatch fn 27 at $9C7D; canonical CP/M 2.2 Get Allocation Vector.
4312  A911              ; ----------------------------------------------------------------------
4313  A911              DRV_ALLOCVEC_H:
4314  A911                      ; HL = address of the current drive's allocation bit vector
4315  A911 2A BF A9             LD HL,(ALLOC_VEC_PTR)
4316  A914                      ; store HL as the 16-bit BDOS result
4317  A914 C3 29 A9             JP BDOS_RET_RESULT_HL
4318  A917              ; ----------------------------------------------------------------------
4319  A917              ; DRV_ROVEC_H -- BDOS function 29 (Return Read-Only Vector): report which drives are read-only.
4320  A917              ;   In: DRV_LOGIN_VECTOR -- here read as the read-only bit vector master copy.
4321  A917              ;   Out: BDOS result HL = the read-only drive vector (bit d set = drive d is R/O).
4322  A917              ;   Clobbers: HL.
4323  A917              ;   Algorithm: load the R/O vector and store it as the 16-bit BDOS result.
4324  A917              ;   [RE] dispatch fn 29 at $9C81; canonical CP/M 2.2 Get Read-Only Vector. [?] Source operand is the
4325  A917              ;   DRV_LOGIN_VECTOR cell; per CP/M 2.2 the R/O vector is a distinct mask -- the symbol name may be
4326  A917              ;   a misnomer for the R/O vector cell, or this build keeps the R/O bits in the same word.
4327  A917              ; ----------------------------------------------------------------------
4328  A917              DRV_ROVEC_H:
4329  A917                      ; HL = read-only drive vector (one bit per R/O drive)
4330  A917 2A AD A9             LD HL,(DRV_LOGIN_VECTOR)
4331  A91A                      ; store HL as the 16-bit BDOS result
4332  A91A C3 29 A9             JP BDOS_RET_RESULT_HL
4333  A91D              ; ----------------------------------------------------------------------
4334  A91D              ; F_ATTRIB_H -- BDOS function 30 (Set File Attributes): write the FCB's attribute bits into its
4335  A91D              ; directory entries.
4336  A91D              ;   In: BDOS_PARAM_PTR = pointer to the FCB carrying the desired attribute (high) bits in its
4337  A91D              ;       name/type bytes.
4338  A91D              ;   Out: matching directory entries updated with the new attributes; result via
4339  A91D              ;        DIR_RETURN_MATCH_FLAG.
4340  A91D              ;   Clobbers: A, BC, DE, HL.
4341  A91D              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; F_ATTRIB_HND walks the directory
4342  A91D              ;              copying
4343  A91D              ;              the FCB's attribute bits into each matched entry; tail into the
4344  A91D              ;              directory-update/result path.
4345  A91D              ;   [RE] dispatch fn 30 at $9C83; canonical CP/M 2.2 Set File Attributes.
4346  A91D              ; ----------------------------------------------------------------------
4347  A91D              F_ATTRIB_H:
4348  A91D                      ; auto-select the FCB's drive prefix
4349  A91D CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4350  A920                      ; copy the FCB's attribute bits into every matching directory entry
4351  A920 CD 3B A4             CALL F_ATTRIB_HND
4352  A923                      ; flush the directory and return the result code
4353  A923 C3 01 A3             JP DIR_RETURN_MATCH_FLAG
4354  A926              ; ----------------------------------------------------------------------
4355  A926              ; DRV_DPB_H -- BDOS function 31 (Return Disk Parameter Block address).
4356  A926              ;   In: DPB_PTR = address of the current drive's DPB (set during disk select/log-in).
4357  A926              ;   Out: BDOS result HL = the DPB address.
4358  A926              ;   Clobbers: HL.
4359  A926              ;   Algorithm: load the DPB pointer and store it as the 16-bit BDOS result.
4360  A926              ;   [RE] dispatch fn 31 at $9C85; canonical CP/M 2.2 Get DPB; falls into the shared result-store
4361  A926              ;   BDOS_RET_RESULT_HL.
4362  A926              ; ----------------------------------------------------------------------
4363  A926              DRV_DPB_H:
4364  A926                      ; HL = address of the current drive's Disk Parameter Block
4365  A926 2A BB A9             LD HL,(DPB_PTR)
4366  A929              ; ----------------------------------------------------------------------
4367  A929              ; BDOS_RET_RESULT_HL -- common exit: store the 16-bit value in HL as the BDOS return result.
4368  A929              ;   In: HL = value to return to the caller.
4369  A929              ;   Out: BDOS result cell BDOS_RETVAL = HL.
4370  A929              ;   Clobbers: none (writes memory).
4371  A929              ;   Algorithm: store HL at the BDOS result cell and return.
4372  A929              ;   [RE] the HL-valued counterpart of BDOS_RET_RESULT (which returns A); used by the get-vector /
4373  A929              ;   get-pointer functions (login vector, alloc vector, R/O vector, DPB) and fallen into from
4374  A929              ;   DRV_DPB_H.
4375  A929              ; ----------------------------------------------------------------------
4376  A929              BDOS_RET_RESULT_HL:
4377  A929                      ; store HL as the 16-bit BDOS result
4378  A929 22 45 9F             LD (BDOS_RETVAL),HL
4379  A92C C9                   RET
4380  A92D              ; ----------------------------------------------------------------------
4381  A92D              ; F_USERNUM_H -- BDOS function 32 (Get/Set User Code).
4382  A92D              ;   In: DRV_SELECT_ARG = caller's argument byte ($FF = 'get', else the user number to set);
4383  A92D              ;       BDOS_STACK_TOP =
4384  A92D              ;       current user number.
4385  A92D              ;   Out: if get: BDOS result A = current user number; if set: current user number BDOS_STACK_TOP
4386  A92D              ;        updated to (arg AND $1F).
4387  A92D              ;   Clobbers: A.
4388  A92D              ;   Algorithm: if the argument is $FF, return the current user number; otherwise mask the argument
4389  A92D              ;              to 0..31 and store it as the current user number.
4390  A92D              ;   [RE] dispatch fn 32 at $9C87; canonical CP/M 2.2 Get/Set User; $FF = query.
4391  A92D              ; ----------------------------------------------------------------------
4392  A92D              F_USERNUM_H:
4393  A92D                      ; A = caller's argument ($FF = query current user)
4394  A92D 3A D6 A9             LD A,(DRV_SELECT_ARG)
4395  A930                      ; is this a 'get current user' request?
4396  A930 FE FF                CP $FF
4397  A932                      ; no: it is a 'set user number' request
4398  A932 C2 3B A9             JP NZ,SET_USER_NUMBER
4399  A935                      ; get path: load the current user number
4400  A935 3A 41 9F             LD A,(BDOS_STACK_TOP)
4401  A938                      ; return it as the BDOS result
4402  A938 C3 01 9F             JP BDOS_RET_RESULT
4403  A93B              ; ----------------------------------------------------------------------
4404  A93B              ; SET_USER_NUMBER -- set path of BDOS function 32: change the current user number.
4405  A93B              ;   In: A = requested user number.
4406  A93B              ;   Out: current user number BDOS_STACK_TOP = A AND $1F (0..31).
4407  A93B              ;   Clobbers: A.
4408  A93B              ;   Algorithm: mask the requested user number to 5 bits and store it.
4409  A93B              ;   [RE] continuation of F_USERNUM_H (Get/Set User).
4410  A93B              ; ----------------------------------------------------------------------
4411  A93B              SET_USER_NUMBER:
4412  A93B                      ; clamp the user number to the range 0..31
4413  A93B E6 1F                AND $1F
4414  A93D                      ; store the new current user number
4415  A93D 32 41 9F             LD (BDOS_STACK_TOP),A
4416  A940 C9                   RET
4417  A941              ; ----------------------------------------------------------------------
4418  A941              ; F_READRAND_H -- BDOS function 33 (Read Random): read the record addressed by the FCB's
4419  A941              ; random-record field.
4420  A941              ;   In: BDOS_PARAM_PTR = pointer to an open FCB whose r0/r1/r2 ($21..$23) hold the target record
4421  A941              ;       number.
4422  A941              ;   Out: that record read into the DMA buffer; A = 0 on success or a random-read error code (e.g.
4423  A941              ;        1=reading unwritten data, 6=record number out of range); FCB positioned at that record.
4424  A941              ;   Clobbers: A, BC, DE, HL.
4425  A941              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the random-read core
4426  A941              ;              (FCB_EXTENT_TO_TRKSEC_8) which seeks to the random record and reads it.
4427  A941              ;   [RE] dispatch fn 33 at $9C89; canonical CP/M 2.2 Read Random.
4428  A941              ; ----------------------------------------------------------------------
4429  A941              F_READRAND_H:
4430  A941                      ; auto-select the FCB's drive prefix
4431  A941 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4432  A944                      ; position to the FCB's random record and read it
4433  A944 C3 93 A7             JP FCB_EXTENT_TO_TRKSEC_8
4434  A947              ; ----------------------------------------------------------------------
4435  A947              ; F_WRITERAND_H -- BDOS function 34 (Write Random): write the record addressed by the FCB's
4436  A947              ; random-record field.
4437  A947              ;   In: BDOS_PARAM_PTR = pointer to an open FCB whose r0/r1/r2 hold the target record number; DMA
4438  A947              ;       buffer holds the record.
4439  A947              ;   Out: that record written; A = 0 on success or a random-write error code; file extended/allocated
4440  A947              ;        as needed.
4441  A947              ;   Clobbers: A, BC, DE, HL.
4442  A947              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the random-write core
4443  A947              ;              (FCB_EXTENT_TO_TRKSEC_9).
4444  A947              ;   [RE] dispatch fn 34 at $9C8B; canonical CP/M 2.2 Write Random.
4445  A947              ; ----------------------------------------------------------------------
4446  A947              F_WRITERAND_H:
4447  A947                      ; auto-select the FCB's drive prefix
4448  A947 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4449  A94A                      ; position to the FCB's random record and write it
4450  A94A C3 9C A7             JP FCB_EXTENT_TO_TRKSEC_9
4451  A94D              ; ----------------------------------------------------------------------
4452  A94D              ; F_SIZE_H -- BDOS function 35 (Compute File Size): set the FCB's random-record field to the file's
4453  A94D              ; record count.
4454  A94D              ;   In: BDOS_PARAM_PTR = pointer to the FCB naming the file.
4455  A94D              ;   Out: FCB r0/r1/r2 ($21..$23) set to the number of 128-byte records in the file (its 'virtual
4456  A94D              ;        size').
4457  A94D              ;   Clobbers: A, BC, DE, HL.
4458  A94D              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the size-compute core
4459  A94D              ;              (FCB_ALLOC_BLOCK_NUM_2) which scans the directory extents to find the highest record
4460  A94D              ;              and writes it into the FCB random-record field.
4461  A94D              ;   [RE] dispatch fn 35 at $9C8D; canonical CP/M 2.2 Compute File Size.
4462  A94D              ; ----------------------------------------------------------------------
4463  A94D              F_SIZE_H:
4464  A94D                      ; auto-select the FCB's drive prefix
4465  A94D CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4466  A950                      ; scan the file's extents and write its record count into the FCB
4467  A950 C3 D2 A7             JP FCB_ALLOC_BLOCK_NUM_2
4468  A953              ; ----------------------------------------------------------------------
4469  A953              ; DRV_RESET_H -- BDOS function 37 (Reset Drive): mark the drives named by the caller's bit mask as
4470  A953              ; no longer logged in.
4471  A953              ;   In: BDOS_PARAM_PTR = caller's reset bit-mask (one bit per drive to reset); DRV_SELECT_VECTOR =
4472  A953              ;       working
4473  A953              ;       login vector; DRV_LOGIN_VECTOR = master logged-in / R-O master vector.
4474  A953              ;   Out: for each drive bit set in the mask, that drive's bit is cleared in both DRV_SELECT_VECTOR
4475  A953              ;        and
4476  A953              ;        DRV_LOGIN_VECTOR, forcing a fresh log-in on next access.
4477  A953              ;   Clobbers: A, DE, HL.
4478  A953              ;   Algorithm: form the bitwise complement of the caller's reset mask (CPL of each byte of
4479  A953              ;              BDOS_PARAM_PTR); AND it into DRV_SELECT_VECTOR to clear those login bits and store
4480  A953              ;              back; then
4481  A953              ;              AND the now-masked login word with DRV_LOGIN_VECTOR (which also has the reset bits
4482  A953              ;              cleared) and store back, so the master vector loses the reset drives' bits too.
4483  A953              ;   [RE] dispatch fn 37 at $9C91; canonical CP/M 2.2 Reset Drive (selective reset). The auto-label
4484  A953              ;   'DIR_NAME_MASK' is unrelated to its real function.
4485  A953              ; ----------------------------------------------------------------------
4486  A953              DRV_RESET_H:
4487  A953                      ; HL = caller's reset bit-mask (one bit per drive to reset)
4488  A953 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4489  A956 7D                   LD A,L
4490  A957                      ; complement the mask low byte (a 1 marks a drive to KEEP; 0 marks a drive being reset)
4491  A957 2F                   CPL
4492  A958 5F                   LD E,A
4493  A959 7C                   LD A,H
4494  A95A 2F                   CPL
4495  A95B                      ; HL = working login vector
4496  A95B 2A AF A9             LD HL,(DRV_SELECT_VECTOR)
4497  A95E                      ; clear the reset drives' bits in the login vector (high byte path)
4498  A95E A4                   AND H
4499  A95F 57                   LD D,A
4500  A960 7D                   LD A,L
4501  A961 A3                   AND E
4502  A962 5F                   LD E,A
4503  A963                      ; HL = master logged-in / R-O vector
4504  A963 2A AD A9             LD HL,(DRV_LOGIN_VECTOR)
4505  A966 EB                   EX DE,HL
4506  A967                      ; store the updated login vector
4507  A967 22 AF A9             LD (DRV_SELECT_VECTOR),HL
4508  A96A 7D                   LD A,L
4509  A96B A3                   AND E
4510  A96C 6F                   LD L,A
4511  A96D 7C                   LD A,H
4512  A96E A2                   AND D
4513  A96F 67                   LD H,A
4514  A970                      ; store the master vector with the reset drives cleared
4515  A970 22 AD A9             LD (DRV_LOGIN_VECTOR),HL
4516  A973 C9                   RET
4517  A974              ; ----------------------------------------------------------------------
4518  A974              ; FCB_AUTO_DRIVE_RESTORE -- file-operation epilogue: undo a temporary drive switch made by
4519  A974              ; FCB_AUTO_DRIVE_SELECT, then return the BDOS result.
4520  A974              ;   In: DRV_RESTORE_FLAG = restore-pending flag (0 = no switch was made); BDOS_PARAM_PTR = FCB
4521  A974              ;       pointer; DRV_SAVED_FCB_BYTE
4522  A974              ;       = saved FCB drive byte; DRV_SAVED_DRIVE = saved drive number; BDOS_SAVED_SP = saved BDOS
4523  A974              ;       stack
4524  A974              ;       pointer; BDOS_RETVAL = BDOS result.
4525  A974              ;   Out: if a switch was pending, the FCB's drive byte and the current drive are restored to their
4526  A974              ;        pre-call values (DRV_SET_H reselects the original drive); then control falls into
4527  A974              ;        BDOS_RETURN_RESULT to restore the BDOS stack and deliver A = result low byte (B = high
4528  A974              ;        byte).
4529  A974              ;   Clobbers: A, B, HL, SP.
4530  A974              ;   Algorithm: if no temporary switch was made (DRV_RESTORE_FLAG==0) skip to the result return; else
4531  A974              ;              clear the
4532  A974              ;              FCB drive byte ($00), and if the saved original byte (DRV_SAVED_FCB_BYTE) is nonzero
4533  A974              ;              restore it;
4534  A974              ;              restore the saved current drive (DRV_SAVED_DRIVE -> DRV_SELECT_ARG) and reselect it
4535  A974              ;              via DRV_SET_H;
4536  A974              ;              fall into BDOS_RETURN_RESULT.
4537  A974              ;   [RE] this is the universal file-op epilogue that pairs with FCB_AUTO_DRIVE_SELECT; the
4538  A974              ;   'DIR_NAME_MASK' auto-label is unrelated.
4539  A974              ; ----------------------------------------------------------------------
4540  A974              FCB_AUTO_DRIVE_RESTORE:
4541  A974                      ; was a temporary drive switch made by the preamble?
4542  A974 3A DE A9             LD A,(DRV_RESTORE_FLAG)
4543  A977 B7                   OR A
4544  A978                      ; no switch: skip restore, go straight to the result return
4545  A978 CA 91 A9             JP Z,BDOS_RETURN_RESULT
4546  A97B                      ; HL -> FCB whose drive byte was modified
4547  A97B 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4548  A97E                      ; clear the FCB drive byte before restoring it
4549  A97E 36 00                LD (HL),$00
4550  A980                      ; A = saved original FCB drive-prefix byte
4551  A980 3A E0 A9             LD A,(DRV_SAVED_FCB_BYTE)
4552  A983 B7                   OR A
4553  A984                      ; saved byte was 0 (no real prefix): nothing to put back, go to result return
4554  A984 CA 91 A9             JP Z,BDOS_RETURN_RESULT
4555  A987                      ; restore the original FCB drive-prefix byte
4556  A987 77                   LD (HL),A
4557  A988                      ; A = saved current drive number
4558  A988 3A DF A9             LD A,(DRV_SAVED_DRIVE)
4559  A98B                      ; set it as the drive to reselect
4560  A98B 32 D6 A9             LD (DRV_SELECT_ARG),A
4561  A98E                      ; reselect the drive that was current before the call
4562  A98E CD 45 A8             CALL DRV_SET_H
4563  A991              ; ----------------------------------------------------------------------
4564  A991              ; BDOS_RETURN_RESULT -- final BDOS exit: restore the entry stack and deliver the result to the
4565  A991              ; caller.
4566  A991              ;   In: BDOS_SAVED_SP = saved BDOS entry stack pointer; BDOS_RETVAL = 16-bit BDOS result.
4567  A991              ;   Out: SP restored to the BDOS entry stack; A = result low byte, B = result high byte (HL also =
4568  A991              ;        result).
4569  A991              ;   Clobbers: A, B, HL, SP.
4570  A991              ;   Algorithm: load the saved stack pointer into SP; load the 16-bit result into HL; copy L->A and
4571  A991              ;              H->B so both the 8-bit (A) and 16-bit (HL/BA) return conventions are satisfied;
4572  A991              ;              return to the BDOS dispatcher.
4573  A991              ;   [RE] the common tail every BDOS function returns through; pairs the saved-SP restore with the
4574  A991              ;   result hand-off.
4575  A991              ; ----------------------------------------------------------------------
4576  A991              BDOS_RETURN_RESULT:
4577  A991                      ; HL = saved BDOS entry stack pointer
4578  A991 2A 0F 9F             LD HL,(BDOS_SAVED_SP)
4579  A994                      ; restore the BDOS entry stack (drop any locals)
4580  A994 F9                   LD SP,HL
4581  A995                      ; HL = the 16-bit BDOS result value
4582  A995 2A 45 9F             LD HL,(BDOS_RETVAL)
4583  A998                      ; A = result low byte (8-bit return convention)
4584  A998 7D                   LD A,L
4585  A999                      ; B = result high byte (16-bit return convention)
4586  A999 44                   LD B,H
4587  A99A C9                   RET
4588  A99B              ; ----------------------------------------------------------------------
4589  A99B              ; F_WRITEZF_H -- BDOS function 40 (Write Random with Zero Fill): like Write Random, but newly
4590  A99B              ; allocated blocks are pre-filled with zeros.
4591  A99B              ;   In: BDOS_PARAM_PTR = pointer to an open FCB whose r0/r1/r2 hold the target record number; DMA
4592  A99B              ;       buffer holds the record.
4593  A99B              ;   Out: the record written at the random position; any block newly allocated to reach it is
4594  A99B              ;        zero-filled first; A = 0 or a random-write error code.
4595  A99B              ;   Clobbers: A, BC, DE, HL.
4596  A99B              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; set write-mode WRITE_TYPE_FLAG=2
4597  A99B              ;              (zero-fill);
4598  A99B              ;              C=0; call the random-record extract/seek core (BDOS_SEEK_COMPUTE) and, on success
4599  A99B              ;              (Z), perform the write (BDOS_WRITE).
4600  A99B              ;   [RE] dispatch fn 40 at $9C97; canonical CP/M 2.2 Write Random with Zero Fill; WRITE_TYPE_FLAG=2
4601  A99B              ;   distinguishes it from normal Write Random.
4602  A99B              ; ----------------------------------------------------------------------
4603  A99B              F_WRITEZF_H:
4604  A99B                      ; auto-select the FCB's drive prefix
4605  A99B CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4606  A99E                      ; write-mode 2 = write random with zero fill of new blocks
4607  A99E 3E 02                LD A,$02
4608  A9A0                      ; select zero-fill write mode
4609  A9A0 32 D5 A9             LD (WRITE_TYPE_FLAG),A
4610  A9A3                      ; C=0 parameter to the random-record extract core
4611  A9A3 0E 00                LD C,$00
4612  A9A5                      ; decode the FCB random record and seek/allocate to it
4613  A9A5 CD 07 A7             CALL BDOS_SEEK_COMPUTE
4614  A9A8                      ; on success, write the record (with zero-filled new blocks)
4615  A9A8 CC 03 A6             CALL Z,BDOS_WRITE
4616  A9AB C9                   RET
4617  A9AC              ; ----------------------------------------------------------------------
4618  A9AC              ; EMPTY_DIR_FCB -- Sentinel byte $E5 used as an empty/deleted directory-entry marker and zero-FCB
4619  A9AC              ; source. [RE]
4620  A9AC              ; ----------------------------------------------------------------------
4621  A9AC              EMPTY_DIR_FCB:
4622  A9AC E5                   DEFB    $E5
4623  A9AD              ; ----------------------------------------------------------------------
4624  A9AD              ; DRV_LOGIN_VECTOR -- 16-bit login vector: bit per drive that has been logged in (selected at least
4625  A9AD              ; once). [RE]
4626  A9AD              ; ----------------------------------------------------------------------
4627  A9AD              DRV_LOGIN_VECTOR:
4628  A9AD 00 00                DEFB    "\0\0"
4629  A9AF              ; ----------------------------------------------------------------------

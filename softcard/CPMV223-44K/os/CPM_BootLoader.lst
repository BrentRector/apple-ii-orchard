0011B0  1               ; [AI] Z80_BOOT_STUB: the SoftCard slot-probe handshake. A leading $00 (the copy-loop's
0011B0  1               ;      index-0 cell, data, never copied) followed by 13 bytes of Z-80 code. COPY_Z80_STUB
0011B0  1               ;      moves $11B1..$11BE to $1000..$100D, over the loader's own startup region (the 6502
0011B0  1               ;      has finished with it). From then on those bytes run on the Z-80, never the 6502: the
0011B0  1               ;      SoftCard maps the Z-80 reset address ($0000) to Apple $1000, so the slot-probe write
0011B0  1               ;      (the self-modified STA KBD in SLOTSCAN) switches to the Z-80 and lands it at $1000,
0011B0  1               ;      where it clears the $3E "found" flag and bounces back. The 13 Z-80 bytes are assembled
0011B0  1               ;      from CPM_BootLoader_ProbeOvl.asm and INCBIN'd; the JR's offset byte ($F2) is the
0011B0  1               ;      following SIG_BYTE5_TBL[0] (so SAVEBIN stops at the JR opcode).
0011B0  1               Z80_BOOT_STUB:
0011B0  1  00                   .byte   $00                     ; $11B0  copy index-0 cell (data, not copied)
0011B1  1               ;   >>> CPM_BootLoader_ProbeOvl.asm -- verbatim listing of the INCBIN'd source (regen: inject_incbin_listing) >>>
0011B1  1               ;
0011B1  1               ; FOUND   EQU $F03E        ; the 6502's $3E "SoftCard found" flag (Z-80 view of $003E)
0011B1  1               ; PROBED  EQU $F03D        ; the probed slot's $Cn high byte, set by the 6502 ($003D)
0011B1  1               ;
0011B1  1               ;     ORG $1000
0011B1  1               ;
0011B1  1               ; PROBE_OVL:
0011B1  1               ;     XOR A                ; A = 0
0011B1  1               ;     LD (FOUND),A         ; $3E = 0 -> "SoftCard found in the probed slot"
0011B1  1               ;     LD L,A               ; HL low = 0
0011B1  1               ;     LD A,(PROBED)        ; A = probed slot $Cn
0011B1  1               ;     ADD A,$20            ; $Cn -> $En (the slot's Z-80 I/O page)
0011B1  1               ;     LD H,A               ; HL = $En00
0011B1  1               ;     LD (HL),A            ; touch $En00 -> Apple $Cn00 -> switch back to the 6502
0011B1  1               ;     JR PROBE_OVL         ; loop ($18; offset byte $F2 supplied by host SIG_BYTE5_TBL[0])
0011B1  1               ;   <<< end listing <<<
0011B1  1  AF 32 3E F0          .incbin "CPM_BootLoader_ProbeOvl.bin"   ; $11B1-$11BD  (Z-80; JR offset = SIG_BYTE5_TBL[0])
0011B5  1  6F 3A 3D F0  
0011B9  1  C6 20 67 77  
0011BE  1               ; [AI] SIG_BYTE5_TBL / SIG_BYTE7_TBL: the slot-ROM ID bytes (ROM offsets $05 and $07)
0011BE  1               ;      the probe matches to classify Disk II / serial / Videx-class / printer cards.
0011BE  1               SIG_BYTE5_TBL:
0011BE  1  F2 03 18 38          .byte   $F2, $03, $18, $38                               ; $11BE
0011C2  1               SIG_BYTE7_TBL:
0011C2  1  48 3C 38 18          .byte   $48, $3C, $38, $18, $48                          ; $11C2
0011C6  1  48           

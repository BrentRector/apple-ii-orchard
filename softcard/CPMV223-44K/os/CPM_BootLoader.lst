001062  1               ; [AI] SLOTSCAN ($1062): the SoftCard / peripheral slot probe. For each slot 7..1 it
001062  1               ;      checksums the slot ROM (SLOT_CHECKSUM, 256-byte add) to locate the SoftCard (the
001062  1               ;      $3E found flag + its $03C7/$03DE control-address fields get set at
001062  1               ;      SLOTSCAN_SOFTCARD), and classifies every card by matching ROM ID bytes at offset
001062  1               ;      5 and 7 against SIG_BYTE5_TBL/SIG_BYTE7_TBL, writing a device code into the
001062  1               ;      Card-Type byte for the slot ($02F8+slot) and bumping the disk-controller count
001062  1               ;      at $03B8 for Disk II matches.
001062  1               ; [DOC S&HD 2-26/2-27] The per-slot detected-card byte forms the Card Type Table
001062  1               ;      (manual symbol SLTTYP, Z-80 $F3B9 = 6502 $03B9; entry for slot S at $03B8+S),
001062  1               ;      with the Disk Count Byte (controllers x2) at $03B8. [DOC S&HD 2-26/2-27 ; facts sec.3.6] Values:
001062  1               ;      0=no ROM, 1=ROM unknown, 2=Apple Disk II, 3=Apple Comms/CCS 7710A serial,
001062  1               ;      4=Apple High-Speed Serial / Videx Videoterm / M&R Sup-R-Term / Silentype,
001062  1               ;      5=Apple Parallel Printer.
001062  1               SLOTSCAN:
001062  1  84 3D                STY $3D                      ; $1062  84 3D
001064  1  8C 69 10             STY $1069                    ; $1064  8C 69 10
001067  1  8D 00 C0             STA KBD                      ; $1067  8D 00 C0
00106A  1  A5 3E                LDA $3E                      ; $106A  A5 3E
00106C  1  F0 18                BEQ SLOTSCAN_SOFTCARD                   ; $106C  F0 18
00106E  1  20 4E 11             JSR SLOT_CHECKSUM                 ; $106E  20 4E 11
001071  1  85 40                STA $40                      ; $1071  85 40
001073  1  86 41                STX $41                      ; $1073  86 41
001075  1  20 4E 11             JSR SLOT_CHECKSUM                 ; $1075  20 4E 11
001078  1  E0 00                CPX #$00                     ; $1078  E0 00
00107A  1  F0 1E                BEQ SLOTSCAN_NONE                   ; $107A  F0 1E
00107C  1  C5 40                CMP $40                      ; $107C  C5 40
00107E  1  D0 1A                BNE SLOTSCAN_NONE                   ; $107E  D0 1A
001080  1  E4 41                CPX $41                      ; $1080  E4 41
001082  1  F0 1A                BEQ SLOTSCAN_TYPE                   ; $1082  F0 1A
001084  1  D0 14                BNE SLOTSCAN_NONE                   ; $1084  D0 14
001086  1               ; [DOC S&HD 2-24/2-25 ; facts sec.4.3] $03DE/$03DF is Z$CPU, the SoftCard-location cell
001086  1               ;      (Z-80 $F3DE): the loader plants low byte = 0 ($03DE) and high byte = $En = found
001086  1               ;      slot $Cn + $20 ($03DF), the form a later WRITE uses to switch CPUs.
001086  1               SLOTSCAN_SOFTCARD:
001086  1  E6 3E                INC $3E                      ; $1086  E6 3E
001088  1  8C C8 03             STY $03C8                    ; $1088  8C C8 03
00108B  1  A9 00                LDA #$00                     ; $108B  A9 00
00108D  1  8D C7 03             STA $03C7                    ; $108D  8D C7 03
001090  1  8D DE 03             STA $03DE                    ; $1090  8D DE 03   Z$CPU low byte = 0
001093  1  98                   TYA                          ; $1093  98
001094  1  18                   CLC                          ; $1094  18
001095  1  69 20                ADC #$20                     ; $1095  69 20       $Cn -> $En
001097  1  8D DF 03             STA $03DF                    ; $1097  8D DF 03   Z$CPU high byte = $En (N = SoftCard slot)
00109A  1               SLOTSCAN_NONE:
00109A  1  A2 00                LDX #$00                     ; $109A  A2 00
00109C  1  F0 2D                BEQ SLOTSCAN_STORE                   ; $109C  F0 2D
00109E  1               SLOTSCAN_TYPE:
00109E  1  A2 04                LDX #$04                     ; $109E  A2 04
0010A0  1               SLOTSCAN_TYPE_1:
0010A0  1  A0 05                LDY #$05                     ; $10A0  A0 05
0010A2  1  B1 3C                LDA ($3C),Y                  ; $10A2  B1 3C
0010A4  1  DD BE 11             CMP SIG_BYTE5_TBL,X                 ; $10A4  DD BE 11
0010A7  1  D0 09                BNE SLOTSCAN_TYPE_2                   ; $10A7  D0 09
0010A9  1  A0 07                LDY #$07                     ; $10A9  A0 07
0010AB  1  B1 3C                LDA ($3C),Y                  ; $10AB  B1 3C
0010AD  1  DD C2 11             CMP SIG_BYTE7_TBL,X                 ; $10AD  DD C2 11
0010B0  1  F0 03                BEQ SLOTSCAN_TYPE_3                   ; $10B0  F0 03
0010B2  1               SLOTSCAN_TYPE_2:
0010B2  1  CA                   DEX                          ; $10B2  CA
0010B3  1  D0 EB                BNE SLOTSCAN_TYPE_1                   ; $10B3  D0 EB
0010B5  1               SLOTSCAN_TYPE_3:
0010B5  1  E8                   INX                          ; $10B5  E8
0010B6  1  E0 02                CPX #$02                     ; $10B6  E0 02
0010B8  1  D0 03                BNE SLOTSCAN_TYPE_4                   ; $10B8  D0 03
0010BA  1  EE B8 03             INC $03B8                    ; $10BA  EE B8 03
0010BD  1               ; [AI] (2.23 EXTENSION, NOT in the 1980 manual) After a value-4 (High-Speed-Serial /
0010BD  1               ;      Videx-class) signature match, the 2.23 scan reads the slot Pascal-1.1 signature
0010BD  1               ;      byte at $Cn0B and, on a match (==$01), overrides the stored device code with 6.
0010BD  1               ;      The 2.20 loader lacks this branch. Per Apple ][ Tech Note Misc #8 this is a
0010BD  1               ;      Pascal-1.1 firmware probe, not Videx-specific; do not [DOC]-cite device 6.
0010BD  1               SLOTSCAN_TYPE_4:
0010BD  1  E0 04                CPX #$04                     ; $10BD  E0 04
0010BF  1  D0 0A                BNE SLOTSCAN_STORE                   ; $10BF  D0 0A
0010C1  1  A0 0B                LDY #$0B                     ; $10C1  A0 0B
0010C3  1  B1 3C                LDA ($3C),Y                  ; $10C3  B1 3C
0010C5  1  C9 01                CMP #$01                     ; $10C5  C9 01
0010C7  1  D0 02                BNE SLOTSCAN_STORE                   ; $10C7  D0 02
0010C9  1  A2 06                LDX #$06                     ; $10C9  A2 06
0010CB  1               SLOTSCAN_STORE:
0010CB  1  A4 3D                LDY $3D                      ; $10CB  A4 3D
0010CD  1  8A                   TXA                          ; $10CD  8A
0010CE  1  99 F8 02             STA $02F8,Y                  ; $10CE  99 F8 02
0010D1  1  88                   DEY                          ; $10D1  88
0010D2  1  C0 C0                CPY #$C0                     ; $10D2  C0 C0
0010D4  1  D0 8C                BNE SLOTSCAN                   ; $10D4  D0 8C
0010D6  1  0E B8 03             ASL $03B8                    ; $10D6  0E B8 03
0010D9  1  A5 3E                LDA $3E                      ; $10D9  A5 3E
0010DB  1  C9 01                CMP #$01                     ; $10DB  C9 01
0010DD  1  F0 10                BEQ HANDOFF                   ; $10DD  F0 10
0010DF  1  A0 00                LDY #$00                     ; $10DF  A0 00

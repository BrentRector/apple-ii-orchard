001142  1               ; [AI] Copy 6 bytes from $116C to $FFF9 -> the $FFFA-$FFFF vectors (NMI/RESET/IRQ) all
001142  1               ;      point at $03C0, the RPC service loop. [DOC S&HD 2-25 ; facts sec.2.4/4.4] $03C0
001142  1               ;      (Z-80 $F3C0) is the documented start of the 6502->Z-80 mode-switch routine, and the
001142  1               ;      6502 RESET/NMI/BREAK vectors are specified to point here. [DOC S&HD 2-24/2-25 ;
001142  1               ;      facts sec.4.3] The actual CPU flip happens inside that loop by writing the SoftCard
001142  1               ;      control location (Z$CPU, $03DE = 6502 $F3DE) holding $Cn00 (N = SoftCard slot); the
001142  1               ;      write switches the bus to the Z-80. JMP $03D2 enters the loop and never returns to
001142  1               ;      6502 stage-2 code.
001142  1               HANDOFF_VECS:
001142  1  B9 6C 11             LDA $116C,Y                  ; $1142  B9 6C 11
001145  1  99 F9 FF             STA $FFF9,Y                  ; $1145  99 F9 FF
001148  1  88                   DEY                          ; $1148  88
001149  1  D0 F7                BNE HANDOFF_VECS                   ; $1149  D0 F7
00114B  1  4C D2 03             JMP $03D2                    ; $114B  4C D2 03
00114E  1               ; [AI] SLOT_CHECKSUM ($114E): 256-byte additive checksum of the slot ROM at ($3C),
00114E  1               ;      returning sum in A and carry-count in X (used to fingerprint the SoftCard ROM).
00114E  1               SLOT_CHECKSUM:
00114E  1  A9 00                LDA #$00                     ; $114E  A9 00
001150  1  AA                   TAX                          ; $1150  AA
001151  1  A8                   TAY                          ; $1151  A8
001152  1               SLOT_CHECKSUM_1:
001152  1  18                   CLC                          ; $1152  18
001153  1  71 3C                ADC ($3C),Y                  ; $1153  71 3C
001155  1  90 01                BCC SLOT_CHECKSUM_2               ; $1155  90 01
001157  1  E8                   INX                          ; $1157  E8
001158  1               SLOT_CHECKSUM_2:
001158  1  C8                   INY                          ; $1158  C8
001159  1  D0 F7                BNE SLOT_CHECKSUM_1               ; $1159  D0 F7
00115B  1  60                   RTS                          ; $115B  60
00115C  1               ; [AI] PAGE_COPY ($115C): copy X pages from ($52) to ($50) (256 bytes each, high bytes
00115C  1               ;      auto-incremented). Used to relocate the RWTS and the Z-80 glue into LC RAM.
00115C  1               PAGE_COPY:
00115C  1  A0 00                LDY #$00                     ; $115C  A0 00
00115E  1               PAGE_COPY_1:
00115E  1  B1 52                LDA ($52),Y                  ; $115E  B1 52
001160  1  91 50                STA ($50),Y                  ; $1160  91 50
001162  1  88                   DEY                          ; $1162  88
001163  1  D0 F9                BNE PAGE_COPY_1               ; $1163  D0 F9
001165  1  E6 53                INC $53                      ; $1165  E6 53
001167  1  E6 51                INC $51                      ; $1167  E6 51
001169  1  CA                   DEX                          ; $1169  CA
00116A  1  D0 F0                BNE PAGE_COPY                 ; $116A  D0 F0
00116C  1  60                   RTS                          ; $116C  60

0013C0  1               ; [AI] RPC SERVICE LOOP image  ($13C0-$13DB in file -> $03C0-$03DB at run time).
0013C0  1               ;      6502 code copied to $03C0 by HANDOFF and entered by the final JMP $03D2 (it
0013C0  1               ;      then loops at $03C0 forever, servicing Z-80 disk requests: flip to the 6502,
0013C0  1               ;      run RWTS, flip back). Written below as real instructions: it RUNS at $03C0
0013C0  1               ;      but is assembled here in the install image and copied there. Every operand
0013C0  1               ;      is absolute, so the bytes are identical at either address, and the self-loop
0013C0  1               ;      JMP target stays the literal runtime $03C0 (not this $13C0 image copy). The
0013C0  1               ;      STA $FFFF operand is patched at runtime to $Cn00 (N = SoftCard slot); that
0013C0  1               ;      write switches the bus to the Z-80.
0013C0  1               ; [DOC S&HD 2-25 ; facts sec.4.4] This $03C0 body is the documented 6502->Z-80
0013C0  1               ;      mode-switch routine (Z-80 $F3C0): the RESET/NMI/BREAK vectors point here, and it
0013C0  1               ;      hands the bus back to the Z-80.
0013C0  1  AD 83 C0             LDA LC_RAM_BANK2_RDWR           ; $03C0  AD 83 C0  bank LC RAM bank2 R/W
0013C3  1  AD 83 C0             LDA LC_RAM_BANK2_RDWR           ; $03C3  AD 83 C0   (two reads arm the LC write latch)
0013C6  1                       ; [DOC S&HD 2-24/2-25 ; facts sec.2.5/4.3] operand patched to $Cn00 (the SoftCard's
0013C6  1                       ;   slot-dependent control area / Z$CPU $03DE); a WRITE (not a read) there switches CPUs.
0013C6  1  8D FF FF             STA $FFFF                       ; $03C6  8D FF FF  operand patched to $Cn00 -> switch to Z-80
0013C9  1  AD 81 C0             LDA LC_ROM_BANK2_WR             ; $03C9  AD 81 C0  bank ROM
0013CC  1  20 36 0E             JSR $0E36                       ; $03CC  20 36 0E  into the RWTS read-byte spin (loader resident)
0013CF  1  20 58 FF             JSR IORTS                       ; $03CF  20 58 FF  bare RTS (addressing probe / no-op)
0013D2  1  8D 81 C0             STA LC_ROM_BANK2_WR             ; $03D2  8D 81 C0  (resume here) bank ROM
0013D5  1  78                   SEI                             ; $03D5  78
0013D6  1                       ; [DOC S&HD 2-24/2-25 ; facts sec.4.1] save area $45-$49 are the RPC register-pass
0013D6  1                       ;   cells (A=$45, Y=$46, X=$47, P=$48, 6502 SP at $49 on exit) the Z-80 reads back.
0013D6  1  20 4A FF             JSR SAVE                        ; $03D6  20 4A FF  A,X,Y,P,S -> $45-$49 (results for Z-80)
0013D9  1  4C C0 03             JMP $03C0                       ; $03D9  4C C0 03  loop -> hand the bus back to the Z-80
0013DC  1  00 20                .byte   $00, $20                                 ; $13DC  config cells (data)
0013DE  1  00 00 00 00          .res    9, $00    ; $13DE  fill
0013E2  1  00 00 00 00  
0013E6  1  00           
0013E7  1  60                   .byte   $60                                              ; $13E7
0013E8  1  00 00 00 00          .res    8, $00    ; $13E8  fill
0013EC  1  00 00 00 00  
0013F0  1  C0 03 C0 03          .byte   $C0, $03, $C0, $03, $A6, $4C, $C0, $03, $4C, $C0, $03, $4C, $C0, $03, $C0, $03 ; $13F0
0013F4  1  A6 4C C0 03  

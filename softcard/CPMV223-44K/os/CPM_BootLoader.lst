000000r 1               ; NOTE: comments marked [AI] are machine-generated by claude-opus-4-8 from the code alone
000000r 1               ; and may be inaccurate; treat them as hints, not verified annotation. Comments marked
000000r 1               ; [DOC <manual> <page>] have been reconciled against the primary-source Microsoft SoftCard
000000r 1               ; manuals (CP/M 2.20, (C) 1980) and are authoritative: S&HD = "Software and Hardware
000000r 1               ; Details", CPMREF = the CP/M 2.2 Reference Manual. See the consolidated fact sheet at
000000r 1               ; ../../docs/CPM_Manual_Reconcile_Facts.md. This is the 2.23 / 44K 6502 stage-2 loader;
000000r 1               ; the manual documents 2.20, so any 2.23-only feature (notably the Pascal-1.1 / device-6
000000r 1               ; branch) is flagged as a post-1980 extension, NOT carried as a [DOC] manual citation.
000000r 1               ;
000000r 1               ; [AI] DECOMPILE OVERVIEW (independent decode of loader_223.bin, $0800-$13FF):
000000r 1               ;   This 3072-byte image is the 2.23 / 44K SoftCard boot image. It holds FIVE distinct
000000r 1               ;   bodies of code/data, several of which run at an address DIFFERENT from where they sit
000000r 1               ;   in this file, and two of which are executed by the Z-80, not the 6502. The two Z-80
000000r 1               ;   bodies are real Z-80 source sub-assembled by sjasmplus and INCBIN'd here (the
000000r 1               ;   CPM_RPC6502 pattern with the CPUs swapped); everything else is decoded 6502 source:
000000r 1               ;     (1) $0800-$0837  6502  stage dispatcher (runs in place at $0800).
000000r 1               ;     (2) $0A00-$0FFF  6502  an Apple DOS 3.3-style RWTS, but it RUNS AT $BA00-$BFFF
000000r 1               ;                            (language-card RAM). LOAD_CPM copies these six pages there
000000r 1               ;                            with PAGE_COPY before use; every JSR inside it targets a
000000r 1               ;                            $BAxx/$BBxx/$BExx/$BFxx run-address, never the $0Axx store
000000r 1               ;                            address. Decoded here at its store address; the instruction
000000r 1               ;                            stream is identical either way.
000000r 1               ;     (3) $0C39-$0D4A  Z-80  a Z-80 routine embedded inside the RWTS page image (it lives
000000r 1               ;                            in LC RAM at $BC39 after the copy, interleaved with the 6502
000000r 1               ;                            nibble tables that physically follow at $BD5A/$BD9A). It is
000000r 1               ;                            executed by the Z-80 CPU after the handoff, NOT by the 6502.
000000r 1               ;                            Assembled from CPM_BootLoader_DiskXlate.asm and INCBIN'd.
000000r 1               ;     (4) $11B1-$11BD  Z-80  the slot-probe handshake (Z80_BOOT_STUB), copied to $1000 and
000000r 1               ;                            run by the Z-80 to clear the $3E "found" flag and bounce back.
000000r 1               ;                            Assembled from CPM_BootLoader_ProbeOvl.asm and INCBIN'd.
000000r 1               ;     (5) $1200-$13FF  6502  the install image: data copied to $0200-$03FF by LOAD_CPM. Its
000000r 1               ;                            tail ($13C0-$13FF -> $03C0-$03FF) is the 6502 RPC service loop,
000000r 1               ;                            written below as real 6502 instructions (it assembles at $13C0
000000r 1               ;                            but RUNS AT $03C0/$03D2; every operand is absolute, so the bytes
000000r 1               ;                            are identical at either address).
000000r 1               ;   The real entry is LOAD_CPM ($1000), reached from the stage dispatcher. The slot probe,
000000r 1               ;   LOAD_CPM disk read, page-2/3 install, and the Z-80 CPU handoff all live there.
000000r 1               
000000r 1               ; Range:  $0800-$13FF  (3072 bytes)
000000r 1               
000000r 1               .setcpu "6502"
000000r 1               .segment "CODE"
000000r 1               
000000r 1               ; --- emit a high-bit (Apple "screen") ASCII string literal, byte-for-byte ---
000000r 1               .macro  ASCHI str
000000r 1                       .repeat .strlen(str), i
000000r 1                               .byte   .strat(str, i) | $80
000000r 1                       .endrep
000000r 1               .endmacro
000000r 1               
000000r 1               ; -- External symbols --
000000r 1               H2                   = $002C             ; End column for horizontal line / right edge for HLINE
000000r 1               A2L                  = $003E             ; General-purpose pointer 2 low (MOVE/VERIFY source end)
000000r 1               IN                   = $0200             ; GETLN input buffer ($0200-$02FF)
000000r 1               DOSRWA               = $03E3             ; DOS RWTS IOB address
000000r 1               SCRN_HOLE_0478_S0    = $0478             ; Screen-hole base; slot N adds N (e.g. slot 3 -> $047B). Per-card use varies; Videx firmware uses $0478+N as CRFLAG
000000r 1               SCRN_HOLE_04F8_S0    = $04F8             ; Screen-hole; slot N -> $04F8+N
000000r 1               SCRN_HOLE_0578_S0    = $0578             ; Screen-hole; slot N -> $0578+N
000000r 1               SCRN_HOLE_05F8_S0    = $05F8             ; Screen-hole; slot N -> $05F8+N. Pascal protocol byte 5 (status bits) per Tech Note Misc #8 lives here for slot N
000000r 1               SCRN_HOLE_0678_S0    = $0678             ; Screen-hole; slot N -> $0678+N
000000r 1               SCRN_HOLE_06F8_S0    = $06F8             ; Screen-hole; slot N -> $06F8+N
000000r 1               KBD                  = $C000             ; Read: keyboard data (high bit set when key pending). IIe write: CLR80STORE
000000r 1               LC_RAM_BANK2_RD      = $C080             ; Language card: read RAM bank 2 ($D000-$DFFF), write protect
000000r 1               LC_ROM_BANK2_WR      = $C081             ; Language card: read ROM, write enable bank 2 (read twice to enable write)
000000r 1               LC_RAM_BANK2_RDWR    = $C083             ; Language card: read/write RAM bank 2 (read twice to enable write)
000000r 1               LC_RAM_BANK1_RD      = $C088             ; Language card: read RAM bank 1, write protect
000000r 1               LC_ROM_BANK1_WR      = $C089             ; Language card: read ROM, write enable bank 1
000000r 1               LC_ROM_RD2           = $C08A             ; Language card: read ROM, write protect (alias)
000000r 1               LC_RAM_BANK1_RDWR    = $C08B             ; Language card: read/write RAM bank 1
000000r 1               TEXT                 = $FB2F             ; Set text mode + reset window to full screen
000000r 1               COUT                 = $FDED             ; Output character A via (CSW). Default routes to COUT1 (screen)
000000r 1               SETKBD               = $FE89             ; Reset KSW to default keyboard input ($FD1B); CSWL,KSWL := $1B,$FD
000000r 1               SETVID               = $FE93             ; Reset CSW to default screen output ($FDF0); CSWL,CSWH := $F0,$FD
000000r 1               RESTORE              = $FF3F             ; Monitor: A,X,Y,P <- save area $45-$48 (RPC handoff)
000000r 1               SAVE                 = $FF4A             ; Monitor: A,X,Y,P,S -> save area $45-$49 (RPC handoff)
000000r 1               IORTS                = $FF58             ; Monitor: a bare RTS (known no-op / addressing probe)
000000r 1               PRERR                = $FF2D             ; Print 'ERR' + bell
000000r 1               MONZ                 = $FF65             ; Monitor entry (clear stack, print '*', GETLN, parse)
000000r 1               
000000r 1               ; -- Mid-instruction references (shown inline as cover+offset) --
000000r 1               ;   $0F3F -> RWTS_MAIN_EXIT+1             6502 skip idiom: enters the operand of $24 at $0F3E
000000r 1               ;   $0FBC -> RWTS_PRENIB_2+1             6502 skip idiom: enters the operand of $2C at $0FBB
000000r 1               
000000r 1               .org $0800
000800  1               
000800  1  01                   .byte   $01                                              ; $0800
000801  1               ; ============================================================================
000801  1               ; STAGE DISPATCHER  ($0800-$0837, runs in place)
000801  1               ; ============================================================================
000801  1               ; [AI] $0800 holds a single flag byte ($01); $0801 is the real entry, called
000801  1               ;      repeatedly from the slot-ROM disk trampoline as each track-0 sector is
000801  1               ;      read in. $27 counts entries: on the first pass after sector 9 ($27==9)
000801  1               ;      it builds an indirect vector A2L/A2H ($3E/$3F) = $Cn5C (boot slot ROM +
000801  1               ;      $5C, slot N = X/16). $00 is the stage counter; each call bumps it and,
000801  1               ;      until it reaches $0B, re-enters the slot ROM via JMP (A2L) to pull the
000801  1               ;      next sector. When $00 == $0B (all 11 stage-2 sectors loaded) it jumps to
000801  1               ;      LOAD_CPM. STAGE_SECTOR_TBL is the physical-sector order for the staged
000801  1               ;      reads (DOS 3.3 2:1 interleave).
000801  1               STAGE_DISPATCH:
000801  1  A5 27                LDA $27                      ; $0801  A5 27
000803  1  C9 09                CMP #$09                     ; $0803  C9 09
000805  1  D0 13                BNE STAGE_NEXT                   ; $0805  D0 13
000807  1  8A                   TXA                          ; $0807  8A
000808  1  4A                   LSR                          ; $0808  4A
000809  1  4A                   LSR                          ; $0809  4A
00080A  1  4A                   LSR                          ; $080A  4A
00080B  1  4A                   LSR                          ; $080B  4A
00080C  1  09 C0                ORA #$C0                     ; $080C  09 C0
00080E  1  85 3F                STA $3F                      ; $080E  85 3F
000810  1  A9 5C                LDA #$5C                     ; $0810  A9 5C
000812  1  85 3E                STA $3E                      ; $0812  85 3E
000814  1  A9 00                LDA #$00                     ; $0814  A9 00
000816  1  85 00                STA $00                      ; $0816  85 00
000818  1  E6 27                INC $27                      ; $0818  E6 27
00081A  1               STAGE_NEXT:
00081A  1  E6 00                INC $00                      ; $081A  E6 00
00081C  1  A4 00                LDY $00                      ; $081C  A4 00
00081E  1  C0 0B                CPY #$0B                     ; $081E  C0 0B
000820  1  D0 03                BNE STAGE_JUMP                   ; $0820  D0 03
000822  1  4C 00 10             JMP LOAD_CPM                   ; $0822  4C 00 10
000825  1               STAGE_JUMP:
000825  1  B9 2D 08             LDA STAGE_SECTOR_TBL,Y                 ; $0825  B9 2D 08
000828  1  85 3D                STA $3D                      ; $0828  85 3D
00082A  1  6C 3E 00             JMP (A2L)                    ; $082A  6C 3E 00
00082D  1               ; [AI] Physical-sector fetch order for the staged track-0 reads, then the
00082D  1               ;      sign-on string ".COPYRIGHT (C) 1982 MICROSOFT - CP" (the 2.23 banner; the
00082D  1               ;      leading 1980/NK fragment is prior on-disk text the loader overwrites).
00082D  1               ;      Followed by $00 fill to the end of the boot sector image.
00082D  1               STAGE_SECTOR_TBL:
00082D  1  00 02 04 06          .byte   $00, $02, $04, $06, $08, $0A, $0C, $0E, $01, $03, $05, $07, $09, $0B, $0D, $0F ; $082D
000831  1  08 0A 0C 0E  
000835  1  01 03 05 07  
00083D  1               ; Sign-on banner. A high-bit fragment of the 1980/NK build banner (prior on-disk
00083D  1               ; text the 2.23 build left in place) immediately followed by the live low-bit
00083D  1               ; 1982/CP banner, then a $00 terminator.
00083D  1               BANNER:
00083D  1  A0 C3 CF D0          ASCHI   " COPYRIGHT (C) 1980 MICROSOFT - NK "   ; $083D  high-bit (overwritten 1980/NK)
000841  1  D9 D2 C9 C7  
000845  1  C8 D4 A0 A8  
000860  1  20 43 4F 50          .byte   " COPYRIGHT (C) 1982 MICROSOFT - CP "   ; $0860  low-bit (live 1982/CP banner)
000864  1  59 52 49 47  
000868  1  48 54 20 28  
000883  1  00                   .byte   $00                                     ; $0883  terminator
000884  1  00 00 00 00          .res    380, $00    ; $0884  fill
000888  1  00 00 00 00  
00088C  1  00 00 00 00  
000A00  1               ; ============================================================================
000A00  1               ; RWTS  ($0A00-$0FFF in this file == RUNS AT $BA00-$BFFF in LC RAM)
000A00  1               ; ============================================================================
000A00  1               ; [AI] A standard Apple DOS 3.3 Read/Write Track Sector package. LOAD_CPM copies
000A00  1               ;      these six pages to $BA00 (PAGE_COPY) before calling them, so every label
000A00  1               ;      below is decoded at its STORE address ($0Axx) while the code actually
000A00  1               ;      EXECUTES at run-address +$B000 ($BA00). All internal JSR/JMP operands you
000A00  1               ;      see as bare $BAxx/$BBxx/$BExx/$BFxx are those run-addresses.
000A00  1               ;
000A00  1               ; [AI] RWTS_WRITE ($BA00): write one sector. Sends the self-sync field, the D5 AA AD
000A00  1               ;      address prologue, the 6-and-2 encoded data from the $0900/$0C00 buffers via
000A00  1               ;      the write-translate table at $BD5A, then the DE AA EB epilogue.
000A00  1               RWTS_WRITE:
000A00  1  38                   SEC                          ; $0A00  38
000A01  1  86 27                STX $27                      ; $0A01  86 27
000A03  1  8E 78 06             STX SCRN_HOLE_0678_S0        ; $0A03  8E 78 06
000A06  1  BD 8D C0             LDA $C08D,X                  ; $0A06  BD 8D C0
000A09  1  BD 8E C0             LDA $C08E,X                  ; $0A09  BD 8E C0
000A0C  1  30 7C                BMI RWTS_WRITE_DONE                   ; $0A0C  30 7C
000A0E  1  AD 00 0C             LDA $0C00                    ; $0A0E  AD 00 0C
000A11  1  85 26                STA $26                      ; $0A11  85 26
000A13  1  A9 FF                LDA #$FF                     ; $0A13  A9 FF
000A15  1  9D 8F C0             STA $C08F,X                  ; $0A15  9D 8F C0
000A18  1  1D 8C C0             ORA $C08C,X                  ; $0A18  1D 8C C0
000A1B  1  48                   PHA                          ; $0A1B  48
000A1C  1  68                   PLA                          ; $0A1C  68
000A1D  1  EA                   NOP                          ; $0A1D  EA
000A1E  1  A0 04                LDY #$04                     ; $0A1E  A0 04
000A20  1               RWTS_WRITE_1:
000A20  1  48                   PHA                          ; $0A20  48
000A21  1  68                   PLA                          ; $0A21  68
000A22  1  20 90 BA             JSR $BA90                    ; $0A22  20 90 BA
000A25  1  88                   DEY                          ; $0A25  88
000A26  1  D0 F8                BNE RWTS_WRITE_1                   ; $0A26  D0 F8
000A28  1  A9 D5                LDA #$D5                     ; $0A28  A9 D5
000A2A  1  20 8F BA             JSR $BA8F                    ; $0A2A  20 8F BA
000A2D  1  A9 AA                LDA #$AA                     ; $0A2D  A9 AA
000A2F  1  20 8F BA             JSR $BA8F                    ; $0A2F  20 8F BA
000A32  1  A9 AD                LDA #$AD                     ; $0A32  A9 AD
000A34  1  20 8F BA             JSR $BA8F                    ; $0A34  20 8F BA
000A37  1  98                   TYA                          ; $0A37  98
000A38  1  A0 56                LDY #$56                     ; $0A38  A0 56
000A3A  1  D0 03                BNE RWTS_WRITE_3                   ; $0A3A  D0 03
000A3C  1               RWTS_WRITE_2:
000A3C  1  B9 00 0C             LDA $0C00,Y                  ; $0A3C  B9 00 0C
000A3F  1               RWTS_WRITE_3:
000A3F  1  59 FF 0B             EOR $0BFF,Y                  ; $0A3F  59 FF 0B
000A42  1  AA                   TAX                          ; $0A42  AA
000A43  1  BD 5A BD             LDA $BD5A,X                  ; $0A43  BD 5A BD
000A46  1  A6 27                LDX $27                      ; $0A46  A6 27
000A48  1  9D 8D C0             STA $C08D,X                  ; $0A48  9D 8D C0
000A4B  1  BD 8C C0             LDA $C08C,X                  ; $0A4B  BD 8C C0
000A4E  1  88                   DEY                          ; $0A4E  88
000A4F  1  D0 EB                BNE RWTS_WRITE_2                   ; $0A4F  D0 EB
000A51  1  A5 26                LDA $26                      ; $0A51  A5 26
000A53  1  EA                   NOP                          ; $0A53  EA
000A54  1               RWTS_WRITE_4:
000A54  1  59 00 09             EOR $0900,Y                  ; $0A54  59 00 09
000A57  1  AA                   TAX                          ; $0A57  AA
000A58  1  BD 5A BD             LDA $BD5A,X                  ; $0A58  BD 5A BD
000A5B  1  AE 78 06             LDX SCRN_HOLE_0678_S0        ; $0A5B  AE 78 06
000A5E  1  9D 8D C0             STA $C08D,X                  ; $0A5E  9D 8D C0
000A61  1  BD 8C C0             LDA $C08C,X                  ; $0A61  BD 8C C0
000A64  1  B9 00 09             LDA $0900,Y                  ; $0A64  B9 00 09
000A67  1  C8                   INY                          ; $0A67  C8
000A68  1  D0 EA                BNE RWTS_WRITE_4                   ; $0A68  D0 EA
000A6A  1  AA                   TAX                          ; $0A6A  AA
000A6B  1  BD 5A BD             LDA $BD5A,X                  ; $0A6B  BD 5A BD
000A6E  1  A6 27                LDX $27                      ; $0A6E  A6 27
000A70  1  20 92 BA             JSR $BA92                    ; $0A70  20 92 BA
000A73  1  A9 DE                LDA #$DE                     ; $0A73  A9 DE
000A75  1  20 8F BA             JSR $BA8F                    ; $0A75  20 8F BA
000A78  1  A9 AA                LDA #$AA                     ; $0A78  A9 AA
000A7A  1  20 8F BA             JSR $BA8F                    ; $0A7A  20 8F BA
000A7D  1  A9 EB                LDA #$EB                     ; $0A7D  A9 EB
000A7F  1  20 8F BA             JSR $BA8F                    ; $0A7F  20 8F BA
000A82  1  A9 FF                LDA #$FF                     ; $0A82  A9 FF
000A84  1  20 8F BA             JSR $BA8F                    ; $0A84  20 8F BA
000A87  1  BD 8E C0             LDA $C08E,X                  ; $0A87  BD 8E C0
000A8A  1               RWTS_WRITE_DONE:
000A8A  1  BD 8C C0             LDA $C08C,X                  ; $0A8A  BD 8C C0
000A8D  1  60                   RTS                          ; $0A8D  60
000A8E  1               RWTS_NIB_NOP:
000A8E  1  EA                   NOP                          ; $0A8E  EA
000A8F  1               ; [AI] $BA8F/$BA90/$BA92: write-a-nibble helpers (timed PHA/PLA pad + STA $C08D,X
000A8F  1               ;      to the data latch). Entered with carry management to control bit timing.
000A8F  1               RWTS_NIB_CLC:
000A8F  1  18                   CLC                          ; $0A8F  18
000A90  1               RWTS_NIB_DLY:
000A90  1  48                   PHA                          ; $0A90  48
000A91  1  68                   PLA                          ; $0A91  68
000A92  1               RWTS_NIB_OUT:
000A92  1  9D 8D C0             STA $C08D,X                  ; $0A92  9D 8D C0
000A95  1  1D 8C C0             ORA $C08C,X                  ; $0A95  1D 8C C0
000A98  1  60                   RTS                          ; $0A98  60
000A99  1               ; [AI] RWTS_READADDR ($BA99): spin on the data latch ($C08C,X) to find and verify the
000A99  1               ;      D5 AA 96 address field, decode track/sector/volume/checksum (4-and-4), and
000A99  1               ;      confirm the DE AA epilogue. Returns carry set on any mismatch/timeout.
000A99  1               RWTS_READADDR:
000A99  1  A0 20                LDY #$20                     ; $0A99  A0 20
000A9B  1               RWTS_READADDR_1:
000A9B  1  88                   DEY                          ; $0A9B  88
000A9C  1  F0 63                BEQ RWTS_READADDR_ERR                   ; $0A9C  F0 63
000A9E  1               RWTS_READADDR_2:
000A9E  1  BD 8C C0             LDA $C08C,X                  ; $0A9E  BD 8C C0
000AA1  1  10 FB                BPL RWTS_READADDR_2                   ; $0AA1  10 FB
000AA3  1               RWTS_READADDR_3:
000AA3  1  49 D5                EOR #$D5                     ; $0AA3  49 D5
000AA5  1  D0 F4                BNE RWTS_READADDR_1                   ; $0AA5  D0 F4
000AA7  1  EA                   NOP                          ; $0AA7  EA
000AA8  1               RWTS_READADDR_4:
000AA8  1  BD 8C C0             LDA $C08C,X                  ; $0AA8  BD 8C C0
000AAB  1  10 FB                BPL RWTS_READADDR_4                   ; $0AAB  10 FB
000AAD  1  C9 AA                CMP #$AA                     ; $0AAD  C9 AA
000AAF  1  D0 F2                BNE RWTS_READADDR_3                   ; $0AAF  D0 F2
000AB1  1  A0 56                LDY #$56                     ; $0AB1  A0 56
000AB3  1               RWTS_READADDR_5:
000AB3  1  BD 8C C0             LDA $C08C,X                  ; $0AB3  BD 8C C0
000AB6  1  10 FB                BPL RWTS_READADDR_5                   ; $0AB6  10 FB
000AB8  1  C9 AD                CMP #$AD                     ; $0AB8  C9 AD
000ABA  1  D0 E7                BNE RWTS_READADDR_3                   ; $0ABA  D0 E7
000ABC  1  EA                   NOP                          ; $0ABC  EA
000ABD  1  EA                   NOP                          ; $0ABD  EA
000ABE  1  A9 00                LDA #$00                     ; $0ABE  A9 00
000AC0  1               RWTS_READADDR_6:
000AC0  1  88                   DEY                          ; $0AC0  88
000AC1  1  84 26                STY $26                      ; $0AC1  84 26
000AC3  1               RWTS_READADDR_7:
000AC3  1  BC 8C C0             LDY $C08C,X                  ; $0AC3  BC 8C C0
000AC6  1  10 FB                BPL RWTS_READADDR_7                   ; $0AC6  10 FB
000AC8  1  59 04 BD             EOR $BD04,Y                  ; $0AC8  59 04 BD
000ACB  1  A4 26                LDY $26                      ; $0ACB  A4 26
000ACD  1  99 00 0C             STA $0C00,Y                  ; $0ACD  99 00 0C
000AD0  1  D0 EE                BNE RWTS_READADDR_6                   ; $0AD0  D0 EE
000AD2  1               RWTS_READADDR_8:
000AD2  1  84 26                STY $26                      ; $0AD2  84 26
000AD4  1               RWTS_READADDR_9:
000AD4  1  BC 8C C0             LDY $C08C,X                  ; $0AD4  BC 8C C0
000AD7  1  10 FB                BPL RWTS_READADDR_9                   ; $0AD7  10 FB
000AD9  1  59 04 BD             EOR $BD04,Y                  ; $0AD9  59 04 BD
000ADC  1  A4 26                LDY $26                      ; $0ADC  A4 26
000ADE  1  99 00 09             STA $0900,Y                  ; $0ADE  99 00 09
000AE1  1  C8                   INY                          ; $0AE1  C8
000AE2  1  D0 EE                BNE RWTS_READADDR_8                   ; $0AE2  D0 EE
000AE4  1               RWTS_READADDR_10:
000AE4  1  BC 8C C0             LDY $C08C,X                  ; $0AE4  BC 8C C0
000AE7  1  10 FB                BPL RWTS_READADDR_10                   ; $0AE7  10 FB
000AE9  1  D9 04 BD             CMP $BD04,Y                  ; $0AE9  D9 04 BD
000AEC  1  D0 13                BNE RWTS_READADDR_ERR                   ; $0AEC  D0 13
000AEE  1               RWTS_READADDR_11:
000AEE  1  BD 8C C0             LDA $C08C,X                  ; $0AEE  BD 8C C0
000AF1  1  10 FB                BPL RWTS_READADDR_11                   ; $0AF1  10 FB
000AF3  1  C9 DE                CMP #$DE                     ; $0AF3  C9 DE
000AF5  1  D0 0A                BNE RWTS_READADDR_ERR                   ; $0AF5  D0 0A
000AF7  1  EA                   NOP                          ; $0AF7  EA

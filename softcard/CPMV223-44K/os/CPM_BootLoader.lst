000C39  1               ;
000C39  1               ; ; -- page-3 IOB mirror (Z-80 $F3xx = Apple $03xx) --
000C39  1               ; IOB_SECTOR  EQU $F3E0        ; IOB sector / load-address cell (Apple $03E0..)
000C39  1               ; IOB_TRACK   EQU $F3E4        ; IOB track cell (Apple $03E4)
000C39  1               ; IOB_VOL     EQU $F3E6        ; IOB volume cell (Apple $03E6)
000C39  1               ; IOB_BUF     EQU $F3E8        ; IOB buffer pointer (Apple $03E8/$03E9)
000C39  1               ; IOB_CMD     EQU $F3EB        ; IOB command cell (Apple $03EB)
000C39  1               ; IOB_RETCODE EQU $F3EA        ; IOB return-code cell (Apple $03EA)
000C39  1               ;
000C39  1               ; ; -- Z-80 BIOS disk scratch ($FExx) --
000C39  1               ; SCR_D1      EQU $FED1        ; requested sector (low) scratch
000C39  1               ; SCR_D2      EQU $FED2        ; requested track scratch
000C39  1               ; SCR_D6      EQU $FED6        ; current track scratch
000C39  1               ; SCR_D7      EQU $FED7        ; saved current track
000C39  1               ; SCR_D8      EQU $FED8        ; first-call flag
000C39  1               ; SCR_D9      EQU $FED9        ; pending-reseek flag
000C39  1               ; SCR_DA      EQU $FEDA        ; direction / move flags
000C39  1               ; SCR_DB      EQU $FEDB        ; read/write direction flag
000C39  1               ; SCR_DC      EQU $FEDC        ; seek-needed flag (16-bit cell)
000C39  1               ; SCR_DD      EQU $FEDD        ; retry / settle counter (16-bit cell)
000C39  1               ; SCR_DF      EQU $FEDF        ; last track/sector cache (16-bit cell)
000C39  1               ; SCR_E1      EQU $FEE1        ; host buffer pointer (16-bit cell)
000C39  1               ; SCR_E3      EQU $FEE3        ; deblock flag scratch
000C39  1               ;
000C39  1               ; ; -- Z-80 BIOS helper routines --
000C39  1               ; BIOS_SKEW   EQU $AD4A        ; logical->physical sector skew table base
000C39  1               ; BIOS_SEEK   EQU $AD25        ; BIOS seek/recalibrate helper
000C39  1               ; BIOS_FLUSH  EQU $AD2C        ; BIOS deblock-flush helper
000C39  1               ; BIOS_RWTS   EQU $FEC3        ; BIOS RWTS issue (runs one IOB operation)
000C39  1               ; BIOS_ERR    EQU $FEC6        ; BIOS RWTS error-handler entry (read failed)
000C39  1               ; BIOS_RETRY  EQU $FECA        ; BIOS RWTS retry/return continuation
000C39  1               ;
000C39  1               ;     ORG $BC39

00134A  1               
00134A  1               ; --- $134A..$137B : Z-80 console driver for a slot-3 serial (type-3) card -----
00134A  1               ;  These 50 bytes are Z-80 code, not 6502 -- assembled by the Z-80 assembler from
00134A  1               ;  CPM_BootLoader_ConInit.asm (ORG'd at its $F34A run address) and INCBIN'd here.
00134A  1               ;  Stored at this offset in the boot image, copied to Apple $034A at install,
00134A  1               ;  executed by the Z-80 at $F34A. The exact source listing follows so this file
00134A  1               ;  is self-documenting; CPM_BootLoader_ConInit.asm is authoritative.
00134A  1               ;  Structures the driver touches (manual-documented): SLTTYP3 0F3BBH = the
00134A  1               ;  Card Type Table entry for slot 3, =3 for a serial card [DOC S&HD 2-26/2-27 ;
00134A  1               ;  facts sec.3.6]; A_ACC 0F045H = the 6502 A-register RPC pass cell, A_VEC
00134A  1               ;  0F3D0H = 6502 sub-call address, Z_CPU 0F3DEH = SoftCard location (a store
00134A  1               ;  there flips CPUs) [DOC S&HD 2-24/2-25 ; facts sec.4.1/4.2/4.3].
00134A  1               ;   >>> CPM_BootLoader_ConInit.asm -- verbatim listing of the INCBIN'd source (regen: inject_incbin_listing) >>>
00134A  1               ;     INCLUDE "apple_softcard.inc"   ; Apple/SoftCard external names (single source of truth)
00134A  1               ;
00134A  1               ; SLOT3IO EQU $E0BE        ; slot-3 device status register (Apple $C0BE)
00134A  1               ;
00134A  1               ;     ORG $F34A
00134A  1               ;
00134A  1               ; ; ----------------------------------------------------------------------------
00134A  1               ; ; CON_STATUS -- console input status. A type-3 (serial) slot-3 card: return $FF
00134A  1               ; ;   if a character is ready, else $00. Any other card type defers to the BIOS
00134A  1               ; ;   console-status entry.
00134A  1               ; ;   Out: A = $FF (char ready) / $00 (not).  Clobbers: A, flags.
00134A  1               ; ; ----------------------------------------------------------------------------
00134A  1               ; CON_STATUS:                     ; console status
00134A  1               ;     LD A,(SLTTYP3)              ; slot-3 card type
00134A  1               ;     CP $03                      ; a type-3 (serial) card?
00134A  1               ;     JP NZ,$AB0C                 ; no -> BIOS console status
00134A  1               ;     LD A,(SLOT3IO)              ; serial status register
00134A  1               ;     RRA                         ; bit0 (char ready) -> carry
00134A  1               ;     SBC A,A                     ; A = $FF if ready else $00
00134A  1               ;     RET
00134A  1               ;
00134A  1               ; ; ----------------------------------------------------------------------------
00134A  1               ; ; CON_INPUT -- console input. Fetch a raw key via the BIOS and strip the high bit.
00134A  1               ; ;   Out: A = 7-bit ASCII char.  Clobbers: A, flags.
00134A  1               ; ; ----------------------------------------------------------------------------
00134A  1               ; CON_INPUT:                      ; console input
00134A  1               ;     CALL $AB12                  ; fetch raw key via BIOS
00134A  1               ;     AND $7F                     ; strip high bit
00134A  1               ;     RET
00134A  1               ;
00134A  1               ; ; ----------------------------------------------------------------------------
00134A  1               ; ; CON_OUTPUT -- console output (char in C). A type-3 serial card: spin until the
00134A  1               ; ;   Tx register is ready (OUT_WAIT), then RPC the char to the 6502 -- A$VEC points
00134A  1               ; ;   at the "STA $C0BF ; RTS" stub ($037C), fired by touching Z$CPU. Any other card
00134A  1               ; ;   type defers to the BIOS console-output entry.
00134A  1               ; ;   In: C = char.  Clobbers: A, HL, flags.
00134A  1               ; ; ----------------------------------------------------------------------------
00134A  1               ; CON_OUTPUT:                     ; console output (char in C)
00134A  1               ;     LD A,(SLTTYP3)              ; slot-3 card type
00134A  1               ;     CP $03                      ; a type-3 (serial) card?
00134A  1               ;     JP NZ,$AC3E                 ; no -> BIOS console output
00134A  1               ; OUT_WAIT:                       ; spin until the serial Tx register is ready
00134A  1               ;     LD A,(SLOT3IO)              ; serial status register
00134A  1               ;     AND $02                     ; Tx-ready bit set?
00134A  1               ;     JR Z,OUT_WAIT               ; spin until ready
00134A  1               ;     LD A,C                      ; char to send
00134A  1               ;     LD (RPC_ACC),A                ; hand it to the 6502 (A-reg cell)
00134A  1               ;     LD HL,$037C                 ; 6502 sub: STA $C0BF ; RTS
00134A  1               ;     LD (A_VEC),HL               ; A$VEC := $037C
00134A  1               ;     LD HL,(Z_CPU)               ; HL := $En00
00134A  1               ;     LD (HL),A                   ; touch $En00 -> RPC runs the 6502
00134A  1               ;     RET
00134A  1               ;   <<< end listing <<<
00134A  1  3A BB F3 FE          .incbin "CPM_BootLoader_ConInit.bin" ; ..$137B  (Z-80; byte-identical)
00134E  1  03 C2 0C AB  
001352  1  3A BE E0 1F  
00137C  1               
00137C  1               ; ----------------------------------------------------------------------
00137C  1               ; RPC_SERIAL_OUT -- 6502 RPC stub: push one queued character to the slot-3 serial data register.
00137C  1               ;   In:        A = character to transmit (placed in the 6502 A-reg by RESTORE from the $45-$48 save
00137C  1               ;              area in the RPC loop before this runs). Stored at image $137C, RUN address $037C.
00137C  1               ;   Out:       character written to the slot-3 serial card data register ($C0BF); RTS returns to the
00137C  1               ;              RPC service loop, which then SAVEs results and hands the bus back to the Z-80.
00137C  1               ;   Clobbers:  nothing (A preserved; no flags of interest).
00137C  1               ;   Algorithm: [RE] The Z-80 CON_OUTPUT path (INCBIN'd ConInit) loads the char into the A-reg pass
00137C  1               ;              cell, arms A$VEC=$037C (this stub's run address), then touches Z$CPU to switch to the
00137C  1               ;              6502; the $03C0 loop RESTOREs A then JSRs the armed A$VEC, landing here. STA $C0BF
00137C  1               ;              emits the byte; RTS resumes the loop. $C0BF is fixed slot-3 serial hardware (not
00137C  1               ;              in-image, not relocatable) -> literal.
00137C  1               ; ----------------------------------------------------------------------
00137C  1               RPC_SERIAL_OUT:
00137C  1                       ; transmit the queued character: store A to the slot-3 serial card's data register ($C0BF,
00137C  1                       ; fixed hardware)
00137C  1  8D BF C0             STA $C0BF                        ; (run $037C) char -> slot-3 serial data reg
00137F  1                       ; return to the RPC service loop (which SAVEs results and switches the bus back to the Z-80)
00137F  1  60                   RTS
001380  1               ; --- $1380..$13BF : I/O Vector Table + screen-function / keyboard config -----------
001380  1               ;  This window is part of the I/O Configuration Block; at install offset $1380 it
001380  1               ;  copies to runtime $0380 = Z-80 0F380H.
001380  1               ;
001380  1               ;  $1380..$1395 (runtime $0380..$0394 = 0F380H..0F394H): the I/O Vector Table --
001380  1               ;  eleven two-byte little-endian primitive character-I/O vectors, each the address
001380  1               ;  the BIOS CONST/CONIN/CONOUT/READER/PUNCH/LIST routine JMPs through. In order:
001380  1               ;  #1 Console Status, #2/#3 Console Input, #4/#5 Console Output, #6/#7 Reader Input,
001380  1               ;  #8/#9 Punch Output, #10/#11 List Output. Here they point at this disk's console
001380  1               ;  handlers ($F34A CON_STATUS, $F358 CON_INPUT, $AB12, $F35E CON_OUTPUT, $AC3E) and
001380  1               ;  at the BIOS reader/punch/list stubs ($AD45, $AD3F, $AD2B, $AD20)
001380  1               ;  [DOC S&HD 2-18/2-19 ; facts sec.3.2].
001380  1               ;
001380  1               ;  $1396/$1397 (runtime $0396/$0397 = 0F396H/0F397H): the software screen-function
001380  1               ;  header -- SXYOFF (cursor XY coordinate offset; high bit selects X/Y transmit
001380  1               ;  order) then SFLDIN (lead-in character, 0 = none) [DOC S&HD 2-14 ; facts sec.3.3].
001380  1               ;  $1398.. (runtime $0398.. = SSFTAB 0F398H): the Software Screen Function table,
001380  1               ;  nine one-byte entries (Clear Screen, Clear-to-EOP, Clear-to-EOL, Set Normal,
001380  1               ;  Set Inverse, Home, Address Cursor, Cursor Up, Cursor Forward; 0 = unimplemented)
001380  1               ;  followed by the parallel Hardware Screen Function table (offset/lead-in at
001380  1               ;  0F3A1H/0F3A2H, fns at 0F3A3H..0F3AAH) [DOC S&HD 2-14/2-15 ; facts sec.3.4].
001380  1               ;  $13AC.. (runtime $03AC = 0F3ACH): Keyboard Character Redefinition Table -- up to
001380  1               ;  six {from,to} ASCII pairs (both high bits clear), end marked by a high-bit-set
001380  1               ;  byte [DOC S&HD 2-17 ; facts sec.3.5].
001380  1               ;  $13B8/$13B9.. (runtime $03B8/$03B9): install-time placeholder for the Disk Count
001380  1               ;  Byte (0F3B8H, #controllers x2) [DOC S&HD 2-27 ; facts sec.3.7] and the Card Type
001380  1               ;  Table (SLTTYP 0F3B9H, slot S at 0F3B8H+S) [DOC S&HD 2-26/2-27 ; facts sec.3.6];
001380  1               ;  CAVEAT: these two are rebuilt by the runtime slot scan (S2_SLOTSCAN above writes
001380  1               ;  the disk-count to $03B8 and per-slot types to $03B9+), so the bytes shipped here
001380  1               ;  are overwritten before use.
001380  1  4A F3 58 F3          .byte   $4A, $F3, $58, $F3, $12, $AB, $5E, $F3
001384  1  12 AB 5E F3  
001388  1  3E AC 45 AD          .byte   $3E, $AC, $45, $AD, $45, $AD, $3F, $AD
00138C  1  45 AD 3F AD  
001390  1  3F AD 2B AD          .byte   $3F, $AD, $2B, $AD, $2B, $AD, $20, $1B
001394  1  2B AD 20 1B  
001398  1  AA D9 D4 A9          .byte   $AA, $D9, $D4, $A9, $A8, $1E, $BD, $0B
00139C  1  A8 1E BD 0B  
0013A0  1  0C A0 00 0C          .byte   $0C, $A0, $00, $0C, $0B, $1D, $0E, $0F
0013A4  1  0B 1D 0E 0F  
0013A8  1  19 1E 1F 1C          .byte   $19, $1E, $1F, $1C, $0B, $5B, $00, $7F
0013AC  1  0B 5B 00 7F  
0013B0  1  02 5C 15 09          .byte   $02, $5C, $15, $09, $FF, $FF, $FF, $FF
0013B4  1  FF FF FF FF  
0013B8  1  02 03 00 04          .byte   $02, $03, $00, $04, $01, $00, $02, $00
0013BC  1  01 00 02 00  
0013C0  1               
0013C0  1               ; ----------------------------------------------------------------------
0013C0  1               ; RPC_SERVICE_LOOP -- the 6502 side of the cooperative two-CPU (RPC) protocol; the 6502
0013C0  1               ; idle/dispatch loop. Stored at image $13C0, RUN address $03C0 (after S2_COPYCFG copies it there).
0013C0  1               ; The 6502 RESET/NMI/IRQ-BRK hardware vectors all point here [DOC S&HD 2-25 ; facts sec.2.4/4.4].
0013C0  1               ;   In:        entered at $03C0 on a CPU-switch INTO the 6502 (the Z-80 touched Z$CPU). The Monitor
0013C0  1               ;              save area $45-$48 holds the Z-80's call parameters; A$VEC ($03D0) was armed by the
0013C0  1               ;              Z-80; the requested routine is reached via the runtime dispatch at $1010.
0013C0  1               ;   Out:       runs ONE requested 6502 routine, writes its results back to $45-$49 ($49 = 6502 SP),
0013C0  1               ;              then switches the bus back to the Z-80 and loops forever awaiting the next request.
0013C0  1               ;   Clobbers:  A, X, Y, P (loaded from / stored to the $45-$49 save area); the Language Card
0013C0  1               ;              read/write banking is toggled around the call.
0013C0  1               ;   Algorithm: [DOC S&HD 2-24/2-25 ; facts sec.4.1] Arm the Language Card for RAM bank-2 read+write
0013C0  1               ;              (two reads of $C083), then WRITE $C700 -- the slot-7 access that toggles the CPU back
0013C0  1               ;              to the Z-80 (the corrected 2.20 $C800-window hang point, see
0013C0  1               ;              CPM_SoftCard_RealMap_Findings.md). Execution PARKS at STA $C700 until the Z-80
0013C0  1               ;              switches back IN, resuming at $03C9: restore the LC to read-ROM, RESTORE A/X/Y/P from
0013C0  1               ;              $45-$48 (NOTE: $45 A / $46 Y / $47 X / $48 P per this file's EQU block; apple2.json
0013C0  1               ;              orders $46=XREG/$47=YREG -- see FLAG 2), JSR the dispatch at runtime $1010 to run the
0013C0  1               ;              requested routine, STA $C081 (LC read-ROM), JSR SAVE A/X/Y/P/S to $45-$49 (results),
0013C0  1               ;              then JMP $03C0 to hand the bus back. Every operand here is hardware
0013C0  1               ;              ($C083/$C081/$C700), Monitor (RESTORE/SAVE), or a fixed RUNTIME address ($1010
0013C0  1               ;              dispatch, $03C0 self) -- all stay literal; this loop is staged as data here and only
0013C0  1               ;              ever EXECUTES at $03C0.
0013C0  1               ; ----------------------------------------------------------------------
0013C0  1               RPC_SERVICE_LOOP:
0013C0  1  AD 83 C0             LDA $C083                        ; LC: read RAM bank2, write-enable
0013C3  1  AD 83 C0             LDA $C083                        ; (two reads arm the LC write latch)
0013C6  1  8D 00 C7             STA $C700                        ; WRITE to the slot-7 page ($CN00)
0013C9  1                                                       ;        switches CPUs -> to the Z-80
0013C9  1                                                       ;        [DOC S&HD 2-24/2-31 ; facts sec.2.5]
0013C9  1  AD 81 C0             LDA $C081                        ; (resume here) LC: read ROM
0013CC  1  20 3F FF             JSR RESTORE                      ; A,X,Y,P <- $45-$48 (Z-80's call params)
0013CF  1  20 10 10             JSR $1010                        ; dispatch the requested 6502 RPC routine
0013D2  1  8D 81 C0             STA $C081                        ; LC: read ROM
0013D5  1  20 4A FF             JSR SAVE                         ; A,X,Y,P,S -> $45-$49 (results for Z-80)
0013D8  1  4C C0 03             JMP $03C0                        ; loop -> hand the bus back to the Z-80
0013DB  1               
0013DB  1               ; --- $13DB..$13EE : RPC / config cells (-> $03DB..$03EE) ----------------------
0013DB  1               ;  $03D0 A$VEC (6502 sub-call address, low-high) [DOC S&HD 2-25 ; facts sec.4.2]
0013DB  1               ;  and $03DE Z$CPU (SoftCard location) [DOC S&HD 2-24/2-25 ; facts sec.4.3] live
0013DB  1               ;  in this window; here as initialized data.
0013DB  1  00 00                .byte   $00, $00
0013DD  1  20 00 E7 00          .byte   $20, $00, $E7, $00, $0A, $00, $CD, $01
0013E1  1  0A 00 CD 01  
0013E5  1  01 60 60 00          .byte   $01, $60, $60, $00, $03, $00, $02, $00
0013E9  1  03 00 02 00  
0013ED  1  00 00                .byte   $00, $00
0013EF  1               
0013EF  1               ; ----------------------------------------------------------------------
0013EF  1               ; RWTS_PARM -- install-image source for the config-block tail; copied to $03F0-$03FF (Z-80
0013EF  1               ; 0F3F0H-0F3FFH) by S2_COPYPARM at boot.
0013EF  1               ;   In:        none (data). NOTE: S2_COPYPARM loads Y=$10 then DEY/BNE-loops, so it writes Y=$10..$1
0013EF  1               ;              -> $03FF..$03F0 and SKIPS Y=0 -- the byte at $13EF/$03EF is not copied; the file's
0013EF  1               ;              '$13EF..$13FF -> $03EF..$03FF' comment slightly overstates the low end.
0013EF  1               ;   Out:       the high tail of the I/O Configuration Block ($03F0-$03FF) is seeded with these
0013EF  1               ;              bytes.
0013EF  1               ;   Clobbers:  none (data).
0013EF  1               ;   Algorithm: OBSERVED bytes: $00, $C0,$03, $C0,$03, $A6, then three '4C C0 03' groups (= JMP
0013EF  1               ;              $03C0), then $C0,$03. The recurring $03C0/$C003 are the RPC-loop run address and an
0013EF  1               ;              address word; the 'JMP $03C0' groups plant jumps into RPC_SERVICE_LOOP's run address.
0013EF  1               ;              UNKNOWN: the precise per-cell role of this $03F0-$03FF tail -- the DOCUMENTED RWTS
0013EF  1               ;              caller IOB is the LOWER block $03E0-$03EB [DOC CPM_SoftCard_RWTS_IOB.md], so these
0013EF  1               ;              are NOT the standard caller params. All operands point at fixed runtime addresses
0013EF  1               ;              ($03C0/$C003) -> kept as .byte literals; marked [RE]/UNKNOWN rather than guessed.
0013EF  1               ; ----------------------------------------------------------------------
0013EF  1               RWTS_PARM:
0013EF  1                       ; [RE] config-block tail seed: address words $C003 plus the first of three planted 'JMP
0013EF  1                       ; $03C0' ($4C $C0 $03) groups into the RPC-loop run address; precise per-cell semantics
0013EF  1                       ; UNKNOWN (the documented RWTS caller IOB is the lower $03E0-$03EB block)
0013EF  1  00 C0 03 C0          .byte   $00, $C0, $03, $C0, $03, $A6, $4C, $C0
0013F3  1  03 A6 4C C0  
0013F7  1  03 4C C0 03          .byte   $03, $4C, $C0, $03, $4C, $C0, $03, $C0
0013FB  1  4C C0 03 C0  
0013FF  1  03                   .byte   $03
0013FF  1               

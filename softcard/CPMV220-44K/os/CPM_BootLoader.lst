000000r 1               ; ============================================================================
000000r 1               ;  CPM_BootLoader.s  -  Microsoft SoftCard CP/M 2.20 (44K), 6502 boot image
000000r 1               ; ============================================================================
000000r 1               ;  On-disk image $0800-$13FF (3072 bytes) read from track 0 by the Apple
000000r 1               ;  Disk II controller PROM.  Reverse-engineered from the raw on-disk bytes;
000000r 1               ;  reassembles BYTE-IDENTICAL.
000000r 1               ;
000000r 1               ;  Clean-room: decompiled solely from these bytes + public Apple II / Disk II /
000000r 1               ;  SoftCard knowledge and softcard/docs/CPM_Manual_Reconcile_Facts.md -- no
000000r 1               ;  56K/2.23 source. The code/data split was adversarially verified; comment
000000r 1               ;  PROSE is [AI] machine-inferred (a hint, not a manual citation) unless marked
000000r 1               ;  [DOC <manual> <page>]; [?] = open question.
000000r 1               ;
000000r 1               ;  Layout (6502 addresses; this image lives on disk and at $0800 at boot):
000000r 1               ;    $0800        sector-count byte read by the $Cn00 boot PROM (data, =$01)
000000r 1               ;    $0801-$082C  BOOT0  - sector-load loop, then JMP $1000 (stage-2)
000000r 1               ;    $082D-$083C  16-byte sector interleave table read by BOOT0
000000r 1               ;    $083D-$085F  sign-on banner, high-bit ASCII, $FF-terminated
000000r 1               ;    $0860-$08FF  $FF fill (rest of boot sector)
000000r 1               ;    $0900-$09FF  $00 fill - the unused P6 PROM gap / secondary nibble buffer
000000r 1               ;    $0A00-$0BDD  RWTS read primitives: pre-nibble, write, read, denibblize
000000r 1               ;    $0ABE-$0AFF  $FF fill
000000r 1               ;    $0BDE-$0C4F  RWTS seek (arm-step) routine
000000r 1               ;    $0C50-$0C67  seek phase on/off countdown tables
000000r 1               ;    $0C68-$0D55  $FF fill (CFF/$0D00 secondary nibble buffer overlay)
000000r 1               ;    $0D56-$0DFF  6-and-2 read/write nibble translate table
000000r 1               ;    $0E00-$0FFC  RWTS dispatch (READ/SEEK), front end, controller I/O
000000r 1               ;    $0F9D-$0FAC  sector physical-to-logical interleave/skew table
000000r 1               ;    $0FAD-$0FFC  RWTS top-level: read CP/M system into memory
000000r 1               ;    $1000-$1188  STAGE-2 loader: find SoftCard, build config block, go Z-80
000000r 1               ;    $1189-$11FF  $FF fill
000000r 1               ;    $1200-$13FF  install image copied to $0200-$03FF at install time:
000000r 1               ;                 Z-80 console/SoftCard init code, the 6502 $03C0 CPU-mode
000000r 1               ;                 switch routine, and config-block parameter cells (all DATA
000000r 1               ;                 here - never executed from $1200, only after the copy).
000000r 1               ;
000000r 1               ;  Manual anchors (SoftCard CP/M 2.20, (C)1980 Microsoft): config block at
000000r 1               ;  $0200-$03FF (Z-80 0F200H-0F3FFH) [DOC S&HD 2-6/2-12 ; facts sec.2.2/3];
000000r 1               ;  disk drivers+buffers $800-$FFF, screen $400-$7FF [DOC S&HD 2-6 ; facts sec.2.2];
000000r 1               ;  Card Type Table SLTTYP=0F3B9H, slot S at 0F3B8H+S [DOC S&HD 2-26/2-27 ; facts
000000r 1               ;  sec.3.6]; disk-count byte 0F3B8H [DOC S&HD 2-27 ; facts sec.3.7]; A$VEC=0F3D0H
000000r 1               ;  [DOC S&HD 2-25 ; facts sec.4.2]; Z$CPU=0F3DEH [DOC S&HD 2-24/2-25 ; facts
000000r 1               ;  sec.4.3]; 6502 mode-switch routine at $03C0, RESET/NMI/BRK vectors point here
000000r 1               ;  [DOC S&HD 2-25 ; facts sec.2.4/4.4].
000000r 1               ; ============================================================================
000000r 1               
000000r 1               .setcpu "6502"
000000r 1               .segment "CODE"
000000r 1               
000000r 1               ; --- emit a high-bit (Apple "screen") ASCII string literal, byte-for-byte ---
000000r 1               .macro  ASCHI str
000000r 1                       .repeat .strlen(str), i
000000r 1                               .byte   .strat(str, i) | $80
000000r 1                       .endrep
000000r 1               .endmacro
000000r 1               
000000r 1               ; --- zero-page / soft-switch / Monitor symbols used below --------------------
000000r 1               SECTCNT         = $27           ; BOOT0 sector counter (also $27 RWTS scratch)
000000r 1               PTRL            = $3E           ; BOOT0 indirect-JMP / RWTS buffer pointer low
000000r 1                                               ; (STAGE-2's slot scan reuses $3E as the
000000r 1                                               ;  SoftCard-found flag -- see $105B/$1063)
000000r 1               PTRH            = $3F           ; BOOT0 indirect-JMP / RWTS buffer pointer high
000000r 1               
000000r 1               ; --- Apple II Autostart Monitor ROM entry points ($F800-$FFFF) ---------------
000000r 1               ;  Canonical names per the Apple II Reference Manual / Monitor ROM disassembly;
000000r 1               ;  single source of truth is shared/symbols/apple2.json. Now that the SoftCard
000000r 1               ;  runs the genuine ROM these are the real routines, so the code below calls
000000r 1               ;  them by name. "[used]" marks the entries this file references; the rest are
000000r 1               ;  the standard callable entry points, kept here as the canonical table.
000000r 1               ;  (Earlier this block carried ad-hoc, partly WRONG names -- e.g. $FB2F was
000000r 1               ;  labelled MON_SETKBD, but $FB2F is TEXT and SETKBD is $FE89.)
000000r 1               ; -- character / line output --
000000r 1               COUT            = $FDED         ; output A via (CSW); default -> COUT1            [used]
000000r 1               COUT1           = $FDF0         ; screen-only character output (default CSW target)
000000r 1               CROUT           = $FD8E         ; output a carriage return via COUT
000000r 1               PRBYTE          = $FDDA         ; print A as two hex digits
000000r 1               PRHEX           = $FDE3         ; print A's low nibble as one hex digit
000000r 1               ; -- keyboard / line input --
000000r 1               RDKEY           = $FD0C         ; read a key via (KSW); default -> KEYIN
000000r 1               KEYIN           = $FD1B         ; default keyboard input (spin on KBD, clear strobe)
000000r 1               GETLN           = $FD6A         ; read a line into IN ($0200); returns X = length
000000r 1               ; -- screen control --
000000r 1               TEXT            = $FB2F         ; set text mode + reset window to full screen     [used]
000000r 1               TEXT2           = $FB39         ; reset text window only
000000r 1               TABV            = $FB40         ; set cursor row (A), recompute BASL/BASH
000000r 1               BASCALC         = $FB5B         ; compute text base (BASL/BASH) from A = row
000000r 1               VIDOUT          = $FB78         ; plot A at cursor (no scroll / control handling)
000000r 1               VTAB            = $FC22         ; set BASL/BASH from CV
000000r 1               CLREOP          = $FC42         ; clear from cursor to end of page
000000r 1               HOME            = $FC58         ; clear text window, home cursor
000000r 1               SCROLL          = $FC70         ; scroll text window up one line
000000r 1               CLREOL          = $FC9C         ; clear from cursor to end of line
000000r 1               WAIT            = $FCA8         ; delay loop, duration from A
000000r 1               BELL            = $FBE4         ; sound the bell
000000r 1               ; -- video/keyboard hooks + inverse flag --
000000r 1               SETINV          = $FE80         ; INVFLG = $3F  (COUT prints inverse)
000000r 1               SETNORM         = $FE84         ; INVFLG = $FF  (COUT prints normal)
000000r 1               SETKBD          = $FE89         ; reset KSW to KEYIN (keyboard input)             [used]
000000r 1               SETVID          = $FE93         ; reset CSW to COUT1 (screen output)              [used]
000000r 1               ; -- register save/restore (the 6502<->Z-80 RPC handoff rides through these) --
000000r 1               ;  The $45-$49 save area = the RPC register-pass cells: $45 A, $46 Y, $47 X,
000000r 1               ;  $48 P, $49 = 6502 SP on exit [DOC S&HD 2-24/2-25 ; facts sec.4.1].
000000r 1               RESTORE         = $FF3F         ; A,X,Y,P <- save area $45-$48                    [used: $03C0]
000000r 1               SAVE            = $FF4A         ; A,X,Y,P,S -> save area $45-$49                   [used: $03C0]
000000r 1               ; -- monitor / misc --
000000r 1               PRERR           = $FF2D         ; print "ERR" + bell                             [used]
000000r 1               IORTS           = $FF58         ; a bare RTS in the Apple Monitor ROM; the RPC
000000r 1                                               ; interrupt handler uses it as a no-op 6502 call
000000r 1                                               ; target [DOC S&HD 2-25 ; facts sec.4.5]
000000r 1               MONZ            = $FF65         ; monitor cold entry (reset stack, '*', GETLN)    [used]
000000r 1               MONITOR         = $FF69         ; monitor warm entry
000000r 1               
000000r 1               .org $0800
000800  1               
000800  1               ; ----------------------------------------------------------------------------
000800  1               ;  $0800  sector-count byte.  The Disk II boot PROM reads this byte as the
000800  1               ;  count of additional sectors to load; it is DATA, not code.
000800  1               ; ----------------------------------------------------------------------------
000800  1  01                   .byte   $01                      ; boot sector-count
000801  1               
000801  1               ; ----------------------------------------------------------------------
000801  1               ; BOOT0 -- second-stage sector-load loop entered by the Disk II $Cn00 boot PROM
000801  1               ;   In:        X = slot*16 (left by the controller PROM at $0801 entry). $27
000801  1               ;              (named SECTCNT here) = the PROM's DESTINATION PAGE byte: the PROM
000801  1               ;              loaded boot sector 0 to $0800 then INC'd it to $09, so $27=$09 on
000801  1               ;              first entry [RE, from the standard Disk II P6 PROM convention:
000801  1               ;              $26/$27 = dest_lo/dest_hi, $3D = the sector the $Cn5C search looks
000801  1               ;              for]. ZP $00 is BOOT0's own logical index into SECTAB. The PROM has
000801  1               ;              already read sector 0 ($0800-$08FF) into memory.
000801  1               ;   Out:       10 further sectors of track 0 (physical 2,4,6,8,A,C,E,1,3,5 per
000801  1               ;              SECTAB[1..10]) read into $0A00..$13FF via the PROM's $Cn5C entry,
000801  1               ;              then JMP STAGE2 ($1000) to hand off to the stage-2 loader.
000801  1               ;   Clobbers:  A, Y; ZP $00 (SECTAB index), $3D (the physical sector the PROM
000801  1               ;              searches for), PTRL/PTRH ($3E/$3F = the $Cn5C indirect-call vector),
000801  1               ;              $27 (bumped once on the first pass).
000801  1               ;   Algorithm: On the FIRST pass only (detected by $27 = $09, i.e. the PROM's
000801  1               ;              destination page sits at $0900 right after it loaded $0800), derive
000801  1               ;              the slot number from X (slot*16 >> 4), OR in $C0 to form the PROM
000801  1               ;              page $Cn, and build the indirect-call vector PTRL/PTRH = $Cn5C (the
000801  1               ;              controller PROM's read-sector / search-for-prolog entry), then zero
000801  1               ;              the SECTAB index. Each pass advances the index in $00; once 10
000801  1               ;              sectors have been requested (index reaches $0B) it jumps to STAGE2.
000801  1               ;              Otherwise it fetches the next PHYSICAL sector number from the SECTAB
000801  1               ;              interleave table, stores it in $3D (where the PROM's search expects
000801  1               ;              it), and re-enters the PROM read routine via JMP (PTRL); the PROM
000801  1               ;              reads one sector, bumps its dest page, and JMPs back to $0801.
000801  1               ; ----------------------------------------------------------------------
000801  1               BOOT0:
000801  1  A5 27                LDA SECTCNT                      ; sector # just read by PROM
000803  1                       ; first pass? the PROM's destination page is $09 right after it loaded $0800; if so, build
000803  1                       ; the $Cn5C read vector below [RE]
000803  1  C9 09                CMP #$09                         ; reached sector 9 yet?
000805  1  D0 13                BNE @notdone
000807  1                       ; derive the slot number from X (= slot*16) to form the controller PROM page $Cn
000807  1  8A                   TXA                              ; X = slot*16
000808  1  4A                   LSR                              ; -> slot # in low nibble
000809  1  4A                   LSR
00080A  1  4A                   LSR
00080B  1  4A                   LSR
00080C  1                       ; form the PROM page byte: slot N -> $Cn, the high byte of the $Cn5C read-sector entry
00080C  1  09 C0                ORA #$C0                         ; form $Cn (PROM page)
00080E  1  85 3F                STA PTRH                         ; high byte of read vector
000810  1                       ; low byte $5C: PTRL/PTRH now address the Disk II PROM read-sector / search-prolog entry
000810  1                       ; $Cn5C
000810  1  A9 5C                LDA #$5C                         ; $Cn5C = PROM read-sector entry
000812  1  85 3E                STA PTRL
000814  1  A9 00                LDA #$00
000816  1                       ; reset BOOT0's SECTAB index to 0
000816  1  85 00                STA $00                          ; reset index
000818  1  E6 27                INC SECTCNT                      ; bump physical sector
00081A  1               @notdone:
00081A  1                       ; advance to the next SECTAB index (sectors requested so far)
00081A  1  E6 00                INC $00                          ; advance load index
00081C  1  A4 00                LDY $00
00081E  1                       ; all 10 further sectors requested (index reached $0B = 11)? if so the image is loaded
00081E  1  C0 0B                CPY #$0B                         ; loaded 11 sectors ($00..$0A)?
000820  1  D0 03                BNE @next
000822  1                       ; image fully loaded -- hand off to the stage-2 loader at $1000
000822  1  4C 00 10             JMP STAGE2                       ; -> stage-2 loader at $1000
000825  1               @next:
000825  1                       ; map the logical index to the next PHYSICAL sector via the interleave table
000825  1  B9 2D 08             LDA SECTAB,Y                     ; next physical sector to read
000828  1                       ; tell the PROM which physical sector to find (its $Cn5C search compares against $3D) [RE]
000828  1  85 3D                STA $3D
00082A  1                       ; re-enter the controller PROM at $Cn5C through PTRL/PTRH to read that sector (it returns
00082A  1                       ; via JMP $0801)
00082A  1  6C 3E 00             JMP ($003E)                      ; call $Cn5C PROM read-sector
00082D  1               
00082D  1               ; ----------------------------------------------------------------------
00082D  1               ; SECTAB -- 16-byte physical-sector interleave table read by BOOT0
00082D  1               ;   In:        indexed by BOOT0's logical sector counter Y (indices 1..10 used).
00082D  1               ;   Out:       the physical sector number to feed the PROM's $Cn5C search via $3D.
00082D  1               ;   Algorithm: pure DATA. Maps each logical load index to a physical track-0
00082D  1               ;              sector in even-then-odd order ($00,$02,..,$0E, $01,$03,..,$0F).
00082D  1               ;              BOOT0 uses indices 1..10 (physical 2,4,6,8,A,C,E,1,3,5); index 0
00082D  1               ;              (sector 0) is skipped because the PROM already loaded it, and
00082D  1               ;              indices 11..15 are unused. Genuine table data, not relocatable.
00082D  1               ; ----------------------------------------------------------------------
00082D  1               SECTAB:
00082D  1                       ; even physical sectors $00..$0E (logical indices 0..7; BOOT0 uses 1..7)
00082D  1  00 02 04 06          .byte   $00, $02, $04, $06, $08, $0A, $0C, $0E
000831  1  08 0A 0C 0E  
000835  1                       ; odd physical sectors $01..$0F (logical indices 8..15; BOOT0 uses only 8..10)
000835  1  01 03 05 07          .byte   $01, $03, $05, $07, $09, $0B, $0D, $0F
000839  1  09 0B 0D 0F  
00083D  1               
00083D  1               ; ----------------------------------------------------------------------
00083D  1               ; BANNER -- cold-boot sign-on string (high-bit Apple screen ASCII)
00083D  1               ;   In:        none (DATA).
00083D  1               ;   Out:       the literal text " COPYRIGHT (C) 1980 MICROSOFT - NK ".
00083D  1               ;   Algorithm: pure string DATA, each byte OR $80 (Apple screen ASCII), bounded by
00083D  1               ;              the $FF fill that follows. The "(C) 1980 MICROSOFT" copyright
00083D  1               ;              matches the manual cold-boot sign-on line [DOC Vol1 1-8 ; facts
00083D  1               ;              sec.8.6]; the full three-line APPLE II CP/M banner is emitted later
00083D  1               ;              by the BIOS, not from this boot sector. Whether/where the boot
00083D  1               ;              loader itself prints this string is UNKNOWN from these bytes. Kept
00083D  1               ;              as an ASCHI literal -- not relocatable.
00083D  1               ; ----------------------------------------------------------------------
00083D  1               BANNER:
00083D  1  A0 C3 CF D0          ASCHI   " COPYRIGHT (C) 1980 MICROSOFT - NK " ; -$085F
000841  1  D9 D2 C9 C7  
000845  1  C8 D4 A0 A8  
000860  1               
000860  1  FF FF FF FF          .res    160, $FF                 ; rest of boot sector ($FF)
000864  1  FF FF FF FF  
000868  1  FF FF FF FF  
000900  1               ; ----------------------------------------------------------------------
000900  1               ; SECBUF2 -- $0900-$09FF nibble buffer (boot-time $00 fill; RWTS scratch at run time)
000900  1               ;   In:        on disk this page is all $00 (it occupies the unused P6 PROM gap).
000900  1               ;              At RWTS run time it is one of the two 6-and-2 nibble buffers: it
000900  1               ;              holds the 256 high-6-bit values of the sector (PRENIBBLE shifts each
000900  1               ;              user byte's top bits here via STA SECBUF2,Y; WRITESECT/READSECT
000900  1               ;              stream it to/from disk). The companion 86-entry low-2-bits buffer is
000900  1               ;              at $0D00 (NIBBUF). [RE -- the file's layout map calls $0D00 the
000900  1               ;              "secondary" buffer, so the SECBUF2 vs NIBBUF naming is loose.]
000900  1               ;   Out:       n/a (scratch).
000900  1               ;   Clobbers:  rewritten wholesale by every RWTS sector operation.
000900  1               ;   Algorithm: DATA region, not code. Stored as 256 bytes of $00 in the image; the
000900  1               ;              RWTS primitives ($0A00+) reuse the page as nibble storage at run
000900  1               ;              time. TEMPORAL tenants: $00 fill on disk (boot) -> RWTS 6-and-2
000900  1               ;              nibble buffer once the loader runs the 6502 RWTS. Kept as a $00
000900  1               ;              fill -- not relocatable.
000900  1               ; ----------------------------------------------------------------------
000900  1               SECBUF2:
000900  1  00 00 00 00          .res    256, $00                 ; $00 fill / secondary buffer
000904  1  00 00 00 00  
000908  1  00 00 00 00  
000A00  1               
000A00  1               ; ============================================================================
000A00  1               ;  RWTS read primitives  ($0A00..$0BDD)
000A00  1               ; ============================================================================
000A00  1               
000A00  1               ; ----------------------------------------------------------------------
000A00  1               ; PRENIBBLE -- pre-shift the user data buffer into the 6-and-2 primary + secondary buffers
000A00  1               ;   In:        (PTRL/PTRH $3E/$3F) -> 256-byte user sector buffer to encode
000A00  1               ;   Out:       SECBUF2 ($0900..$09FF) holds the 256 PRIMARY bytes (the upper 6
000A00  1               ;              bits of every user data byte); NIBBUF ($0D00..$0D55, reached as
000A00  1               ;              NIBBUF-$AA,X with X=$AA..$FF) holds the 86 SECONDARY bytes (the
000A00  1               ;              low 2 bits of three user bytes packed per cell)
000A00  1               ;   Clobbers:  A, X, Y; SECBUF2[0..$FF]; NIBBUF[0..$55] (zeroed then filled)
000A00  1               ;   Algorithm: zero the 86-byte secondary buffer (NIBBUF[$55..0]), then walk the
000A00  1               ;              256 user bytes backwards (Y wraps $00 -> $FF down to 0). For each
000A00  1               ;              byte, shift its two low bits out (LSR/ROL pairs) into the secondary
000A00  1               ;              cell selected by X (three source bytes feed one secondary cell) and
000A00  1               ;              store the remaining upper 6 bits into SECBUF2,Y. This is the standard
000A00  1               ;              Apple 6-and-2 pre-nibble; WRITESECT then maps each value through
000A00  1               ;              WRTRANS and clocks it onto the disk. [RE]
000A00  1               ; ----------------------------------------------------------------------
000A00  1               PRENIBBLE:
000A00  1                       ; clear the 86-byte secondary buffer NIBBUF[$55..$00]
000A00  1  A2 55                LDX #$55
000A02  1  A9 00                LDA #$00
000A04  1               @clr:
000A04  1  9D 00 0D             STA NIBBUF,X                     ; zero $0D00..$0D55
000A07  1  CA                   DEX
000A08  1  10 FA                BPL @clr
000A0A  1                       ; Y = $00: walk all 256 user bytes (the first DEY wraps Y to $FF)
000A0A  1  A8                   TAY
000A0B  1                       ; X = secondary-buffer column base ($0C56+$AC = NIBBUF+2)
000A0B  1  A2 AC                LDX #$AC
000A0D  1               @skip:
000A0D  1  2C                   .byte   $2C                      ; cover (BIT-abs opcode): the FIRST pass falls
000A0E  1                                                        ; through from LDX #$AC and the BIT swallows the
000A0E  1                                                        ; next 2 bytes, skipping the LDX #$AA so X stays $AC
000A0E  1               PRENIB_RELOAD:
000A0E  1  A2 AA                LDX #$AA                         ; real mid-byte entry (reached by BNE PRENIB_RELOAD):
000A10  1                                                        ; reset the secondary-column base for each later group
000A10  1               @loop:
000A10  1                       ; pre-shift one user byte into the primary + secondary buffers
000A10  1  88                   DEY
000A11  1                       ; fetch the user data byte
000A11  1  B1 3E                LDA (PTRL),Y                     ; user buffer byte
000A13  1  4A                   LSR
000A14  1  3E 56 0C             ROL NIBBUF-$AA,X                 ; -> 6+2 secondary buffer
000A17  1  4A                   LSR
000A18  1  3E 56 0C             ROL NIBBUF-$AA,X                 ; (base $0C56, X>=$AC: $0D02+)
000A1B  1                       ; store the upper 6 bits to the primary buffer (SECBUF2)
000A1B  1  99 00 09             STA SECBUF2,Y
000A1E  1  E8                   INX
000A1F  1                       ; advance the secondary column; X wrapping to $00 ends this group
000A1F  1  D0 EF                BNE @loop
000A21  1  98                   TYA
000A22  1                       ; more user bytes? re-enter at PRENIB_RELOAD to reset the column base
000A22  1  D0 EA                BNE PRENIB_RELOAD
000A24  1  60                   RTS
000A25  1               
000A25  1               ; ----------------------------------------------------------------------
000A25  1               ; WRITESECT -- 6-and-2 encode the pre-nibbled sector and clock it onto the diskette
000A25  1               ;   In:        X = slot*16 (the drive's Disk II $C0n0 base index); NIBBUF (86 secondary
000A25  1               ;              bytes) and SECBUF2 (256 primary bytes) already filled by PRENIBBLE
000A25  1               ;   Out:       data field written as D5 AA AD <secondary stream + primary stream +
000A25  1               ;              checksum> DE AA EB FF, controller left in read mode; on write-protect,
000A25  1               ;              aborts to WR_DONE2 with no write
000A25  1               ;   Clobbers:  A, X, Y; SECTCNT ($27) and $0678 (two copies of slot*16), $26 (running
000A25  1               ;              EOR-chain checksum seed); leaves the controller in read mode on exit
000A25  1               ;   Algorithm: sense write-protect (Q6H then Q7L; bit7 set = protected) and abort if
000A25  1               ;              set. Else switch to write mode (Q7H), emit the self-sync gap and the
000A25  1               ;              D5 AA AD data prologue, then write the 86-byte secondary stream and the
000A25  1               ;              256-byte primary stream, each byte EOR-chained with the previous (the
000A25  1               ;              running checksum) and mapped through WRTRANS to a legal disk nibble.
000A25  1               ;              Write the final checksum nibble, the DE AA EB epilogue + an FF sync,
000A25  1               ;              then drop the latch back to read mode. WR_NIB/WR_NIB1/WR_NIB2 hold the
000A25  1               ;              inter-nibble spacing. [RE]
000A25  1               ; ----------------------------------------------------------------------
000A25  1               WRITESECT:
000A25  1  38                   SEC
000A26  1  86 27                STX SECTCNT
000A28  1                       ; keep a second copy of slot*16 (X is reloaded with translated nibbles in the inner loops)
000A28  1  8E 78 06             STX $0678                        ; save slot index *16
000A2B  1  BD 8D C0             LDA $C08D,X                      ; Q6L (sense write-protect)
000A2E  1                       ; sense write-protect via Q7L (after the Q6H above); bit7 set = protected
000A2E  1  BD 8E C0             LDA $C08E,X                      ; Q7L
000A31  1                       ; write-protected -> abort without writing
000A31  1  30 7C                BMI WR_DONE2                     ; write protected -> abort
000A33  1  AD 00 0D             LDA NIBBUF
000A36  1  85 26                STA $26
000A38  1  A9 FF                LDA #$FF
000A3A  1                       ; Q7H: switch the controller into write mode
000A3A  1  9D 8F C0             STA $C08F,X                      ; Q7H (write mode)
000A3D  1  1D 8C C0             ORA $C08C,X                      ; Q6L
000A40  1  48                   PHA
000A41  1  68                   PLA
000A42  1  EA                   NOP
000A43  1                       ; emit 4 self-sync $FF gap nibbles ahead of the data field
000A43  1  A0 04                LDY #$04
000A45  1               @gap:
000A45  1  48                   PHA
000A46  1  68                   PLA
000A47  1  20 B5 0A             JSR WR_NIB1
000A4A  1  88                   DEY
000A4B  1  D0 F8                BNE @gap
000A4D  1                       ; write the D5 AA AD data-field prologue
000A4D  1  A9 D5                LDA #$D5                         ; data prologue D5 AA AD
000A4F  1  20 B4 0A             JSR WR_NIB
000A52  1  A9 AA                LDA #$AA
000A54  1  20 B4 0A             JSR WR_NIB
000A57  1  A9 AD                LDA #$AD
000A59  1  20 B4 0A             JSR WR_NIB
000A5C  1  98                   TYA
000A5D  1                       ; phase 1: write the 86-byte secondary stream (NIBBUF), EOR-chained
000A5D  1  A0 56                LDY #$56
000A5F  1  D0 03                BNE @sec2
000A61  1               @sec2lp:
000A61  1                       ; EOR-chain successive secondary bytes (NIBBUF), then translate via WRTRANS
000A61  1  B9 00 0D             LDA NIBBUF,Y
000A64  1               @sec2:
000A64  1  59 FF 0C             EOR NIBBUF-1,Y
000A67  1  AA                   TAX
000A68  1  BD 56 0D             LDA WRTRANS,X                    ; 6+2 write translate
000A6B  1  A6 27                LDX SECTCNT
000A6D  1  9D 8D C0             STA $C08D,X
000A70  1  BD 8C C0             LDA $C08C,X
000A73  1  88                   DEY
000A74  1  D0 EB                BNE @sec2lp
000A76  1                       ; phase 2: re-seed the running checksum, then write the 256 primary bytes
000A76  1  A5 26                LDA $26
000A78  1  EA                   NOP
000A79  1               @mainlp:
000A79  1                       ; EOR-chain each primary byte (SECBUF2), translate, and clock it out
000A79  1  59 00 09             EOR SECBUF2,Y
000A7C  1  AA                   TAX
000A7D  1  BD 56 0D             LDA WRTRANS,X
000A80  1  AE 78 06             LDX $0678
000A83  1  9D 8D C0             STA $C08D,X
000A86  1  BD 8C C0             LDA $C08C,X
000A89  1  B9 00 09             LDA SECBUF2,Y
000A8C  1  C8                   INY
000A8D  1  D0 EA                BNE @mainlp
000A8F  1  AA                   TAX
000A90  1                       ; translate and write the final running-checksum nibble
000A90  1  BD 56 0D             LDA WRTRANS,X
000A93  1  A6 27                LDX SECTCNT
000A95  1  20 B7 0A             JSR WR_NIB2
000A98  1                       ; write the DE AA EB data-field epilogue + a trailing FF sync
000A98  1  A9 DE                LDA #$DE                         ; data epilogue DE AA EB
000A9A  1  20 B4 0A             JSR WR_NIB
000A9D  1  A9 AA                LDA #$AA
000A9F  1  20 B4 0A             JSR WR_NIB
000AA2  1  A9 EB                LDA #$EB
000AA4  1  20 B4 0A             JSR WR_NIB
000AA7  1  A9 FF                LDA #$FF
000AA9  1  20 B4 0A             JSR WR_NIB
000AAC  1                       ; Q7L: drop the controller back to read mode
000AAC  1  BD 8E C0             LDA $C08E,X                      ; Q7L (read mode)
000AAF  1               ; ----------------------------------------------------------------------
000AAF  1               ; WR_DONE2 -- common write exit: settle the controller into read mode and return
000AAF  1               ;   In:        X = slot*16 (Disk II base index); reached by fall-through after a
000AAF  1               ;              completed write, or by branch from the write-protect check
000AAF  1               ;   Out:       controller left in read mode; A = the Q6L read
000AAF  1               ;   Clobbers:  A
000AAF  1               ;   Algorithm: read Q6L ($C08C,X) to settle the data register into read mode, then
000AAF  1               ;              return to the RWTS dispatcher (which records completion status). [RE]
000AAF  1               ; ----------------------------------------------------------------------
000AAF  1               WR_DONE2:
000AAF  1                       ; Q6L: leave the controller in read mode, then return
000AAF  1  BD 8C C0             LDA $C08C,X                      ; Q6L
000AB2  1  60                   RTS
000AB3  1  EA                   NOP
000AB4  1               ; ----------------------------------------------------------------------
000AB4  1               ; WR_NIB -- write one disk nibble with the longest inter-nibble spacing (slowest entry)
000AB4  1               ;   In:        A = nibble to write; X = slot*16 (Disk II base index)
000AB4  1               ;   Out:       A = the Q6L read; the nibble has been clocked onto the diskette
000AB4  1               ;   Clobbers:  A, carry (CLC); stack used transiently by PHA/PLA in WR_NIB1
000AB4  1               ;   Algorithm: clear carry (a 2-cycle pad), then fall into WR_NIB1. Used between bytes
000AB4  1               ;              that need the widest gap (the prologue/epilogue marks) so successive
000AB4  1               ;              latch writes stay spaced to the disk bit-cell cadence. [RE]
000AB4  1               ; ----------------------------------------------------------------------
000AB4  1               WR_NIB:
000AB4  1                       ; longest-spacing entry: a 2-cycle pad, then fall into WR_NIB1
000AB4  1  18                   CLC
000AB5  1               ; ----------------------------------------------------------------------
000AB5  1               ; WR_NIB1 -- write one disk nibble with medium inter-nibble spacing
000AB5  1               ;   In:        A = nibble to write; X = slot*16
000AB5  1               ;   Out:       A = the Q6L read; the nibble has been clocked onto the diskette
000AB5  1               ;   Clobbers:  A; stack used transiently by PHA/PLA
000AB5  1               ;   Algorithm: a PHA/PLA pair adds a fixed delay, then fall into WR_NIB2. Used for the
000AB5  1               ;              self-sync gap nibbles -- one step faster than WR_NIB (no CLC pad). [RE]
000AB5  1               ; ----------------------------------------------------------------------
000AB5  1               WR_NIB1:
000AB5  1                       ; medium-spacing entry: PHA/PLA pad delay, then fall into WR_NIB2
000AB5  1  48                   PHA
000AB6  1  68                   PLA
000AB7  1               ; ----------------------------------------------------------------------
000AB7  1               ; WR_NIB2 -- bare latch write, no pre-delay (fastest entry; the shared write tail)
000AB7  1               ;   In:        A = nibble to write; X = slot*16; controller already in write mode (Q7H)
000AB7  1               ;   Out:       A = the Q6L read; the nibble has been clocked onto the diskette
000AB7  1               ;   Clobbers:  A
000AB7  1               ;   Algorithm: STA Q6H ($C08D,X) loads the byte into the write latch; the following
000AB7  1               ;              access of Q6L ($C08C,X) strobes it out (the standard Apple write-nibble
000AB7  1               ;              idiom). All three WR_NIB* entries converge here; callers pick WR_NIB /
000AB7  1               ;              WR_NIB1 / WR_NIB2 to hold the per-nibble cadence when surrounding code
000AB7  1               ;              has already consumed part of the gap. [RE]
000AB7  1               ; ----------------------------------------------------------------------
000AB7  1               WR_NIB2:
000AB7  1                       ; Q6H: load the nibble into the write latch
000AB7  1  9D 8D C0             STA $C08D,X                      ; Q6H (load latch)
000ABA  1                       ; Q6L: strobe the latched byte out onto the diskette
000ABA  1  1D 8C C0             ORA $C08C,X                      ; Q6L (shift out)
000ABD  1  60                   RTS
000ABE  1               
000ABE  1  FF FF FF FF          .res    66, $FF                  ; fill
000AC2  1  FF FF FF FF  
000AC6  1  FF FF FF FF  
000B00  1               
000B00  1               ; ----------------------------------------------------------------------
000B00  1               ; READSECT -- find the 6-and-2 data field and denibblize one sector into the buffers
000B00  1               ;   In:        X = slot*16 (Disk II soft-switch base $C08x,X; the controller is already in
000B00  1               ;              read mode and the head settled on the target track by the RWTS caller). NIBBUF
000B00  1               ;              ($0D00) and SECBUF2 ($0900) are the destination half-buffers. The combined
000B00  1               ;              read/write nibble table at WRTRANS ($0D56) doubles as the disk-nibble->6-bit
000B00  1               ;              read-translate in its tail: indexing NIBBUF ($0D00),Y with a raw disk nibble
000B00  1               ;              Y in $96..$FF lands at $0D96..$0DFF, the read-translate entries.
000B00  1               ;   Out:       Carry CLEAR on success (branches to RDADDR_OK at $0BC4) with 86 secondary
000B00  1               ;              nibbles in NIBBUF[$00..$55] and 256 primary bytes in SECBUF2[$00..$FF], data
000B00  1               ;              checksum and DE AA epilogue verified. Carry SET on any failure (falls through
000B00  1               ;              to RD_FAIL).
000B00  1               ;   Clobbers:  A, Y, ZP $26 (running buffer-index save), NIBBUF, SECBUF2. X is preserved as
000B00  1               ;              the slot index throughout (only read via $C08x,X, never written).
000B00  1               ;   Algorithm: Spin the data latch hunting the D5 AA AD data prologue, decrementing a $20-entry
000B00  1               ;              retry budget and re-syncing on each mismatch. Then read 86 secondary (2-bit)
000B00  1               ;              nibbles into NIBBUF top-down and 256 primary (6-bit) nibbles into SECBUF2,
000B00  1               ;              maintaining a running checksum in A: each raw disk byte is fetched into Y and
000B00  1               ;              EOR'd through the read-translate tail of WRTRANS (EOR NIBBUF,Y) into the prior
000B00  1               ;              value, then stored decoded. After the data bytes, verify the trailing on-disk
000B00  1               ;              checksum nibble equals the accumulated value, then verify the DE AA data
000B00  1               ;              epilogue. POSTNIBBLE later recombines the two half-buffers into the user buffer. [AI]
000B00  1               ; ----------------------------------------------------------------------
000B00  1               READSECT:
000B00  1                       ; retry budget: up to $20 attempts to catch the D5 AA AD data prologue before giving up
000B00  1  A0 20                LDY #$20                         ; retry budget
000B02  1               RD_RETRY:
000B02  1  88                   DEY
000B03  1  F0 63                BEQ RD_FAIL
000B05  1               RD_D5:
000B05  1                       ; spin on the data latch (Q6L) until a full nibble has shifted in (high bit set)
000B05  1  BD 8C C0             LDA $C08C,X
000B08  1  10 FB                BPL RD_D5
000B0A  1               RD_CHK1:
000B0A  1                       ; match the first data-prologue mark D5; any miss re-arms the retry loop
000B0A  1  49 D5                EOR #$D5
000B0C  1  D0 F4                BNE RD_RETRY
000B0E  1  EA                   NOP
000B0F  1               RD_AA:
000B0F  1  BD 8C C0             LDA $C08C,X
000B12  1  10 FB                BPL RD_AA
000B14  1                       ; match the second data-prologue mark AA (re-sync to the D5 hunt on a miss)
000B14  1  C9 AA                CMP #$AA
000B16  1  D0 F2                BNE RD_CHK1
000B18  1  A0 56                LDY #$56
000B1A  1               RD_AD:
000B1A  1  BD 8C C0             LDA $C08C,X
000B1D  1  10 FB                BPL RD_AD
000B1F  1                       ; match the third data-prologue mark AD: D5 AA AD complete, the data field follows
000B1F  1  C9 AD                CMP #$AD
000B21  1  D0 E7                BNE RD_CHK1
000B23  1  EA                   NOP
000B24  1  EA                   NOP
000B25  1  A9 00                LDA #$00
000B27  1               RD_SEC2:
000B27  1                       ; read the 86 secondary (low 2-bit) nibbles into NIBBUF[$55..$00], counting down
000B27  1  88                   DEY
000B28  1  84 26                STY $26
000B2A  1               RD_SEC2B:
000B2A  1                       ; fetch the next raw disk nibble into Y as the index into the read-translate tail of WRTRANS
000B2A  1  BC 8C C0             LDY $C08C,X
000B2D  1  10 FB                BPL RD_SEC2B
000B2F  1                       ; translate-and-accumulate: XOR running value with read-translate[nibble] (NIBBUF base, Y in
000B2F  1                       ; $96..$FF)
000B2F  1  59 00 0D             EOR NIBBUF,Y                     ; via read-translate table
000B32  1  A4 26                LDY $26
000B34  1                       ; store the decoded secondary nibble into NIBBUF[buffer index in $26]
000B34  1  99 00 0D             STA NIBBUF,Y
000B37  1  D0 EE                BNE RD_SEC2
000B39  1               RD_MAIN:
000B39  1  84 26                STY $26
000B3B  1               RD_MAINB:
000B3B  1                       ; main loop: read the 256 primary (6-bit) nibbles, decoding into SECBUF2[$00..$FF]
000B3B  1  BC 8C C0             LDY $C08C,X
000B3E  1  10 FB                BPL RD_MAINB
000B40  1  59 00 0D             EOR NIBBUF,Y
000B43  1  A4 26                LDY $26
000B45  1                       ; store the decoded primary byte into SECBUF2[buffer index in $26]
000B45  1  99 00 09             STA SECBUF2,Y
000B48  1  C8                   INY
000B49  1  D0 EE                BNE RD_MAIN
000B4B  1               RD_CKSUM:
000B4B  1  BC 8C C0             LDY $C08C,X
000B4E  1  10 FB                BPL RD_CKSUM
000B50  1                       ; checksum: the final accumulated value must equal the translated disk checksum nibble, else
000B50  1                       ;           fail
000B50  1  D9 00 0D             CMP NIBBUF,Y                     ; checksum check
000B53  1  D0 13                BNE RD_FAIL
000B55  1               RD_DE:
000B55  1  BD 8C C0             LDA $C08C,X                      ; data epilogue DE AA
000B58  1  10 FB                BPL RD_DE
000B5A  1                       ; verify the first data-epilogue mark DE
000B5A  1  C9 DE                CMP #$DE
000B5C  1  D0 0A                BNE RD_FAIL
000B5E  1  EA                   NOP
000B5F  1               RD_DE2:
000B5F  1  BD 8C C0             LDA $C08C,X
000B62  1  10 FB                BPL RD_DE2
000B64  1                       ; verify the second data-epilogue mark AA; on match branch to RDADDR_OK (carry clear =
000B64  1                       ; success)
000B64  1  C9 AA                CMP #$AA
000B66  1  F0 5C                BEQ RDADDR_OK
000B68  1               RD_FAIL:
000B68  1                       ; shared read-error exit (also reached from READADDR): carry set signals a read failure to
000B68  1                       ; RWTS
000B68  1  38                   SEC                              ; carry set = error
000B69  1  60                   RTS
000B6A  1               
000B6A  1               ; ----------------------------------------------------------------------
000B6A  1               ; READADDR -- find and verify the next address field on the current track
000B6A  1               ;   In:        X = slot*16 (indexes the Disk II data latch $C08C,X); the head
000B6A  1               ;              is positioned over the target track and the disk is spinning in
000B6A  1               ;              read mode (set up by the RWTS_RW caller).
000B6A  1               ;   Out:       carry CLEAR (falls into RDADDR_OK) on a good address field, with
000B6A  1               ;              the four decoded fields stored at $2C..$2F = cksum/sector/track/
000B6A  1               ;              volume; carry SET (via the shared RD_FAIL exit, $0B68) on search
000B6A  1               ;              timeout or any prologue / checksum / epilogue mismatch.
000B6A  1               ;   Clobbers:  A, Y; scratch ZP cells $26 (search-timeout high byte, then the
000B6A  1               ;              rotated odd-nibble holder) and $27 (running odd/even checksum);
000B6A  1               ;              result cells $2C..$2F.
000B6A  1               ;   Algorithm: Spin reading raw nibbles, hunting the D5 AA 96 address prologue
000B6A  1               ;              under a 16-bit search budget (Y counts up from $FC, $26 its high
000B6A  1               ;              byte; budget exhausted -> RD_FAIL). Then read four 4-and-4
000B6A  1               ;              ('odd/even') encoded fields -- volume, track, sector, checksum --
000B6A  1               ;              each as two nibbles: the odd nibble is shifted left (ROL) to
000B6A  1               ;              supply the high bits and ANDed with the even nibble to rebuild
000B6A  1               ;              the byte, stored descending into $2F,$2E,$2D,$2C. A running XOR
000B6A  1               ;              checksum in $27 must come out zero. Finally verify the DE AA
000B6A  1               ;              address-field epilogue.
000B6A  1               ; ----------------------------------------------------------------------
000B6A  1               READADDR:
000B6A  1                       ; seed the prologue-search budget: Y counts up from $FC via INY and $26 holds its high byte,
000B6A  1                       ; giving a bounded 16-bit scan for the D5 AA 96 mark
000B6A  1  A0 FC                LDY #$FC
000B6C  1  84 26                STY $26
000B6E  1               RA_NEXT:
000B6E  1  C8                   INY
000B6F  1  D0 04                BNE RA_D5
000B71  1  E6 26                INC $26
000B73  1  F0 F3                BEQ RD_FAIL                      ; timeout -> error
000B75  1               RA_D5:
000B75  1                       ; spin reading raw nibbles from the data latch until one arrives (high bit set)
000B75  1  BD 8C C0             LDA $C08C,X                      ; address prologue D5 AA 96
000B78  1  10 FB                BPL RA_D5
000B7A  1               RA_CHK:
000B7A  1                       ; match the first address-prologue nibble D5; on mismatch loop back via RA_NEXT and keep
000B7A  1                       ; hunting
000B7A  1  C9 D5                CMP #$D5
000B7C  1  D0 F0                BNE RA_NEXT
000B7E  1  EA                   NOP
000B7F  1               RA_AA:
000B7F  1  BD 8C C0             LDA $C08C,X
000B82  1  10 FB                BPL RA_AA
000B84  1                       ; match the second prologue nibble AA
000B84  1  C9 AA                CMP #$AA
000B86  1  D0 F2                BNE RA_CHK
000B88  1                       ; four address fields to decode (volume, track, sector, checksum): index Y runs 3 down to 0
000B88  1  A0 03                LDY #$03                         ; 4 odd/even fields to read
000B8A  1               RA_96:
000B8A  1  BD 8C C0             LDA $C08C,X
000B8D  1  10 FB                BPL RA_96
000B8F  1                       ; match the address-prologue's third nibble 96 (data fields use AD instead)
000B8F  1  C9 96                CMP #$96
000B91  1  D0 E7                BNE RA_CHK
000B93  1  A9 00                LDA #$00
000B95  1               RA_FIELD:
000B95  1                       ; reset / re-store the running odd/even checksum accumulator before each field
000B95  1  85 27                STA $27
000B97  1               RA_ODD:
000B97  1  BD 8C C0             LDA $C08C,X
000B9A  1  10 FB                BPL RA_ODD
000B9C  1                       ; decode one 4-and-4 field: shift the odd nibble left so its bits land in the high (even)
000B9C  1                       ; positions
000B9C  1  2A                   ROL
000B9D  1  85 26                STA $26
000B9F  1               RA_EVEN:
000B9F  1  BD 8C C0             LDA $C08C,X
000BA2  1  10 FB                BPL RA_EVEN
000BA4  1                       ; AND the shifted odd nibble with the even nibble to reconstruct the original data byte
000BA4  1  25 26                AND $26                          ; odd/even -> byte
000BA6  1                       ; store the rebuilt field descending into the IOB quartet: Y=3->$2F volume, 2->$2E track,
000BA6  1                       ; 1->$2D sector, 0->$2C checksum
000BA6  1  99 2C 00             STA $002C,Y                      ; store vol/trk/sec/cksum
000BA9  1                       ; fold the byte into the running XOR checksum (held back into $27 by the next RA_FIELD pass)
000BA9  1  45 27                EOR $27
000BAB  1  88                   DEY
000BAC  1  10 E7                BPL RA_FIELD
000BAE  1                       ; after the last field the folded checksum in A must be zero; nonzero -> RD_FAIL
000BAE  1  A8                   TAY
000BAF  1  D0 B7                BNE RD_FAIL                      ; checksum nonzero -> error
000BB1  1               RA_DE:
000BB1  1  BD 8C C0             LDA $C08C,X                      ; address epilogue DE AA
000BB4  1  10 FB                BPL RA_DE
000BB6  1                       ; verify the address-field epilogue first nibble DE
000BB6  1  C9 DE                CMP #$DE
000BB8  1  D0 AE                BNE RD_FAIL
000BBA  1  EA                   NOP
000BBB  1               RA_DE2:
000BBB  1  BD 8C C0             LDA $C08C,X
000BBE  1  10 FB                BPL RA_DE2
000BC0  1                       ; verify the address-field epilogue second nibble AA, then fall into the shared RDADDR_OK
000BC0  1                       ; success exit
000BC0  1  C9 AA                CMP #$AA
000BC2  1  D0 A4                BNE RD_FAIL
000BC4  1               ; ----------------------------------------------------------------------
000BC4  1               ; RDADDR_OK -- shared success exit for the address- and data-field readers
000BC4  1               ;   In:        reached only after a field passed every prologue / checksum /
000BC4  1               ;              epilogue check.
000BC4  1               ;   Out:       carry CLEAR signalling success; returns to the RWTS search loop.
000BC4  1               ;   Clobbers:  carry only.
000BC4  1               ;   Algorithm: Clear carry and return. Tail-shared by READADDR (good address
000BC4  1               ;              field, fall-through) and by READSECT's data-epilogue check
000BC4  1               ;              (C3 RD_DE2 BEQ RDADDR_OK), so a single CLC+RTS serves both.
000BC4  1               ; ----------------------------------------------------------------------
000BC4  1               RDADDR_OK:
000BC4  1  18                   CLC                              ; carry clear = success
000BC5  1  60                   RTS
000BC6  1               
000BC6  1               ; ----------------------------------------------------------------------
000BC6  1               ; POSTNIBBLE -- recombine the 6-and-2 buffers into the 256-byte user buffer
000BC6  1               ;   In:        SECBUF2 holds the 256 high-6-bit values just read; NIBBUF holds
000BC6  1               ;              the 86 packed low-2-bit groups; (PTRL) points at the caller's
000BC6  1               ;              user buffer; X/Y free.
000BC6  1               ;   Out:       256 fully reconstructed data bytes written through (PTRL),Y.
000BC6  1               ;   Clobbers:  A, X, Y; NIBBUF is consumed (shifted out by the LSR pair).
000BC6  1               ;   Algorithm: For each of the 256 output bytes, take the high-6-bit value from
000BC6  1               ;              SECBUF2,Y and graft on two low bits drawn from the matching
000BC6  1               ;              NIBBUF entry: inner index X cycles $55..$00 (each of the 86
000BC6  1               ;              NIBBUF bytes serves three output bytes), and each visit LSRs two
000BC6  1               ;              low bits out of NIBBUF,X and rolls them into the bottom of the
000BC6  1               ;              value before storing it via (PTRL),Y.
000BC6  1               ; ----------------------------------------------------------------------
000BC6  1               POSTNIBBLE:
000BC6  1                       ; Y walks all 256 output positions
000BC6  1  A0 00                LDY #$00
000BC8  1               @col:
000BC8  1                       ; (re)load the inner NIBBUF index to 86; each NIBBUF byte feeds three output bytes
000BC8  1  A2 56                LDX #$56
000BCA  1               @row:
000BCA  1  CA                   DEX
000BCB  1                       ; X underflowed past 0 -> reload the 86-entry NIBBUF index and continue with the NEXT output
000BCB  1                       ; byte (Y has already advanced)
000BCB  1  30 FB                BMI @col
000BCD  1                       ; fetch the high 6 bits for this output byte
000BCD  1  B9 00 09             LDA SECBUF2,Y
000BD0  1                       ; shift the low-bit pair out of the packed nibble buffer, low bit first...
000BD0  1  5E 00 0D             LSR NIBBUF,X
000BD3  1                       ; ...rolling each bit into the bottom of the value
000BD3  1  2A                   ROL
000BD4  1  5E 00 0D             LSR NIBBUF,X
000BD7  1  2A                   ROL
000BD8  1                       ; store the reconstructed byte into the user buffer
000BD8  1  91 3E                STA (PTRL),Y
000BDA  1  C8                   INY
000BDB  1                       ; loop until Y wraps through all 256 bytes
000BDB  1  D0 ED                BNE @row
000BDD  1  60                   RTS
000BDE  1               
000BDE  1               ; ----------------------------------------------------------------------
000BDE  1               ; SEEK -- step the Disk II arm from the current track to a target track
000BDE  1               ;   In:        A  = target track in half-track units (one phase step = one
000BDE  1               ;                    half-track; see SEEK_TRACK's ASL/LSR track<->half-track [RE])
000BDE  1               ;              X  = slot index (slot*16); forms the $C080,X phase base
000BDE  1               ;              $0478 = current track for this drive (half-track units)
000BDE  1               ;   Out:       arm positioned at the target track; $0478 updated to A
000BDE  1               ;   Clobbers:  A, X (restored to slot via LDX $2B in the phase core), Y,
000BDE  1               ;              $2A (target), $2B (slot), $26 (step counter), $27 (prior track),
000BDE  1               ;              $46/$47 (SEEK_DELAY settle counter)
000BDE  1               ;   Algorithm: Classic DOS-3.3 stepper seek. Each iteration moves the arm one
000BDE  1               ;              half-track toward the target by energizing the next stepper phase
000BDE  1               ;              ON (carry set), waiting PHTAB_ON[Y] settle ticks, then turning the
000BDE  1               ;              previous phase OFF (carry clear) and waiting PHTAB_OFF[Y]. The
000BDE  1               ;              settle index Y = min(steps-taken, steps-remaining) clamped 0..11,
000BDE  1               ;              so total settle is long at the seek ends (accelerate away, decelerate
000BDE  1               ;              in) and short while cruising -- this prevents overshoot. Returns when
000BDE  1               ;              current == target (BEQ SEEK_RET early-out / BEQ SEEK_DONE).
000BDE  1               ; ----------------------------------------------------------------------
000BDE  1               SEEK:
000BDE  1  86 2B                STX $2B                          ; slot index
000BE0  1  85 2A                STA $2A                          ; target track (half-track*2)
000BE2  1                       ; already on the target track? then nothing to do (BEQ SEEK_RET)
000BE2  1  CD 78 04             CMP $0478                        ; current track
000BE5  1  F0 53                BEQ SEEK_RET                     ; already there
000BE7  1  A9 00                LDA #$00
000BE9  1                       ; $26 = steps taken so far (the acceleration ramp counter), start at 0
000BE9  1  85 26                STA $26                          ; step count
000BEB  1               SEEK_LOOP:
000BEB  1  AD 78 04             LDA $0478
000BEE  1                       ; remember the track we are stepping AWAY from (the phase to release later)
000BEE  1  85 27                STA $27                          ; prior track
000BF0  1  38                   SEC
000BF1  1                       ; distance = current - target; carry/sign picks step direction
000BF1  1  E5 2A                SBC $2A
000BF3  1  F0 33                BEQ SEEK_DONE
000BF5  1  B0 07                BCS @out
000BF7  1  49 FF                EOR #$FF                         ; outward...
000BF9  1                       ; target is inward (higher track #): step the arm one half-track up
000BF9  1  EE 78 04             INC $0478
000BFC  1  90 05                BCC @cmp
000BFE  1               @out:
000BFE  1  69 FE                ADC #$FE                         ; ...vs inward
000C00  1                       ; target is outward (lower track #): step the arm one half-track down
000C00  1  CE 78 04             DEC $0478
000C03  1               @cmp:
000C03  1                       ; settle index Y = min(steps-remaining, steps-taken): accelerate early, decelerate near the
000C03  1                       ; target
000C03  1  C5 26                CMP $26
000C05  1  90 02                BCC @lim
000C07  1  A5 26                LDA $26
000C09  1               @lim:
000C09  1                       ; clamp the settle-table index to 0..11 (12-entry tables); >=12 keeps the prior Y
000C09  1  C9 0C                CMP #$0C
000C0B  1  B0 01                BCS @clamp
000C0D  1  A8                   TAY
000C0E  1               @clamp:
000C0E  1                       ; carry SET selects the phase-ON sub-switch (energize the new phase)
000C0E  1  38                   SEC
000C0F  1                       ; energize the phase for the half-track we just stepped to (attract the arm)
000C0F  1  20 2C 0C             JSR PHASE_FROM_CURTRK
000C12  1  B9 50 0C             LDA PHTAB_ON,Y                   ; phase-on settle delay
000C15  1  20 3B 0C             JSR SEEK_DELAY
000C18  1  A5 27                LDA $27
000C1A  1                       ; carry CLEAR selects the phase-OFF sub-switch (release the old phase)
000C1A  1  18                   CLC
000C1B  1                       ; de-energize the phase for the prior track ($27); the arm now coasts on
000C1B  1  20 2F 0C             JSR PHASE_SWITCH
000C1E  1  B9 5C 0C             LDA PHTAB_OFF,Y                  ; phase-off settle delay
000C21  1  20 3B 0C             JSR SEEK_DELAY
000C24  1                       ; one more step taken; loop until current reaches target
000C24  1  E6 26                INC $26
000C26  1  D0 C3                BNE SEEK_LOOP
000C28  1               ; ----------------------------------------------------------------------
000C28  1               ; SEEK_DONE -- arm has reached the target track; final settle, then release the phase
000C28  1               ;   In:        $0478 == $2A (target reached); $2B = slot index
000C28  1               ;   Out:       falls through to PHASE_FROM_CURTRK with carry CLEAR to de-energize
000C28  1               ;              the phase holding the current (final) track
000C28  1               ;   Clobbers:  A, X, $46/$47
000C28  1               ;   Algorithm: One last SEEK_DELAY so the head fully stops, then CLC and fall into
000C28  1               ;              PHASE_FROM_CURTRK (carry clear = phase-OFF sub-switch) to drop the
000C28  1               ;              holding phase. Reached by BEQ SEEK_DONE from the loop top.
000C28  1               ; ----------------------------------------------------------------------
000C28  1               SEEK_DONE:
000C28  1                       ; final settle so the arm fully stops before the holding phase is released
000C28  1  20 3B 0C             JSR SEEK_DELAY
000C2B  1                       ; carry CLEAR -> the fall-through to PHASE_FROM_CURTRK hits the OFF sub-switch
000C2B  1  18                   CLC
000C2C  1               ; ----------------------------------------------------------------------
000C2C  1               ; PHASE_FROM_CURTRK -- derive the stepper phase from the CURRENT track, then switch it
000C2C  1               ;   In:        $0478 = current track (half-track units); $2B = slot index;
000C2C  1               ;              CARRY selects the sub-switch: set = phase ON, clear = phase OFF
000C2C  1               ;   Out:       the selected $C080,X stepper soft switch has been touched;
000C2C  1               ;              X restored to the slot index
000C2C  1               ;   Clobbers:  A, X
000C2C  1               ;   Algorithm: Upper entry of the shared phase-switch core: load $0478 as the phase
000C2C  1               ;              source and fall into PHASE_SWITCH. NOTE the historical name PHASE_FROM_CURTRK
000C2C  1               ;              is misleading -- this entry does NOT always turn a phase off; the
000C2C  1               ;              CALLER's carry flag decides (SEEK enters with carry SET at $0C0F to
000C2C  1               ;              energize ON; SEEK_DONE falls in with carry CLEAR to release OFF).
000C2C  1               ; ----------------------------------------------------------------------
000C2C  1               PHASE_FROM_CURTRK:
000C2C  1                       ; phase source = current track; PHASE_SWITCH masks it to a phase 0..3
000C2C  1  AD 78 04             LDA $0478                        ; derive phase from track
000C2F  1               ; ----------------------------------------------------------------------
000C2F  1               ; PHASE_SWITCH -- compute and touch a Disk II stepper-phase soft switch
000C2F  1               ;   In:        A = track whose low 2 bits select the phase (0..3); $2B = slot
000C2F  1               ;              index (slot*16); CARRY = the on/off sub-switch select
000C2F  1               ;   Out:       $C080 + slot + phase*2 + carry has been read (toggles the stepper
000C2F  1               ;              phase on or off); X = slot index on return
000C2F  1               ;   Clobbers:  A, X
000C2F  1               ;   Algorithm: phase = A AND 3; ROL folds CARRY into bit0 so A = phase*2 + (carry);
000C2F  1               ;              OR in the slot index to form the X offset, then touch $C080,X. For
000C2F  1               ;              slot 6 this lands in $C0E0..$C0E7 = PHASE0_OFF..PHASE3_ON [DOC apple2.json].
000C2F  1               ;              Shared by the phase-ON (carry set) and phase-OFF (carry clear) callers;
000C2F  1               ;              SEEK enters here directly (A = prior track $27, carry clear) to release
000C2F  1               ;              the old phase, bypassing the current-track load.
000C2F  1               ; ----------------------------------------------------------------------
000C2F  1               PHASE_SWITCH:
000C2F  1                       ; phase number 0..3 = track mod 4
000C2F  1  29 03                AND #$03
000C31  1                       ; phase*2 with CARRY shifted into bit0 = the on(1)/off(0) sub-switch select
000C31  1  2A                   ROL
000C32  1                       ; OR in the slot index so $C080,X lands on this drive's controller
000C32  1  05 2B                ORA $2B                          ; | slot index
000C34  1  AA                   TAX
000C35  1                       ; touch PHASEn off/on (slot 6 -> $C0E0..$C0E7); $C080 base kept literal = Disk II HW, NOT
000C35  1                       ; the language card at the same addr
000C35  1  BD 80 C0             LDA $C080,X                      ; PHASEn off/on soft switch
000C38  1                       ; restore X = slot index for the caller
000C38  1  A6 2B                LDX $2B
000C3A  1               ; ----------------------------------------------------------------------
000C3A  1               ; SEEK_RET -- shared RTS for SEEK's early-out and the phase-switch core
000C3A  1               ;   In:        none
000C3A  1               ;   Out:       returns to caller
000C3A  1               ;   Algorithm: Single RTS reached by SEEK's BEQ SEEK_RET (already on track) and by
000C3A  1               ;              the fall-through tail of PHASE_SWITCH.
000C3A  1               ; ----------------------------------------------------------------------
000C3A  1               SEEK_RET:
000C3A  1  60                   RTS
000C3B  1               
000C3B  1               ; ----------------------------------------------------------------------
000C3B  1               ; SEEK_DELAY -- busy-wait settle delay between stepper-phase transitions (DOS-3.3 MSWAIT)
000C3B  1               ;   In:        A = outer settle-tick count (from PHTAB_ON / PHTAB_OFF)
000C3B  1               ;   Out:       A = 0 on return; $46/$47 advanced as a 16-bit elapsed counter
000C3B  1               ;              that SATURATES (high byte pinned at $FF instead of wrapping)
000C3B  1               ;   Clobbers:  A, X, $46/$47, flags
000C3B  1               ;   Algorithm: Nested countdown: a 17-iteration inner X loop is one settle unit, then
000C3B  1               ;              a 16-bit INC of $46/$47 ticks an elapsed accumulator (a DEC $47 guard
000C3B  1               ;              undoes a high-byte wrap so it saturates at $FF), then A is decremented;
000C3B  1               ;              repeat until A reaches 0. Calibrated so each unit ~= the phase settle time.
000C3B  1               ; ----------------------------------------------------------------------
000C3B  1               SEEK_DELAY:
000C3B  1                       ; 17-iteration inner busy loop = one settle time unit
000C3B  1  A2 11                LDX #$11
000C3D  1               @inner:
000C3D  1  CA                   DEX
000C3E  1  D0 FD                BNE @inner
000C40  1                       ; advance the 16-bit elapsed accumulator ($46 low, $47 high)
000C40  1  E6 46                INC $46
000C42  1  D0 06                BNE @next
000C44  1  E6 47                INC $47
000C46  1  D0 02                BNE @next
000C48  1                       ; guard: undo the high-byte bump so $47 saturates at $FF instead of wrapping to 0
000C48  1  C6 47                DEC $47
000C4A  1               @next:
000C4A  1  38                   SEC
000C4B  1                       ; one settle unit done; repeat A times then return
000C4B  1  E9 01                SBC #$01
000C4D  1  D0 EC                BNE SEEK_DELAY
000C4F  1  60                   RTS
000C50  1               
000C50  1               ; ----------------------------------------------------------------------
000C50  1               ; PHTAB_ON -- stepper phase-ON settle-delay table (DATA), 12 entries, index 0..11
000C50  1               ;   Layout:    one SEEK_DELAY tick count per ramp index Y = min(steps-taken,
000C50  1               ;              steps-remaining), clamped 0..11. SEEK loads PHTAB_ON[Y] AFTER
000C50  1               ;              energizing the new phase.
000C50  1               ;   Values:    $01,$30,$28,$24,$20,$1E,$1D,$1C,$1C,$1C,$1C,$1C [OBSERVED]. Index 0
000C50  1               ;              ($01) is the FIRST step; the larger early values then decay to a
000C50  1               ;              steady $1C for the cruising mid-seek steps -- the phase-ON half of
000C50  1               ;              the accel/decel profile, paired with PHTAB_OFF [RE].
000C50  1               ;   Note:      pure data; referenced only as PHTAB_ON,Y (relocatable). PHTAB_ON2
000C50  1               ;              labels this table's 7th byte (PHTAB_ON+6).
000C50  1               ; ----------------------------------------------------------------------
000C50  1               PHTAB_ON:
000C50  1  01 30 28 24          .byte   $01, $30, $28, $24, $20, $1E
000C54  1  20 1E        
000C56  1               ; ----------------------------------------------------------------------
000C56  1               ; PHTAB_ON2 -- mid-table marker: the steady-state tail of the phase-ON table
000C56  1               ;   Layout:    $1D,$1C,$1C,$1C,$1C,$1C [OBSERVED] -- NOT a separate table; this is
000C56  1               ;              PHTAB_ON+6, ramp indices 6..11 of the phase-ON settle table.
000C56  1               ;   TEMPORAL OVERLAP [RE, verified]: this label's address $0C56 is ALSO used, as a
000C56  1               ;              raw literal base, by PRENIBBLE's 'ROL $0C56,X' ($0A14 and $0A18).
000C56  1               ;              There X >= $AC so $0C56,X reaches $0D02..$0D55 = the NIBBUF 6+2
000C56  1               ;              secondary nibble buffer -- a base-minus-offset addressing trick into
000C56  1               ;              NIBBUF, NOT a reference to this settle table. The two uses never
000C56  1               ;              collide in time: the settle bytes are read during a SEEK; the ROL
000C56  1               ;              writes happen during PRENIBBLE sector encoding. That PRENIBBLE literal
000C56  1               ;              is intentionally left as $0C56 (it lives outside C5); do NOT relabel it.
000C56  1               ; ----------------------------------------------------------------------
000C56  1               PHTAB_ON2:
000C56  1  1D 1C 1C 1C          .byte   $1D, $1C, $1C, $1C, $1C, $1C
000C5A  1  1C 1C        
000C5C  1               ; ----------------------------------------------------------------------
000C5C  1               ; PHTAB_OFF -- stepper phase-OFF settle-delay table (DATA), 12 entries, index 0..11
000C5C  1               ;   Layout:    one SEEK_DELAY tick count per ramp index Y (same Y as PHTAB_ON).
000C5C  1               ;              SEEK loads PHTAB_OFF[Y] AFTER releasing the old phase.
000C5C  1               ;   Values:    $70,$2C,$26,$22,$1F,$1E,$1D,$1C,$1C,$1C,$1C,$1C [OBSERVED]. Index 0
000C5C  1               ;              ($70) is the long settle on the FIRST step; values decay to a steady
000C5C  1               ;              $1C while cruising -- the phase-OFF half of the accel/decel profile,
000C5C  1               ;              paired with PHTAB_ON [RE].
000C5C  1               ;   Note:      pure data; referenced only as PHTAB_OFF,Y (relocatable).
000C5C  1               ; ----------------------------------------------------------------------
000C5C  1               PHTAB_OFF:
000C5C  1  70 2C 26 22          .byte   $70, $2C, $26, $22, $1F, $1E
000C60  1  1F 1E        
000C62  1  1D 1C 1C 1C          .byte   $1D, $1C, $1C, $1C, $1C, $1C
000C66  1  1C 1C        
000C68  1               
000C68  1  FF FF FF FF          .res    151, $FF                 ; fill ($CFF read-translate -1)
000C6C  1  FF FF FF FF  
000C70  1  FF FF FF FF  
000CFF  1  FF                   .byte   $FF
000D00  1               ; ----------------------------------------------------------------------
000D00  1               ; NIBBUF -- primary 86-byte 6-and-2 nibble scratch buffer; ALSO the index base for the reverse
000D00  1               ; (read) translate window (two non-overlapping temporal tenants)
000D00  1               ;   In:        Data label at $0D00 ($56 bytes). On disk it is $FF fill; it carries meaning only once
000D00  1               ;              the running 6502 RWTS uses it.
000D00  1               ;              As BUFFER:  indices X/Y = $00..$55 (the 86 two-bit groups of a 256-byte sector).
000D00  1               ;              As READ-XLATE BASE: index Y = a raw disk nibble $96..$FF read from the Disk II data
000D00  1               ;              latch ($C08C,X).
000D00  1               ;   Out:       As BUFFER:  the packed low-2-bit halves of the sector (PRENIBBLE fills/clears it;
000D00  1               ;              POSTNIBBLE consumes it).
000D00  1               ;              As READ-XLATE BASE: NIBBUF,Y for Y in $96..$FF resolves to $0D96..$0DFF (the tail of
000D00  1               ;              WRTRANS), giving disk nibble -> 6-bit value.
000D00  1               ;   Clobbers:  n/a (data region).
000D00  1               ;   Algorithm: [RE] Two NON-overlapping temporal tenants share this $0D00 base. (1) RUNTIME BUFFER:
000D00  1               ;              PRENIBBLE clears
000D00  1               ;              NIBBUF[$00..$55] ($0A04); WRITESECT reads it via LDA NIBBUF,Y / EOR NIBBUF-1,Y;
000D00  1               ;              READSECT stores into it
000D00  1               ;              ($0B34) and checks the checksum cell ($0B50); POSTNIBBLE shifts it out ($0BD0/$0BD4).
000D00  1               ;              Only offsets $00..$55
000D00  1               ;              are valid buffer cells. (2) READ-TRANSLATE INDEX BASE: a freshly read disk nibble
000D00  1               ;              (always >= $96, high bit
000D00  1               ;              set) goes into Y and is used as EOR/STA/CMP NIBBUF,Y; because Y >= $96, NIBBUF,Y
000D00  1               ;              addresses $0D96.. = the
000D00  1               ;              upper third of WRTRANS, whose bytes there are the INVERSE map (disk nibble -> 6-bit
000D00  1               ;              value). The two uses
000D00  1               ;              never collide: buffer cells are $0D00..$0D55, valid disk nibbles index $0D96..$0DFF.
000D00  1               ;              OBSERVED: the whole
000D00  1               ;              region is $FF on disk; it gains meaning only after the running RWTS writes the buffer
000D00  1               ;              cells and the WRTRANS
000D00  1               ;              data backs the reverse-translate window.
000D00  1               ; ----------------------------------------------------------------------
000D00  1               NIBBUF:
000D00  1                       ; The 86 ($56) primary-buffer cells $0D00..$0D55 (one per 2-bit group of a 256-byte sector).
000D00  1                       ; $FF on disk; cleared/filled by the running RWTS (PRENIBBLE/READSECT) and never read as the
000D00  1                       ; on-disk $FF.
000D00  1  FF FF FF FF          .res    86, $FF                  ; primary 6+2 nibble buffer
000D04  1  FF FF FF FF  
000D08  1  FF FF FF FF  
000D56  1               
000D56  1               ; ----------------------------------------------------------------------
000D56  1               ; WRTRANS -- 6-and-2 GCR nibble translate table; used in BOTH directions (disk write and disk read)
000D56  1               ;   In:        WRITE direction: LDA WRTRANS,X with X = a 6-bit code 0..63 (a packed 6+2 group).
000D56  1               ;              READ direction:  reached as NIBBUF($0D00)+Y for Y = a disk nibble $96..$FF (i.e.
000D56  1               ;              WRTRANS+$40..).
000D56  1               ;   Out:       WRITE: A = the legal disk nibble ($96..$FF) for that 6-bit code.
000D56  1               ;              READ:  A (after EOR) = the recovered 6-bit code 0..63 for that disk nibble.
000D56  1               ;   Clobbers:  n/a (data region).
000D56  1               ;   Algorithm: [RE] A single 170-byte data table ($0D56..$0DFF) encoding the standard Apple 6-and-2
000D56  1               ;              GCR mapping in both
000D56  1               ;              directions over the same bytes. FORWARD (write): WRTRANS[code] = disk nibble; entries
000D56  1               ;              $0D56.. are
000D56  1               ;              $96,$97,$9A,$9B,... so code 0->$96, 1->$97, ...; WRITESECT does LDA WRTRANS,X then
000D56  1               ;              ships A out the latch
000D56  1               ;              ($0A68/$0A7D/$0A90). The 64 forward entries ($0D56..$0D95) are all >= $96 (the legal
000D56  1               ;              GCR nibble set).
000D56  1               ;              REVERSE (read): the tail of the SAME table, entered as NIBBUF,Y for a disk-nibble Y
000D56  1               ;              in $96..$FF (landing at
000D56  1               ;              $0D96..$0DFF = WRTRANS+$40..), holds the inverse map: disk nibble -> 6-bit value
000D56  1               ;              (e.g. the byte at $0D96 is
000D56  1               ;              $00, so nibble $96 decodes to value 0). READSECT uses EOR NIBBUF,Y for this. VERIFIED
000D56  1               ;              self-consistent:
000D56  1               ;              WRTRANS[0]=$96 and NIBBUF[$96]=$00. OBSERVED genuine data (the canonical 6&2 table)
000D56  1               ;              -- NOT code, keep as
000D56  1               ;              .byte. No in-image address operands here, so nothing to relocate; the routines that
000D56  1               ;              index it (WRITESECT,
000D56  1               ;              READSECT) already use the WRTRANS / NIBBUF labels.
000D56  1               ; ----------------------------------------------------------------------
000D56  1               WRTRANS:
000D56  1                       ; Forward map start ($0D56): WRTRANS[6-bit code] -> legal disk nibble. Code 0 -> $96, 1 ->
000D56  1                       ; $97, 2 -> $9A, ... The 64 forward entries ($0D56..$0D95) are all >= $96 (the standard 6&2
000D56  1                       ; GCR nibble set).
000D56  1  96 97 9A 9B          .byte   $96, $97, $9A, $9B, $9D, $9E, $9F, $A6
000D5A  1  9D 9E 9F A6  
000D5E  1  A7 AB AC AD          .byte   $A7, $AB, $AC, $AD, $AE, $AF, $B2, $B3
000D62  1  AE AF B2 B3  
000D66  1  B4 B5 B6 B7          .byte   $B4, $B5, $B6, $B7, $B9, $BA, $BB, $BC
000D6A  1  B9 BA BB BC  
000D6E  1  BD BE BF CB          .byte   $BD, $BE, $BF, $CB, $CD, $CE, $CF, $D3
000D72  1  CD CE CF D3  
000D76  1  D6 D7 D9 DA          .byte   $D6, $D7, $D9, $DA, $DB, $DC, $DD, $DE
000D7A  1  DB DC DD DE  
000D7E  1  DF E5 E6 E7          .byte   $DF, $E5, $E6, $E7, $E9, $EA, $EB, $EC
000D82  1  E9 EA EB EC  
000D86  1  ED EE EF F2          .byte   $ED, $EE, $EF, $F2, $F3, $F4, $F5, $F6
000D8A  1  F3 F4 F5 F6  
000D8E  1  F7 F9 FA FB          .byte   $F7, $F9, $FA, $FB, $FC, $FD, $FE, $FF
000D92  1  FC FD FE FF  
000D96  1                       ; $0D96 = WRTRANS+$40, reached as NIBBUF($0D00),Y for disk nibble Y in $96..$FF: the INVERSE
000D96  1                       ; (read) map, disk nibble -> 6-bit value. The leading $00 means nibble $96 decodes to value
000D96  1                       ; 0; entries for non-legal nibbles are don't-cares the read path never indexes.
000D96  1  00 01 98 99          .byte   $00, $01, $98, $99, $02, $03, $9C, $04
000D9A  1  02 03 9C 04  
000D9E  1  05 06 A0 A1          .byte   $05, $06, $A0, $A1, $A2, $A3, $A4, $A5
000DA2  1  A2 A3 A4 A5  
000DA6  1  07 08 A8 A9          .byte   $07, $08, $A8, $A9, $AA, $09, $0A, $0B
000DAA  1  AA 09 0A 0B  
000DAE  1  0C 0D B0 B1          .byte   $0C, $0D, $B0, $B1, $0E, $0F, $10, $11
000DB2  1  0E 0F 10 11  
000DB6  1  12 13 B8 14          .byte   $12, $13, $B8, $14, $15, $16, $17, $18
000DBA  1  15 16 17 18  
000DBE  1  19 1A C0 C1          .byte   $19, $1A, $C0, $C1, $C2, $C3, $C4, $C5
000DC2  1  C2 C3 C4 C5  
000DC6  1  C6 C7 C8 C9          .byte   $C6, $C7, $C8, $C9, $CA, $1B, $CC, $1C
000DCA  1  CA 1B CC 1C  
000DCE  1  1D 1E D0 D1          .byte   $1D, $1E, $D0, $D1, $D2, $1F, $D4, $D5
000DD2  1  D2 1F D4 D5  
000DD6  1  20 21 D8 22          .byte   $20, $21, $D8, $22, $23, $24, $25, $26
000DDA  1  23 24 25 26  
000DDE  1  27 28 E0 E1          .byte   $27, $28, $E0, $E1, $E2, $E3, $E4, $29
000DE2  1  E2 E3 E4 29  
000DE6  1  2A 2B E8 2C          .byte   $2A, $2B, $E8, $2C, $2D, $2E, $2F, $30
000DEA  1  2D 2E 2F 30  
000DEE  1  31 32 F0 F1          .byte   $31, $32, $F0, $F1, $33, $34, $35, $36
000DF2  1  33 34 35 36  
000DF6  1  37 38 F8 39          .byte   $37, $38, $F8, $39, $3A, $3B, $3C, $3D
000DFA  1  3A 3B 3C 3D  
000DFE  1  3E 3F                .byte   $3E, $3F
000E00  1               
000E00  1               ; ============================================================================
000E00  1               ;  RWTS dispatch / controller front end  ($0E00..$0FFC)
000E00  1               ; ============================================================================
000E00  1               
000E00  1               ; ----------------------------------------------------------------------
000E00  1               ; RWTS_ENTRY -- published RWTS read entry vector ($0E00)
000E00  1               ;   In:        (none -- a fixed jump vector)
000E00  1               ;   Out:       transfers control to RWTS_TOP, which reads the CP/M
000E00  1               ;              system image off track 0 into memory
000E00  1               ;   Clobbers:  (none here; RWTS_TOP / RWTS_RW do the work)
000E00  1               ;   Algorithm: A fixed 3-byte JMP at the very top of the RWTS dispatch
000E00  1               ;              page so callers (and BOOT0's stage-2) have a stable entry
000E00  1               ;              address regardless of how the routines below are laid out.
000E00  1               ; ----------------------------------------------------------------------
000E00  1               RWTS_ENTRY:
000E00  1  4C AD 0F             JMP RWTS_TOP                     ; top-level read entry
000E03  1               
000E03  1               ; ----------------------------------------------------------------------
000E03  1               ; RWTS_DOIO -- IRQ-safe Language-Card-bank wrapper around one RWTS op ($0E03)
000E03  1               ;   In:        the RWTS-IOB caller cells ($03E0-$03EB) already filled in by
000E03  1               ;              the caller (track/sector/drive/slot/buffer/command)
000E03  1               ;              [DOC CPM_SoftCard_RWTS_IOB ; facts sec.RWTS-IOB]
000E03  1               ;   Out:       RWTS_RW's result; carry + the IOB status cell $03EA
000E03  1               ;              (DSK_STATUS: 0=OK / error code) reflect the outcome
000E03  1               ;   Clobbers:  A, X, Y, processor status; Disk II latch + LC bank state
000E03  1               ;   Algorithm: Selects read/write Language-Card RAM bank 2 (the bank the
000E03  1               ;              RWTS code and its sector buffers live in), saves the
000E03  1               ;              caller's IRQ-enable state and masks interrupts so the
000E03  1               ;              cycle-counted GCR read/write is not preempted, runs one
000E03  1               ;              operation via RWTS_RW, then re-selects read-ROM and
000E03  1               ;              restores the prior interrupt state. (Motor-off is NOT done
000E03  1               ;              here -- it happens in RWTS_RW's exit path at $0F45.)
000E03  1               ; ----------------------------------------------------------------------
000E03  1               RWTS_DOIO:
000E03  1                       ; enter the RWTS execution context: select read/write Language-Card RAM bank 2 (where the
000E03  1                       ; RWTS code + nibble buffers reside)
000E03  1  AD 83 C0             LDA $C083                        ; read/write LC bank (RWTS ctx)
000E06  1                       ; save the caller's interrupt-enable state across the operation
000E06  1  08                   PHP
000E07  1                       ; mask interrupts: the GCR read/write loops are cycle-counted bit-banging and must not be
000E07  1                       ; preempted
000E07  1  78                   SEI
000E08  1  20 10 0E             JSR RWTS_RW
000E0B  1                       ; leave the RWTS context: re-select read-ROM with bank-2 write still enabled ($C081 =
000E0B  1                       ; LC_ROM_BANK2_WR) before returning
000E0B  1  AD 81 C0             LDA $C081                        ; restore ROM bank
000E0E  1  28                   PLP
000E0F  1  60                   RTS
000E10  1               
000E10  1               ; ----------------------------------------------------------------------
000E10  1               ; RWTS_RW -- select drive, coast/spin-up, seek to track, then read/write one sector ($0E10)
000E10  1               ;   In:        RWTS-IOB cells [DOC CPM_SoftCard_RWTS_IOB]:
000E10  1               ;                $03E6 DSK_SLOT  = requested controller slot << 4,
000E10  1               ;                $03E4 DSK_DRIVE = requested drive (1 or 2),
000E10  1               ;                $03E0 DSK_TRACK = requested track,
000E10  1               ;                $03E1 DSK_SECTOR= requested logical sector,
000E10  1               ;                $03E8/$03E9 DSK_BUFFER = DMA buffer pointer,
000E10  1               ;                $03EB DSK_COMMAND = 1 read / else write.
000E10  1               ;              $03E5 / $03E7 = the driver's current-DRIVE / current-SLOT
000E10  1               ;              latches (last drive/controller it selected).
000E10  1               ;   Out:       sector transferred to/from the buffer; carry + $03EA
000E10  1               ;              DSK_STATUS hold the result. $03E5/$03E7 updated to the now-
000E10  1               ;              current drive/slot.
000E10  1               ;   Clobbers:  A, X (slot*16), Y; ZP $35/$46/$47; tables $04F8/$05F8/$06F8;
000E10  1               ;              Disk II motor/drive/phase soft switches.
000E10  1               ;   Algorithm: (1) Arm the whole-op ($06F8=2) and per-sector ($04F8=4)
000E10  1               ;              retry budgets. (2) If the requested controller slot differs
000E10  1               ;              from the last one, let the previously-spinning spindle coast
000E10  1               ;              to a stop (so two controllers are never driven at once)
000E10  1               ;              before switching. (3) Select the requested slot, turn its
000E10  1               ;              motor on, and wait for the spindle to reach speed. (4)
000E10  1               ;              Latch the DMA buffer pointer and preset the 16-bit settle
000E10  1               ;              counter; if the requested DRIVE differs from the current
000E10  1               ;              one, flag (via the pushed Z) that an initial head-settle is
000E10  1               ;              needed after the switch. (5) Select drive 1 vs 2 from
000E10  1               ;              $03E4's low bit, fold the half-track parity into $35, run
000E10  1               ;              the initial settle delay only on a drive change, then map
000E10  1               ;              the requested TRACK ($03E0) through SEEK_TRACK (which seeks
000E10  1               ;              the arm) and fall into the sector search/transfer of
000E10  1               ;              cluster C8. RW_* labels below are this routine's internal
000E10  1               ;              control-flow anchors.
000E10  1               ; ----------------------------------------------------------------------
000E10  1               RWTS_RW:
000E10  1  A0 02                LDY #$02
000E12  1                       ; arm the whole-operation retry budget (2 recalibrate-and-retry passes)
000E12  1  8C F8 06             STY $06F8                        ; retry count (whole-op)
000E15  1  A0 04                LDY #$04
000E17  1                       ; arm the per-sector retry budget (4 tries); this drive-0 slot of the $04F8,Y track table is
000E17  1                       ; reused as the retry counter [RE]
000E17  1  8C F8 04             STY $04F8                        ; retry count (per-sector)
000E1A  1                       ; fetch the requested controller slot (DSK_SLOT = slot<<4) into X as the soft-switch base
000E1A  1                       ; index
000E1A  1  AD E6 03             LDA $03E6                        ; requested slot*16
000E1D  1  AA                   TAX
000E1E  1                       ; same controller slot as the last operation? if so skip the coast-down and go straight to
000E1E  1                       ; spin-up
000E1E  1  CD E7 03             CMP $03E7                        ; same drive as last?
000E21  1  F0 1D                BEQ RW_SAMEDRV
000E23  1  8A                   TXA
000E24  1  A8                   TAY
000E25  1                       ; a different controller: load the previously-selected slot<<4 so its spindle can be coasted
000E25  1                       ; down first
000E25  1  AD E7 03             LDA $03E7                        ; prior slot*16
000E28  1  AA                   TAX
000E29  1  98                   TYA
000E2A  1  48                   PHA
000E2B  1                       ; record the requested slot as the new current-slot latch
000E2B  1  8D E7 03             STA $03E7
000E2E  1                       ; put the prior controller into read mode (Q7L) so its read latch can be sampled to detect
000E2E  1                       ; spindle motion
000E2E  1  BD 8E C0             LDA $C08E,X                      ; Q7L on prior drive
000E31  1               RW_WAIT1:
000E31  1                       ; coast-down: require 8 consecutive identical latch reads before declaring the old spindle
000E31  1                       ; stopped
000E31  1  A0 08                LDY #$08
000E33  1  BD 8C C0             LDA $C08C,X
000E36  1               RW_WAIT2:
000E36  1                       ; re-sample the read data latch (Q6L); if it still changes the spindle is turning, so
000E36  1                       ; restart the 8-count
000E36  1  DD 8C C0             CMP $C08C,X                      ; wait for spindle to coast
000E39  1  D0 F6                BNE RW_WAIT1
000E3B  1  88                   DEY
000E3C  1  D0 F8                BNE RW_WAIT2
000E3E  1                       ; old spindle has coasted to a stop: restore the requested slot<<4 into X
000E3E  1  68                   PLA
000E3F  1  AA                   TAX
000E40  1               RW_SAMEDRV:
000E40  1                       ; select read mode (Q7L) on the requested controller, then read Q6L to begin sampling for
000E40  1                       ; spin-up
000E40  1  BD 8E C0             LDA $C08E,X                      ; Q7L (read mode)
000E43  1  BD 8C C0             LDA $C08C,X                      ; Q6L
000E46  1  A0 08                LDY #$08
000E48  1               RW_SPIN:
000E48  1  BD 8C C0             LDA $C08C,X
000E4B  1  48                   PHA
000E4C  1  68                   PLA
000E4D  1  48                   PHA
000E4E  1  68                   PLA
000E4F  1                       ; latch the active slot<<4 ($05F8) -- the current-drive index used throughout the rest of
000E4F  1                       ; the operation
000E4F  1  8E F8 05             STX $05F8                        ; current slot*16
000E52  1                       ; the read latch changed -> the spindle is already up to speed, so stop waiting
000E52  1  DD 8C C0             CMP $C08C,X                      ; spinning yet?
000E55  1  D0 03                BNE RW_GO
000E57  1  88                   DEY
000E58  1  D0 EE                BNE RW_SPIN
000E5A  1               RW_GO:
000E5A  1  08                   PHP
000E5B  1                       ; turn the selected controller's drive motor on (indexed Disk II MOTOR-ON soft switch; slot
000E5B  1                       ; 6 -> $C0E9)
000E5B  1  BD 89 C0             LDA $C089,X                      ; motor on
000E5E  1                       ; latch the caller's DMA buffer pointer (DSK_BUFFER low then high) into the RWTS buffer
000E5E  1                       ; pointer PTRL/PTRH
000E5E  1  AD E8 03             LDA $03E8                        ; buffer pointer low
000E61  1  85 3E                STA PTRL
000E63  1  AD E9 03             LDA $03E9                        ; buffer pointer high
000E66  1  85 3F                STA PTRH
000E68  1                       ; preset the 16-bit seek-settle countdown ($46/$47 = $D8EF), counted up to $0000 by the
000E68  1                       ; RW_SETTLE loop
000E68  1  A9 EF                LDA #$EF                         ; seek settle counter
000E6A  1  85 46                STA $46
000E6C  1  A9 D8                LDA #$D8
000E6E  1  85 47                STA $47
000E70  1                       ; compare the requested DRIVE (DSK_DRIVE) against the driver's current-drive latch to detect
000E70  1                       ; a drive change
000E70  1  AD E4 03             LDA $03E4                        ; target track
000E73  1  CD E5 03             CMP $03E5                        ; current track
000E76  1  F0 07                BEQ RW_NOSEEK
000E78  1                       ; drive changed: record it as the new current-drive latch and flag (Y=0 / PHP) that an
000E78  1                       ; initial head-settle is needed
000E78  1  8D E5 03             STA $03E5
000E7B  1  28                   PLP
000E7C  1  A0 00                LDY #$00
000E7E  1  08                   PHP
000E7F  1               RW_NOSEEK:
000E7F  1  6A                   ROR
000E80  1  90 05                BCC @rd1
000E82  1                       ; select drive 1 vs drive 2 ($C08A/$C08B,X) from the low bit of DSK_DRIVE rotated out into
000E82  1                       ; carry
000E82  1  BD 8A C0             LDA $C08A,X                      ; select drive 1/2
000E85  1  B0 03                BCS @rd2
000E87  1               @rd1:
000E87  1  BD 8B C0             LDA $C08B,X
000E8A  1               @rd2:
000E8A  1                       ; fold the drive-select / half-track-parity bit into $35 (the parity flag SEEK_TRACK/RECAL
000E8A  1                       ; test)
000E8A  1  66 35                ROR $35
000E8C  1  28                   PLP
000E8D  1  08                   PHP
000E8E  1  D0 0B                BNE RW_AFTERSEEK
000E90  1                       ; drive changed: run an initial 7-pass settle delay to let the newly-selected head land
000E90  1                       ; before searching
000E90  1  A0 07                LDY #$07                         ; initial settle delay
000E92  1               @dly:
000E92  1  20 3B 0C             JSR SEEK_DELAY
000E95  1  88                   DEY
000E96  1  D0 FA                BNE @dly
000E98  1  AE F8 05             LDX $05F8
000E9B  1               RW_AFTERSEEK:
000E9B  1                       ; take the requested TRACK (DSK_TRACK) and feed it to SEEK_TRACK, which half-tracks it and
000E9B  1                       ; seeks the arm there
000E9B  1  AD E0 03             LDA $03E0                        ; requested sector
000E9E  1  20 52 0F             JSR SEEK_TRACK                   ; physical interleave
000EA1  1                       ; load the command (DSK_COMMAND); a read (1) of an already-settled track skips the extra
000EA1  1                       ; settle, else fall into RW_SETTLE
000EA1  1  AD EB 03             LDA $03EB
000EA4  1  28                   PLP
000EA5  1  D0 11                BNE RW_FINDSEC
000EA7  1  C9 01                CMP #$01
000EA9  1  F0 0D                BEQ RW_FINDSEC
000EAB  1               RW_SETTLE:
000EAB  1                       ; extra post-seek settle: spin a short inner delay, then count the $46/$47 16-bit counter up
000EAB  1                       ; to zero before the sector search
000EAB  1  A0 12                LDY #$12                         ; extra seek settle
000EAD  1               RW_SETTLE2:
000EAD  1  88                   DEY
000EAE  1  D0 FD                BNE RW_SETTLE2
000EB0  1  E6 46                INC $46
000EB2  1  D0 F7                BNE RW_SETTLE
000EB4  1  E6 47                INC $47
000EB6  1  D0 F3                BNE RW_SETTLE
000EB8  1               ; ----------------------------------------------------------------------
000EB8  1               ; RW_FINDSEC -- arrived on the located track; for a WRITE pre-encode the user buffer, then start the
000EB8  1               ; sector search
000EB8  1               ;   In:        A = command byte (bit0: 1=read, 0=write) loaded from $03EB by the front end; arm
000EB8  1               ;              settled on the target track; $05F8 = current slot*16
000EB8  1               ;   Out:       falls into RW_REARM with the read/write decision pushed (PHP) for RW_SECOK to consume
000EB8  1               ;   Clobbers:  A, processor status (saved/restored via the stack); on the write path the secondary
000EB8  1               ;              nibble buffer (via PRENIBBLE)
000EB8  1               ;   Algorithm: ROR shifts the command's bit0 into carry and PHP saves it as the read/write flag.
000EB8  1               ;              Carry set (read) skips
000EB8  1               ;              straight to the search; carry clear (write) first calls PRENIBBLE to 6-and-2
000EB8  1               ;              pre-encode the caller's buffer
000EB8  1               ;              so WRITESECT can stream it out. [RE] command-byte bit0 semantics inferred from the
000EB8  1               ;              $03EB front-end writes.
000EB8  1               ; ----------------------------------------------------------------------
000EB8  1               RW_FINDSEC:
000EB8  1                       ; shift the command's bit0 into carry (1 = read, 0 = write); PHP saves it for the
000EB8  1                       ; post-search read/write dispatch
000EB8  1  6A                   ROR
000EB9  1  08                   PHP
000EBA  1                       ; read request: nothing to encode, go straight to the sector search
000EBA  1  B0 03                BCS RW_REARM
000EBC  1                       ; write request: 6-and-2 pre-encode the caller's buffer into the secondary nibble buffer for
000EBC  1                       ; WRITESECT
000EBC  1  20 00 0A             JSR PRENIBBLE
000EBF  1               ; ----------------------------------------------------------------------
000EBF  1               ; RW_REARM -- (re)arm the per-track sector-search budget
000EBF  1               ;   In:        none
000EBF  1               ;   Out:       $0578 = $30 (48) address-field reads allowed before recalibrating this pass
000EBF  1               ;   Clobbers:  Y, $0578
000EBF  1               ;   Algorithm: Reset the sector-search countdown. Entered from RW_FINDSEC and re-entered (JMP
000EBF  1               ;              RW_REARM) from RW_RESEEK
000EBF  1               ;              after a recalibrate, so each fresh seek gets a full search budget.
000EBF  1               ; ----------------------------------------------------------------------
000EBF  1               RW_REARM:
000EBF  1                       ; allow up to $30 address-field reads to find the wanted sector before recalibrating
000EBF  1  A0 30                LDY #$30                         ; sector-search budget
000EC1  1  8C 78 05             STY $0578
000EC4  1               ; ----------------------------------------------------------------------
000EC4  1               ; RW_SEARCH -- read the next address field off the spinning track
000EC4  1               ;   In:        $05F8 = current slot*16; $0578 = remaining search budget
000EC4  1               ;   Out:       on success (carry clear from READADDR) the decoded volume/track/sector/checksum are
000EC4  1               ;              in $2F/$2E/$2D/$2C and
000EC4  1               ;              control falls to RW_GOTADDR; on failure (carry set) falls to RW_RETRY
000EC4  1               ;   Clobbers:  X, A, Y, $2C-$2F, $26/$27 (READADDR scratch)
000EC4  1               ;   Algorithm: Reload the slot index and call READADDR to scan for and decode one D5 AA 96 address
000EC4  1               ;              field; the carry flag
000EC4  1               ;              reports success/failure for the caller to branch on.
000EC4  1               ; ----------------------------------------------------------------------
000EC4  1               RW_SEARCH:
000EC4  1  AE F8 05             LDX $05F8
000EC7  1                       ; scan the track for the next address field (D5 AA 96 ...) and decode
000EC7  1                       ; volume/track/sector/checksum into $2F/$2E/$2D/$2C
000EC7  1  20 6A 0B             JSR READADDR                     ; read address field
000ECA  1                       ; got a valid address field -> check whether it is the track/sector we want
000ECA  1  90 24                BCC RW_GOTADDR
000ECC  1               ; ----------------------------------------------------------------------
000ECC  1               ; RW_RETRY -- charge one search attempt; loop until the per-track budget is spent
000ECC  1               ;   In:        $0578 = remaining search budget
000ECC  1               ;   Out:       branches back to RW_SEARCH while budget remains; falls into RW_RECAL when exhausted
000ECC  1               ;   Clobbers:  $0578
000ECC  1               ;   Algorithm: Decrement the search countdown; while it stays non-negative keep scanning the same
000ECC  1               ;              track. This is the common
000ECC  1               ;              landing spot for every miss (bad address field, wrong volume, wrong sector, or a read
000ECC  1               ;              CRC error).
000ECC  1               ; ----------------------------------------------------------------------
000ECC  1               RW_RETRY:
000ECC  1                       ; one search attempt consumed
000ECC  1  CE 78 05             DEC $0578
000ECF  1                       ; budget left: keep scanning this track for the wanted sector
000ECF  1  10 F3                BPL RW_SEARCH
000ED1  1               ; ----------------------------------------------------------------------
000ED1  1               ; RW_RECAL -- the track is unreadable; recalibrate the arm and re-seek (bounded by the whole-op
000ED1  1               ; budget)
000ED1  1               ;   In:        $0478,(drive) = believed current track; $06F8 = whole-op recal budget; $35 =
000ED1  1               ;              half-track parity
000ED1  1               ;   Out:       on budget exhaustion -> RW_HARDFAIL (error $40); otherwise reseeds the per-sector
000ED1  1               ;              retry count and falls into
000ED1  1               ;              RW_RESEEK to re-arm and search again
000ED1  1               ;   Clobbers:  A, X, Y, the stack (one saved track byte), $04F8, the per-drive track cells
000ED1  1               ;              $0478/$04F8 (via RECAL/SEEK_TRACK)
000ED1  1               ;   Algorithm: Save the current track, then RECAL with A=$60 -- this seeds a high phantom
000ED1  1               ;              current-track value so the next seek
000ED1  1               ;              steps the head all the way back toward track 0 (a recalibrate). Decrement the
000ED1  1               ;              whole-op budget and bail to
000ED1  1               ;              RW_HARDFAIL at zero; else reset the per-sector retry count to 4, re-run the sector
000ED1  1               ;              translation, and re-seek. [RE]
000ED1  1               ; ----------------------------------------------------------------------
000ED1  1               RW_RECAL:
000ED1  1                       ; remember the track we believe we are on so we can return to it after recalibrating
000ED1  1  AD 78 04             LDA $0478                        ; recalibrate on repeated miss
000ED4  1  48                   PHA
000ED5  1  A9 60                LDA #$60
000ED7  1                       ; A=$60 seeds a high phantom current-track so the next seek steps the head hard toward track
000ED7  1                       ; 0 (recalibrate)
000ED7  1  20 84 0F             JSR RECAL
000EDA  1                       ; spend one whole-operation recalibrate attempt
000EDA  1  CE F8 06             DEC $06F8
000EDD  1                       ; out of recal attempts: give up with a hard error
000EDD  1  F0 28                BEQ RW_HARDFAIL
000EDF  1  A9 04                LDA #$04
000EE1  1                       ; reset the per-sector retry count to 4 for the upcoming re-seek
000EE1  1  8D F8 04             STA $04F8
000EE4  1  A9 00                LDA #$00
000EE6  1                       ; re-run the logical->physical sector translation (its tail re-seeks)
000EE6  1  20 52 0F             JSR SEEK_TRACK
000EE9  1  68                   PLA
000EEA  1               ; ----------------------------------------------------------------------
000EEA  1               ; RW_RESEEK -- re-seek to the saved track, then re-arm the search
000EEA  1               ;   In:        A = saved track (PLA'd by the caller); $35 = half-track parity
000EEA  1               ;   Out:       JMP RW_REARM to restart the sector search on this track
000EEA  1               ;   Clobbers:  A, X, Y, the per-drive track cells $0478/$04F8, $2E (via SEEK_TRACK)
000EEA  1               ;   Algorithm: Translate the saved track through the current parity (SEEK_TRACK, whose tail issues
000EEA  1               ;              the physical seek), then
000EEA  1               ;              jump back to re-arm the per-track search budget. Entered from RW_RECAL and from
000EEA  1               ;              RW_GOTADDR's wrong-track path.
000EEA  1               ; ----------------------------------------------------------------------
000EEA  1               RW_RESEEK:
000EEA  1                       ; translate + physically seek to the saved track
000EEA  1  20 52 0F             JSR SEEK_TRACK
000EED  1                       ; restart the sector search with a fresh budget
000EED  1  4C BF 0E             JMP RW_REARM                     ; re-arm (LDY #$30 at @noseek2)
000EF0  1               ; ----------------------------------------------------------------------
000EF0  1               ; RW_GOTADDR -- an address field decoded cleanly; confirm it is on the track we want
000EF0  1               ;   In:        $2E = address-field track; $0478,(drive) = current/target track
000EF0  1               ;   Out:       on a track match -> RW_ONTRACK; on a mismatch, step toward the correct track and
000EF0  1               ;              re-seek (RW_RESEEK) or, when
000EF0  1               ;              the per-sector retries are spent, recalibrate (RW_RECAL)
000EF0  1               ;   Clobbers:  A, Y, X, the stack (one saved track byte), $04F8
000EF0  1               ;   Algorithm: Compare the track read from the disk header ($2E) against the wanted track. If equal,
000EF0  1               ;              proceed to the volume/
000EF0  1               ;              sector check. If not, the head drifted: RECAL from the actual track toward the wanted
000EF0  1               ;              one and, while per-sector
000EF0  1               ;              retries remain, re-seek; otherwise fall back to a full recalibrate.
000EF0  1               ; ----------------------------------------------------------------------
000EF0  1               RW_GOTADDR:
000EF0  1                       ; track number read from the address field (READADDR put volume/track/sector/cksum in
000EF0  1                       ; $2F/$2E/$2D/$2C)
000EF0  1  A4 2E                LDY $2E
000EF2  1                       ; are we positioned on the track we asked for?
000EF2  1  CC 78 04             CPY $0478                        ; on the right track?
000EF5  1  F0 19                BEQ RW_ONTRACK
000EF7  1  AD 78 04             LDA $0478
000EFA  1  48                   PHA
000EFB  1  98                   TYA
000EFC  1                       ; wrong track: step the head from where we actually are toward the wanted track
000EFC  1  20 84 0F             JSR RECAL                        ; step to correct track
000EFF  1  68                   PLA
000F00  1                       ; charge a per-sector retry; re-seek if any remain, else escalate to a full recalibrate
000F00  1  CE F8 04             DEC $04F8
000F03  1  D0 E5                BNE RW_RESEEK
000F05  1  F0 CA                BEQ RW_RECAL
000F07  1               ; ----------------------------------------------------------------------
000F07  1               ; RW_HARDFAIL -- unrecoverable: too many recalibrates without reaching the track
000F07  1               ;   In:        stack holds one track byte pushed by the recal path
000F07  1               ;   Out:       A = $40 (hard/seek error code); falls into RW_RETURN to store status and exit
000F07  1               ;   Clobbers:  A, stack (one PLA balances the pushed track)
000F07  1               ;   Algorithm: Discard the saved track from the stack and load error code $40, then join the common
000F07  1               ;              error return path.
000F07  1               ; ----------------------------------------------------------------------
000F07  1               RW_HARDFAIL:
000F07  1  68                   PLA
000F08  1                       ; error $40 = sector never found / arm could not reach the track
000F08  1  A9 40                LDA #$40                         ; error code
000F0A  1               ; ----------------------------------------------------------------------
000F0A  1               ; RW_RETURN -- common error return: discard the saved read/write flag and store the error status
000F0A  1               ;   In:        A = error code ($40 hard, $20 wrong volume) set by the caller; stack top = the
000F0A  1               ;              read/write flag from RW_FINDSEC
000F0A  1               ;   Out:       jumps into the status-store sequence at RW_STORESTATUS (A -> $03EA), motor off, RTS
000F0A  1               ;   Clobbers:  processor status (PLP balances the pushed read/write flag)
000F0A  1               ;   Algorithm: Pull the read/write flag RW_FINDSEC pushed (not needed on the error path) and JMP to
000F0A  1               ;              RW_STORESTATUS -- the
000F0A  1               ;              mid-byte entry past the BIT-zp cover -- so the error code in A is written to $03EA.
000F0A  1               ; ----------------------------------------------------------------------
000F0A  1               RW_RETURN:
000F0A  1                       ; drop the read/write flag RW_FINDSEC pushed; not needed on the error exit
000F0A  1  28                   PLP
000F0B  1  4C 3E 0F             JMP RW_STORESTATUS               ; -> $0F3E (skip into STA $03EA)
000F0E  1               ; ----------------------------------------------------------------------
000F0E  1               ; RW_UNUSED -- UNREACHABLE dead code (verified)
000F0E  1               ;   In:        n/a
000F0E  1               ;   Out:       n/a
000F0E  1               ;   Clobbers:  n/a
000F0E  1               ;   Algorithm: A lone `BEQ RW_OKEXIT` ($0F0E) whose only textual predecessor is the unconditional
000F0E  1               ;              JMP RW_STORESTATUS at $0F0B
000F0E  1               ;              (which never falls through) and to which no branch targets; the bytes are retained
000F0E  1               ;              for byte-identical
000F0E  1               ;              reassembly but are never executed. UNKNOWN whether this is a stale fragment or
000F0E  1               ;              deliberate padding.
000F0E  1               ; ----------------------------------------------------------------------
000F0E  1               RW_UNUSED:
000F0E  1  F0 2A                BEQ RW_OKEXIT
000F10  1               ; ----------------------------------------------------------------------
000F10  1               ; RW_ONTRACK -- on the correct track; verify the disk VOLUME matches the request
000F10  1               ;   In:        $2F = address-field VOLUME; $03E2 = wanted volume (0 = accept any)
000F10  1               ;   Out:       stores the found volume at $03E3; on match (or wanted=0) -> RW_SECOK; on mismatch ->
000F10  1               ;              RW_RETURN with error $20
000F10  1               ;   Clobbers:  A
000F10  1               ;   Algorithm: Record the volume read from the address header, then if a specific volume was
000F10  1               ;              requested compare it; a mismatch
000F10  1               ;              raises error $20 (wrong VOLUME). NOTE: $2F is the VOLUME field -- READADDR stores
000F10  1               ;              volume/track/sector/checksum
000F10  1               ;              into $2F/$2E/$2D/$2C (LDY #$03 down to 0) -- so the sector match happens later in
000F10  1               ;              RW_SECOK against $2D.
000F10  1               ; ----------------------------------------------------------------------
000F10  1               RW_ONTRACK:
000F10  1                       ; volume number from the address field (READADDR put volume in $2F, track $2E, sector $2D,
000F10  1                       ; cksum $2C)
000F10  1  A5 2F                LDA $2F                          ; found sector #
000F12  1                       ; report the volume we actually found
000F12  1  8D E3 03             STA $03E3
000F15  1                       ; wanted volume; 0 means accept any volume
000F15  1  AD E2 03             LDA $03E2
000F18  1                       ; no specific volume requested -> skip the volume check
000F18  1  F0 08                BEQ RW_SECOK
000F1A  1                       ; does the disk's volume match the requested one?
000F1A  1  C5 2F                CMP $2F                          ; is it the one we want?
000F1C  1  F0 04                BEQ RW_SECOK
000F1E  1                       ; error $20 = wrong VOLUME (NOT wrong sector)
000F1E  1  A9 20                LDA #$20                         ; wrong sector
000F20  1  D0 E8                BNE RW_RETURN
000F22  1               ; ----------------------------------------------------------------------
000F22  1               ; RW_SECOK -- right track and volume; confirm this is the wanted sector, then transfer the data
000F22  1               ; field
000F22  1               ;   In:        $03E1 = wanted logical sector; $2D = address-field physical sector; stack top =
000F22  1               ;              read/write flag from
000F22  1               ;              RW_FINDSEC (carry set = read)
000F22  1               ;   Out:       on sector mismatch -> RW_RETRY (keep searching); on a write -> RW_WRITE; on a read,
000F22  1               ;              READSECT then POSTNIBBLE
000F22  1               ;              decode into the user buffer, then fall into RW_OKEXIT
000F22  1               ;   Clobbers:  A, Y, processor status; the nibble buffers and user buffer on transfer
000F22  1               ;   Algorithm: Map the wanted logical sector through SKEWTAB (interleave) to its physical sector and
000F22  1               ;              compare with the
000F22  1               ;              address-field sector $2D; on a match, restore the read/write flag and dispatch: carry
000F22  1               ;              clear -> WRITESECT, else
000F22  1               ;              READSECT the data field (retry on CRC error) and POSTNIBBLE-decode it into the
000F22  1               ;              caller's buffer.
000F22  1               ; ----------------------------------------------------------------------
000F22  1               RW_SECOK:
000F22  1                       ; logical sector the caller asked for
000F22  1  AD E1 03             LDA $03E1                        ; logical sector wanted
000F25  1  A8                   TAY
000F26  1                       ; map logical -> physical sector via the interleave/skew table
000F26  1  B9 9D 0F             LDA SKEWTAB,Y                    ; interleave skew
000F29  1                       ; does the physical sector under the head ($2D) match the one we want?
000F29  1  C5 2D                CMP $2D                          ; matches found sector?
000F2B  1                       ; wrong sector: keep searching this track
000F2B  1  D0 9F                BNE RW_RETRY
000F2D  1  28                   PLP
000F2E  1                       ; restored read/write flag: carry clear -> write the data field
000F2E  1  90 19                BCC RW_WRITE                     ; carry clear -> write op
000F30  1                       ; read + checksum-verify the data field into the nibble buffers
000F30  1  20 00 0B             JSR READSECT                     ; read the data field
000F33  1  08                   PHP
000F34  1                       ; data-field read error: retry the search
000F34  1  B0 96                BCS RW_RETRY
000F36  1  28                   PLP
000F37  1                       ; 6-and-2 decode the nibble buffers into the caller's user buffer
000F37  1  20 C6 0B             JSR POSTNIBBLE                   ; decode into user buffer
000F3A  1               ; ----------------------------------------------------------------------
000F3A  1               ; RW_OKEXIT -- success: set status = 0 and fall through the cover into the store/exit sequence
000F3A  1               ;   In:        none
000F3A  1               ;   Out:       A = $00 (OK), carry clear; falls through the BIT-zp cover into the status store and
000F3A  1               ;              motor-off exit
000F3A  1               ;   Clobbers:  A, carry
000F3A  1               ;   Algorithm: CLC + load status 0; the following unlabeled .byte $24 (BIT-zp cover) harmlessly
000F3A  1               ;              reads ZP $38 on this
000F3A  1               ;              fall-through path, so control reaches STA $03EA and stores OK.
000F3A  1               ; ----------------------------------------------------------------------
000F3A  1               RW_OKEXIT:
000F3A  1  18                   CLC
000F3B  1                       ; completion status = 0 (success)
000F3B  1  A9 00                LDA #$00                         ; status = ok
000F3D  1               ; ----------------------------------------------------------------------
000F3D  1               ; RW_STORESTATUS -- store the completion code and turn the drive motor off (shared store/exit tail)
000F3D  1               ;   In:        A = completion status (0 = OK, $10 write error, $20 wrong volume, $40 hard/seek
000F3D  1               ;              error); $05F8 = slot*16
000F3D  1               ;   Out:       $03EA = status; drive motor off; RTS to the RWTS caller
000F3D  1               ;   Clobbers:  X, A
000F3D  1               ;   Algorithm: Two entries share this tail. The OK path (RW_OKEXIT) falls through the unlabeled
000F3D  1               ;              .byte $24 BIT-zp cover (a no-op read of ZP $38). The error paths JMP/BNE to
000F3D  1               ;              RW_STORESTATUS, the cover's operand byte $38 decoding as SEC (carry is unused by
000F3D  1               ;              STA, so it is inert). Both then STA the status to $03EA, strobe $C088,X to drop the
000F3D  1               ;              motor, and RTS. The dead RW_EXIT label is removed by this cover split.
000F3D  1               ; ----------------------------------------------------------------------
000F3D  1  24                   .byte $24                        ; cover (BIT-zp opcode $24): on the OK fall-through this harmlessly BITs ZP $38, skipping the SEC below
000F3E  1               RW_STORESTATUS:
000F3E  1  38                   SEC                              ; mid-byte entry ($38 = SEC) reached from the error paths (JMP/BNE RW_STORESTATUS); carry is inert here, falls into the status store
000F3F  1  8D EA 03             STA $03EA                        ; store the completion status for the RWTS caller
000F42  1  AE F8 05             LDX $05F8                        ; reload slot*16 to address this drive's soft switches
000F45  1  BD 88 C0             LDA $C088,X                      ; strobe the slot-6 drive MOTOR-OFF soft switch ($C088,X = DISKII_MOTOR_OFF) to spin the drive down
000F48  1  60                   RTS                              ; return to the RWTS caller (RWTS_RW)
000F49  1               ; ----------------------------------------------------------------------
000F49  1               ; RW_WRITE -- write the pre-encoded data field to the located sector
000F49  1               ;   In:        the nibble buffers hold the 6-and-2 pre-encoded sector (from PRENIBBLE); positioned
000F49  1               ;              at the wanted track/
000F49  1               ;              sector; X/$05F8 = slot*16
000F49  1               ;   Out:       on success (carry clear from WRITESECT) -> RW_OKEXIT (status 0); on
000F49  1               ;              write-protect/failure -> store error $10
000F49  1               ;              via RW_STORESTATUS
000F49  1               ;   Clobbers:  A, X, Y, controller state
000F49  1               ;   Algorithm: Call WRITESECT to stream the prologue, encoded data, checksum and epilogue onto the
000F49  1               ;              track. Clear carry means
000F49  1               ;              the write completed; set carry (e.g. write-protected) raises error $10.
000F49  1               ; ----------------------------------------------------------------------
000F49  1               RW_WRITE:
000F49  1                       ; stream the pre-encoded data field (prologue, data, checksum, epilogue) onto the sector
000F49  1  20 25 0A             JSR WRITESECT
000F4C  1                       ; write succeeded -> exit with status OK
000F4C  1  90 EC                BCC RW_OKEXIT
000F4E  1                       ; error $10 = write failed / disk write-protected
000F4E  1  A9 10                LDA #$10                         ; write error code
000F50  1  D0 EC                BNE RW_STORESTATUS               ; -> $0F3E (skip into STA $03EA)
000F52  1               
000F52  1               ; ----------------------------------------------------------------------
000F52  1               ; SEEK_TRACK -- seek to the requested TRACK, in half-track stepper units.
000F52  1               ;   In:        A = desired logical track (whole track #, from $03E0 = DSK_TRACK);
000F52  1               ;              X = slot*16 (for DRIVE_IDX); $35 bit7 = drive parity (set by the
000F52  1               ;              caller's RW_NOSEEK/RECAL path) selects which per-drive table is live.
000F52  1               ;   Out:       arm positioned over the target track; the live current-track cell
000F52  1               ;              $0478 left as a WHOLE-track value (halved back after the seek).
000F52  1               ;   Clobbers:  A, Y, $2E, $0478, $0478,Y/$04F8,Y, plus SEEK's ($26/$27/$2A/$2B).
000F52  1               ;   Algorithm: double the whole track to half-track stepper units (ASL) -- the
000F52  1               ;              phase stepper in SEEK works in half-track increments -- run
000F52  1               ;              SEEK_TRACK_BODY (swap in the live drive's saved track and seek),
000F52  1               ;              then LSR the $0478 bookkeeping cell to restore the whole-track
000F52  1               ;              value. NOTE: this is a TRACK seek, not a sector map -- the prior
000F52  1               ;              name SEEK_TRACK was a mis-NAMING (the caller passes $03E0 = track;
000F52  1               ;              $03E1 is the sector and never reaches here -- the logical->physical
000F52  1               ;              sector skew is applied separately at SKEWTAB, see RW_SECOK).
000F52  1               ; ----------------------------------------------------------------------
000F52  1               SEEK_TRACK:
000F52  1                       ; double the whole-track number into half-track stepper units (SEEK steps in half-track
000F52  1                       ; increments)
000F52  1  0A                   ASL
000F53  1  20 5A 0F             JSR SEEK_TRACK_BODY
000F56  1                       ; halve the live current-track cell back to a whole-track value after the seek
000F56  1  4E 78 04             LSR $0478
000F59  1  60                   RTS
000F5A  1               ; ----------------------------------------------------------------------
000F5A  1               ; SEEK_TRACK_BODY -- swap in the active drive's saved track, then seek to A.
000F5A  1               ;   In:        A = target track (already doubled to half-track units); X = slot*16
000F5A  1               ;              (consumed by DRIVE_IDX); $35 bit7 = drive parity (set by the caller).
000F5A  1               ;   Out:       tail-calls SEEK with $0478 = the chosen drive's prior track so SEEK
000F5A  1               ;              can step from there to A; the new target track is written back into
000F5A  1               ;              that drive's saved-track table for next time.
000F5A  1               ;   Clobbers:  A, Y, $2E, $0478, $0478,Y or $04F8,Y.
000F5A  1               ;   Algorithm: Y = slot index (DRIVE_IDX). $0478,Y and $04F8,Y are the two
000F5A  1               ;              per-slot saved-track tables (one per drive of the slot's pair).
000F5A  1               ;              Using the $35 parity bit, copy the live drive's saved track into
000F5A  1               ;              the single working cell $0478, then stash the new target track
000F5A  1               ;              (held in $2E) back into that same drive's table, and JMP SEEK.
000F5A  1               ; ----------------------------------------------------------------------
000F5A  1               SEEK_TRACK_BODY:
000F5A  1                       ; save the target track across the table juggling (A is reused below)
000F5A  1  85 2E                STA $2E
000F5C  1                       ; Y = slot index, used to address the two per-drive saved-track tables
000F5C  1  20 7D 0F             JSR DRIVE_IDX
000F5F  1                       ; pick the saved track of the live drive: $0478,Y on one parity, $04F8,Y on the other ($35
000F5F  1                       ; bit7)
000F5F  1  B9 78 04             LDA $0478,Y
000F62  1  24 35                BIT $35
000F64  1  30 03                BMI @b1
000F66  1  B9 F8 04             LDA $04F8,Y
000F69  1               @b1:
000F69  1                       ; make it the single working current-track cell that SEEK steps from
000F69  1  8D 78 04             STA $0478
000F6C  1  A5 2E                LDA $2E
000F6E  1  24 35                BIT $35
000F70  1  30 05                BMI @b2
000F72  1                       ; write the new target back into this drive's saved-track table ($35 parity picks $0478,Y vs
000F72  1                       ; $04F8,Y)
000F72  1  99 F8 04             STA $04F8,Y
000F75  1  10 03                BPL @b3
000F77  1               @b2:
000F77  1  99 78 04             STA $0478,Y
000F7A  1               @b3:
000F7A  1                       ; step the arm from $0478 to the target track
000F7A  1  4C DE 0B             JMP SEEK
000F7D  1               
000F7D  1               ; ----------------------------------------------------------------------
000F7D  1               ; DRIVE_IDX -- convert a slot*16 controller index into a 0..15 table index.
000F7D  1               ;   In:        X = slot number << 4 (the $C08x form, e.g. $60 for slot 6).
000F7D  1               ;   Out:       Y = slot number (0..15), the index into the per-drive saved-track
000F7D  1               ;              tables $0478,Y / $04F8,Y.
000F7D  1               ;   Clobbers:  A, Y.
000F7D  1               ;   Algorithm: A = X >> 4 (four LSRs), then TAY. Pure index arithmetic.
000F7D  1               ; ----------------------------------------------------------------------
000F7D  1               DRIVE_IDX:
000F7D  1  8A                   TXA
000F7E  1                       ; shift slot*16 down by 4 bits -> bare slot number (0..15)
000F7E  1  4A                   LSR
000F7F  1  4A                   LSR
000F80  1  4A                   LSR
000F81  1  4A                   LSR
000F82  1                       ; Y = slot index for the per-drive saved-track tables
000F82  1  A8                   TAY
000F83  1  60                   RTS
000F84  1               
000F84  1               ; ----------------------------------------------------------------------
000F84  1               ; RECAL -- record a track as the live drive's current track in the saved-track table.
000F84  1               ;   In:        A = track to record (whole-track units; doubled below). RW_GOTADDR
000F84  1               ;              passes the actually-found track to correct the recorded position;
000F84  1               ;              RW_RECAL passes a large value ($60) to force a deliberate recalibrate.
000F84  1               ;              $03E4 = DSK_DRIVE (its low bit selects parity), X = slot*16.
000F84  1               ;   Out:       the live drive's saved-track table entry ($0478,Y or $04F8,Y) set to
000F84  1               ;              A*2; $35 bit7 = drive parity. Does NOT itself seek -- a later
000F84  1               ;              SEEK_TRACK steps from the now-(re)recorded position; an over-large
000F84  1               ;              recorded value makes that seek slam the head into the track-0 stop
000F84  1               ;              = recalibrate.
000F84  1               ;   Clobbers:  A, Y, $35, $0478,Y or $04F8,Y.
000F84  1               ;   Algorithm: derive the drive parity from DSK_DRIVE's low bit (LDA $03E4 then
000F84  1               ;              ROR A -> carry, then ROR $35 puts it in $35 bit7), get the slot
000F84  1               ;              index (DRIVE_IDX), double the passed track (ASL), and store it into
000F84  1               ;              the matching per-drive saved-track table.
000F84  1               ; ----------------------------------------------------------------------
000F84  1               RECAL:
000F84  1  48                   PHA
000F85  1                       ; DSK_DRIVE: its low bit is the drive parity (which of the slot's two drives)
000F85  1  AD E4 03             LDA $03E4
000F88  1  6A                   ROR
000F89  1                       ; rotate that drive-parity bit into $35 bit7 = the saved-track table selector
000F89  1  66 35                ROR $35
000F8B  1  20 7D 0F             JSR DRIVE_IDX
000F8E  1  68                   PLA
000F8F  1                       ; double the passed track into half-track units to match the saved-track tables
000F8F  1  0A                   ASL
000F90  1  24 35                BIT $35
000F92  1  30 05                BMI @b1
000F94  1                       ; record this track as the live drive's current track (RW_RECAL's over-large value makes the
000F94  1                       ; next seek slam to the track-0 stop = recalibrate)
000F94  1  99 F8 04             STA $04F8,Y
000F97  1  10 03                BPL @b2
000F99  1               @b1:
000F99  1  99 78 04             STA $0478,Y
000F9C  1               @b2:
000F9C  1  60                   RTS
000F9D  1               
000F9D  1               ; ----------------------------------------------------------------------
000F9D  1               ; SKEWTAB -- logical-to-physical sector interleave (skew) table, 16 entries.
000F9D  1               ;   Layout:    indexed by logical sector 0..15 (from $03E1 = DSK_SECTOR, at RW_SECOK),
000F9D  1               ;              yields the physical sector to match against the disk's address header.
000F9D  1               ;   Values:    00 02 04 06 08 0A 0C 0E 01 03 05 07 09 0B 0D 0F -- the 2:1
000F9D  1               ;              (Apple Pascal / ProDOS) interleave SoftCard CP/M uses; NOT DOS 3.3's
000F9D  1               ;              descending skew [DOC CPM_SoftCard_RWTS_IOB.md sec 'Sector interleave'].
000F9D  1               ;   Genuine DATA: kept as .byte; not code, not an in-image address table.
000F9D  1               ; ----------------------------------------------------------------------
000F9D  1               SKEWTAB:
000F9D  1                       ; even physical sectors for logical 0-7 (2:1 Pascal/ProDOS interleave)
000F9D  1  00 02 04 06          .byte   $00, $02, $04, $06, $08, $0A, $0C, $0E
000FA1  1  08 0A 0C 0E  
000FA5  1                       ; odd physical sectors for logical 8-15
000FA5  1  01 03 05 07          .byte   $01, $03, $05, $07, $09, $0B, $0D, $0F
000FA9  1  09 0B 0D 0F  
000FAD  1               
000FAD  1               ; ----------------------------------------------------------------------
000FAD  1               ; RWTS_TOP -- read the CP/M system image off the boot disk into high RAM.
000FAD  1               ;   In:        none (constants set up here). STAGE2 self-patches the sector-count
000FAD  1               ;              operand at $0FCC (the LDA #imm at $0FCB) from $1C to $16 after the
000FAD  1               ;              first call (STA $0FCC at $1106).
000FAD  1               ;   Out:       the requested run of sectors copied into $A400.. (one 256-byte page
000FAD  1               ;              per sector); $03E9 restored to $08 on exit. Loops forever (re-
000FAD  1               ;              printing 'ERR' via PRERR) until every sector reads back clean.
000FAD  1               ;   Clobbers:  A, X, Y, the IOB cells $03E0/$03E1/$03E6/$03E8/$03E9/$03EB/$03E4,
000FAD  1               ;              and everything RWTS_RW/SEEK touch.
000FAD  1               ;   Algorithm: fill the RWTS parameter block -- track=0, drive=1, command=1(read),
000FAD  1               ;              slot 6, buffer=$A400, starting logical sector=11 -- with a sector
000FAD  1               ;              counter in A. For each sector: read it (RWTS_RW); on a miss print
000FAD  1               ;              ERR and restart the whole run; on success advance the buffer one
000FAD  1               ;              page and step the logical sector, wrapping at 16 to sector 0 +
000FAD  1               ;              next track, until the counter hits zero.
000FAD  1               ;   IOB note:  cells follow the boot loader's RWTS block ($03E0-$03EB): $03E0=track,
000FAD  1               ;              $03E1=sector, $03E4=drive, $03E6=slot*16, $03E8/9=buffer ptr,
000FAD  1               ;              $03EB=command (1=read) [DOC CPM_SoftCard_RWTS_IOB.md]. (The existing
000FAD  1               ;              inline 'sector'/'track' trailing notes on $03E0/$03E4 are swapped
000FAD  1               ;              -- see summary.) $A400 is an off-image low-RAM destination, literal.
000FAD  1               ; ----------------------------------------------------------------------
000FAD  1               RWTS_TOP:
000FAD  1                       ; set up the RWTS parameter block: DMA buffer = $A400 (high byte $A4)
000FAD  1  A9 A4                LDA #$A4                         ; buffer high = $A4
000FAF  1  8D E9 03             STA $03E9
000FB2  1  A0 00                LDY #$00
000FB4  1  8C E8 03             STY $03E8                        ; buffer low = $00
000FB7  1                       ; track = 0 (DSK_TRACK; the inline 'sector' note is wrong -- this is the track)
000FB7  1  8C E0 03             STY $03E0                        ; sector = 0
000FBA  1  C8                   INY
000FBB  1                       ; drive = 1 (DSK_DRIVE; the inline 'track' note is wrong -- this is the drive)
000FBB  1  8C E4 03             STY $03E4                        ; track = 1
000FBE  1                       ; command = 1 (read)
000FBE  1  8C EB 03             STY $03EB
000FC1  1  A9 60                LDA #$60
000FC3  1  8D E6 03             STA $03E6                        ; slot 6 (=$60): the disk
000FC6  1                                                        ;        controller for drives A:/B:
000FC6  1                                                        ;        must be in slot 6 [DOC S&HD
000FC6  1                                                        ;        1-3/1-4 ; facts sec.8.9]
000FC6  1                       ; start at logical sector 11
000FC6  1  A9 0B                LDA #$0B
000FC8  1  8D E1 03             STA $03E1                        ; starting logical sector
000FCB  1                       ; sector count = 28 for the first call; STAGE2 self-patches this $0FCC operand to 22 ($16)
000FCB  1                       ; for later calls
000FCB  1  A9 1C                LDA #$1C                         ; sectors-to-read count
000FCD  1               ; ----------------------------------------------------------------------
000FCD  1               ; RWTS_TOP_LP -- per-sector read loop inside RWTS_TOP.
000FCD  1               ;   In:        A = sectors remaining; IOB cells point at the next sector/buffer.
000FCD  1               ;   Out:       on success falls through to RWTS_TOP_OK; on error never returns here
000FCD  1               ;              (restarts the whole run).
000FCD  1               ;   Clobbers:  A (saved/restored across the read), P; plus RWTS_RW's.
000FCD  1               ;   Algorithm: save A and the processor status, mask interrupts (SEI), read one
000FCD  1               ;              sector (RWTS_RW); on success fall to RWTS_TOP_OK; on a read error
000FCD  1               ;              print ERR (PRERR), restore A/P, and JMP RWTS_TOP to restart the
000FCD  1               ;              entire load from the first sector.
000FCD  1               ; ----------------------------------------------------------------------
000FCD  1               RWTS_TOP_LP:
000FCD  1  48                   PHA
000FCE  1  08                   PHP
000FCF  1                       ; mask interrupts so the bit-banged nibble read is not disturbed
000FCF  1  78                   SEI
000FD0  1  20 10 0E             JSR RWTS_RW                      ; read one sector
000FD3  1  90 08                BCC RWTS_TOP_OK
000FD5  1  20 2D FF             JSR PRERR                        ; read error -> "ERR" + bell, retry
000FD8  1  28                   PLP
000FD9  1  68                   PLA
000FDA  1                       ; read failed -- restart the whole load from the first sector
000FDA  1  4C AD 0F             JMP RWTS_TOP
000FDD  1               ; ----------------------------------------------------------------------
000FDD  1               ; RWTS_TOP_OK -- post-read advance: bump buffer + sector, decrement the counter.
000FDD  1               ;   In:        A (pushed on the stack) = sectors remaining; the just-read sector
000FDD  1               ;              landed at the current buffer page.
000FDD  1               ;   Out:       buffer advanced one page; logical sector incremented (wrapping at 16
000FDD  1               ;              to sector 0 and track+1); loops back to RWTS_TOP_LP until the count
000FDD  1               ;              reaches zero, then resets the buffer high byte to $08 and returns.
000FDD  1               ;   Clobbers:  A, X, P, $03E9, $03E1, $03E0.
000FDD  1               ;   Algorithm: INC $03E9 (next page); INX the logical sector, on reaching 16 wrap
000FDD  1               ;              to 0 and INC the track; pull and decrement the counter, loop or end.
000FDD  1               ; ----------------------------------------------------------------------
000FDD  1               RWTS_TOP_OK:
000FDD  1  28                   PLP
000FDE  1                       ; advance the DMA buffer pointer one 256-byte page
000FDE  1  EE E9 03             INC $03E9                        ; next buffer page
000FE1  1  AE E1 03             LDX $03E1                        ; next logical sector
000FE4  1  E8                   INX
000FE5  1                       ; at logical sector 16? wrap to sector 0 on the next track
000FE5  1  E0 10                CPX #$10
000FE7  1  D0 05                BNE @same
000FE9  1  A2 00                LDX #$00                         ; wrap to track+1, sector 0
000FEB  1                       ; sector wrapped -> step the track number (DSK_TRACK)
000FEB  1  EE E0 03             INC $03E0
000FEE  1               @same:
000FEE  1  8E E1 03             STX $03E1
000FF1  1  68                   PLA
000FF2  1  38                   SEC
000FF3  1                       ; one fewer sector to read; loop until the counter hits zero
000FF3  1  E9 01                SBC #$01
000FF5  1  D0 D6                BNE RWTS_TOP_LP
000FF7  1                       ; restore the buffer high byte to $08 (default low-RAM DMA page) before returning
000FF7  1  A9 08                LDA #$08
000FF9  1  8D E9 03             STA $03E9
000FFC  1  60                   RTS
000FFD  1               
000FFD  1  FF FF                .byte   $FF, $FF                 ; fill
000FFF  1  FF                   .byte   $FF                      ; (overwritten at runtime)
001000  1               
001000  1               ; ============================================================================
001000  1               ;  STAGE-2 loader  ($1000..$1188)
001000  1               ;  These are STAGE-2's own instructions; the 6502 runs them once, here, at boot
001000  1               ;  start. Be aware that the RAM at $1000..$100D is then REWRITTEN twice, so over
001000  1               ;  the boot it holds three unrelated pieces of code in turn -- one tenant at a
001000  1               ;  time, never together:
001000  1               ;    1. these STAGE-2 startup instructions       -- run by the 6502 (now)
001000  1               ;    2. SOFTCARD_PROBE_OVL (copied in just below) -- run by the Z-80 during the
001000  1               ;       slot scan (the SoftCard maps the Z-80 reset address $0000 to Apple $1000)
001000  1               ;    3. JMP $AA00 (planted after the system loads) -- run by the Z-80 to enter BIOS
001000  1               ;  The 6502 only ever runs tenant 1; the Z-80 only ever runs tenants 2 and 3.
001000  1               ;  No bytes here are ever executed by both CPUs, or as both 6502 and Z-80.
001000  1               ; ============================================================================
001000  1               
001000  1               ; ----------------------------------------------------------------------
001000  1               ; STAGE2 -- CP/M cold-boot brain: reset console, verify boot slot, classify
001000  1               ;          the peripheral slots, locate the SoftCard, load CP/M, hand to Z-80.
001000  1               ;   In:    Entered by BOOT0 (JMP STAGE2 at $0822) once 11 sectors are loaded.
001000  1               ;          X = slot*16 of the boot controller; the RWTS primitives below it.
001000  1               ;   Out:   Does not return -- ends with JMP $03D2 (the $03C0 6502->Z-80 mode
001000  1               ;          switch), leaving the Z-80 running CP/M from the loaded system image.
001000  1               ;          On error prints a message and JMP MONZ (drops to the monitor).
001000  1               ;   Clobbers: A,X,Y,S; ZP $3C/$3D/$3E/$40/$41; the $02xx/$03xx config block;
001000  1               ;          the $FFFA-$FFFF CPU vectors; the STAGE2 RAM at $1000.
001000  1               ;   Algorithm:
001000  1               ;     1. Stop the boot drive, reset the Apple text screen + COUT/KEYIN hooks,
001000  1               ;        reset the stack, and confirm we booted from slot 6 (else error).
001000  1               ;     2. Copy the Z-80 slot-probe overlay over $1000 and copy the install image
001000  1               ;        ($1200-$13FF) down into the $0200-$03FF I/O config block.
001000  1               ;     3. Scan slots $C7..$C1: write each slot page (SCAN_PROBE) to find the
001000  1               ;        SoftCard (its probe clears $3E), and checksum/signature-classify every
001000  1               ;        other card into the Card Type Table at $02F8+slot.
001000  1               ;     4. Having found the SoftCard, copy the RWTS parameter cells, plant
001000  1               ;        JMP $AA00 at $1000 (the Z-80 BIOS entry), read the CP/M system into
001000  1               ;        memory (RWTS_TOP), patch the RWTS sector count, install the
001000  1               ;        $FFFA-$FFFF reset/NMI/IRQ vectors (all -> $03C0), then JMP $03D2 to
001000  1               ;        switch the machine to the Z-80.
001000  1               ; ----------------------------------------------------------------------
001000  1               STAGE2:
001000  1                       ; read ROM / language-card config back into the ROM bank for the monitor calls below
001000  1  AD 81 C0             LDA $C081                        ; read ROM / LC config
001003  1  AD 81 C0             LDA $C081
001006  1  20 7D 0F             JSR DRIVE_IDX
001009  1  48                   PHA
00100A  1                       ; spin the boot drive's motor off -- the slot scan and CP/M load happen with the drive idle
00100A  1                       ; until RWTS_TOP
00100A  1  9D 88 C0             STA $C088,X                      ; motor off
00100D  1  A9 00                LDA #$00
00100F  1                       ; zero this drive's current-track shadow cells so the next seek recalibrates from track 0
00100F  1  99 78 04             STA $0478,Y                      ; zero current-track tables
001012  1  99 F8 04             STA $04F8,Y
001015  1                       ; put the Apple screen back to text mode + full-screen window and restore the standard
001015  1                       ; COUT/KEYIN I/O hooks
001015  1  20 2F FB             JSR TEXT                         ; text mode + full-screen window
001018  1  20 93 FE             JSR SETVID                       ; CSW -> COUT1 (screen output)
00101B  1  20 89 FE             JSR SETKBD                       ; KSW -> KEYIN (keyboard input)
00101E  1  68                   PLA
00101F  1  A2 FF                LDX #$FF
001021  1                       ; reset the 6502 stack to $01FF before the long boot sequence
001021  1  9A                   TXS                              ; reset stack
001022  1                       ; the loader requires the slot-6 disk controller as the A:/B: boot device; refuse any other
001022  1                       ; slot
001022  1  C9 06                CMP #$06                         ; booted from slot 6? -- the
001024  1                                                        ;        slot-6 disk controller is the
001024  1                                                        ;        required A:/B: boot device
001024  1                                                        ;        [DOC Vol1 1-3/1-4 ; facts sec.8.9]
001024  1  F0 10                BEQ S2_OK
001026  1  A0 00                LDY #$00
001028  1               ; ----------------------------------------------------------------------
001028  1               ; S2_ERR1 -- wrong-slot error: print "MUST BOOT FROM SLOT SIX", then halt.
001028  1               ;   In:    Reached when the boot slot != 6.  Y = 0 on entry.
001028  1               ;   Out:   Falls into S2_ERR1_END (JMP MONZ); never returns to STAGE2.
001028  1               ;   Clobbers: A, Y.
001028  1               ;   Algorithm: COUT each high-bit char of MSG_SLOT6 until the $00 terminator,
001028  1               ;     then drop to the monitor.
001028  1               ; ----------------------------------------------------------------------
001028  1               S2_ERR1:
001028  1                       ; walk the CR-padded slot-6 error string a char at a time (in-image source -> label
001028  1                       ; MSG_SLOT6)
001028  1  B9 4A 11             LDA MSG_SLOT6,Y                  ; "MUST BOOT FROM SLOT SIX"
00102B  1  F0 06                BEQ S2_ERR1_END
00102D  1                       ; emit the char to the screen via the standard output hook
00102D  1  20 ED FD             JSR COUT                         ; print error message char
001030  1  C8                   INY
001031  1  D0 F5                BNE S2_ERR1
001033  1               ; ----------------------------------------------------------------------
001033  1               ; S2_ERR1_END -- give up to the Apple monitor after the slot-6 error.
001033  1               ;   Algorithm: JMP MONZ (monitor cold entry: reset stack, print '*', GETLN).
001033  1               ; ----------------------------------------------------------------------
001033  1               S2_ERR1_END:
001033  1                       ; boot cannot continue -- hand control to the monitor cold-start prompt
001033  1  4C 65 FF             JMP MONZ                         ; drop to the monitor
001036  1               ; ----------------------------------------------------------------------
001036  1               ; S2_OK -- boot slot verified: install the Z-80 slot-probe overlay over $1000.
001036  1               ;   In:    Y is the byte counter (loaded #$0E here).
001036  1               ;   Out:   $1000..$100D hold the slot-probe handshake (13 Z-80 instruction bytes
001036  1               ;          plus the JR offset byte at $100D, which is SIG_BYTE5[0]=$F2).
001036  1               ;   Clobbers: A, Y.
001036  1               ;   Algorithm: copy SOFTCARD_PROBE_OVL[1..14] down to $0FFF+1..$0FFF+14, i.e.
001036  1               ;     $1000..$100D, overwriting STAGE2's own (now-finished) startup bytes with
001036  1               ;     the overlay the Z-80 will run during the slot scan.
001036  1               ; ----------------------------------------------------------------------
001036  1               S2_OK:
001036  1                       ; copy the 14 bytes at SOFTCARD_PROBE_OVL+1..+14 ($1169..$1176); offset 0 of the source is
001036  1                       ; the MSG_SLOT6 $00 terminator (data)
001036  1  A0 0E                LDY #$0E                         ; install Z-80 SoftCard-probe overlay
001038  1               ; ----------------------------------------------------------------------
001038  1               ; S2_INSTOVL -- copy loop for the Z-80 slot-probe overlay.
001038  1               ;   In:    Y = source/dest offset (counts 14 down to 1).
001038  1               ;   Out:   $1000..$100D = the probe overlay; falls into S2_COPYCFG with Y=0.
001038  1               ;   Clobbers: A, Y.
001038  1               ;   Algorithm: LDA SOFTCARD_PROBE_OVL,Y / STA $0FFF,Y down to Y=1.
001038  1               ; ----------------------------------------------------------------------
001038  1               S2_INSTOVL:
001038  1                       ; SOURCE is in-image (label SOFTCARD_PROBE_OVL); DEST $0FFF,Y resolves to $1000.. -- the
001038  1                       ; future Z-80 reset page (DEST kept literal)
001038  1  B9 68 11             LDA SOFTCARD_PROBE_OVL,Y         ; copy +1..+14 -> $1000..$100D
00103B  1  99 FF 0F             STA $0FFF,Y
00103E  1  88                   DEY
00103F  1  D0 F7                BNE S2_INSTOVL
001041  1               ; ----------------------------------------------------------------------
001041  1               ; S2_COPYCFG -- copy the low page of the install image into the config block.
001041  1               ;   In:    Y = 0 on entry (the first iteration copies offset $00, then DEY wraps
001041  1               ;          it to $FF for the rest of the loop).
001041  1               ;   Out:   $0200..$02FF = INSTALL_IMG[$00..$FF] (the $1200 page, all 256 bytes).
001041  1               ;   Clobbers: A, Y.
001041  1               ;   Algorithm: standard byte-page copy $1200->$0200 (Y=$00 first, then $FF..$01
001041  1               ;     via DEY/BNE = all 256 bytes), staging the low half of the I/O
001041  1               ;     Configuration Block the Z-80 reads as 0F200H-0F2FFH after the CPU switch.
001041  1               ; ----------------------------------------------------------------------
001041  1               S2_COPYCFG:
001041  1                       ; SOURCE in-image (INSTALL_IMG = $1200); DEST $0200,Y is low RAM -- the config block, NOT
001041  1                       ; part of this stored image (DEST kept literal)
001041  1  B9 00 12             LDA INSTALL_IMG,Y                ; copy config image lo half
001044  1  99 00 02             STA $0200,Y                      ; $1200..$12FF -> $0200..$02FF
001047  1  88                   DEY
001048  1  D0 F7                BNE S2_COPYCFG
00104A  1  A0 F1                LDY #$F1
00104C  1               ; ----------------------------------------------------------------------
00104C  1               ; S2_COPYCFG2 -- copy the high page of the install image into the config block.
00104C  1               ;   In:    Y = $F1 on entry.
00104C  1               ;   Out:   $0300..$03F0 (via $02FF,Y) = INSTALL_IMG[$100..$1F0] (the $1300.. page).
00104C  1               ;   Clobbers: A, Y.
00104C  1               ;   Algorithm: LDA INSTALL_IMG+$FF,Y / STA $02FF,Y down to Y=1, copying
00104C  1               ;     $1300..$13F0 to $0300..$03F0; the rest of the I/O Configuration Block
00104C  1               ;     ($03xx tail + $03EF.. RWTS cells) is built/copied separately below.
00104C  1               ; ----------------------------------------------------------------------
00104C  1               S2_COPYCFG2:
00104C  1                       ; SOURCE in-image (base INSTALL_IMG+$FF=$12FF, indexed by Y); DEST $02FF,Y is low RAM -- the
00104C  1                       ; config block's high page (DEST kept literal)
00104C  1  B9 FF 12             LDA INSTALL_IMG+$FF,Y            ; copy config image hi half
00104F  1  99 FF 02             STA $02FF,Y                      ; $12FF..$13F0 -> $02FF..$03F0
001052  1  88                   DEY
001053  1  D0 F7                BNE S2_COPYCFG2
001055  1  8C B8 03             STY $03B8                        ; disk-count byte = 0 (Z-80
001058  1                                                        ;        0F3B8H; = #controllers x2)
001058  1                                                        ;        [DOC S&HD 2-27 ; facts sec.3.7]
001058  1  84 3C                STY $3C                          ; scan pointer low = 0
00105A  1  88                   DEY
00105B  1  84 3E                STY $3E                          ; $3E = $FF: the SoftCard-found
00105D  1                                                        ;        flag (cleared to 0 by a slot's
00105D  1                                                        ;        probe handshake, INC'd to 1 once
00105D  1                                                        ;        found -- see $107F / $10C4)
00105D  1  A0 C7                LDY #$C7                         ; scan slots $C7..$C1
00105F  1               ; ----------------------------------------------------------------------
00105F  1               ; S2_SLOTSCAN -- per-slot scan: probe for the SoftCard, else classify the card.
00105F  1               ;   In:    Y = current slot's $Cn high byte (starts $C7, walks down to $C1);
00105F  1               ;          $3E = $FF (SoftCard-not-yet-found flag); $03B8 = 0 (disk count).
00105F  1               ;   Out:   For each slot, either marks the SoftCard (S2_SOFTCARD) or records a
00105F  1               ;          card type at $02F8+slot; loops to S2_STORETYPE then back here.
00105F  1               ;   Clobbers: A, X, Y, $3C/$3D/$3E/$40/$41.
00105F  1               ;   Algorithm: SCAN_PROBE writes the slot page (the SoftCard probe). If $3E was
00105F  1               ;     cleared, the SoftCard lives here -> S2_SOFTCARD. Otherwise twice-checksum
00105F  1               ;     the slot ROM (SUM_ROM); a stable, ROM-present card goes to signature
00105F  1               ;     classification (S2_DISKCTRL), an unstable/absent one is type 0 (S2_HASROM).
00105F  1               ; ----------------------------------------------------------------------
00105F  1               S2_SLOTSCAN:
00105F  1                       ; write this slot's $Cn00 page -- on the SoftCard's slot the write toggles the CPU and the
00105F  1                       ; Z-80 probe overlay clears $3E
00105F  1  20 80 11             JSR SCAN_PROBE                   ; WRITE $Cn00 to probe for SoftCard
001062  1  EA                   NOP
001063  1                       ; $3E was cleared by the probe handshake iff this slot is the SoftCard
001063  1  A5 3E                LDA $3E                          ; the probe's handshake clears $3E
001065  1  F0 18                BEQ S2_SOFTCARD                  ; $3E=0 -> SoftCard found in this slot
001067  1                       ; checksum the slot's $Cn00 ROM page once
001067  1  20 17 11             JSR SUM_ROM                      ; checksum the card ROM
00106A  1  85 40                STA $40
00106C  1  86 41                STX $41
00106E  1                       ; checksum again -- a card whose ROM reads identically twice (X=0, sums match) is a real,
00106E  1                       ; stable ROM card
00106E  1  20 17 11             JSR SUM_ROM                      ; checksum again, compare
001071  1  E0 00                CPX #$00
001073  1  F0 1E                BEQ S2_HASROM
001075  1  C5 40                CMP $40
001077  1  D0 1A                BNE S2_HASROM
001079  1  E4 41                CPX $41
00107B  1                       ; stable ROM present -> go signature-match it against the known card-type table
00107B  1  F0 1A                BEQ S2_DISKCTRL                  ; stable -> classify
00107D  1  D0 14                BNE S2_HASROM
00107F  1               ; ----------------------------------------------------------------------
00107F  1               ; S2_SOFTCARD -- record the SoftCard's slot in the Z$CPU location cell.
00107F  1               ;   In:    Y = the SoftCard slot's $Cn high byte; reached when the probe cleared $3E.
00107F  1               ;   Out:   $3E -> 1 (found); $03C7/$03C8 set; Z$CPU $03DE/$03DF = $En00 form
00107F  1               ;          (low 0, high $En where N = SoftCard slot).  Card type stays 0 below.
00107F  1               ;   Clobbers: A, $3E, $03C7, $03C8, $03DE, $03DF.
00107F  1               ;   Algorithm: flag found, then store the SoftCard's Z-80 I/O page ($Cn + $20 =
00107F  1               ;     $En) into Z$CPU (Apple $03DE/$03DF -> Z-80 0F3DEH) so later code can flip
00107F  1               ;     the CPU by touching that page.  Falls into S2_HASROM (type 0).
00107F  1               ; ----------------------------------------------------------------------
00107F  1               S2_SOFTCARD:
00107F  1                       ; $3E: $FF -> $00 was the probe's clear; INC makes it 1 = "SoftCard found, slot recorded"
00107F  1  E6 3E                INC $3E                          ; mark SoftCard found at $Cn00
001081  1  8C C8 03             STY $03C8
001084  1  A9 00                LDA #$00
001086  1  8D C7 03             STA $03C7
001089  1                       ; Z$CPU low byte = 0 (DEST low RAM; becomes Z-80 0F3DEH after the config copy)
001089  1  8D DE 03             STA $03DE                        ; Z$CPU low byte = 0 -- the
00108C  1                                                        ;        SoftCard-location cell at Z-80
00108C  1                                                        ;        0F3DEH: low byte 0, high byte
00108C  1                                                        ;        of form 0ENH (N = SoftCard slot)
00108C  1                                                        ;        [DOC S&HD 2-24/2-25 ; facts sec.4.3]
00108C  1  98                   TYA
00108D  1  18                   CLC
00108E  1                       ; convert the slot $Cn high byte to the Z-80 I/O page $En (a store to $En00 switches CPUs)
00108E  1  69 20                ADC #$20                         ; form $En high byte ($Cn + $20)
001090  1                       ; Z$CPU high byte = $En -- the SoftCard's CPU-switch page (DEST low RAM)
001090  1  8D DF 03             STA $03DF                        ; Z$CPU high byte = $En
001093  1               ; ----------------------------------------------------------------------
001093  1               ; S2_HASROM -- classify this slot as type 0 (no recognized ROM / not a match).
001093  1               ;   In:    Reached for the SoftCard slot and for unstable/empty slots.
001093  1               ;   Out:   X = 0 (card type 0); branches to S2_STORETYPE to record it.
001093  1               ;   Clobbers: X.
001093  1               ;   Algorithm: set the card type to 0 and store it.
001093  1               ; ----------------------------------------------------------------------
001093  1               S2_HASROM:
001093  1                       ; card type 0 = none/unknown (the SoftCard itself records as 0 here; its slot is tracked via
001093  1                       ; $3E/Z$CPU)
001093  1  A2 00                LDX #$00                         ; card type = unknown/none
001095  1  F0 1F                BEQ S2_STORETYPE
001097  1               ; ----------------------------------------------------------------------
001097  1               ; S2_DISKCTRL -- begin signature classification of a ROM-bearing card.
001097  1               ;   In:    ($3C)/$3D point at the slot's $Cn00 ROM page.
001097  1               ;   Out:   X = 4, the starting index into the SIG_BYTE5/SIG_BYTE7 signature
001097  1               ;          tables; falls into the S2_SIGCMP compare loop.
001097  1               ;   Clobbers: X.
001097  1               ;   Algorithm: seed the signature-table walk; the loop tests ROM bytes $Cn05
001097  1               ;     and $Cn07 against the known card signatures to identify the card type.
001097  1               ; ----------------------------------------------------------------------
001097  1               S2_DISKCTRL:
001097  1                       ; start at signature-table index 4 and walk down, matching $Cn05/$Cn07 against known card
001097  1                       ; types
001097  1  A2 04                LDX #$04                         ; signature compare index
001099  1               ; ----------------------------------------------------------------------
001099  1               ; S2_SIGCMP -- compare a slot ROM's id bytes against one signature entry.
001099  1               ;   In:    X = signature index; ($3C),Y addresses the slot ROM page.
001099  1               ;   Out:   On full match falls to S2_SIGMATCH; else S2_SIGNEXT (try next index).
001099  1               ;   Clobbers: A, Y.
001099  1               ;   Algorithm: read ROM byte $Cn05 and compare SIG_BYTE5[X]; if equal, read
001099  1               ;     $Cn07 and compare SIG_BYTE7[X]; both equal => a recognized card.
001099  1               ; ----------------------------------------------------------------------
001099  1               S2_SIGCMP:
001099  1  A0 05                LDY #$05
00109B  1                       ; fetch ROM identification byte $Cn05 from the slot page
00109B  1  B1 3C                LDA ($3C),Y                      ; ROM byte $Cn05
00109D  1                       ; compare against the SIG_BYTE5 signature (in-image table -> label)
00109D  1  DD 76 11             CMP SIG_BYTE5,X
0010A0  1  D0 09                BNE S2_SIGNEXT
0010A2  1  A0 07                LDY #$07
0010A4  1                       ; byte $Cn05 matched -- now fetch ROM byte $Cn07
0010A4  1  B1 3C                LDA ($3C),Y                      ; ROM byte $Cn07
0010A6  1                       ; and compare against SIG_BYTE7; a match here identifies the card type (index)
0010A6  1  DD 7A 11             CMP SIG_BYTE7,X
0010A9  1  F0 03                BEQ S2_SIGMATCH
0010AB  1               ; ----------------------------------------------------------------------
0010AB  1               ; S2_SIGNEXT -- step to the next signature-table entry.
0010AB  1               ;   In:    X = current signature index.
0010AB  1               ;   Out:   If more entries remain, loops back to S2_SIGCMP; else (X=0) falls into
0010AB  1               ;          S2_SIGMATCH, where INX makes the unmatched-ROM type = 1.
0010AB  1               ;   Clobbers: X.
0010AB  1               ;   Algorithm: DEX; while nonzero retry the compare.
0010AB  1               ; ----------------------------------------------------------------------
0010AB  1               S2_SIGNEXT:
0010AB  1                       ; advance to the next-lower signature index and retry until the table is exhausted
0010AB  1  CA                   DEX
0010AC  1  D0 EB                BNE S2_SIGCMP
0010AE  1               ; ----------------------------------------------------------------------
0010AE  1               ; S2_SIGMATCH -- resolve the matched index to a card type; count disk controllers.
0010AE  1               ;   In:    X = matched signature index (1..4), or 0 if none of the 4 matched.
0010AE  1               ;   Out:   X = card-type value (X+1; an unmatched stable ROM becomes type 1); if
0010AE  1               ;          type 2 (Disk II controller) the disk-count byte $03B8 is bumped.
0010AE  1               ;          Falls into S2_STORETYPE.
0010AE  1               ;   Clobbers: X, $03B8.
0010AE  1               ;   Algorithm: INX turns the signature index into the Card Type Table value; if
0010AE  1               ;     it is 2 (Apple Disk II Controller) increment the controller count.
0010AE  1               ; ----------------------------------------------------------------------
0010AE  1               S2_SIGMATCH:
0010AE  1                       ; convert the signature index into the Card Type Table value (index + 1; unmatched X=0 ->
0010AE  1                       ; type 1)
0010AE  1  E8                   INX
0010AF  1                       ; type 2 = Apple Disk II controller card
0010AF  1  E0 02                CPX #$02                         ; type 2 = Disk II controller?
0010B1  1                                                        ;        (Card Type Table value 2 =
0010B1  1                                                        ;        Apple Disk II Controller)
0010B1  1                                                        ;        [DOC S&HD 2-26/2-27 ; facts sec.3.6]
0010B1  1  D0 03                BNE S2_STORETYPE
0010B3  1                       ; count this disk controller (DEST $03B8 = Z-80 disk-count cell 0F3B8H)
0010B3  1  EE B8 03             INC $03B8                        ; bump disk-count byte (one per
0010B6  1               ; ----------------------------------------------------------------------
0010B6  1               ; S2_STORETYPE -- record this slot's card type and advance the slot scan.
0010B6  1               ;   In:    X = card-type value; $3D = the slot's $Cn high byte.
0010B6  1               ;   Out:   $02F8+slot = card type; loops back to S2_SLOTSCAN until slot $C0.
0010B6  1               ;   Clobbers: A, Y, $02F8,Y.
0010B6  1               ;   Algorithm: store the type at the Card Type Table offset $02F8+slot, then
0010B6  1               ;     walk the slot $Cn high byte down by one and rescan until past $C1 (=$C0).
0010B6  1               ; ----------------------------------------------------------------------
0010B6  1               S2_STORETYPE:
0010B6  1                       ; Y = the current slot's $Cn high byte (the table is indexed by slot)
0010B6  1  A4 3D                LDY $3D                          ; slot # ($Cn high byte)
0010B8  1  8A                   TXA
0010B9  1                       ; Card Type Table entry (DEST $02F8+slot in low RAM -> runtime SLTTYP 0F3B9H, slot S at
0010B9  1                       ; 0F3B8H+S)
0010B9  1  99 F8 02             STA $02F8,Y                      ; Card Type Table entry, install
0010BC  1                                                        ;        offset $02F8+slot -> runtime
0010BC  1                                                        ;        SLTTYP 0F3B9H, slot S at
0010BC  1                                                        ;        0F3B8H+S [DOC S&HD 2-26/2-27 ;
0010BC  1                                                        ;        facts sec.3.6]
0010BC  1  88                   DEY
0010BD  1                       ; stop once we have scanned past slot 1 (Y reaches $C0)
0010BD  1  C0 C0                CPY #$C0                         ; done all 7 slots?
0010BF  1  D0 9E                BNE S2_SLOTSCAN
0010C1  1  0E B8 03             ASL $03B8                        ; disk count *2: the Disk Count
0010C4  1                                                        ;        Byte = #controllers x2 [DOC
0010C4  1                                                        ;        S&HD 2-27 ; facts sec.3.7]
0010C4  1  A5 3E                LDA $3E
0010C6  1  C9 01                CMP #$01                         ; SoftCard found?
0010C8  1  F0 1D                BEQ S2_GOTSOFTCARD
0010CA  1  84 3D                STY $3D
0010CC  1  A9 85                LDA #$85
0010CE  1  85 3C                STA $3C
0010D0  1  8D 85 C0             STA $C085
0010D3  1  A5 3E                LDA $3E
0010D5  1  F0 10                BEQ S2_GOTSOFTCARD
0010D7  1  A0 00                LDY #$00
0010D9  1               ; ----------------------------------------------------------------------
0010D9  1               ; S2_ERR2 -- no-SoftCard error: print "CAN'T FIND Z80 SOFTCARD", then halt.
0010D9  1               ;   In:    Reached when the scan completes and $3E shows no SoftCard. Y=0.
0010D9  1               ;   Out:   Falls into S2_ERR2_END (JMP MONZ); never returns.
0010D9  1               ;   Clobbers: A, Y.
0010D9  1               ;   Algorithm: COUT MSG_NOCARD chars to the $00 terminator, then to the monitor.
0010D9  1               ; ----------------------------------------------------------------------
0010D9  1               S2_ERR2:
0010D9  1                       ; walk the CR-padded no-card error string (in-image source -> label MSG_NOCARD)
0010D9  1  B9 2B 11             LDA MSG_NOCARD,Y                 ; "CAN'T FIND Z80 SOFTCARD"
0010DC  1  F0 06                BEQ S2_ERR2_END
0010DE  1                       ; emit the char via the standard output hook
0010DE  1  20 ED FD             JSR COUT                         ; print message char
0010E1  1  C8                   INY
0010E2  1  D0 F5                BNE S2_ERR2
0010E4  1               ; ----------------------------------------------------------------------
0010E4  1               ; S2_ERR2_END -- give up to the Apple monitor after the no-SoftCard error.
0010E4  1               ;   Algorithm: JMP MONZ (monitor cold entry).
0010E4  1               ; ----------------------------------------------------------------------
0010E4  1               S2_ERR2_END:
0010E4  1                       ; no SoftCard present -- boot cannot continue; hand control to the monitor
0010E4  1  4C 65 FF             JMP MONZ                         ; drop to the monitor
0010E7  1               ; ----------------------------------------------------------------------
0010E7  1               ; S2_GOTSOFTCARD -- SoftCard located: copy RWTS params, plant the Z-80 entry JMP.
0010E7  1               ;   In:    Reached once $3E == 1; the config block ($0200-$03FF) is built.
0010E7  1               ;   Out:   $03EF..$03FF = the RWTS parameter cells; $1000 = C3 00 AA (JMP $AA00).
0010E7  1               ;   Clobbers: A, Y, $03EF,Y, the STAGE2 RAM at $1000-$1002.
0010E7  1               ;   Algorithm: copy the RWTS_PARM block into the live RWTS cells, then plant the
0010E7  1               ;     bytes C3 00 AA at STAGE2..STAGE2+2 ($1000..$1002) so that, after the CPU
0010E7  1               ;     switch, the Z-80 jumps to $AA00 (the BIOS cold entry). Then falls into the
0010E7  1               ;     system load below.
0010E7  1               ;   Tenant note: $1000 is reused over the boot -- it held STAGE2's startup code
0010E7  1               ;     (run by the 6502), then the probe overlay (run by the Z-80), and now this
0010E7  1               ;     JMP $AA00 (run by the Z-80). The 6502 only WRITES the JMP here; it never
0010E7  1               ;     executes it.
0010E7  1               ; ----------------------------------------------------------------------
0010E7  1               S2_GOTSOFTCARD:
0010E7  1                       ; copy the 16-byte RWTS parameter block down into the live RWTS cells
0010E7  1  A0 10                LDY #$10                         ; copy RWTS param block
0010E9  1               ; ----------------------------------------------------------------------
0010E9  1               ; S2_COPYPARM -- copy loop for the RWTS parameter block, then load CP/M + arm vectors.
0010E9  1               ;   In:    Y = 16 counting down to 1; reached from S2_GOTSOFTCARD.
0010E9  1               ;   Out:   $03EF..$03FF populated; CP/M system read into RAM; RWTS sector-count
0010E9  1               ;          patched; $FFFA-$FFFF CPU vectors installed (all -> $03C0).
0010E9  1               ;   Clobbers: A, Y, $03EF,Y, $0FCC, $FFF9,Y.
0010E9  1               ;   Algorithm: copy RWTS_PARM into $03EF.. ; RWTS_TOP reads the CP/M system
0010E9  1               ;     image off disk; patch the RWTS sector-count cell $0FCC to $16 for the
0010E9  1               ;     runtime read pattern; then fall into S2_VECCOPY to install the reset
0010E9  1               ;     vectors before the CPU switch.
0010E9  1               ; ----------------------------------------------------------------------
0010E9  1               S2_COPYPARM:
0010E9  1                       ; SOURCE in-image (label RWTS_PARM, $13EF..); DEST $03EF,Y is low RAM (the live RWTS
0010E9  1                       ; parameter cells)
0010E9  1  B9 EF 13             LDA RWTS_PARM,Y                  ; $13EF..$13FF -> $03EF..$03FF
0010EC  1  99 EF 03             STA $03EF,Y
0010EF  1  88                   DEY
0010F0  1  D0 F7                BNE S2_COPYPARM
0010F2  1                       ; $C3 is the Z-80 JMP opcode -- the 6502 plants the 3-byte Z-80 jump the SoftCard will run
0010F2  1                       ; after the CPU switch
0010F2  1  A9 C3                LDA #$C3                         ; plant JMP at $1000 ...
0010F4  1                       ; STAGE2 ($1000) = the Z-80 JMP opcode; in-image self-plant into the STAGE-2 RAM, executed
0010F4  1                       ; later by the Z-80 (not the 6502)
0010F4  1  8D 00 10             STA STAGE2
0010F7  1  A9 00                LDA #$00
0010F9  1                       ; STAGE2+1 = JMP target low byte $00 (in-image plant; the Z-80 runs the resulting JMP after
0010F9  1                       ; the switch)
0010F9  1  8D 01 10             STA $1001
0010FC  1  A9 AA                LDA #$AA                         ; ... = JMP $AA00 (BIOS, later)
0010FE  1                       ; STAGE2+2 = JMP target high byte $AA -> the planted instruction is JMP $AA00 (Z-80 BIOS
0010FE  1                       ; entry)
0010FE  1  8D 02 10             STA $1002
001101  1                       ; read the CP/M system image off track 0 into memory (the BIOS/BDOS/CCP the Z-80 will run)
001101  1  20 AD 0F             JSR RWTS_TOP                     ; read the CP/M system image
001104  1  A9 16                LDA #$16                         ; patch sector count in RWTS
001106  1                       ; self-patch the RWTS sector-count cell $0FCC (the LDA #$1C immediate operand at $0FCB) to
001106  1                       ; $16 for subsequent reads
001106  1  8D CC 0F             STA $0FCC
001109  1  A0 06                LDY #$06                         ; install 6502 reset vectors --
00110B  1               ; ----------------------------------------------------------------------
00110B  1               ; S2_VECCOPY -- install the 6502 RESET/NMI/IRQ vectors, then switch to the Z-80.
00110B  1               ;   In:    Y = 6 counting down to 1; VEC_IMG holds 6 bytes ($C0 $03 x3).
00110B  1               ;   Out:   $FFFA-$FFFF = $03C0 x3 (NMI, RESET, IRQ/BRK all -> the mode switch);
00110B  1               ;          control transfers to JMP $03D2 (the 6502->Z-80 switch) -- no return.
00110B  1               ;   Clobbers: A, Y, $FFF9,Y.
00110B  1               ;   Algorithm: copy the 6-byte VEC_IMG into $FFFA..$FFFF so every 6502 hardware
00110B  1               ;     vector points at the $03C0 mode-switch routine, then JMP $03D2 (mid-
00110B  1               ;     routine, at the STA $C081) to hand the machine to the Z-80 running CP/M.
00110B  1               ; ----------------------------------------------------------------------
00110B  1               S2_VECCOPY:
00110B  1                       ; Y-indexed read of VEC_IMG (base VEC_IMG-1, Y=1..6 -> $1125..$112A): in-image table source,
00110B  1                       ; NOT a frozen literal (VEC_IMG is a label)
00110B  1  B9 24 11             LDA VEC_IMG-1,Y                  ; reads $1125..$112A -> $FFFA..
00110E  1                       ; DEST $FFF9+Y = $FFFA..$FFFF, the 6502 NMI/RESET/IRQ-BRK vectors (all set to $03C0;
00110E  1                       ; off-image HW, kept literal)
00110E  1  99 F9 FF             STA $FFF9,Y
001111  1  88                   DEY
001112  1  D0 F7                BNE S2_VECCOPY
001114  1                       ; enter the copied $03C0 mode-switch routine at $03D2 (the STA $C081 step; $03D2 is the run
001114  1                       ; address of the $13C0 image, off-image) -> the SoftCard switches CPUs and the Z-80 takes
001114  1                       ; over CP/M
001114  1  4C D2 03             JMP $03D2                        ; enter mode-switch ($03C0 rtn
001117  1                                                        ;        at STA $C081) -> hand to Z-80.
001117  1                                                        ;        $03C0 = the 6502->Z-80 mode-
001117  1                                                        ;        switch routine [DOC S&HD 2-25 ;
001117  1                                                        ;        facts sec.2.4/4.4]
001117  1               
001117  1               ; ----------------------------------------------------------------------
001117  1               ; SUM_ROM -- 8-bit-wrapping additive checksum of a peripheral-card ROM page
001117  1               ;   In:        ($3C/$3D) -> the card's $Cn00 ROM page (the slot scan points it
001117  1               ;              at the slot being probed). A/X/Y entry values are not used.
001117  1               ;   Out:       A = low byte = sum (mod 256) of all 256 ROM bytes;
001117  1               ;              X = high byte = count of byte-adds that overflowed; Y = 0.
001117  1               ;              A present, stable ROM gives a repeatable A and non-zero X; a
001117  1               ;              floating-bus empty slot gives an unstable, often-zero result.
001117  1               ;   Clobbers:  A, X, Y, carry
001117  1               ;   Algorithm: zero A/X/Y, then for Y = 0..255 add ROM[($3C)+Y] into A,
001117  1               ;              bumping X once for each add that carried out. The caller runs it
001117  1               ;              twice and compares A (vs $40) and X (vs $41): equal + non-zero X
001117  1               ;              means a real, stable card ROM is present in the slot.
001117  1               ; ----------------------------------------------------------------------
001117  1               SUM_ROM:
001117  1                       ; clear the running sum (A = low byte, X = carry count) and the index Y
001117  1  A9 00                LDA #$00
001119  1  AA                   TAX
00111A  1  A8                   TAY
00111B  1               @lp:
00111B  1  18                   CLC
00111C  1                       ; add the next ROM byte at ($3C)+Y into the low sum
00111C  1  71 3C                ADC ($3C),Y
00111E  1  90 01                BCC @nc
001120  1                       ; the byte add carried out -> bump the high-byte carry count
001120  1  E8                   INX
001121  1               @nc:
001121  1  C8                   INY
001122  1                       ; continue until Y wraps past $FF (all 256 ROM bytes summed)
001122  1  D0 F7                BNE @lp
001124  1  60                   RTS
001125  1               
001125  1               ; 6502 reset/NMI/IRQ vector image installed at $FFF9..$FFFF (point at $03C0):
001125  1               ; the three 6502 hardware vectors (NMI/RESET/IRQ-BRK) all target the $03C0
001125  1               ; 6502->Z-80 mode-switch routine [DOC S&HD 2-6, 2-25 ; facts sec.2.4/4.4].
001125  1               VEC_IMG:
001125  1  C0 03 C0 03          .byte   $C0, $03, $C0, $03, $C0, $03
001129  1  C0 03        
00112B  1               
00112B  1               ; MSG_NOCARD: "CAN'T FIND Z80 SOFTCARD" (CR-padded), $00-terminated.
00112B  1               MSG_NOCARD:
00112B  1  8D 8D 8D 8D          .byte   $8D, $8D, $8D, $8D
00112F  1  C3 C1 CE A7          ASCHI   "CAN'T FIND Z80 SOFTCARD"
001133  1  D4 A0 C6 C9  
001137  1  CE C4 A0 DA  
001146  1  8D                   .byte   $8D
001147  1  8D 8D 00             .byte   $8D, $8D, $00
00114A  1               
00114A  1               ; MSG_SLOT6: "MUST BOOT FROM SLOT SIX" (CR-padded), $00-terminated (at $1168).
00114A  1               MSG_SLOT6:
00114A  1  8D 8D 8D 8D          .byte   $8D, $8D, $8D, $8D
00114E  1  CD D5 D3 D4          ASCHI   "MUST BOOT FROM SLOT SIX"
001152  1  A0 C2 CF CF  
001156  1  D4 A0 C6 D2  
001165  1  8D                   .byte   $8D
001166  1  8D 8D                .byte   $8D, $8D
001168  1               
001168  1               ; SOFTCARD_PROBE_OVL: the slot-probe handshake. A leading $00 (the MSG_SLOT6
001168  1               ; terminator, data) followed by 13 bytes of Z-80 code. During the slot scan the
001168  1               ; boot copies those 13 bytes to RAM at $1000..$100C, over STAGE-2's startup
001168  1               ; instructions (which the 6502 has already finished with -- see STAGE2). From then
001168  1               ; on they run on the Z-80, never the 6502: the SoftCard maps the Z-80 reset address
001168  1               ; ($0000) to Apple $1000, so a slot-probe write (SCAN_PROBE) switches to the Z-80
001168  1               ; and lands it here, where it flags "found" and bounces back to the 6502. The 13
001168  1               ; Z-80 bytes are assembled from CPM_BootLoader_ProbeOvl.asm and INCBIN'd; the JR's
001168  1               ; offset byte is the following SIG_BYTE5[0]=$F2 (so SAVEBIN stops at the opcode).
001168  1               SOFTCARD_PROBE_OVL:
001168  1  00                   .byte   $00                      ; MSG_SLOT6 terminator (data)
001169  1               ;   >>> CPM_BootLoader_ProbeOvl.asm -- verbatim listing of the INCBIN'd source (regen: inject_incbin_listing) >>>
001169  1               ;
001169  1               ; FOUND   EQU $F03E        ; the 6502's $3E "SoftCard found" flag (Z-80 view of $003E)
001169  1               ; PROBED  EQU $F03D        ; the probed slot's $Cn high byte, set by the 6502 ($003D)
001169  1               ;
001169  1               ;     ORG $1000
001169  1               ;
001169  1               ; ; ----------------------------------------------------------------------------
001169  1               ; ; PROBE_OVL -- slot-probe handshake. Installed over $1000..$100C; during the slot
001169  1               ; ;   scan a probe write lands the Z-80 here. Clear the $3E "SoftCard found" flag,
001169  1               ; ;   then touch the probed slot's Z-80 I/O page ($En00 = $Cn + $20) to switch back
001169  1               ; ;   to the 6502, and loop (the JR offset byte is the host's SIG_BYTE5[0]).
001169  1               ; ;   In: $3D = probed slot $Cn (set by the 6502).  Clobbers: A, HL.
001169  1               ; ; ----------------------------------------------------------------------------
001169  1               ; PROBE_OVL:
001169  1               ;     XOR A                ; A = 0
001169  1               ;     LD (FOUND),A         ; $3E = 0 -> "SoftCard found in the probed slot"
001169  1               ;     LD L,A               ; HL low = 0
001169  1               ;     LD A,(PROBED)        ; A = probed slot $Cn
001169  1               ;     ADD A,$20            ; $Cn -> $En (the slot's Z-80 I/O page)
001169  1               ;     LD H,A               ; HL = $En00
001169  1               ;     LD (HL),A            ; touch $En00 -> Apple $Cn00 -> switch back to the 6502
001169  1               ;     JR PROBE_OVL         ; loop ($18; offset byte $F2 supplied by host SIG_BYTE5[0])
001169  1               ;   <<< end listing <<<
001169  1  AF 32 3E F0          .incbin "CPM_BootLoader_ProbeOvl.bin" ; -$1175  (Z-80; JR offset = SIG_BYTE5[0])
00116D  1  6F 3A 3D F0  
001171  1  C6 20 67 77  
001176  1               
001176  1               ; Card-signature compare tables (bytes $Cn05 / $Cn07 for known card types).
001176  1               SIG_BYTE5:
001176  1  F2 03 18 38          .byte   $F2, $03, $18, $38
00117A  1               SIG_BYTE7:
00117A  1  48 3C 38 18          .byte   $48, $3C, $38, $18, $48, $FF
00117E  1  48 FF        
001180  1               
001180  1               ; ----------------------------------------------------------------------
001180  1               ; SCAN_PROBE -- probe one slot for the Z-80 SoftCard by WRITING its $Cn00 page
001180  1               ;   In:        Y = the slot's $Cn page high byte (scanned $C7..$C1); A = scratch
001180  1               ;              written to $Cn00 (the value is irrelevant -- the access is the probe)
001180  1               ;   Out:       none directly; if the SoftCard lives in this slot the write hands
001180  1               ;              the bus to the Z-80, which runs SOFTCARD_PROBE_OVL at $1000 and
001180  1               ;              clears the 6502 $3E found-flag before bouncing back (the caller
001180  1               ;              then reads $3E == 0). Ordinary ROM cards / empty slots ignore it.
001180  1               ;   Clobbers:  $3D (= $Cn), the self-modified high operand byte SCAN_PROBE_HI,
001180  1               ;              and (on a SoftCard slot) whatever the Z-80 handshake touches
001180  1               ;   Algorithm: stash the probed slot high byte in $3D, self-patch this routine's
001180  1               ;              own STA operand high byte (SCAN_PROBE_HI) to $Cn, then store to
001180  1               ;              $Cn00. The SoftCard has NO on-board ROM, so any write to its slot
001180  1               ;              control page toggles the bus to the Z-80; on every other slot the
001180  1               ;              write is harmless. The side effect (the found-flag clear) is what
001180  1               ;              distinguishes the SoftCard from inert cards.
001180  1               ; ----------------------------------------------------------------------
001180  1               SCAN_PROBE:
001180  1                       ; record the probed slot's $Cn high byte (also read by the Z-80 handshake via $003D)
001180  1  84 3D                STY $3D                          ; high byte = $Cn
001182  1                       ; self-modify this routine's own STA operand high byte (SCAN_PROBE_HI) to $Cn so the next
001182  1                       ; store targets $Cn00
001182  1  8C 87 11             STY SCAN_PROBE_HI                ; patch high byte of STA operand
001185  1  8D 00                .byte   $8D, $00         ; STA opcode + operand LOW byte ($00) -- the probe write to $Cn00; HIGH byte self-patched below
001187  1               SCAN_PROBE_HI:
001187  1  C0                   .byte   $C0              ; STA operand HIGH byte: STY SCAN_PROBE_HI above patches it to $Cn (target $Cn00). Shipped $C0 -> $C000 = KBD before the patch, never actually stored
001188  1                                                        ;        A WRITE (not a read) to the
001188  1                                                        ;        slot-dependent control area
001188  1                                                        ;        $CN00 switches CPUs [DOC S&HD
001188  1                                                        ;        2-24/2-31 ; facts sec.2.5]
001188  1  60                   RTS
001189  1               
001189  1  FF FF FF FF          .res    119, $FF                 ; fill
00118D  1  FF FF FF FF  
001191  1  FF FF FF FF  
001200  1               
001200  1               ; ============================================================================
001200  1               ;  INSTALL IMAGE  ($1200..$13FF)  -  copied to $0200..$03FF at install time.
001200  1               ;  This is the I/O Configuration Block / mode-switch / Z-80 init image.  It is
001200  1               ;  DATA in this 6502 boot image: nothing here is executed at $1200.  After the
001200  1               ;  copy it becomes, at $0200..$03FF (the I/O Configuration Block, Z-80
001200  1               ;  0F200H-0F3FFH [DOC S&HD 2-6/2-12 ; facts sec.2.2/3]):
001200  1               ;    $034A..  Z-80 console / SoftCard lower-case-driver init code
001200  1               ;    $03C0..  the 6502 -> Z-80 CPU mode-switch routine (runs after the copy)
001200  1               ;             [DOC S&HD 2-25 ; facts sec.2.4/4.4]
001200  1               ;    $03D0..  A$VEC (6502-call vector) [DOC S&HD 2-25 ; facts sec.4.2],
001200  1               ;             $03DE Z$CPU (SoftCard location) [DOC S&HD 2-24/2-25 ; facts sec.4.3]
001200  1               ;    $03EF..  RWTS parameter cells
001200  1               ;  $1200..$1349 is $00 fill (the low config-block page is built at runtime).
001200  1               ; ============================================================================
001200  1               
001200  1               ; ----------------------------------------------------------------------
001200  1               ; INSTALL_IMG -- the install image ($1200-$13FF), copied to $0200-$03FF (Z-80 0F200H-0F3FFH, the I/O
001200  1               ; Configuration Block) by S2_COPYCFG/S2_COPYCFG2 at boot.
001200  1               ;   In:        none (pure data in this 6502 boot image; nothing here executes at $1200).
001200  1               ;   Out:       after the copy, $0200-$03FF holds the config block: $034A Z-80 console/SoftCard init
001200  1               ;              code (INCBIN'd ConInit), $037C the RPC_SERIAL_OUT stub, $0380 the I/O Vector Table +
001200  1               ;              screen/keyboard config, $03C0 the 6502->Z-80 RPC service loop / mode-switch, $03D0
001200  1               ;              A$VEC, $03DE Z$CPU, $03EF.. the RWTS parameter tail.
001200  1               ;   Clobbers:  none (data).
001200  1               ;   Algorithm: OBSERVED: this label marks 330 bytes of $00 fill ($1200-$1349 -> $0200-$0349). [DOC
001200  1               ;              S&HD 2-6/2-12 ; facts sec.2.2/3] The low config-block page ($0200-$02FF) and
001200  1               ;              $0300-$0349 ship as zero here and are BUILT at runtime (S2_SLOTSCAN writes the Card
001200  1               ;              Type Table + disk-count byte; the Z-80 console-init code populates the rest). The
001200  1               ;              non-fill tenants of the image follow at $134A onward.
001200  1               ; ----------------------------------------------------------------------
001200  1               INSTALL_IMG:

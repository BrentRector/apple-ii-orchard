  13  0000                  INCLUDE "cpm_system_220.inc"
# file opened: cpm_system_220.inc
   1+ 0000              ; ============================================================================
   2+ 0000              ; cpm_system_220.inc -- CP/M 2.20 (44K) cross-module system contract
   3+ 0000              ; ----------------------------------------------------------------------------
   4+ 0000              ; The de-skewed 2.20-44K system image is TWO independent compilations -- the CCP
   5+ 0000              ; ($9400-$9BFF) and the BDOS ($9C00-$A9FF) -- decoded at their true RUNTIME
   6+ 0000              ; addresses (see ../docs/CPM_Skew_Findings.md). On the correctly-addressed source
   7+ 0000              ; the two are almost decoupled: the CCP calls the BDOS only through the page-zero
   8+ 0000              ; $0005 ABI (cpm22.inc :: BDOS), and the ONLY direct cross-module symbols are the
   9+ 0000              ; two module bases below. They are defined ONCE here and INCLUDEd by both modules
  10+ 0000              ; (never duplicated -- feedback_no_duplicate_symbol_definitions). The earlier
  11+ 0000              ; "59 CCP->BDOS cross-refs" were sector-skew artifacts and do not exist on the
  12+ 0000              ; de-skewed source.
  13+ 0000              ; ============================================================================
  14+ 0000
  15+ 0000              CCP_ENTRY  EQU $9400      ; CBASE: CCP cold entry (JP cold-start); BDOS fn 0 / warm boot returns here
  16+ 0000              BDOS_FBASE EQU $9C00      ; FBASE: BDOS image base (6-byte serial + JP $9C06 entry); top-of-TPA marker the CCP loads
  17+ 0000
# file closed: cpm_system_220.inc
  14  0000                  ORG $9400
  15  9400                  ENDIF
  16  9400
  17  9400              ; ----------------------------------------------------------------------
  18  9400              ; CCP_ENTRY -- CCP cold/warm entry; jump to the main login-and-prompt setup.
  19  9400              ;   In: C = (drive<<4 | user) packed login byte passed by the BIOS warm boot.
  20  9400              ;   Out: never returns (sets up the CCP then enters the command loop).
  21  9400              ;   Clobbers: all.
  22  9400              ;   Algorithm: JP to the CCP login setup at CCP_COLD_ENTRY ($975C). The 3 bytes after
  23  9400              ;     the JP are a second entry vector 'JP $9758' (C3 58 97); $9758 is CCP_WARM_ENTRY
  24  9400              ;     (clears CCP_INLEN, then re-runs the login setup) -- the warm-start re-entry.
  25  9400              ;   [RE] Standard CP/M 2.2 CCP base (CBASE).
  26  9400              ; ----------------------------------------------------------------------
  27  9400              ; (CCP_ENTRY == module base; defined in cpm_system_220.inc)
  28  9400                      ; enter CCP login setup: reset SP, log in drive/user
  29  9400 C3 5C 97             JP CCP_COLD_ENTRY
  30  9403 C3 58 97             DEFB    $C3,$58,$97
  31  9406              ; ----------------------------------------------------------------------
  32  9406              ; CCP_INBUF -- console line-input buffer descriptor for C_READSTR.
  33  9406              ;   Layout: byte0 ($9406)=max length ($7F=127), byte1 ($9407)=returned count,
  34  9406              ;     bytes2.. ($9408)=the typed command line (also the CCP work text area).
  35  9406              ;   [RE] Standard CP/M 2.2 CCP command buffer.
  36  9406              ; ----------------------------------------------------------------------
  37  9406              CCP_INBUF:
  38  9406 7F                   DEFB    $7F
  39  9407              ; ----------------------------------------------------------------------
  40  9407              ; CCP_INLEN -- count of characters returned by the last C_READSTR (buffer fill).
  41  9407              ;   Also doubles as the auto-command flag: nonzero on entry means a command string
  42  9407              ;   is already staged in CCP_CMDTEXT and is re-parsed instead of re-prompting.
  43  9407              ;   [RE]
  44  9407              ; ----------------------------------------------------------------------
  45  9407              CCP_INLEN:
  46  9407 00                   DEFB    "\0"
  47  9408              ; ----------------------------------------------------------------------
  48  9408              ; CCP_CMDTEXT -- the command-line text area (CCP_INBUF+2).
  49  9408              ;   Holds the upper-cased command line being parsed. On cold start it carries
  50  9408              ;   16 spaces, the DRI string 'COPYRIGHT (C) 1979, DIGITAL RESEARCH  ', a NUL, then
  51  9408              ;   73 zero pad bytes -- this fixed init doubles as the CCP scratch/line area.
  52  9408              ;   [RE]
  53  9408              ; ----------------------------------------------------------------------
  54  9408              CCP_CMDTEXT:
  55  9408 20 20 20...          DEFS    16, $20                  ; fill
  56  9418 43 4F 50 59          DEFB    "COPYRIGHT (C) 1979, DIGITAL RESEARCH  " ; string
  56  941C 52 49 47 48
  56  9420 54 20 28 43
  56  9424 29 20 31 39
  56  9428 37 39 2C 20
  56  942C 44 49 47 49
  56  9430 54 41 4C 20
  56  9434 52 45 53 45
  56  9438 41 52 43 48
  56  943C 20 20
  57  943E 00                   DEFB    $00                      ; terminator
  58  943F 00 00 00...          DEFS    73, $00                  ; fill
  59  9488              ; ----------------------------------------------------------------------
  60  9488              ; CCP_PARSEPTR -- 16-bit scan pointer into CCP_CMDTEXT used during command parse.
  61  9488              ;   Initialized to CCP_CMDTEXT ($9408); advanced as tokens are consumed.
  62  9488              ;   [RE]
  63  9488              ; ----------------------------------------------------------------------
  64  9488              CCP_PARSEPTR:
  65  9488 08 94                DEFB    $08,$94
  66  948A              ; ----------------------------------------------------------------------
  67  948A              ; CCP_TOKENPTR -- 16-bit pointer to the start of the current token.
  68  948A              ;   Saved by the FCB builder and reused by the bad-character echo routine.
  69  948A              ;   [RE]
  70  948A              ; ----------------------------------------------------------------------
  71  948A              CCP_TOKENPTR:
  72  948A 00 00                DEFB    "\0\0"
  73  948C              ; ----------------------------------------------------------------------
  74  948C              ; CCP_CONOUT -- write one character to the console via BDOS C_WRITE.
  75  948C              ;   In: A = character to emit.
  76  948C              ;   Out: none (BDOS return ignored).
  77  948C              ;   Clobbers: C, E; BDOS clobbers per ABI.
  78  948C              ;   Algorithm: E:=A; C:=C_WRITE(2); JP BDOS.
  79  948C              ;   [RE]
  80  948C              ; ----------------------------------------------------------------------
  81  948C              CCP_CONOUT:
  82  948C                      ; E = char to print
  83  948C 5F                   LD E,A
  84  948D                      ; C_WRITE = 2
  85  948D 0E 02                LD C,$02
  86  948F                      ; tail-call BDOS to emit the char
  87  948F C3 05 00             JP $0005
  88  9492              ; ----------------------------------------------------------------------
  89  9492              ; CCP_CONOUT_KEEPBC -- print one char (CCP_CONOUT) preserving BC.
  90  9492              ;   In: A = character.
  91  9492              ;   Out: BC unchanged.
  92  9492              ;   Clobbers: A/flags via BDOS; BC saved/restored.
  93  9492              ;   Algorithm: PUSH BC; call CCP_CONOUT; POP BC; RET.
  94  9492              ;   [RE]
  95  9492              ; ----------------------------------------------------------------------
  96  9492              CCP_CONOUT_KEEPBC:
  97  9492 C5                   PUSH BC
  98  9493                      ; emit char, with BC protected
  99  9493 CD 8C 94             CALL CCP_CONOUT
 100  9496 C1                   POP BC
 101  9497 C9                   RET
 102  9498              ; ----------------------------------------------------------------------
 103  9498              ; CCP_CRLF -- emit a carriage-return + line-feed to the console.
 104  9498              ;   In: none.
 105  9498              ;   Out: cursor at start of next line; BC preserved.
 106  9498              ;   Clobbers: A/flags.
 107  9498              ;   Algorithm: print CR ($0D) then LF ($0A), each via CCP_CONOUT_KEEPBC.
 108  9498              ;   [RE]
 109  9498              ; ----------------------------------------------------------------------
 110  9498              CCP_CRLF:
 111  9498                      ; CR
 112  9498 3E 0D                LD A,$0D
 113  949A CD 92 94             CALL CCP_CONOUT_KEEPBC
 114  949D                      ; LF
 115  949D 3E 0A                LD A,$0A
 116  949F C3 92 94             JP CCP_CONOUT_KEEPBC
 117  94A2              ; ----------------------------------------------------------------------
 118  94A2              ; CCP_SPACE -- emit a single blank to the console.
 119  94A2              ;   In: none.  Out: BC preserved.  Clobbers: A/flags.
 120  94A2              ;   Algorithm: A:=' ' ($20); JP CCP_CONOUT_KEEPBC.
 121  94A2              ;   [RE]
 122  94A2              ; ----------------------------------------------------------------------
 123  94A2              CCP_SPACE:
 124  94A2                      ; space character
 125  94A2 3E 20                LD A,$20
 126  94A4 C3 92 94             JP CCP_CONOUT_KEEPBC
 127  94A7              ; ----------------------------------------------------------------------
 128  94A7              ; CCP_CRLF_MSG -- emit CR/LF then print a NUL-terminated message.
 129  94A7              ;   In: BC -> NUL-terminated message string.
 130  94A7              ;   Out: message printed after a new line.
 131  94A7              ;   Clobbers: A, HL, BC.
 132  94A7              ;   Algorithm: CCP_CRLF; HL:=BC (via PUSH BC/POP HL); fall into CCP_PUTS.
 133  94A7              ;   [RE] Used by the 'READ ERROR' / 'NO FILE' message printers.
 134  94A7              ; ----------------------------------------------------------------------
 135  94A7              CCP_CRLF_MSG:
 136  94A7 C5                   PUSH BC
 137  94A8                      ; new line before the message
 138  94A8 CD 98 94             CALL CCP_CRLF
 139  94AB                      ; HL = message pointer (was BC)
 140  94AB E1                   POP HL
 141  94AC              ; ----------------------------------------------------------------------
 142  94AC              ; CCP_PUTS -- print a NUL-terminated string to the console.
 143  94AC              ;   In: HL -> string.
 144  94AC              ;   Out: HL past the terminator on exit (loop stops at the NUL).
 145  94AC              ;   Clobbers: A, HL.
 146  94AC              ;   Algorithm: loop: A:=(HL); if A==0 RET; INC HL; emit A via CCP_CONOUT;
 147  94AC              ;     repeat.
 148  94AC              ;   [RE]
 149  94AC              ; ----------------------------------------------------------------------
 150  94AC              CCP_PUTS:
 151  94AC                      ; fetch next char
 152  94AC 7E                   LD A,(HL)
 153  94AD B7                   OR A
 154  94AE                      ; NUL terminates the string
 155  94AE C8                   RET Z
 156  94AF 23                   INC HL
 157  94B0 E5                   PUSH HL
 158  94B1                      ; emit this char
 159  94B1 CD 8C 94             CALL CCP_CONOUT
 160  94B4 E1                   POP HL
 161  94B5 C3 AC 94             JP CCP_PUTS
 162  94B8              ; ----------------------------------------------------------------------
 163  94B8              ; BDOS_DRV_ALLRESET -- reset the disk system (BDOS function 13).
 164  94B8              ;   In: none.  Out: per BDOS.  Clobbers: per BDOS ABI.
 165  94B8              ;   Algorithm: C:=DRV_ALLRESET($0D); JP BDOS.
 166  94B8              ;   [RE]
 167  94B8              ; ----------------------------------------------------------------------
 168  94B8              BDOS_DRV_ALLRESET:
 169  94B8                      ; DRV_ALLRESET = 13
 170  94B8 0E 0D                LD C,$0D
 171  94BA C3 05 00             JP $0005
 172  94BD              ; ----------------------------------------------------------------------
 173  94BD              ; BDOS_DRV_SET -- select the default drive (BDOS function 14).
 174  94BD              ;   In: A = drive number (0=A..15=P).
 175  94BD              ;   Out: per BDOS.  Clobbers: C, E; BDOS ABI.
 176  94BD              ;   Algorithm: E:=A; C:=DRV_SET($0E); JP BDOS.
 177  94BD              ;   [RE]
 178  94BD              ; ----------------------------------------------------------------------
 179  94BD              BDOS_DRV_SET:
 180  94BD 5F                   LD E,A
 181  94BE                      ; DRV_SET = 14
 182  94BE 0E 0E                LD C,$0E
 183  94C0 C3 05 00             JP $0005
 184  94C3              ; ----------------------------------------------------------------------
 185  94C3              ; BDOS_FCB_OP -- call BDOS then record the result in CCP_OPENDIRCODE.
 186  94C3              ;   In: C = BDOS function number, DE -> FCB (set by the caller).
 187  94C3              ;   Out: A = BDOS return+1; Z set if the raw code was $FF (error/not-found);
 188  94C3              ;     CCP_OPENDIRCODE ($9BEE) := the raw BDOS result code.
 189  94C3              ;   Clobbers: A/flags.
 190  94C3              ;   Algorithm: CALL BDOS; store A to CCP_OPENDIRCODE; INC A (so $FF->0 sets Z
 191  94C3              ;     meaning 'failed'); RET.  Shared tail for the open/close/search/make-style
 192  94C3              ;     wrappers (those whose error sentinel is $FF).
 193  94C3              ;   [RE]
 194  94C3              ; ----------------------------------------------------------------------
 195  94C3              BDOS_FCB_OP:
 196  94C3                      ; invoke BDOS with C=function, DE=FCB
 197  94C3 CD 05 00             CALL $0005
 198  94C6                      ; save raw BDOS directory code
 199  94C6 32 EE 9B             LD (CCP_BDOS_RESULT),A
 200  94C9                      ; $FF->0 so Z flags 'error/not found'
 201  94C9 3C                   INC A
 202  94CA C9                   RET
 203  94CB              ; ----------------------------------------------------------------------
 204  94CB              ; BDOS_F_OPEN -- open the file named by DE (BDOS function 15).
 205  94CB              ;   In: DE -> FCB.
 206  94CB              ;   Out: A/Z per BDOS_FCB_OP (Z = open failed).
 207  94CB              ;   Clobbers: A/flags.
 208  94CB              ;   Algorithm: C:=F_OPEN($0F); JP BDOS_FCB_OP.
 209  94CB              ;   [RE]
 210  94CB              ; ----------------------------------------------------------------------
 211  94CB              BDOS_F_OPEN:
 212  94CB                      ; F_OPEN = 15
 213  94CB 0E 0F                LD C,$0F
 214  94CD C3 C3 94             JP BDOS_FCB_OP
 215  94D0              ; ----------------------------------------------------------------------
 216  94D0              ; CCP_OPEN_SUBMIT -- open the staged command FCB at record 0.
 217  94D0              ;   In: CCP command FCB at CCP_FCB ($9BCD) holds the file name.
 218  94D0              ;   Out: A/Z per BDOS_F_OPEN.
 219  94D0              ;   Clobbers: A/flags, DE.
 220  94D0              ;   Algorithm: clear CCP_CURREC ($9BED, current-record byte); DE:=CCP_FCB; JP
 221  94D0              ;     BDOS_F_OPEN.
 222  94D0              ;   [RE] Opens the parsed command file (e.g. before a chained read).
 223  94D0              ; ----------------------------------------------------------------------
 224  94D0              CCP_OPEN_SUBMIT:
 225  94D0 AF                   XOR A
 226  94D1                      ; current record := 0
 227  94D1 32 ED 9B             LD (CCP_FCB_CR),A
 228  94D4                      ; DE -> CCP command FCB
 229  94D4 11 CD 9B             LD DE,CCP_FCB
 230  94D7 C3 CB 94             JP BDOS_F_OPEN
 231  94DA              ; ----------------------------------------------------------------------
 232  94DA              ; BDOS_F_CLOSE -- close the file named by DE (BDOS function 16).
 233  94DA              ;   In: DE -> FCB.  Out: A/Z per BDOS_FCB_OP.  Clobbers: A/flags.
 234  94DA              ;   Algorithm: C:=F_CLOSE_HND($10); JP BDOS_FCB_OP.
 235  94DA              ;   [RE]
 236  94DA              ; ----------------------------------------------------------------------
 237  94DA              BDOS_F_CLOSE:
 238  94DA                      ; F_CLOSE_HND = 16
 239  94DA 0E 10                LD C,$10
 240  94DC C3 C3 94             JP BDOS_FCB_OP
 241  94DF              ; ----------------------------------------------------------------------
 242  94DF              ; BDOS_F_SFIRST -- search-for-first matching directory entry (BDOS function 17).
 243  94DF              ;   In: DE -> FCB (may contain '?' wildcards).
 244  94DF              ;   Out: A = directory index 0..3 or $FF if none; Z per BDOS_FCB_OP.
 245  94DF              ;   Clobbers: A/flags.
 246  94DF              ;   Algorithm: C:=F_SFIRST($11); JP BDOS_FCB_OP.
 247  94DF              ;   [RE]
 248  94DF              ; ----------------------------------------------------------------------
 249  94DF              BDOS_F_SFIRST:
 250  94DF                      ; F_SFIRST = 17
 251  94DF 0E 11                LD C,$11
 252  94E1 C3 C3 94             JP BDOS_FCB_OP
 253  94E4              ; ----------------------------------------------------------------------
 254  94E4              ; BDOS_F_SNEXT -- search-for-next matching directory entry (BDOS function 18).
 255  94E4              ;   In: prior F_SFIRST/F_SNEXT context.
 256  94E4              ;   Out: A = next directory index or $FF; Z per BDOS_FCB_OP.
 257  94E4              ;   Clobbers: A/flags.
 258  94E4              ;   Algorithm: C:=F_SNEXT($12); JP BDOS_FCB_OP.
 259  94E4              ;   [RE]
 260  94E4              ; ----------------------------------------------------------------------
 261  94E4              BDOS_F_SNEXT:
 262  94E4                      ; F_SNEXT = 18
 263  94E4 0E 12                LD C,$12
 264  94E6 C3 C3 94             JP BDOS_FCB_OP
 265  94E9              ; ----------------------------------------------------------------------
 266  94E9              ; CCP_SEARCH_FIRST_SUBMIT -- search-for-first on the CCP command FCB.
 267  94E9              ;   In: CCP command FCB at CCP_FCB ($9BCD).
 268  94E9              ;   Out: A/Z per BDOS_F_SFIRST.
 269  94E9              ;   Clobbers: A/flags, DE.
 270  94E9              ;   Algorithm: DE:=CCP_FCB; JP BDOS_F_SFIRST.
 271  94E9              ;   [RE]
 272  94E9              ; ----------------------------------------------------------------------
 273  94E9              CCP_SEARCH_FIRST_SUBMIT:
 274  94E9                      ; DE -> CCP command FCB
 275  94E9 11 CD 9B             LD DE,CCP_FCB
 276  94EC C3 DF 94             JP BDOS_F_SFIRST
 277  94EF              ; ----------------------------------------------------------------------
 278  94EF              ; BDOS_F_DELETE -- delete the file named by DE (BDOS function 19).
 279  94EF              ;   In: DE -> FCB.  Out: per BDOS.  Clobbers: per BDOS ABI.
 280  94EF              ;   Algorithm: C:=F_DELETE_HND($13); JP BDOS.
 281  94EF              ;   [RE]
 282  94EF              ; ----------------------------------------------------------------------
 283  94EF              BDOS_F_DELETE:
 284  94EF                      ; F_DELETE_HND = 19
 285  94EF 0E 13                LD C,$13
 286  94F1 C3 05 00             JP $0005
 287  94F4              ; ----------------------------------------------------------------------
 288  94F4              ; BDOS_CALL_TESTERR -- call BDOS then set Z=1 only when A==0 (success).
 289  94F4              ;   In: C = BDOS function, DE -> FCB.
 290  94F4              ;   Out: A = BDOS code; flags from OR A (Z if A==0, i.e. read/write OK).
 291  94F4              ;   Clobbers: flags.
 292  94F4              ;   Algorithm: CALL BDOS; OR A; RET.  Shared tail for the read/write wrappers
 293  94F4              ;     where 0 = success and nonzero = error/EOF.
 294  94F4              ;   [RE]
 295  94F4              ; ----------------------------------------------------------------------
 296  94F4              BDOS_CALL_TESTERR:
 297  94F4                      ; invoke BDOS
 298  94F4 CD 05 00             CALL $0005
 299  94F7                      ; Z=1 means success (A==0)
 300  94F7 B7                   OR A
 301  94F8 C9                   RET
 302  94F9              ; ----------------------------------------------------------------------
 303  94F9              ; BDOS_F_READ -- read the next sequential record (BDOS function 20).
 304  94F9              ;   In: DE -> FCB; DMA set elsewhere.
 305  94F9              ;   Out: A = 0 on success / nonzero on error or EOF; Z per BDOS_CALL_TESTERR.
 306  94F9              ;   Clobbers: flags.
 307  94F9              ;   Algorithm: C:=F_READ($14); JP BDOS_CALL_TESTERR.
 308  94F9              ;   [RE]
 309  94F9              ; ----------------------------------------------------------------------
 310  94F9              BDOS_F_READ:
 311  94F9                      ; F_READ = 20
 312  94F9 0E 14                LD C,$14
 313  94FB C3 F4 94             JP BDOS_CALL_TESTERR
 314  94FE              ; ----------------------------------------------------------------------
 315  94FE              ; CCP_READ_SUBMIT -- read the next record of the CCP command FCB.
 316  94FE              ;   In: CCP command FCB at CCP_FCB ($9BCD); DMA preset by the caller.
 317  94FE              ;   Out: A/Z per BDOS_F_READ.
 318  94FE              ;   Clobbers: flags, DE.
 319  94FE              ;   Algorithm: DE:=CCP_FCB; JP BDOS_F_READ.
 320  94FE              ;   [RE]
 321  94FE              ; ----------------------------------------------------------------------
 322  94FE              CCP_READ_SUBMIT:
 323  94FE                      ; DE -> CCP command FCB
 324  94FE 11 CD 9B             LD DE,CCP_FCB
 325  9501 C3 F9 94             JP BDOS_F_READ
 326  9504              ; ----------------------------------------------------------------------
 327  9504              ; BDOS_F_WRITE -- write the next sequential record (BDOS function 21).
 328  9504              ;   In: DE -> FCB; DMA holds the record.
 329  9504              ;   Out: A = 0 on success / nonzero on error; Z per BDOS_CALL_TESTERR.
 330  9504              ;   Clobbers: flags.
 331  9504              ;   Algorithm: C:=F_WRITE($15); JP BDOS_CALL_TESTERR.
 332  9504              ;   [RE]
 333  9504              ; ----------------------------------------------------------------------
 334  9504              BDOS_F_WRITE:
 335  9504                      ; F_WRITE = 21
 336  9504 0E 15                LD C,$15
 337  9506 C3 F4 94             JP BDOS_CALL_TESTERR
 338  9509              ; ----------------------------------------------------------------------
 339  9509              ; BDOS_F_MAKE -- create the file named by DE (BDOS function 22).
 340  9509              ;   In: DE -> FCB.  Out: A/Z per BDOS_FCB_OP (Z = create failed/dir full).
 341  9509              ;   Clobbers: A/flags.
 342  9509              ;   Algorithm: C:=F_MAKE($16); JP BDOS_FCB_OP.
 343  9509              ;   [RE]
 344  9509              ; ----------------------------------------------------------------------
 345  9509              BDOS_F_MAKE:
 346  9509                      ; F_MAKE = 22
 347  9509 0E 16                LD C,$16
 348  950B C3 C3 94             JP BDOS_FCB_OP
 349  950E              ; ----------------------------------------------------------------------
 350  950E              ; BDOS_F_RENAME -- rename a file (BDOS function 23).
 351  950E              ;   In: DE -> FCB whose first 16 bytes name the old file and second 16 the new.
 352  950E              ;   Out: per BDOS.  Clobbers: per BDOS ABI.
 353  950E              ;   Algorithm: C:=F_RENAME_HND($17); JP BDOS.
 354  950E              ;   [RE]
 355  950E              ; ----------------------------------------------------------------------
 356  950E              BDOS_F_RENAME:
 357  950E                      ; F_RENAME_HND = 23
 358  950E 0E 17                LD C,$17
 359  9510 C3 05 00             JP $0005
 360  9513              ; ----------------------------------------------------------------------
 361  9513              ; BDOS_USER_GET -- get the current user number (BDOS function 32, E=$FF).
 362  9513              ;   In: none.  Out: A = current user number (0..15).  Clobbers: A, C, E.
 363  9513              ;   Algorithm: E:=$FF (interrogate); fall into BDOS_USERNUM.
 364  9513              ;   [RE]
 365  9513              ; ----------------------------------------------------------------------
 366  9513              BDOS_USER_GET:
 367  9513                      ; $FF = interrogate (get) user number
 368  9513 1E FF                LD E,$FF
 369  9515              ; ----------------------------------------------------------------------
 370  9515              ; BDOS_USERNUM -- set/get the user number (BDOS function 32).
 371  9515              ;   In: E = user number to set, or $FF to interrogate.
 372  9515              ;   Out: A = user number when interrogating.  Clobbers: A, C; BDOS ABI.
 373  9515              ;   Algorithm: C:=F_USERNUM($20); JP BDOS.
 374  9515              ;   [RE]
 375  9515              ; ----------------------------------------------------------------------
 376  9515              BDOS_USERNUM:
 377  9515                      ; F_USERNUM = 32
 378  9515 0E 20                LD C,$20
 379  9517 C3 05 00             JP $0005
 380  951A              ; ----------------------------------------------------------------------
 381  951A              ; CCP_SET_USERDRIVE -- write the packed user/drive byte into base page $0004.
 382  951A              ;   In: current user (from BDOS_USER_GET) and CCP_CDISK ($9BEF, default drive).
 383  951A              ;   Out: base-page $0004 := (user<<4 | drive); the CP/M default-drive/user cell.
 384  951A              ;   Clobbers: A, HL.
 385  951A              ;   Algorithm: A:=BDOS_USER_GET; A<<=4 (ADD A,A x4); OR in CCP_CDISK; store $0004.
 386  951A              ;   [RE] $0004 is the CP/M default-drive/user cell read by the warm boot.
 387  951A              ; ----------------------------------------------------------------------
 388  951A              CCP_SET_USERDRIVE:
 389  951A                      ; A = current user number
 390  951A CD 13 95             CALL BDOS_USER_GET
 391  951D                      ; user << 4 ...
 392  951D 87                   ADD A,A
 393  951E 87                   ADD A,A
 394  951F 87                   ADD A,A
 395  9520 87                   ADD A,A
 396  9521                      ; HL -> CCP default-drive cell
 397  9521 21 EF 9B             LD HL,CCP_CUR_DRIVE
 398  9524                      ; pack (user<<4 | drive)
 399  9524 B6                   OR (HL)
 400  9525                      ; store login byte to base page $0004
 401  9525 32 04 00             LD ($0004),A
 402  9528 C9                   RET
 403  9529              ; ----------------------------------------------------------------------
 404  9529              ; CCP_SET_DRIVE_ONLY -- write just the default drive into base-page $0004.
 405  9529              ;   In: CCP_CDISK ($9BEF).
 406  9529              ;   Out: $0004 := default drive (user nibble cleared).
 407  9529              ;   Clobbers: A.
 408  9529              ;   Algorithm: A:=CCP_CDISK; store to $0004.
 409  9529              ;   [RE]
 410  9529              ; ----------------------------------------------------------------------
 411  9529              CCP_SET_DRIVE_ONLY:
 412  9529                      ; A = default drive
 413  9529 3A EF 9B             LD A,(CCP_CUR_DRIVE)
 414  952C                      ; store to base page $0004
 415  952C 32 04 00             LD ($0004),A
 416  952F C9                   RET
 417  9530              ; ----------------------------------------------------------------------
 418  9530              ; CCP_UPCASE -- fold one ASCII lower-case letter to upper case.
 419  9530              ;   In: A = character.
 420  9530              ;   Out: A = upper-cased character ('a'..'z' -> 'A'..'Z'); others unchanged.
 421  9530              ;   Clobbers: A/flags.
 422  9530              ;   Algorithm: if A < 'a'($61) RET; if A >= '{'($7B) RET; AND $5F to clear bit5.
 423  9530              ;   [RE]
 424  9530              ; ----------------------------------------------------------------------
 425  9530              CCP_UPCASE:
 426  9530                      ; below 'a' -> leave unchanged
 427  9530 FE 61                CP $61
 428  9532 D8                   RET C
 429  9533                      ; above 'z' -> leave unchanged
 430  9533 FE 7B                CP $7B
 431  9535 D0                   RET NC
 432  9536                      ; clear bit 5: lower -> upper
 433  9536 E6 5F                AND $5F
 434  9538 C9                   RET
 435  9539              ; ----------------------------------------------------------------------
 436  9539              ; CCP_GETCMD -- obtain the next command line (from submit file or console).
 437  9539              ;   In: CCP_SUBMITON ($9BAB) flag; CCP_SUBMITFCB ($9BAC); CCP_INBUF buffer.
 438  9539              ;   Out: CCP_CMDTEXT holds the upper-cased command line ready to parse;
 439  9539              ;     CCP_PARSEPTR set to its start.
 440  9539              ;   Clobbers: A, BC, DE, HL.
 441  9539              ;   Algorithm: if a $$$.SUB submit is active (CCP_SUBMITON != 0): select its drive,
 442  9539              ;     open + read the next record of CCP_SUBMITFCB into TBUFF, set its current-record
 443  9539              ;     cell to 0 and decrement its record count, copy the 128-byte record into
 444  9539              ;     CCP_INBUF, close the submit FCB, then poll the console for a ^C abort; if no
 445  9539              ;     submit (or it ends/errs/aborts) discard submit (CCP_DISCARD_SUBMIT) and do a
 446  9539              ;     console C_READSTR into CCP_INBUF.  Either path falls into CCP_UPCASE_LINE to
 447  9539              ;     fold the line to upper case and reset the parse pointer.
 448  9539              ;   [RE] Standard CP/M 2.2 CCP command-acquire with SUBMIT support.
 449  9539              ; ----------------------------------------------------------------------
 450  9539              CCP_GETCMD:
 451  9539                      ; submit-active flag
 452  9539 3A AB 9B             LD A,(CCP_SUBMIT_FLAG)
 453  953C B7                   OR A
 454  953D                      ; no submit -> read from console
 455  953D CA 96 95             JP Z,CCP_READ_CONSOLE
 456  9540 3A EF 9B             LD A,(CCP_CUR_DRIVE)
 457  9543 B7                   OR A
 458  9544 3E 00                LD A,$00
 459  9546 C4 BD 94             CALL NZ,BDOS_DRV_SET
 460  9549 11 AC 9B             LD DE,CCP_SUB_FCB
 461  954C                      ; open the $$$.SUB submit file
 462  954C CD CB 94             CALL BDOS_F_OPEN
 463  954F CA 96 95             JP Z,CCP_READ_CONSOLE
 464  9552                      ; submit FCB record-count byte (FCB+15)
 465  9552 3A BB 9B             LD A,(CCP_SUB_FCB_CR)
 466  9555 3D                   DEC A
 467  9556 32 CC 9B             LD (CCP_SUB_PREV_REC),A
 468  9559 11 AC 9B             LD DE,CCP_SUB_FCB
 469  955C                      ; read the next submit record into TBUFF
 470  955C CD F9 94             CALL BDOS_F_READ
 471  955F C2 96 95             JP NZ,CCP_READ_CONSOLE
 472  9562                      ; DE -> CCP_INBUF count byte
 473  9562 11 07 94             LD DE,CCP_INLEN
 474  9565 21 80 00             LD HL,$0080
 475  9568 06 80                LD B,$80
 476  956A                      ; copy 128 bytes TBUFF -> CCP_INBUF
 477  956A CD 42 98             CALL COPY_N_BYTES
 478  956D 21 BA 9B             LD HL,CCP_SUB_FCB_S2
 479  9570 36 00                LD (HL),$00
 480  9572 23                   INC HL
 481  9573 35                   DEC (HL)
 482  9574 11 AC 9B             LD DE,CCP_SUB_FCB
 483  9577                      ; close submit FCB to commit the shortened file
 484  9577 CD DA 94             CALL BDOS_F_CLOSE
 485  957A CA 96 95             JP Z,CCP_READ_CONSOLE
 486  957D 3A EF 9B             LD A,(CCP_CUR_DRIVE)
 487  9580 B7                   OR A
 488  9581 C4 BD 94             CALL NZ,BDOS_DRV_SET
 489  9584 21 08 94             LD HL,CCP_CMDTEXT
 490  9587 CD AC 94             CALL CCP_PUTS
 491  958A                      ; poll console for a ^C abort of submit
 492  958A CD C2 95             CALL CCP_CHECK_ABORT
 493  958D CA A7 95             JP Z,CCP_UPCASE_LINE
 494  9590                      ; abort: discard the submit file
 495  9590 CD DD 95             CALL CCP_DISCARD_SUBMIT
 496  9593 C3 82 97             JP CCP_PROMPT_AND_READ
 497  9596              ; ----------------------------------------------------------------------
 498  9596              ; CCP_READ_CONSOLE -- discard any pending submit, then read a console line.
 499  9596              ;   In: none.
 500  9596              ;   Out: CCP_INBUF filled by C_READSTR; falls into CCP_UPCASE_LINE.
 501  9596              ;   Clobbers: A, BC, DE.
 502  9596              ;   Algorithm: CCP_DISCARD_SUBMIT; CCP_SET_USERDRIVE; C:=C_READSTR(10),
 503  9596              ;     DE:=CCP_INBUF, CALL BDOS; then CCP_SET_DRIVE_ONLY.
 504  9596              ;   [RE]
 505  9596              ; ----------------------------------------------------------------------
 506  9596              CCP_READ_CONSOLE:
 507  9596                      ; discard any abandoned submit
 508  9596 CD DD 95             CALL CCP_DISCARD_SUBMIT
 509  9599                      ; publish user/drive to base page
 510  9599 CD 1A 95             CALL CCP_SET_USERDRIVE
 511  959C                      ; C_READSTR = 10 (buffered line input)
 512  959C 0E 0A                LD C,$0A
 513  959E                      ; DE -> CCP_INBUF descriptor
 514  959E 11 06 94             LD DE,CCP_INBUF
 515  95A1                      ; read a console line into CCP_INBUF
 516  95A1 CD 05 00             CALL $0005
 517  95A4 CD 29 95             CALL CCP_SET_DRIVE_ONLY
 518  95A7              ; ----------------------------------------------------------------------
 519  95A7              ; CCP_UPCASE_LINE -- upper-case the command line in place and reset the parser.
 520  95A7              ;   In: CCP_INLEN = char count, CCP_CMDTEXT = the typed line.
 521  95A7              ;   Out: CCP_CMDTEXT folded to upper case + NUL-terminated; CCP_PARSEPTR:=
 522  95A7              ;     CCP_CMDTEXT.
 523  95A7              ;   Clobbers: A, B, HL.
 524  95A7              ;   Algorithm: B:=count from CCP_INLEN; for each char apply CCP_UPCASE in place;
 525  95A7              ;     append a terminating NUL; CCP_PARSEPTR:=CCP_CMDTEXT.
 526  95A7              ;   [RE]
 527  95A7              ; ----------------------------------------------------------------------
 528  95A7              CCP_UPCASE_LINE:
 529  95A7                      ; HL -> CCP_INLEN (count) byte
 530  95A7 21 07 94             LD HL,CCP_INLEN
 531  95AA                      ; B = number of typed chars
 532  95AA 46                   LD B,(HL)
 533  95AB              ; ----------------------------------------------------------------------
 534  95AB              ; CCP_UPCASE_LOOP -- per-character upper-case loop body for CCP_UPCASE_LINE.
 535  95AB              ;   In: HL -> char before the current one, B = remaining count.
 536  95AB              ;   Out: char folded in place; loops until B==0 then joins CCP_UPCASE_DONE.
 537  95AB              ;   Clobbers: A, B, HL.
 538  95AB              ;   Algorithm: INC HL; if B==0 done; A:=(HL); A:=CCP_UPCASE(A); store; DEC B; loop.
 539  95AB              ;   [RE]
 540  95AB              ; ----------------------------------------------------------------------
 541  95AB              CCP_UPCASE_LOOP:
 542  95AB 23                   INC HL
 543  95AC 78                   LD A,B
 544  95AD B7                   OR A
 545  95AE CA BA 95             JP Z,CCP_UPCASE_DONE
 546  95B1 7E                   LD A,(HL)
 547  95B2                      ; fold this char to upper case
 548  95B2 CD 30 95             CALL CCP_UPCASE
 549  95B5                      ; write the folded char back
 550  95B5 77                   LD (HL),A
 551  95B6 05                   DEC B
 552  95B7 C3 AB 95             JP CCP_UPCASE_LOOP
 553  95BA              ; ----------------------------------------------------------------------
 554  95BA              ; CCP_UPCASE_DONE -- terminate the upper-cased line and reset the parser.
 555  95BA              ;   In: HL -> byte just past the last char, A = 0.
 556  95BA              ;   Out: NUL written at HL; CCP_PARSEPTR := CCP_CMDTEXT.
 557  95BA              ;   Clobbers: HL.
 558  95BA              ;   Algorithm: (HL):=0 (NUL); CCP_PARSEPTR:=CCP_CMDTEXT; RET.
 559  95BA              ;   [RE]
 560  95BA              ; ----------------------------------------------------------------------
 561  95BA              CCP_UPCASE_DONE:
 562  95BA                      ; append NUL terminator
 563  95BA 77                   LD (HL),A
 564  95BB                      ; HL -> CCP_CMDTEXT
 565  95BB 21 08 94             LD HL,CCP_CMDTEXT
 566  95BE                      ; parse pointer := start of line
 567  95BE 22 88 94             LD (CCP_PARSEPTR),HL
 568  95C1 C9                   RET
 569  95C2              ; ----------------------------------------------------------------------
 570  95C2              ; CCP_CHECK_ABORT -- poll the console; if a key is waiting, consume it.
 571  95C2              ;   In: none.
 572  95C2              ;   Out: Z set if no key was pending (continue); NZ if a key was read (abort the
 573  95C2              ;     running submit); A = the key on the NZ path.
 574  95C2              ;   Clobbers: A/flags.
 575  95C2              ;   Algorithm: C:=C_STAT($0B), CALL BDOS; if A==0 RET (Z, nothing pending); else
 576  95C2              ;     C:=C_READ($01), CALL BDOS to swallow the key; OR A; RET.
 577  95C2              ;   [RE] Lets a typed key abort an active SUBMIT batch.
 578  95C2              ; ----------------------------------------------------------------------
 579  95C2              CCP_CHECK_ABORT:
 580  95C2                      ; C_STAT = 11 (console status)
 581  95C2 0E 0B                LD C,$0B
 582  95C4 CD 05 00             CALL $0005
 583  95C7 B7                   OR A
 584  95C8                      ; no key pending -> keep running submit
 585  95C8 C8                   RET Z
 586  95C9                      ; C_READ = 1: consume the typed key
 587  95C9 0E 01                LD C,$01
 588  95CB CD 05 00             CALL $0005
 589  95CE B7                   OR A
 590  95CF C9                   RET
 591  95D0              ; ----------------------------------------------------------------------
 592  95D0              ; BDOS_DRV_GET -- return the current default drive (BDOS function 25).
 593  95D0              ;   In: none.  Out: A = current drive (0..15).  Clobbers: A, C.
 594  95D0              ;   Algorithm: C:=DRV_GET($19); JP BDOS.
 595  95D0              ;   [RE]
 596  95D0              ; ----------------------------------------------------------------------
 597  95D0              BDOS_DRV_GET:
 598  95D0                      ; DRV_GET = 25
 599  95D0 0E 19                LD C,$19
 600  95D2 C3 05 00             JP $0005
 601  95D5              ; ----------------------------------------------------------------------
 602  95D5              ; CCP_SET_DMA_TBUFF -- set the DMA address back to the default buffer TBUFF.
 603  95D5              ;   In: none.  Out: BDOS DMA := TBUFF ($0080).  Clobbers: C, DE.
 604  95D5              ;   Algorithm: DE:=TBUFF($0080); fall into BDOS_F_DMAOFF.
 605  95D5              ;   [RE]
 606  95D5              ; ----------------------------------------------------------------------
 607  95D5              CCP_SET_DMA_TBUFF:
 608  95D5                      ; DE = TBUFF (default DMA buffer)
 609  95D5 11 80 00             LD DE,$0080
 610  95D8              ; ----------------------------------------------------------------------
 611  95D8              ; BDOS_F_DMAOFF -- set the disk DMA (transfer) address (BDOS function 26).
 612  95D8              ;   In: DE = DMA address.  Out: per BDOS.  Clobbers: C; BDOS ABI.
 613  95D8              ;   Algorithm: C:=F_DMAOFF($1A); JP BDOS.
 614  95D8              ;   [RE]
 615  95D8              ; ----------------------------------------------------------------------
 616  95D8              BDOS_F_DMAOFF:
 617  95D8                      ; F_DMAOFF = 26 (set DMA)
 618  95D8 0E 1A                LD C,$1A
 619  95DA C3 05 00             JP $0005
 620  95DD              ; ----------------------------------------------------------------------
 621  95DD              ; CCP_DISCARD_SUBMIT -- end an active SUBMIT: clear the flag and delete $$$.SUB.
 622  95DD              ;   In: CCP_SUBMITON ($9BAB) flag; CCP_SUBMITFCB ($9BAC); CCP_CDISK ($9BEF).
 623  95DD              ;   Out: if submit was active it is cleared, drive A selected, the submit file
 624  95DD              ;     deleted, and the default drive restored; otherwise a no-op.
 625  95DD              ;   Clobbers: A, DE.
 626  95DD              ;   Algorithm: if CCP_SUBMITON==0 RET; clear it; select drive 0 (BDOS_DRV_SET 0);
 627  95DD              ;     delete CCP_SUBMITFCB (BDOS_F_DELETE); reselect CCP_CDISK (BDOS_DRV_SET).
 628  95DD              ;   [RE]
 629  95DD              ; ----------------------------------------------------------------------
 630  95DD              CCP_DISCARD_SUBMIT:
 631  95DD                      ; HL -> submit-active flag
 632  95DD 21 AB 9B             LD HL,CCP_SUBMIT_FLAG
 633  95E0 7E                   LD A,(HL)
 634  95E1 B7                   OR A
 635  95E2                      ; no submit active -> nothing to discard
 636  95E2 C8                   RET Z
 637  95E3                      ; clear submit-active flag
 638  95E3 36 00                LD (HL),$00
 639  95E5 AF                   XOR A
 640  95E6                      ; select drive A (where $$$.SUB lives)
 641  95E6 CD BD 94             CALL BDOS_DRV_SET
 642  95E9 11 AC 9B             LD DE,CCP_SUB_FCB
 643  95EC                      ; delete the $$$.SUB submit file
 644  95EC CD EF 94             CALL BDOS_F_DELETE
 645  95EF 3A EF 9B             LD A,(CCP_CUR_DRIVE)
 646  95F2                      ; restore the user's default drive
 647  95F2 C3 BD 94             JP BDOS_DRV_SET
 648  95F5              ; ----------------------------------------------------------------------
 649  95F5              ; CCP_CHECK_SERIAL -- verify the resident BDOS serial number is still intact.
 650  95F5              ;   In: CCP_SERIAL ($9728) holds the saved 6-byte CP/M serial number; the live BDOS
 651  95F5              ;     image base is at BDOS_FBASE ($9C00), whose first 6 bytes are that serial.
 652  95F5              ;   Out: returns if the 6 bytes match; otherwise jumps to the warm-boot reload path
 653  95F5              ;     CCP_SERIAL_MISMATCH_HALT ($97CF) to refetch the system from disk.
 654  95F5              ;   Clobbers: A, B, DE, HL.
 655  95F5              ;   Algorithm: compare 6 bytes at $9728 against the BDOS image header; on first
 656  95F5              ;     mismatch JP CCP_SERIAL_MISMATCH_HALT; on full match RET.
 657  95F5              ;   [RE] Standard CP/M 2.2 CCP serial-number self-check: detects a transient that
 658  95F5              ;     overwrote the resident BDOS and forces a fresh system load if so.  NOTE: the
 659  95F5              ;     6 bytes at $9728 are the saved serial, NOT a continuation of the command-name
 660  95F5              ;     string, which ends at $9727.
 661  95F5              ; ----------------------------------------------------------------------
 662  95F5              CCP_CHECK_SERIAL:
 663  95F5                      ; DE -> saved 6-byte CP/M serial number
 664  95F5 11 28 97             LD DE,CCP_SERIAL_STAMP
 665  95F8                      ; HL -> live BDOS image header (serial at +0)
 666  95F8 21 00 9C             LD HL,BDOS_FBASE
 667  95FB                      ; compare 6 serial bytes
 668  95FB 06 06                LD B,$06
 669  95FD              ; ----------------------------------------------------------------------
 670  95FD              ; CCP_CHECK_SERIAL_LOOP -- compare loop for CCP_CHECK_SERIAL.
 671  95FD              ;   In: DE -> saved serial, HL -> live BDOS header, B = bytes remaining.
 672  95FD              ;   Out: on mismatch JP CCP_SERIAL_MISMATCH_HALT (warm-boot reload); on B==0 RET (match).
 673  95FD              ;   Clobbers: A, B, DE, HL.
 674  95FD              ;   Algorithm: A:=(DE); if A != (HL) reload; INC DE/HL; DEC B; loop.
 675  95FD              ;   [RE]
 676  95FD              ; ----------------------------------------------------------------------
 677  95FD              CCP_CHECK_SERIAL_LOOP:
 678  95FD 1A                   LD A,(DE)
 679  95FE BE                   CP (HL)
 680  95FF                      ; BDOS serial clobbered -> reload system image
 681  95FF C2 CF 97             JP NZ,CCP_SERIAL_MISMATCH_HALT
 682  9602 13                   INC DE
 683  9603 23                   INC HL
 684  9604 05                   DEC B
 685  9605 C2 FD 95             JP NZ,CCP_CHECK_SERIAL_LOOP
 686  9608 C9                   RET
 687  9609              ; ----------------------------------------------------------------------
 688  9609              ; CCP_ECHO_TOKEN -- echo the current command token to the console up to a blank.
 689  9609              ;   In: CCP_TOKENPTR ($948A) -> start of the offending token.
 690  9609              ;   Out: token characters printed; falls into CCP_REPORT_BADCMD.
 691  9609              ;   Clobbers: A, HL.
 692  9609              ;   Algorithm: CCP_CRLF; HL:=CCP_TOKENPTR; print each char until a space or NUL,
 693  9609              ;     then report the bad command.
 694  9609              ;   [RE] Used to echo the bad name before the '?' error.
 695  9609              ; ----------------------------------------------------------------------
 696  9609              CCP_ECHO_TOKEN:
 697  9609                      ; new line before echoing the token
 698  9609 CD 98 94             CALL CCP_CRLF
 699  960C                      ; HL -> start of the failing token
 700  960C 2A 8A 94             LD HL,(CCP_TOKENPTR)
 701  960F              ; ----------------------------------------------------------------------
 702  960F              ; CCP_ECHO_TOKEN_LOOP -- character loop for CCP_ECHO_TOKEN.
 703  960F              ;   In: HL -> current char of the token.
 704  960F              ;   Out: prints chars until ' ' or NUL, then joins CCP_REPORT_BADCMD.
 705  960F              ;   Clobbers: A, HL.
 706  960F              ;   Algorithm: A:=(HL); if ' ' or NUL stop; emit A via CCP_CONOUT; INC HL; loop.
 707  960F              ;   [RE]
 708  960F              ; ----------------------------------------------------------------------
 709  960F              CCP_ECHO_TOKEN_LOOP:
 710  960F 7E                   LD A,(HL)
 711  9610                      ; stop at a blank (token boundary)
 712  9610 FE 20                CP $20
 713  9612                      ; blank -> done echoing
 714  9612 CA 22 96             JP Z,CCP_REPORT_BADCMD
 715  9615 B7                   OR A
 716  9616                      ; NUL -> done echoing
 717  9616 CA 22 96             JP Z,CCP_REPORT_BADCMD
 718  9619 E5                   PUSH HL
 719  961A                      ; echo this character
 720  961A CD 8C 94             CALL CCP_CONOUT
 721  961D E1                   POP HL
 722  961E 23                   INC HL
 723  961F C3 0F 96             JP CCP_ECHO_TOKEN_LOOP
 724  9622              ; ----------------------------------------------------------------------
 725  9622              ; CCP_REPORT_BADCMD -- print '?' for an unrecognized command and return to prompt.
 726  9622              ;   In: none (called after the bad token has been echoed).
 727  9622              ;   Out: prints '?' + CR/LF, discards any submit, and jumps to the prompt loop.
 728  9622              ;   Clobbers: A.
 729  9622              ;   Algorithm: emit '?' ($3F); CCP_CRLF; CCP_DISCARD_SUBMIT; JP CCP_PROMPT_AND_READ ($9782,
 730  9622              ;     the CCP prompt).
 731  9622              ;   [RE] This is the CCP's classic 'BADNAME?' error responder.
 732  9622              ; ----------------------------------------------------------------------
 733  9622              CCP_REPORT_BADCMD:
 734  9622                      ; '?' marks an unknown command
 735  9622 3E 3F                LD A,$3F
 736  9624                      ; print the '?'
 737  9624 CD 8C 94             CALL CCP_CONOUT
 738  9627 CD 98 94             CALL CCP_CRLF
 739  962A CD DD 95             CALL CCP_DISCARD_SUBMIT
 740  962D                      ; back to the CCP prompt
 741  962D C3 82 97             JP CCP_PROMPT_AND_READ
 742  9630              ; ----------------------------------------------------------------------
 743  9630              ; CCP_AT_DELIM -- test whether the char at (DE) ends an FCB field.
 744  9630              ;   In: DE -> current command-line char.
 745  9630              ;   Out: Z set if the char is a terminator (NUL, ' ', '=', '_', '.', ':', ';', '<',
 746  9630              ;     '>'); for a control char (<' ', excluding NUL) it diverts to the bad-token echo;
 747  9630              ;     NZ for a normal filename character.
 748  9630              ;   Clobbers: A/flags.
 749  9630              ;   Algorithm: A:=(DE); RET Z on NUL; if A<' ' JP CCP_ECHO_TOKEN (illegal ctrl);
 750  9630              ;     RET Z when A==' ' or A equals any field-delimiter punctuation; else NZ.
 751  9630              ;   [RE] Field/separator classifier used while building the FCB name and type.
 752  9630              ; ----------------------------------------------------------------------
 753  9630              CCP_AT_DELIM:
 754  9630 1A                   LD A,(DE)
 755  9631 B7                   OR A
 756  9632 C8                   RET Z
 757  9633 FE 20                CP $20
 758  9635                      ; control char in name -> bad-token error
 759  9635 DA 09 96             JP C,CCP_ECHO_TOKEN
 760  9638 C8                   RET Z
 761  9639                      ; '=' delimiter
 762  9639 FE 3D                CP $3D
 763  963B C8                   RET Z
 764  963C                      ; '_' delimiter
 765  963C FE 5F                CP $5F
 766  963E C8                   RET Z
 767  963F                      ; '.' (name/type separator)
 768  963F FE 2E                CP $2E
 769  9641 C8                   RET Z
 770  9642                      ; ':' (drive separator)
 771  9642 FE 3A                CP $3A
 772  9644 C8                   RET Z
 773  9645                      ; ';' delimiter
 774  9645 FE 3B                CP $3B
 775  9647 C8                   RET Z
 776  9648                      ; '<' delimiter
 777  9648 FE 3C                CP $3C
 778  964A C8                   RET Z
 779  964B                      ; '>' delimiter
 780  964B FE 3E                CP $3E
 781  964D C8                   RET Z
 782  964E C9                   RET
 783  964F              ; ----------------------------------------------------------------------
 784  964F              ; CCP_SKIP_BLANKS -- advance (DE) past any run of spaces.
 785  964F              ;   In: DE -> command-line char.
 786  964F              ;   Out: DE -> first non-blank (or the NUL); Z set if at end of line.
 787  964F              ;   Clobbers: A/flags, DE.
 788  964F              ;   Algorithm: loop: A:=(DE); RET Z on NUL; if A != ' ' RET NZ; INC DE; loop.
 789  964F              ;   [RE]
 790  964F              ; ----------------------------------------------------------------------
 791  964F              CCP_SKIP_BLANKS:
 792  964F 1A                   LD A,(DE)
 793  9650 B7                   OR A
 794  9651 C8                   RET Z
 795  9652                      ; blank?
 796  9652 FE 20                CP $20
 797  9654                      ; non-blank -> stop here
 798  9654 C0                   RET NZ
 799  9655                      ; skip this space
 800  9655 13                   INC DE
 801  9656 C3 4F 96             JP CCP_SKIP_BLANKS
 802  9659              ; ----------------------------------------------------------------------
 803  9659              ; CCP_HL_ADD_A -- add the unsigned A to HL (16-bit add of an 8-bit offset).
 804  9659              ;   In: HL = base, A = offset.
 805  9659              ;   Out: HL = HL + A.  Clobbers: A, HL, flags.
 806  9659              ;   Algorithm: A:=A+L; L:=A; if no carry RET; else INC H; RET.
 807  9659              ;   [RE] Used to index CCP_FCB by 0 or 16 (parse FCB1 vs FCB2).
 808  9659              ; ----------------------------------------------------------------------
 809  9659              CCP_HL_ADD_A:
 810  9659                      ; low byte of HL + offset
 811  9659 85                   ADD A,L
 812  965A 6F                   LD L,A
 813  965B D0                   RET NC
 814  965C                      ; propagate carry into high byte
 815  965C 24                   INC H
 816  965D C9                   RET
 817  965E              ; ----------------------------------------------------------------------
 818  965E              ; CCP_PARSE_FCB1 -- parse the first command-tail filename into FCB at offset 0.
 819  965E              ;   In: CCP_PARSEPTR ($9488) -> current parse position in CCP_CMDTEXT.
 820  965E              ;   Out: CCP_FCB ($9BCD) filled with drive+name+type; CCP_PARSEPTR advanced;
 821  965E              ;     CCP_DRIVEGIVEN ($9BF0) set if an explicit drive prefix was present.
 822  965E              ;   Clobbers: A, BC, DE, HL.
 823  965E              ;   Algorithm: A:=0 (FCB offset 0); fall into CCP_BUILD_FCB.
 824  965E              ;   [RE]
 825  965E              ; ----------------------------------------------------------------------
 826  965E              CCP_PARSE_FCB1:
 827  965E                      ; offset 0 -> first FCB (CCP_FCB+0)
 828  965E 3E 00                LD A,$00
 829  9660              ; ----------------------------------------------------------------------
 830  9660              ; CCP_BUILD_FCB -- parse one filename token from the command tail into an FCB.
 831  9660              ;   In: A = FCB byte offset (0 for FCB1, 16 for FCB2); CCP_PARSEPTR -> scan point.
 832  9660              ;   Out: the FCB at CCP_FCB+offset holds {drive, 8-char NAME, 3-char TYPE} with '*'
 833  9660              ;     expanded to '?' and unused positions blank-padded; the 3 trailing extent/record
 834  9660              ;     bytes are zeroed; CCP_PARSEPTR / CCP_TOKENPTR advanced past the token;
 835  9660              ;     CCP_DRIVEGIVEN set to the parsed drive if a 'd:' prefix was present; A = the
 836  9660              ;     count of '?' wildcards in the 11 name+type bytes (nonzero => ambiguous FCB).
 837  9660              ;   Clobbers: A, BC, DE, HL.
 838  9660              ;   Algorithm: point HL at CCP_FCB+offset (CCP_HL_ADD_A); clear CCP_DRIVEGIVEN; load
 839  9660              ;     DE from CCP_PARSEPTR and skip leading blanks (CCP_SKIP_BLANKS); save token start
 840  9660              ;     to CCP_TOKENPTR; detect an optional 'd:' drive prefix (letter, via SBC A,$40 to
 841  9660              ;     a 1-based drive number, followed by ':') and store the drive into FCB[0];
 842  9660              ;     copy up to 8 name chars, skip an over-long name, blank-pad a short name; if a
 843  9660              ;     '.' follows copy up to 3 type chars else blank-pad the type; zero the 3 trailing
 844  9660              ;     FCB bytes; save the parse pointer; finally count the '?' wildcards.
 845  9660              ;   [RE] Classic CP/M 2.2 CCP command-tail FCB parser.
 846  9660              ; ----------------------------------------------------------------------
 847  9660              CCP_BUILD_FCB:
 848  9660                      ; HL -> CCP_FCB (drive byte) base
 849  9660 21 CD 9B             LD HL,CCP_FCB
 850  9663                      ; HL += offset (select FCB1 or FCB2)
 851  9663 CD 59 96             CALL CCP_HL_ADD_A
 852  9666 E5                   PUSH HL
 853  9667 E5                   PUSH HL
 854  9668 AF                   XOR A
 855  9669                      ; clear explicit-drive flag
 856  9669 32 F0 9B             LD (CCP_FCB_DRIVE_PREFIX),A
 857  966C                      ; HL = current parse pointer
 858  966C 2A 88 94             LD HL,(CCP_PARSEPTR)
 859  966F EB                   EX DE,HL
 860  9670                      ; skip leading blanks before the token
 861  9670 CD 4F 96             CALL CCP_SKIP_BLANKS
 862  9673 EB                   EX DE,HL
 863  9674                      ; remember token start for echo
 864  9674 22 8A 94             LD (CCP_TOKENPTR),HL
 865  9677 EB                   EX DE,HL
 866  9678 E1                   POP HL
 867  9679 1A                   LD A,(DE)
 868  967A B7                   OR A
 869  967B CA 89 96             JP Z,CCP_FCB_DRIVE_DEFAULT
 870  967E                      ; letter -> 1-based drive number (carry clear)
 871  967E DE 40                SBC A,$40
 872  9680 47                   LD B,A
 873  9681 13                   INC DE
 874  9682 1A                   LD A,(DE)
 875  9683                      ; is the next char ':' (drive prefix)?
 876  9683 FE 3A                CP $3A
 877  9685                      ; yes -> store drive, parse name
 878  9685 CA 90 96             JP Z,CCP_FCB_DRIVE_EXPLICIT
 879  9688                      ; no ':' -> back up, treat as name char
 880  9688 1B                   DEC DE
 881  9689              ; ----------------------------------------------------------------------
 882  9689              ; CCP_FCB_DRIVE_DEFAULT -- use the current default drive in the FCB drive byte.
 883  9689              ;   In: HL -> FCB drive byte; CCP_CDISK ($9BEF).
 884  9689              ;   Out: FCB[0] := default drive; continues into the name-copy setup.
 885  9689              ;   Clobbers: A.
 886  9689              ;   Algorithm: A:=CCP_CDISK; (HL):=A; JP CCP_BUILD_FCB_NAME_SETUP.
 887  9689              ;   [RE] Path taken when the token had no explicit 'd:' prefix.
 888  9689              ; ----------------------------------------------------------------------
 889  9689              CCP_FCB_DRIVE_DEFAULT:
 890  9689                      ; default drive
 891  9689 3A EF 9B             LD A,(CCP_CUR_DRIVE)
 892  968C                      ; FCB drive := default
 893  968C 77                   LD (HL),A
 894  968D C3 96 96             JP CCP_BUILD_FCB_NAME_SETUP
 895  9690              ; ----------------------------------------------------------------------
 896  9690              ; CCP_FCB_DRIVE_EXPLICIT -- store the parsed explicit drive into the FCB.
 897  9690              ;   In: B = 1-based drive number from the 'd:' prefix; HL -> FCB drive byte; DE -> ':'.
 898  9690              ;   Out: FCB[0] := drive; CCP_DRIVEGIVEN := drive; DE advanced past ':'; continues
 899  9690              ;     into the name copy.
 900  9690              ;   Clobbers: A, DE.
 901  9690              ;   Algorithm: A:=B; CCP_DRIVEGIVEN:=A; (HL):=B; INC DE (consume the ':').
 902  9690              ;   [RE]
 903  9690              ; ----------------------------------------------------------------------
 904  9690              CCP_FCB_DRIVE_EXPLICIT:
 905  9690 78                   LD A,B
 906  9691                      ; record that a drive was given
 907  9691 32 F0 9B             LD (CCP_FCB_DRIVE_PREFIX),A
 908  9694                      ; FCB drive := explicit drive number
 909  9694 70                   LD (HL),B
 910  9695                      ; consume the ':' separator
 911  9695 13                   INC DE
 912  9696              ; ----------------------------------------------------------------------
 913  9696              ; CCP_BUILD_FCB_NAME_SETUP -- begin copying the 8-char file name into the FCB.
 914  9696              ;   In: HL -> FCB drive byte (name field follows), DE -> name chars.
 915  9696              ;   Out: B := 8 (name width); falls into CCP_FCB_NAME_LOOP.
 916  9696              ;   Clobbers: B.
 917  9696              ;   Algorithm: B:=8; fall through to the name copy loop.
 918  9696              ;   [RE]
 919  9696              ; ----------------------------------------------------------------------
 920  9696              CCP_BUILD_FCB_NAME_SETUP:
 921  9696                      ; 8 name characters maximum
 922  9696 06 08                LD B,$08
 923  9698              ; ----------------------------------------------------------------------
 924  9698              ; CCP_FCB_NAME_LOOP -- copy one file-name character (handling '*' and delimiters).
 925  9698              ;   In: DE -> source char, HL -> FCB position, B = name chars remaining.
 926  9698              ;   Out: on a delimiter, jumps to CCP_FCB_NAME_PAD to blank-fill; '*' stores a '?' in
 927  9698              ;     this position and branches to fill the rest of the field with '?'; otherwise
 928  9698              ;     the char is stored and the loop continues.
 929  9698              ;   Clobbers: A, HL.
 930  9698              ;   Algorithm: if CCP_AT_DELIM -> pad; INC HL; if char=='*' store '?' and branch to
 931  9698              ;     the per-position fill; else store char + INC DE; DEC B; loop.
 932  9698              ;   [RE]
 933  9698              ; ----------------------------------------------------------------------
 934  9698              CCP_FCB_NAME_LOOP:
 935  9698                      ; stop at a field delimiter
 936  9698 CD 30 96             CALL CCP_AT_DELIM
 937  969B                      ; delimiter -> blank-pad remaining name
 938  969B CA B9 96             JP Z,CCP_FCB_NAME_PAD
 939  969E 23                   INC HL
 940  969F                      ; '*' wildcard?
 941  969F FE 2A                CP $2A
 942  96A1 C2 A9 96             JP NZ,CCP_FCB_NAME_STORE
 943  96A4                      ; '*' -> store '?' in this position
 944  96A4 36 3F                LD (HL),$3F
 945  96A6                      ; '*' fills the rest of the field with '?'
 946  96A6 C3 AB 96             JP CCP_FCB_NAME_NEXT
 947  96A9              ; ----------------------------------------------------------------------
 948  96A9              ; CCP_FCB_NAME_STORE -- store a literal name character into the FCB.
 949  96A9              ;   In: A = char, HL -> FCB position, DE -> source.
 950  96A9              ;   Out: (HL):=char; DE advanced; continues into the loop tail.
 951  96A9              ;   Clobbers: DE.
 952  96A9              ;   Algorithm: (HL):=A; INC DE; fall into CCP_FCB_NAME_NEXT.
 953  96A9              ;   [RE]
 954  96A9              ; ----------------------------------------------------------------------
 955  96A9              CCP_FCB_NAME_STORE:
 956  96A9                      ; store the name character
 957  96A9 77                   LD (HL),A
 958  96AA                      ; advance past the consumed char
 959  96AA 13                   INC DE
 960  96AB              ; ----------------------------------------------------------------------
 961  96AB              ; CCP_FCB_NAME_NEXT -- loop tail for the 8-char name copy.
 962  96AB              ;   In: B = name chars remaining.
 963  96AB              ;   Out: loops back to CCP_FCB_NAME_LOOP until B==0, then falls into the
 964  96AB              ;     over-long-name skip.
 965  96AB              ;   Clobbers: B.
 966  96AB              ;   Algorithm: DEC B; if B != 0 JP CCP_FCB_NAME_LOOP; else fall through.
 967  96AB              ;   [RE]
 968  96AB              ; ----------------------------------------------------------------------
 969  96AB              CCP_FCB_NAME_NEXT:
 970  96AB                      ; one fewer name char to copy
 971  96AB 05                   DEC B
 972  96AC C2 98 96             JP NZ,CCP_FCB_NAME_LOOP
 973  96AF              ; ----------------------------------------------------------------------
 974  96AF              ; CCP_FCB_NAME_SKIP -- discard any name characters beyond the 8-byte field.
 975  96AF              ;   In: DE -> next source char (name field already full).
 976  96AF              ;   Out: DE advanced to the first delimiter; then falls into the type parser.
 977  96AF              ;   Clobbers: A, DE.
 978  96AF              ;   Algorithm: loop: if CCP_AT_DELIM stop; INC DE; repeat.
 979  96AF              ;   [RE] Lets an over-length name (e.g. LONGFILENAME.TXT) truncate cleanly.
 980  96AF              ; ----------------------------------------------------------------------
 981  96AF              CCP_FCB_NAME_SKIP:
 982  96AF                      ; stop skipping at a delimiter
 983  96AF CD 30 96             CALL CCP_AT_DELIM
 984  96B2                      ; delimiter -> go parse the type field
 985  96B2 CA C0 96             JP Z,CCP_FCB_TYPE_BEGIN
 986  96B5                      ; discard excess name char
 987  96B5 13                   INC DE
 988  96B6 C3 AF 96             JP CCP_FCB_NAME_SKIP
 989  96B9              ; ----------------------------------------------------------------------
 990  96B9              ; CCP_FCB_NAME_PAD -- blank-fill the remaining name positions of the FCB.
 991  96B9              ;   In: HL -> last filled name position, B = positions remaining.
 992  96B9              ;   Out: remaining name bytes set to ' '; then falls into the type parser.
 993  96B9              ;   Clobbers: HL, B.
 994  96B9              ;   Algorithm: loop: INC HL; (HL):=' '; DEC B; while B != 0; then type parse.
 995  96B9              ;   [RE]
 996  96B9              ; ----------------------------------------------------------------------
 997  96B9              CCP_FCB_NAME_PAD:
 998  96B9 23                   INC HL
 999  96BA                      ; pad name with a blank
1000  96BA 36 20                LD (HL),$20
1001  96BC 05                   DEC B
1002  96BD C2 B9 96             JP NZ,CCP_FCB_NAME_PAD
1003  96C0              ; ----------------------------------------------------------------------
1004  96C0              ; CCP_FCB_TYPE_BEGIN -- start parsing the 3-char file type, if a '.' is present.
1005  96C0              ;   In: A = current delimiter char, DE -> it, HL -> end of name field.
1006  96C0              ;   Out: B := 3 (type width); if the delimiter is '.', consume it and copy the
1007  96C0              ;     type; otherwise jump straight to blank-padding the type field.
1008  96C0              ;   Clobbers: A, B, DE.
1009  96C0              ;   Algorithm: B:=3; if A != '.' JP CCP_FCB_TYPE_PAD; INC DE (eat the dot).
1010  96C0              ;   [RE]
1011  96C0              ; ----------------------------------------------------------------------
1012  96C0              CCP_FCB_TYPE_BEGIN:
1013  96C0                      ; 3 type characters
1014  96C0 06 03                LD B,$03
1015  96C2                      ; is the delimiter a '.'?
1016  96C2 FE 2E                CP $2E
1017  96C4                      ; no type given -> blank-pad type
1018  96C4 C2 E9 96             JP NZ,CCP_FCB_TYPE_PAD
1019  96C7                      ; consume the '.'
1020  96C7 13                   INC DE
1021  96C8              ; ----------------------------------------------------------------------
1022  96C8              ; CCP_FCB_TYPE_LOOP -- copy one file-type character (handling '*').
1023  96C8              ;   In: DE -> source, HL -> FCB type position, B = type chars remaining.
1024  96C8              ;   Out: on a delimiter, pad the type; '*' -> '?' (fills the rest of the type);
1025  96C8              ;     otherwise store the char.
1026  96C8              ;   Clobbers: A, HL.
1027  96C8              ;   Algorithm: mirror of CCP_FCB_NAME_LOOP for the 3-char type field.
1028  96C8              ;   [RE]
1029  96C8              ; ----------------------------------------------------------------------
1030  96C8              CCP_FCB_TYPE_LOOP:
1031  96C8                      ; stop at a delimiter
1032  96C8 CD 30 96             CALL CCP_AT_DELIM
1033  96CB                      ; delimiter -> blank-pad type
1034  96CB CA E9 96             JP Z,CCP_FCB_TYPE_PAD
1035  96CE 23                   INC HL
1036  96CF                      ; '*' wildcard in type?
1037  96CF FE 2A                CP $2A
1038  96D1 C2 D9 96             JP NZ,CCP_FCB_TYPE_STORE
1039  96D4                      ; '*' -> store '?'
1040  96D4 36 3F                LD (HL),$3F
1041  96D6                      ; '*' fills the rest of the type
1042  96D6 C3 DB 96             JP CCP_FCB_TYPE_NEXT
1043  96D9              ; ----------------------------------------------------------------------
1044  96D9              ; CCP_FCB_TYPE_STORE -- store a literal type character into the FCB.
1045  96D9              ;   In: A = char, HL -> FCB type position, DE -> source.
1046  96D9              ;   Out: (HL):=char; DE advanced; continues into the type loop tail.
1047  96D9              ;   Clobbers: DE.
1048  96D9              ;   Algorithm: (HL):=A; INC DE; fall into CCP_FCB_TYPE_NEXT.
1049  96D9              ;   [RE]
1050  96D9              ; ----------------------------------------------------------------------
1051  96D9              CCP_FCB_TYPE_STORE:
1052  96D9                      ; store the type character
1053  96D9 77                   LD (HL),A
1054  96DA                      ; advance past the consumed char
1055  96DA 13                   INC DE
1056  96DB              ; ----------------------------------------------------------------------
1057  96DB              ; CCP_FCB_TYPE_NEXT -- loop tail for the 3-char type copy.
1058  96DB              ;   In: B = type chars remaining.
1059  96DB              ;   Out: loops to CCP_FCB_TYPE_LOOP until B==0, then falls into the over-long-type
1060  96DB              ;     skip.
1061  96DB              ;   Clobbers: B.
1062  96DB              ;   Algorithm: DEC B; if B != 0 JP CCP_FCB_TYPE_LOOP; else fall through.
1063  96DB              ;   [RE]
1064  96DB              ; ----------------------------------------------------------------------
1065  96DB              CCP_FCB_TYPE_NEXT:
1066  96DB                      ; one fewer type char to copy
1067  96DB 05                   DEC B
1068  96DC C2 C8 96             JP NZ,CCP_FCB_TYPE_LOOP
1069  96DF              ; ----------------------------------------------------------------------
1070  96DF              ; CCP_FCB_TYPE_SKIP -- discard any type characters beyond the 3-byte field.
1071  96DF              ;   In: DE -> next source char (type field already full).
1072  96DF              ;   Out: DE advanced to the next delimiter; then falls into the trailer zero-fill.
1073  96DF              ;   Clobbers: A, DE.
1074  96DF              ;   Algorithm: loop: if CCP_AT_DELIM stop; INC DE; repeat.
1075  96DF              ;   [RE]
1076  96DF              ; ----------------------------------------------------------------------
1077  96DF              CCP_FCB_TYPE_SKIP:
1078  96DF                      ; stop skipping at a delimiter
1079  96DF CD 30 96             CALL CCP_AT_DELIM
1080  96E2                      ; delimiter -> zero the FCB trailer
1081  96E2 CA F0 96             JP Z,CCP_FCB_ZERO_TRAILER
1082  96E5                      ; discard excess type char
1083  96E5 13                   INC DE
1084  96E6 C3 DF 96             JP CCP_FCB_TYPE_SKIP
1085  96E9              ; ----------------------------------------------------------------------
1086  96E9              ; CCP_FCB_TYPE_PAD -- blank-fill the remaining type positions of the FCB.
1087  96E9              ;   In: HL -> last filled type position, B = positions remaining.
1088  96E9              ;   Out: remaining type bytes set to ' '; then zero the FCB trailer.
1089  96E9              ;   Clobbers: HL, B.
1090  96E9              ;   Algorithm: loop: INC HL; (HL):=' '; DEC B; while B != 0.
1091  96E9              ;   [RE]
1092  96E9              ; ----------------------------------------------------------------------
1093  96E9              CCP_FCB_TYPE_PAD:
1094  96E9 23                   INC HL
1095  96EA                      ; pad type with a blank
1096  96EA 36 20                LD (HL),$20
1097  96EC 05                   DEC B
1098  96ED C2 E9 96             JP NZ,CCP_FCB_TYPE_PAD
1099  96F0              ; ----------------------------------------------------------------------
1100  96F0              ; CCP_FCB_ZERO_TRAILER -- zero the 3 reserved FCB bytes after name+type, finish.
1101  96F0              ;   In: HL -> end of the type field.
1102  96F0              ;   Out: the 3 bytes (extent/S1/S2 area) zeroed; CCP_PARSEPTR saved; HL restored
1103  96F0              ;     to the start of the FCB; then falls into the wildcard scan.
1104  96F0              ;   Clobbers: B, HL, DE.
1105  96F0              ;   Algorithm: B:=3; loop INC HL,(HL):=0,DEC B; save DE->CCP_PARSEPTR; restore
1106  96F0              ;     HL from the stack (start of FCB pushed by CCP_BUILD_FCB).
1107  96F0              ;   [RE] The reserved trailer bytes are the FCB extent/record-count cells.
1108  96F0              ; ----------------------------------------------------------------------
1109  96F0              CCP_FCB_ZERO_TRAILER:
1110  96F0                      ; 3 trailer bytes (extent/S1/S2)
1111  96F0 06 03                LD B,$03
1112  96F2              ; ----------------------------------------------------------------------
1113  96F2              ; CCP_FCB_ZERO_LOOP -- zero-fill loop for CCP_FCB_ZERO_TRAILER; then scan wildcards.
1114  96F2              ;   In: HL -> position before the first trailer byte, B = 3.
1115  96F2              ;   Out: 3 zero bytes written; CCP_PARSEPTR := DE; HL := start-of-FCB; then count
1116  96F2              ;     the '?' wildcards in the 11 name+type bytes and return that count in A
1117  96F2              ;     (A != 0 means the FCB is ambiguous).
1118  96F2              ;   Clobbers: A, B, C, HL, DE.
1119  96F2              ;   Algorithm: INC HL,(HL):=0,DEC B loop; EX DE,HL; CCP_PARSEPTR:=HL; POP HL
1120  96F2              ;     (FCB start); BC:=$000B; fall into the wildcard counter FCB_WILDCARD_SCAN.
1121  96F2              ;   [RE]
1122  96F2              ; ----------------------------------------------------------------------
1123  96F2              CCP_FCB_ZERO_LOOP:
1124  96F2 23                   INC HL
1125  96F3                      ; zero a reserved FCB byte
1126  96F3 36 00                LD (HL),$00
1127  96F5 05                   DEC B
1128  96F6 C2 F2 96             JP NZ,CCP_FCB_ZERO_LOOP
1129  96F9 EB                   EX DE,HL
1130  96FA                      ; save the advanced parse pointer
1131  96FA 22 88 94             LD (CCP_PARSEPTR),HL
1132  96FD                      ; HL = start of the parsed FCB
1133  96FD E1                   POP HL
1134  96FE                      ; scan 11 name+type bytes for '?'
1135  96FE 01 0B 00             LD BC,$000B
1136  9701              ; ----------------------------------------------------------------------
1137  9701              ; FCB_WILDCARD_SCAN -- count '?' wildcard chars in a parsed 11-byte FCB filename.
1138  9701              ;   In: HL -> the FCB drive byte ($9BCD); the first INC HL steps onto the 8+3
1139  9701              ;       name field. BC = $000B on entry (B = 0 wildcard counter, C = 11 byte count;
1140  9701              ;       set by 'LD BC,$000B' just before falling in here).
1141  9701              ;   Out: A = number of '?' chars found; Z set if none (plain filename),
1142  9701              ;        NZ if at least one wildcard (ambiguous reference).
1143  9701              ;   Clobbers: A, B, C, HL
1144  9701              ;   Algorithm: walk the 11 name+type bytes (loop C from 11 down to 0); for each
1145  9701              ;     byte that equals '?' increment the wildcard counter B; on exit move B to A
1146  9701              ;     and test it so the caller can branch on ambiguous-vs-plain. [RE]
1147  9701              ; ----------------------------------------------------------------------
1148  9701              FCB_WILDCARD_SCAN:
1149  9701                      ; advance to next FCB name/type byte
1150  9701 23                   INC HL
1151  9702                      ; fetch this name byte
1152  9702 7E                   LD A,(HL)
1153  9703                      ; is it the '?' wildcard char?
1154  9703 FE 3F                CP $3F
1155  9705                      ; no: skip the wildcard count
1156  9705 C2 09 97             JP NZ,FCB_WILDCARD_SCAN_1
1157  9708                      ; yes: bump '?' counter
1158  9708 04                   INC B
1159  9709              FCB_WILDCARD_SCAN_1:
1160  9709                      ; one of the 11 name+type bytes done
1161  9709 0D                   DEC C
1162  970A                      ; loop until all 11 scanned
1163  970A C2 01 97             JP NZ,FCB_WILDCARD_SCAN
1164  970D                      ; return wildcard count...
1165  970D 78                   LD A,B
1166  970E                      ; ...and set Z (plain) / NZ (ambiguous)
1167  970E B7                   OR A
1168  970F C9                   RET
1169  9710              ; ----------------------------------------------------------------------
1170  9710              ; CCP_BUILTIN_NAMES -- table of the six built-in command names, 4 bytes each.
1171  9710              ;   Layout: 'DIR ','ERA ','TYPE','SAVE','REN ','USER' (24 bytes, blank-padded).
1172  9710              ;   Indexed 0..5 by SEARCH_BUILTIN; the matched index then selects a handler in
1173  9710              ;   CCP_BUILTIN_DISPATCH. [RE]
1174  9710              ; ----------------------------------------------------------------------
1175  9710              CCP_BUILTIN_NAMES:
1176  9710                      ; 0=DIR 1=ERA 2=TYPE 3=SAVE 4=REN 5=USER (4 chars each, space-padded)
1177  9710 44 49 52 20          DEFB    "DIR ERA TYPESAVEREN USER" ; string
1177  9714 45 52 41 20
1177  9718 54 59 50 45
1177  971C 53 41 56 45
1177  9720 52 45 4E 20
1177  9724 55 53 45 52
1178  9728              ; ----------------------------------------------------------------------
1179  9728              ; CCP_SERIAL_STAMP -- 6-byte CP/M serial-number stamp embedded in the CCP.
1180  9728              ;   These six bytes are compared against the first six bytes of the BDOS image
1181  9728              ;   header (BDOS_FBASE, $9C00) by the serial-check routine CCP_CHECK_SERIAL (it
1182  9728              ;   loads DE=$9728, HL=$9C00, B=6 and compares byte-for-byte); a mismatch means
1183  9728              ;   the CCP and BDOS are from different copies and CCP_CHECK_SERIAL jumps to
1184  9728              ;   CCP_SERIAL_MISMATCH_HALT.
1185  9728              ;   Treated here as opaque serial data, not code. [RE]
1186  9728              ; ----------------------------------------------------------------------
1187  9728              CCP_SERIAL_STAMP:
1188  9728                      ; CP/M serial-number bytes; must match BDOS header at $9C00 (checked by CCP_CHECK_SERIAL)
1189  9728 BD 16 00 00          DEFB    $BD,$16,$00,$00,$16,$DF
1189  972C 16 DF
1190  972E              ; ----------------------------------------------------------------------
1191  972E              ; SEARCH_BUILTIN -- match the parsed command word against the six built-in names.
1192  972E              ;   In: parsed command FCB name field at CCP_FCB_NAME (the command word lives in the
1193  972E              ;       first 4+ chars of the FCB name).
1194  972E              ;   Out: A = command index 0..5 when a built-in matches with a trailing space; on
1195  972E              ;        no match the loop runs C up to 6 and returns with A = 6 (>=6). The caller
1196  972E              ;        discriminates by the index value (>=6 means 'not a built-in', falls through
1197  972E              ;        to the external-command dispatch slot) -- carry is NOT a result flag here:
1198  972E              ;        both the match path and the exhausted path return via NC.
1199  972E              ;   Clobbers: A, B, C, DE, HL
1200  972E              ;   Algorithm: for command index C = 0..5, point HL at the 4-byte name entry in
1201  972E              ;     CCP_BUILTIN_NAMES and DE at the parsed command bytes; compare 4 bytes; on a
1202  972E              ;     full match require the next parsed byte to be a space (no trailing junk) and
1203  972E              ;     return C as the matched index; otherwise advance HL past this entry and try
1204  972E              ;     the next index. [RE]
1205  972E              ; ----------------------------------------------------------------------
1206  972E              SEARCH_BUILTIN:
1207  972E                      ; HL -> first built-in name entry (CCP_BUILTIN_NAMES)
1208  972E 21 10 97             LD HL,CCP_BUILTIN_NAMES
1209  9731                      ; start at command index 0
1210  9731 0E 00                LD C,$00
1211  9733              SEARCH_BUILTIN_NEXT:
1212  9733                      ; current command index -> A for the range test
1213  9733 79                   LD A,C
1214  9734                      ; tried all 6 built-ins?
1215  9734 FE 06                CP $06
1216  9736                      ; yes: A>=6, none matched -> not a built-in
1217  9736 D0                   RET NC
1218  9737                      ; DE -> parsed command name in the command FCB
1219  9737 11 CE 9B             LD DE,CCP_FCB_NAME
1220  973A                      ; compare 4 name chars
1221  973A 06 04                LD B,$04
1222  973C              SEARCH_BUILTIN_CMP:
1223  973C                      ; next parsed command char
1224  973C 1A                   LD A,(DE)
1225  973D                      ; vs the table name char
1226  973D BE                   CP (HL)
1227  973E                      ; mismatch: skip rest of this entry
1228  973E C2 4F 97             JP NZ,SEARCH_BUILTIN_SKIP
1229  9741 13                   INC DE
1230  9742                      ; advance table ptr to next name char
1231  9742 23                   INC HL
1232  9743 05                   DEC B
1233  9744                      ; loop the 4-char compare
1234  9744 C2 3C 97             JP NZ,SEARCH_BUILTIN_CMP
1235  9747                      ; char after the 4-char name
1236  9747 1A                   LD A,(DE)
1237  9748                      ; must be a space (exact command, no junk)
1238  9748 FE 20                CP $20
1239  974A                      ; trailing junk: not this command, try next
1240  974A C2 54 97             JP NZ,SEARCH_BUILTIN_ADVANCE
1241  974D                      ; matched: return command index in A
1242  974D 79                   LD A,C
1243  974E C9                   RET
1244  974F              SEARCH_BUILTIN_SKIP:
1245  974F                      ; skip remaining bytes of the mismatched entry
1246  974F 23                   INC HL
1247  9750 05                   DEC B
1248  9751                      ; until 4 bytes of this entry consumed
1249  9751 C2 4F 97             JP NZ,SEARCH_BUILTIN_SKIP
1250  9754              SEARCH_BUILTIN_ADVANCE:
1251  9754                      ; advance to next command index
1252  9754 0C                   INC C
1253  9755                      ; retry with the next built-in
1254  9755 C3 33 97             JP SEARCH_BUILTIN_NEXT
1255  9758              ; ----------------------------------------------------------------------
1256  9758              ; CCP_WARM_ENTRY -- warm-boot entry to the Console Command Processor.
1257  9758              ;   In: (cold-boot path enters one line below at CCP_COLD_ENTRY=$975C with C = login
1258  9758              ;       byte from the BIOS: high nibble = user number, low nibble = default drive.)
1259  9758              ;   Out: does not return normally; reads, parses, and dispatches one command,
1260  9758              ;        then loops back through the command processor.
1261  9758              ;   Clobbers: all
1262  9758              ;   Algorithm: the warm entry first clears the submit/auto-command flag
1263  9758              ;     (CCP_SUBMIT_FLAG at CCP_INLEN) then falls into the common entry, which: sets the
1264  9758              ;     user number (F_USERNUM=32) from the high nibble of the login byte, resets the
1265  9758              ;     disk system (DRV_ALLRESET=13), selects the default drive (DRV_SET=14) from the
1266  9758              ;     low nibble, and if no pending submit command prints the 'd>' prompt, reads a
1267  9758              ;     console line into the line buffer, sets DMA back to TBUFF, parses it into the
1268  9758              ;     command FCB, looks it up with SEARCH_BUILTIN, and JP (HL)'s through
1269  9758              ;     CCP_BUILTIN_DISPATCH to the matching built-in (or runs an external .COM). [RE]
1270  9758              ; ----------------------------------------------------------------------
1271  9758              CCP_WARM_ENTRY:
1272  9758                      ; warm entry: clear A
1273  9758 AF                   XOR A
1274  9759                      ; clear the submit/auto-command flag
1275  9759 32 07 94             LD (CCP_INLEN),A
1276  975C              CCP_COLD_ENTRY:
1277  975C                      ; reset CCP stack to its private area
1278  975C 31 AB 9B             LD SP,CCP_SUBMIT_FLAG
1279  975F                      ; save the BIOS login byte (user<<4 | drive)
1280  975F C5                   PUSH BC
1281  9760                      ; login byte -> A
1282  9760 79                   LD A,C
1283  9761                      ; shift high nibble (user number) down...
1284  9761 1F                   RRA
1285  9762 1F                   RRA
1286  9763 1F                   RRA
1287  9764 1F                   RRA
1288  9765                      ; isolate the 4-bit user number
1289  9765 E6 0F                AND $0F
1290  9767                      ; E = user number for the set-user call
1291  9767 5F                   LD E,A
1292  9768                      ; BDOS F_USERNUM(32): set current user code
1293  9768 CD 15 95             CALL BDOS_USERNUM
1294  976B                      ; BDOS DRV_ALLRESET(13): reset disk system, returns login vector
1295  976B CD B8 94             CALL BDOS_DRV_ALLRESET
1296  976E                      ; stash returned login byte in CCP workspace
1297  976E 32 AB 9B             LD (CCP_SUBMIT_FLAG),A
1298  9771                      ; restore login byte
1299  9771 C1                   POP BC
1300  9772                      ; login byte -> A again
1301  9772 79                   LD A,C
1302  9773                      ; isolate the 4-bit default drive number
1303  9773 E6 0F                AND $0F
1304  9775                      ; remember current/default drive
1305  9775 32 EF 9B             LD (CCP_CUR_DRIVE),A
1306  9778                      ; BDOS DRV_SET(14): select the default drive
1307  9778 CD BD 94             CALL BDOS_DRV_SET
1308  977B                      ; pending submit/auto command?
1309  977B 3A 07 94             LD A,(CCP_INLEN)
1310  977E                      ; test the submit flag
1311  977E B7                   OR A
1312  977F                      ; yes: skip the prompt, take the queued line
1313  977F C2 98 97             JP NZ,CCP_PARSE_AND_DISPATCH
1314  9782              CCP_PROMPT_AND_READ:
1315  9782                      ; reset CCP stack before prompting
1316  9782 31 AB 9B             LD SP,CCP_SUBMIT_FLAG
1317  9785                      ; print CR/LF
1318  9785 CD 98 94             CALL CCP_CRLF
1319  9788                      ; BDOS DRV_GET(25): get current drive number
1320  9788 CD D0 95             CALL BDOS_DRV_GET
1321  978B                      ; convert drive 0..15 to ASCII 'A'..'P'
1322  978B C6 41                ADD A,$41
1323  978D                      ; C_WRITE(2): echo the drive letter
1324  978D CD 8C 94             CALL CCP_CONOUT
1325  9790                      ; '>' prompt character
1326  9790 3E 3E                LD A,$3E
1327  9792                      ; C_WRITE(2): print the '>' prompt
1328  9792 CD 8C 94             CALL CCP_CONOUT
1329  9795                      ; read a console command line into the buffer
1330  9795 CD 39 95             CALL CCP_GETCMD
1331  9798              CCP_PARSE_AND_DISPATCH:
1332  9798                      ; DE -> TBUFF ($0080), the default DMA / line area
1333  9798 11 80 00             LD DE,$0080
1334  979B                      ; BDOS F_DMAOFF(26): set DMA back to TBUFF ($0080)
1335  979B CD D8 95             CALL BDOS_F_DMAOFF
1336  979E                      ; BDOS DRV_GET(25): re-read current drive
1337  979E CD D0 95             CALL BDOS_DRV_GET
1338  97A1                      ; update current/default drive
1339  97A1 32 EF 9B             LD (CCP_CUR_DRIVE),A
1340  97A4                      ; parse the typed line into the command FCB
1341  97A4 CD 5E 96             CALL CCP_PARSE_FCB1
1342  97A7                      ; on parse note, echo command tail to first blank
1343  97A7 C4 09 96             CALL NZ,CCP_ECHO_TOKEN
1344  97AA                      ; explicit drive prefix given on the command?
1345  97AA 3A F0 9B             LD A,(CCP_FCB_DRIVE_PREFIX)
1346  97AD                      ; test the drive-prefix flag
1347  97AD B7                   OR A
1348  97AE                      ; yes: go run it as an external command
1349  97AE C2 A5 9A             JP NZ,CCP_DRIVE_SELECT
1350  97B1                      ; SEARCH_BUILTIN: find a built-in command index
1351  97B1 CD 2E 97             CALL SEARCH_BUILTIN
1352  97B4                      ; HL -> built-in dispatch table
1353  97B4 21 C1 97             LD HL,CCP_BUILTIN_DISPATCH_TBL
1354  97B7                      ; E = command index from SEARCH_BUILTIN
1355  97B7 5F                   LD E,A
1356  97B8                      ; DE = zero-extended index
1357  97B8 16 00                LD D,$00
1358  97BA                      ; scale index by 2 (table of words)...
1359  97BA 19                   ADD HL,DE
1360  97BB                      ; ...HL -> the matching DEFW entry
1361  97BB 19                   ADD HL,DE
1362  97BC                      ; load handler address low byte
1363  97BC 7E                   LD A,(HL)
1364  97BD 23                   INC HL
1365  97BE                      ; load handler address high byte
1366  97BE 66                   LD H,(HL)
1367  97BF 6F                   LD L,A
1368  97C0                      ; jump to the built-in command handler
1369  97C0 E9                   JP (HL)
1370  97C1              ; ----------------------------------------------------------------------
1371  97C1              ; CCP_BUILTIN_DISPATCH_TBL -- jump table of the 7 built-in CCP command handlers.
1372  97C1              ;   In: indexed by the command number in A (0..6) returned by the built-in matcher
1373  97C1              ;       SEARCH_BUILTIN (compares the command name against the keyword table at CCP_BUILTIN_NAMES).
1374  97C1              ;   Out: n/a (table of DEFW handler addresses).
1375  97C1              ;   Clobbers: n/a (data).
1376  97C1              ;   Algorithm: the dispatcher at $97B4 loads HL=this table + 2*index, fetches the
1377  97C1              ;              16-bit handler address, and JP (HL)s to it. Order matches the keyword
1378  97C1              ;              table "DIR ERA TYPESAVEREN USER": 0=DIR 1=ERA 2=TYPE 3=SAVE 4=REN
1379  97C1              ;              5=USER, 6=not-a-builtin (load+run as a transient program).
1380  97C1              ;   [RE] Standard CP/M 2.2 CCP built-in dispatch table.
1381  97C1              ; ----------------------------------------------------------------------
1382  97C1              ; ----------------------------------------------------------------------
1383  97C1              ; CCP_BUILTIN_DISPATCH -- word table of the six built-in command handler addresses.
1384  97C1              ;   Indexed (x2) by the command number SEARCH_BUILTIN returns; entries 0..5 are
1385  97C1              ;   DIR, ERA, TYPE, SAVE, REN, USER. A seventh DEFW (external/run path) follows
1386  97C1              ;   so an out-of-range index (6) falls through to the external-command handler. [RE]
1387  97C1              ; ----------------------------------------------------------------------
1388  97C1              CCP_BUILTIN_DISPATCH_TBL:
1389  97C1                      ; index 0: DIR builtin
1390  97C1                      ; 0: DIR built-in
1391  97C1 77 98                DEFW    DIR_CMD
1392  97C3                      ; index 1: ERA builtin
1393  97C3                      ; 1: ERA built-in
1394  97C3 1F 99                DEFW    ERA_CMD
1395  97C5                      ; index 2: TYPE builtin
1396  97C5                      ; 2: TYPE built-in
1397  97C5 5D 99                DEFW    TYPE_CMD
1398  97C7                      ; index 3: SAVE builtin
1399  97C7                      ; 3: SAVE built-in
1400  97C7 AD 99                DEFW    SAVE_CMD
1401  97C9                      ; index 4: REN builtin
1402  97C9                      ; 4: REN built-in
1403  97C9 10 9A                DEFW    REN_CMD
1404  97CB                      ; index 5: USER builtin
1405  97CB                      ; 5: USER built-in
1406  97CB 8E 9A                DEFW    CCP_CMD_USER
1407  97CD                      ; index 6: not a builtin -> load and run transient .COM
1408  97CD                      ; 6: external / run .COM (out-of-range fallthrough)
1409  97CD A5 9A                DEFW    CCP_DRIVE_SELECT
1410  97CF              ; ----------------------------------------------------------------------
1411  97CF              ; CCP_SERIAL_MISMATCH_HALT -- lock the system when the BDOS serial does not match.
1412  97CF              ;   In: reached via JP NZ from the CCP serial check (CCP_CHECK_SERIAL) on a byte mismatch.
1413  97CF              ;   Out: never returns; the CPU is halted.
1414  97CF              ;   Clobbers: HL; overwrites the first 2 bytes of the CCP entry vector at $9400.
1415  97CF              ;   Algorithm: store the bytes $F3,$76 (DI ; HALT) over the CCP cold-entry vector,
1416  97CF              ;              then JP (HL) into $9400 to execute DI then HALT, hanging the machine.
1417  97CF              ;   [RE] Standard DRI CP/M anti-piracy serial trap: a corrupted/foreign BDOS makes
1418  97CF              ;        the CCP destroy its own entry point and stop. $76F3 stored little-endian
1419  97CF              ;        places opcodes F3,76 = DI ; HALT at $9400.
1420  97CF              ; ----------------------------------------------------------------------
1421  97CF              CCP_SERIAL_MISMATCH_HALT:
1422  97CF                      ; $76F3 stored little-endian = bytes F3,76 = DI ; HALT
1423  97CF 21 F3 76             LD HL,$76F3
1424  97D2                      ; overwrite the CCP cold-entry vector with DI ; HALT
1425  97D2 22 00 94             LD (CCP_ENTRY),HL
1426  97D5                      ; point HL at the just-patched entry
1427  97D5 21 00 94             LD HL,CCP_ENTRY
1428  97D8                      ; jump into it: DI then HALT -> system hangs (serial lock)
1429  97D8 E9                   JP (HL)
1430  97D9              ; ----------------------------------------------------------------------
1431  97D9              ; PRINT_READ_ERROR -- emit the "READ ERROR" message on a fresh line.
1432  97D9              ;   In: none.
1433  97D9              ;   Out: message printed via CCP_CRLF_MSG (CRLF then print-string-until-NUL).
1434  97D9              ;   Clobbers: A, BC, HL (per the print helper).
1435  97D9              ;   Algorithm: point BC at the "READ ERROR" string and tail-jump CCP_CRLF_MSG, which
1436  97D9              ;              prints a CRLF then outputs the string until the $00 terminator.
1437  97D9              ;   [RE] CCP disk read-error report.
1438  97D9              ; ----------------------------------------------------------------------
1439  97D9              PRINT_READ_ERROR:
1440  97D9                      ; BC -> "READ ERROR" string
1441  97D9 01 DF 97             LD BC,MSG_READ_ERROR
1442  97DC                      ; tail-call CRLF + print-string-until-NUL
1443  97DC C3 A7 94             JP CCP_CRLF_MSG
1444  97DF              ; ----------------------------------------------------------------------
1445  97DF              ; MSG_READ_ERROR -- NUL-terminated console message "READ ERROR".
1446  97DF              ;   In: pointed to by PRINT_READ_ERROR.
1447  97DF              ;   Out: n/a (data).
1448  97DF              ;   Clobbers: n/a.
1449  97DF              ;   Algorithm: ASCII text + $00 terminator.
1450  97DF              ;   [RE] CCP message string.
1451  97DF              ; ----------------------------------------------------------------------
1452  97DF              MSG_READ_ERROR:
1453  97DF 52 45 41 44          DEFB    "READ ERROR"             ; string
1453  97E3 20 45 52 52
1453  97E7 4F 52
1454  97E9 00                   DEFB    $00                      ; terminator
1455  97EA              ; ----------------------------------------------------------------------
1456  97EA              ; PRINT_NO_FILE -- emit the "NO FILE" message on a fresh line.
1457  97EA              ;   In: none.
1458  97EA              ;   Out: message printed via CCP_CRLF_MSG (CRLF then print-string-until-NUL).
1459  97EA              ;   Clobbers: A, BC, HL (per the print helper).
1460  97EA              ;   Algorithm: point BC at the "NO FILE" string and tail-jump CCP_CRLF_MSG.
1461  97EA              ;   [RE] CCP "file not found" report (DIR/ERA/REN with no matching file).
1462  97EA              ; ----------------------------------------------------------------------
1463  97EA              PRINT_NO_FILE:
1464  97EA                      ; BC -> "NO FILE" string
1465  97EA 01 F0 97             LD BC,MSG_NO_FILE
1466  97ED                      ; tail-call CRLF + print-string-until-NUL
1467  97ED C3 A7 94             JP CCP_CRLF_MSG
1468  97F0              ; ----------------------------------------------------------------------
1469  97F0              ; MSG_NO_FILE -- NUL-terminated console message "NO FILE".
1470  97F0              ;   In: pointed to by PRINT_NO_FILE.
1471  97F0              ;   Out: n/a (data).
1472  97F0              ;   Clobbers: n/a.
1473  97F0              ;   Algorithm: ASCII text + $00 terminator.
1474  97F0              ;   [RE] CCP message string.
1475  97F0              ; ----------------------------------------------------------------------
1476  97F0              MSG_NO_FILE:
1477  97F0 4E 4F 20 46          DEFB    "NO FILE"                ; string
1477  97F4 49 4C 45
1478  97F7 00                   DEFB    $00                      ; terminator
1479  97F8              ; ----------------------------------------------------------------------
1480  97F8              ; PARSE_FCB_DECIMAL -- parse the file-name field of the parsed FCB as a decimal number.
1481  97F8              ;   In: command tail in the CCP command buffer; reparsed here into the CCP FCB.
1482  97F8              ;   Out: A = the 8-bit decimal value (also in B); falls through to error (CCP_ECHO_TOKEN)
1483  97F8              ;        on a bad digit or overflow > 255.
1484  97F8              ;   Clobbers: A, B, C, D, HL.
1485  97F8              ;   Algorithm: rebuild the FCB from the tail (CCP_PARSE_FCB1/CCP_BUILD_FCB); if a second
1486  97F8              ;              drive-prefixed token was parsed (CCP_FCB_DRIVE_PREFIX != 0), error. Walk the 11-char
1487  97F8              ;              name field (HL=CCP_FCB_NAME): a space ends the number (then verify the
1488  97F8              ;              remaining chars are all blank); else subtract '0' and require 0..9,
1489  97F8              ;              accumulate value = value*10 + digit, trapping any carry as overflow.
1490  97F8              ;              Used by SAVE (page count) and USER (user number).
1491  97F8              ;   [RE] CCP numeric-argument parser for SAVE n and USER n.
1492  97F8              ; ----------------------------------------------------------------------
1493  97F8              PARSE_FCB_DECIMAL:
1494  97F8                      ; (re)parse the command tail into the CCP FCB
1495  97F8 CD 5E 96             CALL CCP_PARSE_FCB1
1496  97FB                      ; A = second-token drive-prefix flag from the parse (0 = none)
1497  97FB 3A F0 9B             LD A,(CCP_FCB_DRIVE_PREFIX)
1498  97FE B7                   OR A
1499  97FF                      ; unexpected extra argument -> report bad command line
1500  97FF C2 09 96             JP NZ,CCP_ECHO_TOKEN
1501  9802                      ; HL -> first char of the FCB name field
1502  9802 21 CE 9B             LD HL,CCP_FCB_NAME
1503  9805                      ; B=0 (accumulator), C=11 (name field length)
1504  9805 01 0B 00             LD BC,$000B
1505  9808              ; ----------------------------------------------------------------------
1506  9808              ; PARSE_FCB_DECIMAL_LOOP -- digit accumulation loop for PARSE_FCB_DECIMAL.
1507  9808              ;   In: HL -> current name char, B = running value, C = chars remaining.
1508  9808              ;   Out: loops until a blank or all 11 chars consumed; B holds the accumulated value.
1509  9808              ;   Clobbers: A, B, C, D, HL.
1510  9808              ;   Algorithm: load char; if ' ' jump to the trailing-blank check; else digit=char-'0',
1511  9808              ;              reject if >= 10; pre-reject if value >= 32 (would overflow *8); then
1512  9808              ;              new = value*8 (3x RLCA) + value + value (= *10) + digit, rejecting on
1513  9808              ;              carry at each add (overflow); store back, decrement count, repeat.
1514  9808              ;   [RE] Inner loop of the CCP decimal parser.
1515  9808              ; ----------------------------------------------------------------------
1516  9808              PARSE_FCB_DECIMAL_LOOP:
1517  9808 7E                   LD A,(HL)
1518  9809                      ; space ends the digit run
1519  9809 FE 20                CP $20
1520  980B                      ; verify the rest of the field is blank
1521  980B CA 33 98             JP Z,REQUIRE_TRAILING_BLANKS
1522  980E 23                   INC HL
1523  980F                      ; char - '0' -> digit value
1524  980F D6 30                SUB $30
1525  9811                      ; reject non-decimal (>= 10)
1526  9811 FE 0A                CP $0A
1527  9813 D2 09 96             JP NC,CCP_ECHO_TOKEN
1528  9816 57                   LD D,A
1529  9817 78                   LD A,B
1530  9818                      ; value already >= 32? top 3 bits set means *8 (RLCA x3) overflows a byte
1531  9818 E6 E0                AND $E0
1532  981A C2 09 96             JP NZ,CCP_ECHO_TOKEN
1533  981D 78                   LD A,B
1534  981E                      ; value << 1 (first of three RLCA -> value*8)
1535  981E 07                   RLCA
1536  981F 07                   RLCA
1537  9820 07                   RLCA
1538  9821                      ; value*8 + value -> *9 (trap carry = overflow)
1539  9821 80                   ADD A,B
1540  9822 DA 09 96             JP C,CCP_ECHO_TOKEN
1541  9825                      ; +value -> *10 (trap carry = overflow)
1542  9825 80                   ADD A,B
1543  9826 DA 09 96             JP C,CCP_ECHO_TOKEN
1544  9829                      ; + new digit (trap carry = overflow)
1545  9829 82                   ADD A,D
1546  982A DA 09 96             JP C,CCP_ECHO_TOKEN
1547  982D                      ; store back the running value
1548  982D 47                   LD B,A
1549  982E 0D                   DEC C
1550  982F C2 08 98             JP NZ,PARSE_FCB_DECIMAL_LOOP
1551  9832 C9                   RET
1552  9833              ; ----------------------------------------------------------------------
1553  9833              ; REQUIRE_TRAILING_BLANKS -- assert the remaining FCB name chars are all spaces.
1554  9833              ;   In: HL -> next name char, C = count of chars remaining, B = parsed value.
1555  9833              ;   Out: A = accumulated decimal value (from B) on success; falls to CCP_ECHO_TOKEN
1556  9833              ;        (bad command line) if any non-space is found.
1557  9833              ;   Clobbers: A, C, HL.
1558  9833              ;   Algorithm: scan C chars; any char != ' ' is an error; on reaching the end return
1559  9833              ;              the parsed value held in B.
1560  9833              ;   [RE] Tail of the SAVE/USER decimal parser.
1561  9833              ; ----------------------------------------------------------------------
1562  9833              REQUIRE_TRAILING_BLANKS:
1563  9833 7E                   LD A,(HL)
1564  9834                      ; must be a space
1565  9834 FE 20                CP $20
1566  9836                      ; trailing junk -> bad command line
1567  9836 C2 09 96             JP NZ,CCP_ECHO_TOKEN
1568  9839 23                   INC HL
1569  983A 0D                   DEC C
1570  983B                      ; continue while chars remain
1571  983B C2 33 98             JP NZ,REQUIRE_TRAILING_BLANKS
1572  983E                      ; return the accumulated decimal value
1573  983E 78                   LD A,B
1574  983F C9                   RET
1575  9840              ; ----------------------------------------------------------------------
1576  9840              ; COPY_3_BYTES -- copy a 3-byte field (an FCB type/extension) (HL)->(DE).
1577  9840              ;   In: HL = source, DE = destination.
1578  9840              ;   Out: HL, DE advanced past 3 bytes; B = 0.
1579  9840              ;   Clobbers: A, B, DE, HL.
1580  9840              ;   Algorithm: set B=3 and fall into the generic byte-copy loop COPY_N_BYTES.
1581  9840              ;   [RE] Called only by the transient-program loader (CCP_CMD_TRANSIENT) to save the
1582  9840              ;        command's 3-byte FCB type field (CCP_FCB_EXT) into a holding area (CCP_COM_EXT)
1583  9840              ;        before the FCB is rebuilt.
1584  9840              ; ----------------------------------------------------------------------
1585  9840              COPY_3_BYTES:
1586  9840                      ; 3 bytes = FCB type/extension field
1587  9840 06 03                LD B,$03
1588  9842              ; ----------------------------------------------------------------------
1589  9842              ; COPY_N_BYTES -- copy B bytes from (HL) to (DE).
1590  9842              ;   In: HL = source, DE = destination, B = byte count (> 0).
1591  9842              ;   Out: HL, DE advanced past the copied bytes; B = 0.
1592  9842              ;   Clobbers: A, B, DE, HL.
1593  9842              ;   Algorithm: loop: load (HL), store (DE), bump both pointers, dec B until zero.
1594  9842              ;   [RE] Generic CCP memcpy. Entered with B=16 to copy a whole FCB (REN, REN_CMD),
1595  9842              ;        B=33 to copy the transient FCB to $005C, B=$80 to copy a sector, and B=3 via
1596  9842              ;        COPY_3_BYTES.
1597  9842              ; ----------------------------------------------------------------------
1598  9842              COPY_N_BYTES:
1599  9842                      ; load source byte
1600  9842 7E                   LD A,(HL)
1601  9843                      ; store to destination
1602  9843 12                   LD (DE),A
1603  9844 23                   INC HL
1604  9845 13                   INC DE
1605  9846 05                   DEC B
1606  9847                      ; repeat for B bytes
1607  9847 C2 42 98             JP NZ,COPY_N_BYTES
1608  984A C9                   RET
1609  984B              ; ----------------------------------------------------------------------
1610  984B              ; TBUFF_INDEX_FETCH -- read a byte from the default DMA buffer (TBUFF=$0080) at index C+A.
1611  984B              ;   In: A = an extra offset, C = base index into the buffer.
1612  984B              ;   Out: A = byte read from TBUFF + (C + A); HL = its address.
1613  984B              ;   Clobbers: A, HL.
1614  984B              ;   Algorithm: HL = TBUFF; A = A + C; add A to HL (via CCP_HL_ADD_A); load (HL) into A.
1615  984B              ;   [RE] CCP reads a directory-entry byte out of the BDOS DMA buffer at TBUFF=$0080
1616  984B              ;        (used by DIR to walk the returned directory records).
1617  984B              ; ----------------------------------------------------------------------
1618  984B              TBUFF_INDEX_FETCH:
1619  984B                      ; HL = TBUFF (default DMA buffer at $0080)
1620  984B 21 80 00             LD HL,$0080
1621  984E                      ; combine the two index parts (C + A)
1622  984E 81                   ADD A,C
1623  984F                      ; HL += A (16-bit add)
1624  984F CD 59 96             CALL CCP_HL_ADD_A
1625  9852                      ; fetch the indexed byte
1626  9852 7E                   LD A,(HL)
1627  9853 C9                   RET
1628  9854              ; ----------------------------------------------------------------------
1629  9854              ; RESOLVE_DRIVE_PREFIX -- clear the FCB drive byte, then select the command's drive.
1630  9854              ;   In: parsed FCB at CCP_FCB (drive byte CCP_FCB); explicit drive code in CCP_FCB_DRIVE_PREFIX
1631  9854              ;       (1=A..), 0=default; current logged drive in CCP_CUR_DRIVE.
1632  9854              ;   Out: the requested drive is selected (BDOS Select Disk, fn 14) when it differs from
1633  9854              ;        the current drive; returns with the FCB drive byte forced to 0 (default).
1634  9854              ;   Clobbers: A, HL.
1635  9854              ;   Algorithm: store 0 into the FCB drive byte (auto-select); read the explicit drive
1636  9854              ;              code, if 0 (none) return; decrement to a 0-based number; if it equals the
1637  9854              ;              current drive return; otherwise tail-call BDOS_DRV_SET (BDOS Select Disk).
1638  9854              ;   [RE] CCP drive-prefix handler. Companion CCP_RESTORE_DEFAULT_DRIVE ($9866) keeps the
1639  9854              ;        FCB drive byte (skips the initial clear).
1640  9854              ; ----------------------------------------------------------------------
1641  9854              RESOLVE_DRIVE_PREFIX:
1642  9854 AF                   XOR A
1643  9855                      ; force FCB drive byte = 0 (use selected default drive)
1644  9855 32 CD 9B             LD (CCP_FCB),A
1645  9858                      ; A = explicit drive code from the command (0 = none)
1646  9858 3A F0 9B             LD A,(CCP_FCB_DRIVE_PREFIX)
1647  985B B7                   OR A
1648  985C                      ; no explicit drive -> nothing to select
1649  985C C8                   RET Z
1650  985D                      ; convert 1-based code to 0-based drive number
1651  985D 3D                   DEC A
1652  985E                      ; HL -> current logged drive
1653  985E 21 EF 9B             LD HL,CCP_CUR_DRIVE
1654  9861                      ; already the current drive?
1655  9861 BE                   CP (HL)
1656  9862                      ; yes -> no select needed
1657  9862 C8                   RET Z
1658  9863                      ; tail-call BDOS Select Disk (fn 14) with A=drive
1659  9863 C3 BD 94             JP BDOS_DRV_SET
1660  9866              ; ----------------------------------------------------------------------
1661  9866              ; CCP_RESTORE_DEFAULT_DRIVE -- If the parsed FCB carried an explicit drive prefix, re-select the
1662  9866              ; default drive (no FCB-drive-byte clear).
1663  9866              ;   In: CCP_FCB_DRIVE_PREFIX = explicit drive prefix parsed from the command's FCB (0 = none),
1664  9866              ;       CCP_CUR_DRIVE = current default drive code.
1665  9866              ;   Out: When the FCB had a prefix that differs from the default, the BDOS current disk is set back
1666  9866              ;        to the default drive (CCP_CUR_DRIVE); A clobbered.
1667  9866              ;   Clobbers: A, E, HL.
1668  9866              ;   Algorithm: If the FCB drive byte is 0 (no prefix) return. Otherwise convert the 1-based prefix
1669  9866              ;              to 0-based; if it already equals the default drive (CCP_CUR_DRIVE) return; else load
1670  9866              ;              the DEFAULT drive code (CCP_CUR_DRIVE) and call BDOS F_DRV_SET (fn 14) to re-select
1671  9866              ;              it. Variant of RESOLVE_DRIVE_PREFIX: it does NOT zero the FCB drive byte at CCP_FCB,
1672  9866              ;              and it selects the DEFAULT drive (restoring it on the post-operation/error paths)
1673  9866              ;              rather than the FCB's drive.
1674  9866              ;   [RE]
1675  9866              ; ----------------------------------------------------------------------
1676  9866              CCP_RESTORE_DEFAULT_DRIVE:
1677  9866                      ; Load explicit drive prefix parsed into this FCB (0 => no prefix)
1678  9866 3A F0 9B             LD A,(CCP_FCB_DRIVE_PREFIX)
1679  9869 B7                   OR A
1680  986A                      ; No explicit drive prefix: leave current disk unchanged
1681  986A C8                   RET Z
1682  986B                      ; Convert 1-based prefix (A=1..16) to 0-based drive code
1683  986B 3D                   DEC A
1684  986C 21 EF 9B             LD HL,CCP_CUR_DRIVE
1685  986F                      ; Compare against the current default drive (CCP_CUR_DRIVE)
1686  986F BE                   CP (HL)
1687  9870                      ; Prefix already equals the default drive: nothing to do
1688  9870 C8                   RET Z
1689  9871                      ; Load the DEFAULT drive code as the BDOS F_DRV_SET argument (restore it)
1690  9871 3A EF 9B             LD A,(CCP_CUR_DRIVE)
1691  9874                      ; Tail-call BDOS F_DRV_SET (fn 14) to re-select the default drive
1692  9874 C3 BD 94             JP BDOS_DRV_SET
1693  9877              ; ----------------------------------------------------------------------
1694  9877              ; DIR_CMD -- CCP built-in DIR: list directory entries matching the command-tail filespec.
1695  9877              ;   In: Command tail already parsed; default drive in CCP_CUR_DRIVE.
1696  9877              ;   Out: Matching filenames printed (2 per line as 'd:NAME EXT'); 'NO FILE' if none. Returns via the
1697  9877              ;        CCP command-complete path.
1698  9877              ;   Clobbers: A, B, C, D, E, H, L.
1699  9877              ;   Algorithm: Build the search FCB from the tail (CCP_PARSE_FCB1); select the requested drive
1700  9877              ;              (RESOLVE_DRIVE_PREFIX). If the first FCB name byte is blank (no name given), fall
1701  9877              ;              into DIR_WILDCARD_FILL to set all 11 name/type bytes to '?' (match every file). Falls
1702  9877              ;              through to DIR_START_SEARCH which issues SEARCH_FIRST and enters the format loop.
1703  9877              ;   [RE]
1704  9877              ; ----------------------------------------------------------------------
1705  9877              DIR_CMD:
1706  9877                      ; Parse the command tail into the search FCB at CCP_FCB
1707  9877 CD 5E 96             CALL CCP_PARSE_FCB1
1708  987A                      ; Select the drive named by the filespec prefix
1709  987A CD 54 98             CALL RESOLVE_DRIVE_PREFIX
1710  987D                      ; Point at the FCB name field (first name byte)
1711  987D 21 CE 9B             LD HL,CCP_FCB_NAME
1712  9880 7E                   LD A,(HL)
1713  9881                      ; First name byte blank? => no filespec name was given
1714  9881 FE 20                CP $20
1715  9883 C2 8F 98             JP NZ,DIR_START_SEARCH
1716  9886                      ; 11 = length of the FCB name+type field to wildcard-fill
1717  9886 06 0B                LD B,$0B
1718  9888              ; ----------------------------------------------------------------------
1719  9888              ; DIR_WILDCARD_FILL -- Overwrite the 11 FCB name+type bytes with '?' so DIR matches every file.
1720  9888              ;   In: HL = first name byte of the search FCB; B = 11.
1721  9888              ;   Out: 11 bytes set to '?' ($3F); HL advanced past them; B = 0. Falls into DIR_START_SEARCH.
1722  9888              ;   Clobbers: B, HL (A preserved).
1723  9888              ;   Algorithm: Store '?' through HL, advance, decrement count, repeat 11 times.
1724  9888              ;   [RE]
1725  9888              ; ----------------------------------------------------------------------
1726  9888              DIR_WILDCARD_FILL:
1727  9888                      ; Write '?' wildcard into this FCB name byte
1728  9888 36 3F                LD (HL),$3F
1729  988A 23                   INC HL
1730  988B 05                   DEC B
1731  988C                      ; Loop until all 11 name+type bytes are wildcarded
1732  988C C2 88 98             JP NZ,DIR_WILDCARD_FILL
1733  988F              ; ----------------------------------------------------------------------
1734  988F              ; DIR_START_SEARCH -- Begin the DIR directory scan and test the first SEARCH result.
1735  988F              ;   In: Search FCB at CCP_FCB populated.
1736  988F              ;   Out: E (per-line entry counter) initialised to 0 and pushed; BDOS SEARCH_FIRST issued; if no
1737  988F              ;        match 'NO FILE' is printed. Falls through to DIR_CMD_2.
1738  988F              ;   Clobbers: A, E, flags; pushes DE (the entry counter).
1739  988F              ;   Algorithm: Set the per-line entry counter E=0 and save it on the stack; call BDOS SEARCH_FIRST
1740  988F              ;              (fn 17); on a no-match (Z) print 'NO FILE'. Falls through to DIR_CMD_2 which loops
1741  988F              ;              over results.
1742  988F              ;   [RE]
1743  988F              ; ----------------------------------------------------------------------
1744  988F              DIR_START_SEARCH:
1745  988F                      ; E = directory-entry counter (drives the per-line column layout)
1746  988F 1E 00                LD E,$00
1747  9891                      ; Save the entry counter across the BDOS calls
1748  9891 D5                   PUSH DE
1749  9892                      ; BDOS SEARCH_FIRST (fn 17) on the FCB at CCP_FCB
1750  9892 CD E9 94             CALL CCP_SEARCH_FIRST_SUBMIT
1751  9895                      ; No directory match (Z): print 'NO FILE'
1752  9895 CC EA 97             CALL Z,PRINT_NO_FILE
1753  9898              ; ----------------------------------------------------------------------
1754  9898              ; DIR_CMD_2 -- DIR main loop body: format one matched directory entry from the DMA buffer.
1755  9898              ;   In: Z flag from the preceding SEARCH set when the directory is exhausted; BDOS stored the
1756  9898              ;       matched entry's directory code (0..3) in CCP_BDOS_RESULT; the matched 32-byte entry sits in
1757  9898              ;       the 128-byte DMA buffer (TBUFF $0080).
1758  9898              ;   Out: One entry printed as 'd:NAME EXT'; loops via SEARCH_NEXT; exits to DIR_EXIT when no more
1759  9898              ;        entries.
1760  9898              ;   Clobbers: A, B, C, D, E, H, L.
1761  9898              ;   Algorithm: If SEARCH reported no (further) match, go DIR_EXIT. Convert the directory code (0..3)
1762  9898              ;              in CCP_BDOS_RESULT to the matched entry's byte offset in the DMA buffer = code*32
1763  9898              ;              (RRCA x3 then AND $60), into C. Read the entry's flag byte at offset 10; if its bit7
1764  9898              ;              (RLA into carry) is set, skip this entry. Otherwise pop+increment+re-push the entry
1765  9898              ;              counter, AND $01 to test column parity: odd index continues the current line
1766  9898              ;              (DIR_FMT_ENTRY_COLS), even index starts a fresh CRLF line then prints the drive
1767  9898              ;              letter ('A'+drive) and ':'. Then print the 11-char name. (Layout is 2 entries per
1768  9898              ;              line, per the AND $01 mask.)
1769  9898              ;   [RE]
1770  9898              ; ----------------------------------------------------------------------
1771  9898              DIR_CMD_2:
1772  9898                      ; SEARCH returned no (further) match: finish DIR
1773  9898 CA 1B 99             JP Z,DIR_EXIT
1774  989B                      ; BDOS directory code (0..3) of the matched entry, stored by the SEARCH wrapper
1775  989B 3A EE 9B             LD A,(CCP_BDOS_RESULT)
1776  989E 0F                   RRCA
1777  989F 0F                   RRCA
1778  98A0 0F                   RRCA
1779  98A1                      ; code*32: byte offset of the matched 32-byte entry within the DMA buffer (RRCA x3 then
1780  98A1                      ; mask)
1781  98A1 E6 60                AND $60
1782  98A3                      ; C = base offset of this entry within the DMA buffer
1783  98A3 4F                   LD C,A
1784  98A4                      ; Offset 10 within the entry: the file flag/attribute byte
1785  98A4 3E 0A                LD A,$0A
1786  98A6                      ; Fetch DMA[C + 10] (the entry's flag byte)
1787  98A6 CD 4B 98             CALL TBUFF_INDEX_FETCH
1788  98A9                      ; Move bit7 of the flag byte into carry
1789  98A9 17                   RLA
1790  98AA                      ; Flag bit7 set: skip this entry, advance to SEARCH_NEXT
1791  98AA DA 0F 99             JP C,DIR_NEXT_OR_EXIT
1792  98AD                      ; Recover the running entry counter (E)
1793  98AD D1                   POP DE
1794  98AE 7B                   LD A,E
1795  98AF                      ; Count this displayed entry
1796  98AF 1C                   INC E
1797  98B0 D5                   PUSH DE
1798  98B1                      ; Parity of the entry index => 2-per-line column layout
1799  98B1 E6 01                AND $01
1800  98B3 F5                   PUSH AF
1801  98B4                      ; Odd index: continue on the same line with a column separator
1802  98B4 C2 CC 98             JP NZ,DIR_FMT_ENTRY_COLS
1803  98B7                      ; Even index: start a fresh output line (CRLF)
1804  98B7 CD 98 94             CALL CCP_CRLF
1805  98BA C5                   PUSH BC
1806  98BB                      ; BDOS GET_CUR_DRIVE (fn 25) for the drive number
1807  98BB CD D0 95             CALL BDOS_DRV_GET
1808  98BE C1                   POP BC
1809  98BF                      ; Convert drive 0..15 to letter 'A'..'P'
1810  98BF C6 41                ADD A,$41
1811  98C1 CD 92 94             CALL CCP_CONOUT_KEEPBC
1812  98C4                      ; ':' separator after the drive letter
1813  98C4 3E 3A                LD A,$3A
1814  98C6 CD 92 94             CALL CCP_CONOUT_KEEPBC
1815  98C9 C3 D4 98             JP DIR_PRINT_NAME
1816  98CC              ; ----------------------------------------------------------------------
1817  98CC              ; DIR_FMT_ENTRY_COLS -- Emit the column separator before the 2nd entry on a line.
1818  98CC              ;   In: Reached for an odd entry index (continuing the current output line).
1819  98CC              ;   Out: A space separator and a ':' printed; falls through to DIR_PRINT_NAME.
1820  98CC              ;   Clobbers: A.
1821  98CC              ;   Algorithm: Print the inter-column space (CCP_SPACE), then a ':' separator, then continue into
1822  98CC              ;              the name-print code.
1823  98CC              ;   [RE]
1824  98CC              ; ----------------------------------------------------------------------
1825  98CC              DIR_FMT_ENTRY_COLS:
1826  98CC                      ; Print the inter-column space
1827  98CC CD A2 94             CALL CCP_SPACE
1828  98CF                      ; ':' column separator
1829  98CF 3E 3A                LD A,$3A
1830  98D1 CD 92 94             CALL CCP_CONOUT_KEEPBC
1831  98D4              ; ----------------------------------------------------------------------
1832  98D4              ; DIR_PRINT_NAME -- Print one directory entry's 11-character NAME EXT field.
1833  98D4              ;   In: C = base offset of the entry within the DMA buffer (TBUFF $0080).
1834  98D4              ;   Out: Bytes 1..11 of the name/type printed with high bits stripped.
1835  98D4              ;   Clobbers: A, B.
1836  98D4              ;   Algorithm: Print a leading space (CCP_SPACE), set B=1 (first name byte index, skipping the drive
1837  98D4              ;              byte at 0), and fall into DIR_EMIT_NAME_CHAR.
1838  98D4              ;   [RE]
1839  98D4              ; ----------------------------------------------------------------------
1840  98D4              DIR_PRINT_NAME:
1841  98D4                      ; Leading space before the filename
1842  98D4 CD A2 94             CALL CCP_SPACE
1843  98D7                      ; B = name-byte index, starting at offset 1 (skip the FCB drive byte at 0)
1844  98D7 06 01                LD B,$01
1845  98D9              ; ----------------------------------------------------------------------
1846  98D9              ; DIR_EMIT_NAME_CHAR -- Loop emitting the characters of a directory name/type field.
1847  98D9              ;   In: B = current name byte index (1..11); C = entry base offset in the DMA buffer; the
1848  98D9              ;       entry-parity value pushed by DIR_CMD_2 is on the stack.
1849  98D9              ;   Out: Each character printed (blank positions emitted as a single space); a separator space
1850  98D9              ;        inserted between name (1..8) and type (9..11).
1851  98D9              ;   Clobbers: A, B.
1852  98D9              ;   Algorithm: Fetch DMA[C + B] and strip the high bit (AND $7F). If it is non-blank, print it
1853  98D9              ;              (DIR_PUT_NAME_CHAR). If it is a blank, recover the saved parity value (POP/PUSH AF)
1854  98D9              ;              and CP $03; NOTE in THIS 2.20 build the saved value is the AND $01 parity (only ever
1855  98D9              ;              0 or 1), so CP $03 never matches and the type-peek block at LD A,$09 is effectively
1856  98D9              ;              dead -- the code always substitutes a single space (DIR_EMIT_NAME_CHAR_2). (In the
1857  98D9              ;              4-column 2.23 twin the saved value is AND $03, making that block live.)
1858  98D9              ;   [RE]
1859  98D9              ; ----------------------------------------------------------------------
1860  98D9              DIR_EMIT_NAME_CHAR:
1861  98D9                      ; A = current name byte index
1862  98D9 78                   LD A,B
1863  98DA                      ; Fetch DMA[C + index] = this name/type character
1864  98DA CD 4B 98             CALL TBUFF_INDEX_FETCH
1865  98DD                      ; Strip the directory attribute high bit
1866  98DD E6 7F                AND $7F
1867  98DF                      ; Is this character a blank?
1868  98DF FE 20                CP $20
1869  98E1                      ; Non-blank: print it directly
1870  98E1 C2 F9 98             JP NZ,DIR_PUT_NAME_CHAR
1871  98E4                      ; Recover the saved entry-parity value pushed by DIR_CMD_2
1872  98E4 F1                   POP AF
1873  98E5                      ; Keep it saved for the next iteration
1874  98E5 F5                   PUSH AF
1875  98E6                      ; Compare saved value to 3 (never matches here: AND $01 yields only 0/1)
1876  98E6 FE 03                CP $03
1877  98E8                      ; Always taken in this build: emit a single space for the blank
1878  98E8 C2 F7 98             JP NZ,DIR_EMIT_NAME_CHAR_2
1879  98EB                      ; (Dead in 2.20) offset 9 = first type-field byte, peeked to detect an all-blank extension
1880  98EB 3E 09                LD A,$09
1881  98ED CD 4B 98             CALL TBUFF_INDEX_FETCH
1882  98F0 E6 7F                AND $7F
1883  98F2 FE 20                CP $20
1884  98F4                      ; (Dead in 2.20) all-blank extension: stop and go fetch the next entry
1885  98F4 CA 0E 99             JP Z,DIR_SEARCH_NEXT
1886  98F7              ; ----------------------------------------------------------------------
1887  98F7              ; DIR_EMIT_NAME_CHAR_2 -- Substitute a single space for a blank name character, then fall into the
1888  98F7              ; emit step.
1889  98F7              ;   In: Reached when the current name character is a blank to be rendered as one space.
1890  98F7              ;   Out: A = ' ' ($20); falls into DIR_PUT_NAME_CHAR (CONOUT + advance).
1891  98F7              ;   Clobbers: A.
1892  98F7              ;   Algorithm: Load a space and continue to the character-output/advance step.
1893  98F7              ;   [RE]
1894  98F7              ; ----------------------------------------------------------------------
1895  98F7              DIR_EMIT_NAME_CHAR_2:
1896  98F7                      ; Emit a single space for the blank position
1897  98F7 3E 20                LD A,$20
1898  98F9              ; ----------------------------------------------------------------------
1899  98F9              ; DIR_PUT_NAME_CHAR -- Output one name character and advance to the next name-field position.
1900  98F9              ;   In: A = character to print; B = current name byte index; C = entry base offset.
1901  98F9              ;   Out: Character printed; B incremented; loops back for the next character, or inserts the
1902  98F9              ;        name/type gap, or finishes the field.
1903  98F9              ;   Clobbers: A, B.
1904  98F9              ;   Algorithm: CONOUT the character (CCP_CONOUT_KEEPBC). Increment B; if B reaches 12 the 11-char
1905  98F9              ;              field is done (go DIR_SEARCH_NEXT). When B reaches 9 (start of the type field) print
1906  98F9              ;              an extra separator space then continue the loop; otherwise just continue.
1907  98F9              ;   [RE]
1908  98F9              ; ----------------------------------------------------------------------
1909  98F9              DIR_PUT_NAME_CHAR:
1910  98F9                      ; CONOUT this name/type character (BDOS fn 2)
1911  98F9 CD 92 94             CALL CCP_CONOUT_KEEPBC
1912  98FC                      ; Advance to the next name byte index
1913  98FC 04                   INC B
1914  98FD 78                   LD A,B
1915  98FE                      ; Reached index 12 (all 11 chars done)?
1916  98FE FE 0C                CP $0C
1917  9900                      ; Field complete: fetch the next directory entry
1918  9900 D2 0E 99             JP NC,DIR_SEARCH_NEXT
1919  9903                      ; Reached the first type-field byte (index 9)?
1920  9903 FE 09                CP $09
1921  9905 C2 D9 98             JP NZ,DIR_EMIT_NAME_CHAR
1922  9908                      ; Print the name/extension separator space
1923  9908 CD A2 94             CALL CCP_SPACE
1924  990B                      ; Continue emitting type-field characters
1925  990B C3 D9 98             JP DIR_EMIT_NAME_CHAR
1926  990E              ; ----------------------------------------------------------------------
1927  990E              ; DIR_SEARCH_NEXT -- Drop the saved parity value, then fall into the break-check + SEARCH_NEXT path.
1928  990E              ;   In: The entry-parity value pushed by DIR_CMD_2 is on the stack.
1929  990E              ;   Out: That value discarded; falls into DIR_NEXT_OR_EXIT which polls for a break and issues
1930  990E              ;        SEARCH_NEXT.
1931  990E              ;   Clobbers: AF.
1932  990E              ;   Algorithm: POP the saved parity value off the stack (the per-line entry counter pushed in
1933  990E              ;              DIR_START_SEARCH remains beneath it), then continue into the break-check +
1934  990E              ;              SEARCH_NEXT path.
1935  990E              ;   [RE]
1936  990E              ; ----------------------------------------------------------------------
1937  990E              DIR_SEARCH_NEXT:
1938  990E                      ; Discard the saved entry-parity value pushed by DIR_CMD_2
1939  990E F1                   POP AF
1940  990F              ; ----------------------------------------------------------------------
1941  990F              ; DIR_NEXT_OR_EXIT -- Poll for a console abort, then issue BDOS SEARCH_NEXT to continue DIR.
1942  990F              ;   In: Search FCB still set from the original SEARCH_FIRST.
1943  990F              ;   Out: If a key is waiting (break) DIR aborts to DIR_EXIT; otherwise SEARCH_NEXT (fn 18) runs and
1944  990F              ;        the loop resumes at DIR_CMD_2.
1945  990F              ;   Clobbers: A.
1946  990F              ;   Algorithm: Call the console-status/break check (CCP_CHECK_ABORT); if a key is waiting (NZ), exit
1947  990F              ;              DIR. Else call BDOS SEARCH_NEXT (fn 18) and loop back to DIR_CMD_2 to format the next
1948  990F              ;              entry.
1949  990F              ;   [RE]
1950  990F              ; ----------------------------------------------------------------------
1951  990F              DIR_NEXT_OR_EXIT:
1952  990F                      ; Poll console for a break/abort keypress (BDOS fn 11 then fn 1)
1953  990F CD C2 95             CALL CCP_CHECK_ABORT
1954  9912                      ; Key pressed: abort the directory listing
1955  9912 C2 1B 99             JP NZ,DIR_EXIT
1956  9915                      ; BDOS SEARCH_NEXT (fn 18) for the following entry
1957  9915 CD E4 94             CALL BDOS_F_SNEXT
1958  9918                      ; Format the next matched entry
1959  9918 C3 98 98             JP DIR_CMD_2
1960  991B              ; ----------------------------------------------------------------------
1961  991B              ; DIR_EXIT -- DIR completion: drop the saved entry counter and return to the CCP command-complete
1962  991B              ; path.
1963  991B              ;   In: The per-line entry counter (pushed in DIR_START_SEARCH) is on the stack.
1964  991B              ;   Out: Stack balanced; jumps to the shared CCP end-of-command handler.
1965  991B              ;   Clobbers: DE.
1966  991B              ;   Algorithm: POP the saved DE counter and jump to CCP_RETURN_OK (the CCP post-command /
1967  991B              ;              return-to-prompt handler).
1968  991B              ;   [RE]
1969  991B              ; ----------------------------------------------------------------------
1970  991B              DIR_EXIT:
1971  991B                      ; Balance the entry counter pushed at the start of DIR
1972  991B D1                   POP DE
1973  991C                      ; Return to the CCP command-complete handler
1974  991C C3 86 9B             JP CCP_RETURN_OK
1975  991F              ; ----------------------------------------------------------------------
1976  991F              ; ERA_CMD -- CCP built-in ERA (ERASE): delete the files matching the command-tail filespec.
1977  991F              ;   In: Command tail already parsed; default drive in CCP_CUR_DRIVE.
1978  991F              ;   Out: Matching files deleted via BDOS; if the spec was all-wildcard (all 11 FCB bytes '?') the
1979  991F              ;        user is prompted 'ALL (Y/N)?' first. Returns via the CCP command-complete path.
1980  991F              ;   Clobbers: A, B, C, D, E, H, L.
1981  991F              ;   Algorithm: Build the FCB (CCP_PARSE_FCB1 returns A = count of '?' wildcard bytes in the 11-char
1982  991F              ;              name/type). If A=11 (every position is a wildcard, i.e. '*.*') print 'ALL (Y/N)?',
1983  991F              ;              read a console line, and abort unless it is a single 'Y'. Then fall into
1984  991F              ;              ERA_DO_DELETE.
1985  991F              ;   [RE]
1986  991F              ; ----------------------------------------------------------------------
1987  991F              ERA_CMD:
1988  991F                      ; Parse the command tail into the FCB; A = count of '?' wildcard bytes
1989  991F CD 5E 96             CALL CCP_PARSE_FCB1
1990  9922                      ; All 11 name/type bytes wildcard => the spec was '*.*' (erase everything)
1991  9922 FE 0B                CP $0B
1992  9924                      ; Not '*.*': skip the confirmation prompt
1993  9924 C2 42 99             JP NZ,ERA_DO_DELETE
1994  9927                      ; Point at the 'ALL (Y/N)?' prompt string
1995  9927 01 52 99             LD BC,MSG_ERA_CONFIRM
1996  992A                      ; Print CRLF then the prompt
1997  992A CD A7 94             CALL CCP_CRLF_MSG
1998  992D                      ; Read a console input line (the Y/N reply)
1999  992D CD 39 95             CALL CCP_GETCMD
2000  9930                      ; Point at the read-line character-count byte
2001  9930 21 07 94             LD HL,CCP_INLEN
2002  9933                      ; Require exactly one reply character (count must be 1)
2003  9933 35                   DEC (HL)
2004  9934                      ; Not a single char: abort back to the prompt
2005  9934 C2 82 97             JP NZ,CCP_PROMPT_AND_READ
2006  9937 23                   INC HL
2007  9938 7E                   LD A,(HL)
2008  9939                      ; Reply must be 'Y'
2009  9939 FE 59                CP $59
2010  993B                      ; Not 'Y': cancel the ERA and return to the prompt
2011  993B C2 82 97             JP NZ,CCP_PROMPT_AND_READ
2012  993E 23                   INC HL
2013  993F                      ; Advance the command-tail parse pointer past the consumed reply
2014  993F 22 88 94             LD (CCP_PARSEPTR),HL
2015  9942              ; ----------------------------------------------------------------------
2016  9942              ; ERA_DO_DELETE -- Perform the actual ERA file deletion after any confirmation.
2017  9942              ;   In: FCB at CCP_FCB holds the (possibly wildcard) filespec.
2018  9942              ;   Out: BDOS DELETE_FILE executed; 'NO FILE' printed when nothing matched; returns via the CCP
2019  9942              ;        command-complete path.
2020  9942              ;   Clobbers: A, D, E.
2021  9942              ;   Algorithm: Select the FCB's drive (RESOLVE_DRIVE_PREFIX); DE = FCB; call BDOS DELETE_FILE (fn
2022  9942              ;              19). INC A so a $FF (no-file) return becomes 0/Z; on Z print 'NO FILE'. Jump to the
2023  9942              ;              CCP post-command handler.
2024  9942              ;   [RE]
2025  9942              ; ----------------------------------------------------------------------
2026  9942              ERA_DO_DELETE:
2027  9942                      ; Select the drive named by the filespec
2028  9942 CD 54 98             CALL RESOLVE_DRIVE_PREFIX
2029  9945                      ; DE -> FCB for the delete call
2030  9945 11 CD 9B             LD DE,CCP_FCB
2031  9948                      ; BDOS DELETE_FILE (fn 19) on the FCB
2032  9948 CD EF 94             CALL BDOS_F_DELETE
2033  994B                      ; Map $FF (no file deleted) to 0 so Z signals 'nothing matched'
2034  994B 3C                   INC A
2035  994C                      ; Nothing deleted => print 'NO FILE'
2036  994C CC EA 97             CALL Z,PRINT_NO_FILE
2037  994F                      ; Return to the CCP command-complete handler
2038  994F C3 86 9B             JP CCP_RETURN_OK
2039  9952              ; ----------------------------------------------------------------------
2040  9952              ; MSG_ERA_CONFIRM -- ASCII prompt 'ALL (Y/N)?' shown before erasing every file (ERA *.*).
2041  9952              ;   In: n/a (data).
2042  9952              ;   Out: n/a (null-terminated string constant).
2043  9952              ;   Clobbers: none.
2044  9952              ;   Algorithm: Null-terminated string printed (CRLF-prefixed) by CCP_CRLF_MSG when an ERA names
2045  9952              ;              all-wildcard files.
2046  9952              ;   [RE]
2047  9952              ; ----------------------------------------------------------------------
2048  9952              MSG_ERA_CONFIRM:
2049  9952 41 4C 4C 20          DEFB    "ALL (Y/N)?"             ; string
2049  9956 28 59 2F 4E
2049  995A 29 3F
2050  995C 00                   DEFB    $00                      ; terminator
2051  995D              ; ----------------------------------------------------------------------
2052  995D              ; TYPE_CMD -- CCP built-in TYPE: open the named text file and echo its contents to the console.
2053  995D              ;   In: Command tail already parsed; default drive in CCP_CUR_DRIVE.
2054  995D              ;   Out: File contents printed record by record until the $1A EOF marker or a console break; on open
2055  995D              ;        failure the offending name is echoed. Returns via the CCP command-complete path.
2056  995D              ;   Clobbers: A, B, C, D, E, H, L.
2057  995D              ;   Algorithm: Re-parse the FCB (CCP_PARSE_FCB1); if the parse flagged the spec (NZ, e.g. ambiguous)
2058  995D              ;              reject it via CCP_ECHO_TOKEN. Select the drive and BDOS OPEN the file
2059  995D              ;              (CCP_OPEN_SUBMIT = fn 15); if the open fails (Z) go report it. Emit a leading CRLF,
2060  995D              ;              prime the per-record byte counter CCP_FCB_TAIL to $FF, and enter the read/print loop
2061  995D              ;              (TYPE_PRINT_LOOP).
2062  995D              ;   [RE]
2063  995D              ; ----------------------------------------------------------------------
2064  995D              TYPE_CMD:
2065  995D                      ; Parse the command tail into the FCB at CCP_FCB
2066  995D CD 5E 96             CALL CCP_PARSE_FCB1
2067  9960                      ; Bad/ambiguous filespec: echo the offending token and abort
2068  9960 C2 09 96             JP NZ,CCP_ECHO_TOKEN
2069  9963                      ; Select the file's drive
2070  9963 CD 54 98             CALL RESOLVE_DRIVE_PREFIX
2071  9966                      ; BDOS OPEN_FILE (fn 15) on the FCB at CCP_FCB
2072  9966 CD D0 94             CALL CCP_OPEN_SUBMIT
2073  9969                      ; Open failed (file not found): go report it
2074  9969 CA A7 99             JP Z,TYPE_NO_FILE
2075  996C                      ; Emit a leading CRLF before the file text
2076  996C CD 98 94             CALL CCP_CRLF
2077  996F                      ; Point at the TYPE per-record byte counter
2078  996F 21 F1 9B             LD HL,CCP_FCB_TAIL
2079  9972                      ; Prime the counter so the first loop pass forces a record read
2080  9972 36 FF                LD (HL),$FF
2081  9974              ; ----------------------------------------------------------------------
2082  9974              ; TYPE_PRINT_LOOP -- TYPE inner loop: read each record and print its bytes until EOF.
2083  9974              ;   In: File opened; CCP_FCB_TAIL = per-record byte counter (primed to $FF).
2084  9974              ;   Out: Each 128-byte record's characters echoed; stops at the $1A (CTRL-Z) EOF marker, a non-zero
2085  9974              ;        read status, or a console break. Returns via the CCP command-complete path.
2086  9974              ;   Clobbers: A, B, C, D, E, H, L.
2087  9974              ;   Algorithm: When the byte counter has reached $80 (record consumed) read the next record (BDOS
2088  9974              ;              READ_SEQ, fn 20); a non-zero read status ends the file/handles the error at
2089  9974              ;              TYPE_READ_DONE, and the counter is reset to 0. INC the counter, index TBUFF+counter
2090  9974              ;              (LD HL,$0080 + CCP_HL_ADD_A); if the byte is $1A finish. Otherwise CONOUT it and poll
2091  9974              ;              the console for a break; on break finish, else loop.
2092  9974              ;   [RE]
2093  9974              ; ----------------------------------------------------------------------
2094  9974              TYPE_PRINT_LOOP:
2095  9974                      ; Point at the per-record byte counter
2096  9974 21 F1 9B             LD HL,CCP_FCB_TAIL
2097  9977                      ; Fetch the current record byte (TBUFF + counter)
2098  9977 7E                   LD A,(HL)
2099  9978                      ; Consumed a whole 128-byte record? then read the next one
2100  9978 FE 80                CP $80
2101  997A                      ; Still within the current record: print the next byte
2102  997A DA 87 99             JP C,TYPE_EMIT_CHAR
2103  997D E5                   PUSH HL
2104  997E                      ; BDOS READ_SEQ (fn 20) next record into the DMA buffer
2105  997E CD FE 94             CALL CCP_READ_SUBMIT
2106  9981 E1                   POP HL
2107  9982                      ; Non-zero status: end of file (or error) -> finish at TYPE_READ_DONE
2108  9982 C2 A0 99             JP NZ,TYPE_READ_DONE
2109  9985 AF                   XOR A
2110  9986                      ; Reset the byte counter to 0 for the new record
2111  9986 77                   LD (HL),A
2112  9987              ; ----------------------------------------------------------------------
2113  9987              ; TYPE_EMIT_CHAR -- Emit one buffered character of the TYPE'd file, advancing the record index.
2114  9987              ;   In: HL -> the TYPE record-byte-index cell (CCP_FCB_TAIL); A = the current within-record offset;
2115  9987              ;       the current 128-byte record has already been read into TBUFF ($0080).
2116  9987              ;   Out: character written to the console via C_WRITE; loops back for the next character, or returns
2117  9987              ;        to the CCP command-complete exit on Ctrl-Z (EOF marker) or a console-abort keypress.
2118  9987              ;   Clobbers: A, HL, flags.
2119  9987              ;   Algorithm: INC the index cell; form TBUFF+offset ($0080 + A via CCP_HL_ADD_A) and fetch the
2120  9987              ;              byte. If it is $1A (Ctrl-Z = soft end-of-file) finish the command. Otherwise write
2121  9987              ;              the byte with BDOS C_WRITE (fn 2), poll the console for an abort keystroke
2122  9987              ;              (CCP_CHECK_ABORT), and on abort finish; else continue the TYPE output loop.
2123  9987              ; [RE] TYPE built-in inner emit step; $1A = CP/M text EOF sentinel. [DOC CPMREF: CCP TYPE]
2124  9987              ; ----------------------------------------------------------------------
2125  9987              TYPE_EMIT_CHAR:
2126  9987                      ; advance the TYPE record-byte-index cell (next byte within the current 128-byte record)
2127  9987                      ; advance the within-record byte index (next byte of the current 128-byte record)
2128  9987 34                   INC (HL)
2129  9988                      ; TBUFF base ($0080); CCP_HL_ADD_A adds the current offset in A to form TBUFF+offset
2130  9988                      ; TBUFF base ($0080); the following CCP_HL_ADD_A adds the byte index in A to address
2131  9988                      ; TBUFF+index
2132  9988 21 80 00             LD HL,$0080
2133  998B CD 59 96             CALL CCP_HL_ADD_A
2134  998E 7E                   LD A,(HL)
2135  998F                      ; $1A = Ctrl-Z, CP/M soft end-of-file marker -> stop TYPE
2136  998F                      ; $1A = Ctrl-Z, the CP/M soft end-of-file marker that terminates a text file
2137  998F FE 1A                CP $1A
2138  9991                      ; EOF reached: branch to the CCP command-complete exit
2139  9991                      ; EOF reached: stop TYPE and return through the CCP command-complete path
2140  9991 CA 86 9B             JP Z,CCP_RETURN_OK
2141  9994                      ; BDOS C_WRITE (fn 2): print this character to the console
2142  9994                      ; emit this record byte to the console via BDOS C_WRITE (fn 2)
2143  9994 CD 8C 94             CALL CCP_CONOUT
2144  9997                      ; poll console status (fn 11) then read (fn 1) if a key is down; nonzero = user pressed a
2145  9997                      ; key to abort TYPE
2146  9997                      ; poll the console for a key (fn 11/fn 1); nonzero = user pressed a key to abort TYPE
2147  9997 CD C2 95             CALL CCP_CHECK_ABORT
2148  999A                      ; user aborted: branch to the command-complete exit
2149  999A                      ; user aborted: stop TYPE and return through the CCP command-complete path
2150  999A C2 86 9B             JP NZ,CCP_RETURN_OK
2151  999D                      ; no EOF/abort: continue the TYPE character loop
2152  999D                      ; no EOF and no abort: loop back for the next character/record
2153  999D C3 74 99             JP TYPE_PRINT_LOOP
2154  99A0              ; ----------------------------------------------------------------------
2155  99A0              ; TYPE_READ_DONE -- Handle the result of a failed/short F_READ during TYPE (EOF vs read error).
2156  99A0              ;   In: A = BDOS F_READ (fn 20) return code from the just-attempted sequential read (1 = normal
2157  99A0              ;       end-of-file, other nonzero = read error).
2158  99A0              ;   Out: on normal EOF returns quietly to the CCP exit; on a read error prints "READ ERROR" and
2159  99A0              ;        falls through to the no-file/error tail.
2160  99A0              ;   Clobbers: A, BC, flags.
2161  99A0              ;   Algorithm: DEC A; if the code was 1 (normal EOF) jump to the command-complete exit. Otherwise
2162  99A0              ;              (read error) call the "READ ERROR" message printer, then fall into the drive-restore
2163  99A0              ;              + bad-command echo tail.
2164  99A0              ; [RE] TYPE built-in read-failure dispatch. [DOC CPMREF: CCP TYPE]
2165  99A0              ; ----------------------------------------------------------------------
2166  99A0              TYPE_READ_DONE:
2167  99A0                      ; F_READ code 1 (normal EOF) -> 0 here; any other code stays nonzero = real error
2168  99A0 3D                   DEC A
2169  99A1                      ; normal end-of-file: finish the TYPE command cleanly
2170  99A1 CA 86 9B             JP Z,CCP_RETURN_OK
2171  99A4                      ; print the "READ ERROR" message (disk read failure)
2172  99A4 CD D9 97             CALL PRINT_READ_ERROR
2173  99A7              ; ----------------------------------------------------------------------
2174  99A7              ; TYPE_NO_FILE -- TYPE error/not-found tail: restore the caller's drive and echo the bad command.
2175  99A7              ;   In: none (entered when the TYPE target file could not be opened, or after a read error).
2176  99A7              ;   Out: re-selects the user's original drive and jumps to the bad-command echo path; does not
2177  99A7              ;        return.
2178  99A7              ;   Clobbers: A, HL, flags.
2179  99A7              ;   Algorithm: call CCP_RESTORE_DEFAULT_DRIVE to restore the default drive selection, then jump to
2180  99A7              ;              the CCP_ECHO_TOKEN routine that re-emits the offending command word followed by '?'.
2181  99A7              ; [RE] Shared TYPE failure exit. [DOC CPMREF: CCP TYPE]
2182  99A7              ; ----------------------------------------------------------------------
2183  99A7              TYPE_NO_FILE:
2184  99A7                      ; restore the user's original/default drive after the temporary drive switch
2185  99A7 CD 66 98             CALL CCP_RESTORE_DEFAULT_DRIVE
2186  99AA                      ; echo the unrecognized/failed command token with a '?' and re-prompt
2187  99AA C3 09 96             JP CCP_ECHO_TOKEN
2188  99AD              ; ----------------------------------------------------------------------
2189  99AD              ; SAVE_CMD -- CCP built-in SAVE: write N pages of memory from the TPA to a new disk file.
2190  99AD              ;   In: command line "SAVE n filespec"; n = decimal page count (256-byte pages) parsed from the
2191  99AD              ;       line, filespec built into the CCP command FCB (CCP_FCB).
2192  99AD              ;   Out: creates the named file and writes n*2 128-byte records starting at $0100; on success
2193  99AD              ;        returns via the SAVE finish path, on dir-full/disk-full prints "NO SPACE".
2194  99AD              ;   Clobbers: A, BC, DE, HL, flags.
2195  99AD              ;   Algorithm: parse the numeric page count (PARSE_FCB_DECIMAL) and stash it; build the filename FCB
2196  99AD              ;              (CCP_PARSE_FCB1) and reject a malformed filespec; resolve the drive prefix; delete
2197  99AD              ;              any pre-existing file of that name (F_DELETE_HND fn 19); create the file (F_MAKE fn 22)
2198  99AD              ;              and on failure branch to the NO-SPACE handler; clear the FCB current-record byte;
2199  99AD              ;              convert the page count to a 128-byte record count (count*2) and set the source
2200  99AD              ;              pointer to $0100; then enter the write loop.
2201  99AD              ; [RE] SAVE built-in; source data begins at the TPA base $0100. [DOC CPMREF: CCP SAVE]
2202  99AD              ; ----------------------------------------------------------------------
2203  99AD              SAVE_CMD:
2204  99AD                      ; parse the leading decimal page-count argument; A = number of 256-byte pages
2205  99AD CD F8 97             CALL PARSE_FCB_DECIMAL
2206  99B0                      ; stash the page count across the FCB parse
2207  99B0 F5                   PUSH AF
2208  99B1                      ; build the destination filename into the CCP command FCB (CCP_FCB) from the command tail
2209  99B1 CD 5E 96             CALL CCP_PARSE_FCB1
2210  99B4                      ; malformed filespec: echo the bad command and abort
2211  99B4 C2 09 96             JP NZ,CCP_ECHO_TOKEN
2212  99B7 CD 54 98             CALL RESOLVE_DRIVE_PREFIX
2213  99BA 11 CD 9B             LD DE,CCP_FCB
2214  99BD D5                   PUSH DE
2215  99BE                      ; BDOS F_DELETE_HND (fn 19): remove any existing file with this name first
2216  99BE CD EF 94             CALL BDOS_F_DELETE
2217  99C1 D1                   POP DE
2218  99C2                      ; BDOS F_MAKE (fn 22): create the new (empty) file
2219  99C2 CD 09 95             CALL BDOS_F_MAKE
2220  99C5                      ; no free directory entry: jump to the NO-SPACE error
2221  99C5 CA FB 99             JP Z,SAVE_DISK_FULL
2222  99C8 AF                   XOR A
2223  99C9                      ; clear the FCB current-record byte so writing starts at record 0
2224  99C9 32 ED 9B             LD (CCP_FCB_CR),A
2225  99CC                      ; recover the saved page count
2226  99CC F1                   POP AF
2227  99CD 6F                   LD L,A
2228  99CE 26 00                LD H,$00
2229  99D0                      ; pages*2 = number of 128-byte records to write
2230  99D0 29                   ADD HL,HL
2231  99D1                      ; DE = source pointer, starting at the TPA base $0100
2232  99D1 11 00 01             LD DE,$0100
2233  99D4              ; ----------------------------------------------------------------------
2234  99D4              ; SAVE_WRITE_LOOP -- Write the remaining 128-byte records of a SAVE from successive memory slices.
2235  99D4              ;   In: HL = remaining record count; DE = current source/DMA address (starts $0100, advances by $80
2236  99D4              ;       per record); the CCP command FCB (CCP_FCB) is the open output file.
2237  99D4              ;   Out: writes each record sequentially; on a write failure (disk full) branches to NO-SPACE; falls
2238  99D4              ;        through to the close step when the count reaches zero.
2239  99D4              ;   Clobbers: A, BC, DE, HL, flags.
2240  99D4              ;   Algorithm: while HL != 0: decrement it; precompute the NEXT source pointer ($0080 + DE) and park
2241  99D4              ;              it on the stack; set the DMA to the CURRENT source DE via F_DMAOFF (fn 26); write the
2242  99D4              ;              record with F_WRITE (fn 21) from the FCB; POP the advanced pointer back into DE and
2243  99D4              ;              restore HL; on a nonzero write status jump to NO-SPACE; otherwise loop.
2244  99D4              ;   [RE] DE is the live DMA/source; the $0080 add forms the next record's source, recovered from the
2245  99D4              ;   stack after the write. [DOC CPMREF: CCP SAVE]
2246  99D4              ; ----------------------------------------------------------------------
2247  99D4              SAVE_WRITE_LOOP:
2248  99D4 7C                   LD A,H
2249  99D5                      ; test the 16-bit remaining-record count for zero
2250  99D5 B5                   OR L
2251  99D6                      ; all records written: go close the file
2252  99D6 CA F1 99             JP Z,SAVE_CLOSE
2253  99D9                      ; consume one record from the remaining count
2254  99D9 2B                   DEC HL
2255  99DA E5                   PUSH HL
2256  99DB                      ; compute $0080 + DE = the NEXT record's source (parked on the stack); the DMA below uses
2257  99DB                      ; the CURRENT DE
2258  99DB 21 80 00             LD HL,$0080
2259  99DE 19                   ADD HL,DE
2260  99DF E5                   PUSH HL
2261  99E0                      ; BDOS F_DMAOFF (fn 26): point the DMA at the CURRENT 128-byte source slice (DE)
2262  99E0 CD D8 95             CALL BDOS_F_DMAOFF
2263  99E3 11 CD 9B             LD DE,CCP_FCB
2264  99E6                      ; BDOS F_WRITE (fn 21): append the record to the file
2265  99E6 CD 04 95             CALL BDOS_F_WRITE
2266  99E9 D1                   POP DE
2267  99EA E1                   POP HL
2268  99EB                      ; write failed (disk full): jump to the NO-SPACE error
2269  99EB C2 FB 99             JP NZ,SAVE_DISK_FULL
2270  99EE                      ; continue writing the next record
2271  99EE C3 D4 99             JP SAVE_WRITE_LOOP
2272  99F1              ; ----------------------------------------------------------------------
2273  99F1              ; SAVE_CLOSE -- Close the SAVE output file after all records are written.
2274  99F1              ;   In: the CCP command FCB (CCP_FCB) = the open output file (all records already written).
2275  99F1              ;   Out: closes the file; on success continues to the SAVE finish/cleanup path, on close failure
2276  99F1              ;        falls into the NO-SPACE error.
2277  99F1              ;   Clobbers: A, C, DE, flags.
2278  99F1              ;   Algorithm: point DE at the FCB, call F_CLOSE_HND (fn 16); the wrapper returns $FF+1=0 on failure, so
2279  99F1              ;              INC A here is already folded into the wrapper -- a nonzero result means success and
2280  99F1              ;              branches to the finish path; a zero (failure) result falls into the NO-SPACE handler.
2281  99F1              ; [RE] SAVE close step. [DOC CPMREF: CCP SAVE]
2282  99F1              ; ----------------------------------------------------------------------
2283  99F1              SAVE_CLOSE:
2284  99F1 11 CD 9B             LD DE,CCP_FCB
2285  99F4                      ; BDOS F_CLOSE_HND (fn 16): flush the directory entry for the saved file
2286  99F4 CD DA 94             CALL BDOS_F_CLOSE
2287  99F7                      ; map the $FF close-error code to 0 (failure); a valid directory code becomes nonzero =
2288  99F7                      ; success
2289  99F7 3C                   INC A
2290  99F8                      ; close succeeded: go to the SAVE finish/cleanup path
2291  99F8 C2 01 9A             JP NZ,SAVE_FINISH
2292  99FB              ; ----------------------------------------------------------------------
2293  99FB              ; SAVE_DISK_FULL -- SAVE error tail: report "NO SPACE" and clean up.
2294  99FB              ;   In: none (entered on F_MAKE failure, a failed F_WRITE, or a failed F_CLOSE_HND).
2295  99FB              ;   Out: prints the "NO SPACE" message, then falls into the SAVE finish/cleanup path.
2296  99FB              ;   Clobbers: A, BC, DE, HL, flags.
2297  99FB              ;   Algorithm: load BC with the address of MSG_NO_SPACE, print it (CR/LF + string via CCP_CRLF_MSG),
2298  99FB              ;              then fall through to SAVE_FINISH which restores the default DMA.
2299  99FB              ; [RE] Shared SAVE failure message. [DOC CPMREF: CCP SAVE]
2300  99FB              ; ----------------------------------------------------------------------
2301  99FB              SAVE_DISK_FULL:
2302  99FB                      ; address of the "NO SPACE" message string
2303  99FB 01 07 9A             LD BC,MSG_NO_SPACE
2304  99FE                      ; print CR/LF then the NUL-terminated message via C_WRITE
2305  99FE CD A7 94             CALL CCP_CRLF_MSG
2306  9A01              ; ----------------------------------------------------------------------
2307  9A01              ; SAVE_FINISH -- Restore the default DMA address and return to the CCP after a SAVE.
2308  9A01              ;   In: none.
2309  9A01              ;   Out: resets the BDOS DMA address to the default $0080 and jumps to the CCP command-complete
2310  9A01              ;        exit; does not return.
2311  9A01              ;   Clobbers: A, C, DE, flags.
2312  9A01              ;   Algorithm: call CCP_SET_DMA_TBUFF which loads DE=$0080 and invokes F_DMAOFF (fn 26) to restore
2313  9A01              ;              the default DMA (SAVE had walked the DMA across the TPA), then jump to the
2314  9A01              ;              command-complete exit.
2315  9A01              ; [RE] SAVE cleanup. [DOC CPMREF: CCP SAVE]
2316  9A01              ; ----------------------------------------------------------------------
2317  9A01              SAVE_FINISH:
2318  9A01                      ; restore the DMA to the default $0080 (SAVE had walked it across memory)
2319  9A01 CD D5 95             CALL CCP_SET_DMA_TBUFF
2320  9A04                      ; return to the CCP command-complete exit
2321  9A04 C3 86 9B             JP CCP_RETURN_OK
2322  9A07              ; ----------------------------------------------------------------------
2323  9A07              ; MSG_NO_SPACE -- NUL-terminated console message "NO SPACE" shown when SAVE runs out of room.
2324  9A07              ;   In: referenced by BC in SAVE_DISK_FULL.
2325  9A07              ;   Out: data only (the ASCII string followed by a $00 terminator).
2326  9A07              ;   Clobbers: none.
2327  9A07              ;   Algorithm: data.
2328  9A07              ; [RE] CCP message string. [DOC CPMREF: CCP SAVE]
2329  9A07              ; ----------------------------------------------------------------------
2330  9A07              MSG_NO_SPACE:
2331  9A07 4E 4F 20 53          DEFB    "NO SPACE"               ; string
2331  9A0B 50 41 43 45
2332  9A0F 00                   DEFB    $00                      ; terminator
2333  9A10              ; ----------------------------------------------------------------------
2334  9A10              ; REN_CMD -- CCP built-in REN(AME): rename an existing file given "REN newname=oldname".
2335  9A10              ;   In: command line "REN newfile=oldfile"; the new name is parsed first into the CCP command FCB
2336  9A10              ;       (CCP_FCB).
2337  9A10              ;   Out: renames oldfile to newfile via F_RENAME_HND; errors are reported as "FILE EXISTS", "NO FILE",
2338  9A10              ;        or a bad-command echo.
2339  9A10              ;   Clobbers: A, B, DE, HL, flags.
2340  9A10              ;   Algorithm: parse the new-name FCB; reject a malformed spec; save the new name's drive prefix
2341  9A10              ;              (CCP_FCB_DRIVE_PREFIX); resolve the drive; search the directory for the new name and
2342  9A10              ;              if it already EXISTS branch to the FILE-EXISTS error; copy the 16-byte new-name FCB
2343  9A10              ;              to the second FCB slot at +16 (CCP_FCB_SECOND) so F_RENAME_HND later sees old@+0/new@+16;
2344  9A10              ;              advance the command-line pointer over blanks and require an '=' ($3D) or '_' ($5F)
2345  9A10              ;              separator (else bad-command error); then parse the old name.
2346  9A10              ; [RE] REN built-in; F_RENAME_HND FCB carries old name at +0, new name at +16. [DOC CPMREF: CCP REN]
2347  9A10              ; ----------------------------------------------------------------------
2348  9A10              REN_CMD:
2349  9A10                      ; build the NEW filename into the CCP command FCB (CCP_FCB) from the command line
2350  9A10 CD 5E 96             CALL CCP_PARSE_FCB1
2351  9A13                      ; malformed new-name spec: echo bad command
2352  9A13 C2 09 96             JP NZ,CCP_ECHO_TOKEN
2353  9A16                      ; fetch the explicit drive prefix supplied with the new name
2354  9A16 3A F0 9B             LD A,(CCP_FCB_DRIVE_PREFIX)
2355  9A19                      ; save the new name's drive prefix for the later drive-match check
2356  9A19 F5                   PUSH AF
2357  9A1A CD 54 98             CALL RESOLVE_DRIVE_PREFIX
2358  9A1D                      ; BDOS F_SFIRST (fn 17): search the directory for the NEW name
2359  9A1D CD E9 94             CALL CCP_SEARCH_FIRST_SUBMIT
2360  9A20                      ; new name already exists: report FILE EXISTS
2361  9A20 C2 79 9A             JP NZ,REN_FILE_EXISTS
2362  9A23 21 CD 9B             LD HL,CCP_FCB
2363  9A26 11 DD 9B             LD DE,CCP_FCB_SECOND
2364  9A29                      ; count = 16: copy the new-name FCB into the second FCB slot at +16 (CCP_FCB_SECOND), the
2365  9A29                      ; rename source/target pair
2366  9A29 06 10                LD B,$10
2367  9A2B CD 42 98             CALL COPY_N_BYTES
2368  9A2E 2A 88 94             LD HL,(CCP_PARSEPTR)
2369  9A31 EB                   EX DE,HL
2370  9A32                      ; skip blanks to reach the '=' / '_' separator
2371  9A32 CD 4F 96             CALL CCP_SKIP_BLANKS
2372  9A35                      ; '=' separator between new and old names
2373  9A35 FE 3D                CP $3D
2374  9A37                      ; '=' seen: go parse the old name
2375  9A37 CA 3F 9A             JP Z,REN_PARSE_OLD
2376  9A3A                      ; '_' is also accepted as the new=old separator
2377  9A3A FE 5F                CP $5F
2378  9A3C                      ; no valid separator: bad-command error
2379  9A3C C2 73 9A             JP NZ,REN_ERROR
2380  9A3F              ; ----------------------------------------------------------------------
2381  9A3F              ; REN_PARSE_OLD -- Parse the old-name FCB after the '=' separator and validate the drive match.
2382  9A3F              ;   In: scan pointer is at the separator; the new-name drive prefix is on the stack (pushed by
2383  9A3F              ;       REN_CMD).
2384  9A3F              ;   Out: builds the old-name FCB and confirms both names target the same drive; on mismatch or parse
2385  9A3F              ;        error branches to the bad-command error.
2386  9A3F              ;   Clobbers: A, B, DE, HL, flags.
2387  9A3F              ;   Algorithm: advance past the separator and update the scan pointer (CCP_PARSEPTR); parse the
2388  9A3F              ;              old-name FCB; on parse error -> error tail. Recover the new name's drive prefix into
2389  9A3F              ;              B; read the old name's prefix (CCP_FCB_DRIVE_PREFIX); if it is 0 (no explicit drive)
2390  9A3F              ;              accept it; otherwise the two prefixes must be equal (store B into
2391  9A3F              ;              CCP_FCB_DRIVE_PREFIX and compare) else error.
2392  9A3F              ; [RE] REN old-name parse + same-drive enforcement. [DOC CPMREF: CCP REN]
2393  9A3F              ; ----------------------------------------------------------------------
2394  9A3F              REN_PARSE_OLD:
2395  9A3F EB                   EX DE,HL
2396  9A40                      ; step past the '=' / '_' separator
2397  9A40 23                   INC HL
2398  9A41 22 88 94             LD (CCP_PARSEPTR),HL
2399  9A44                      ; build the OLD filename FCB from the rest of the line
2400  9A44 CD 5E 96             CALL CCP_PARSE_FCB1
2401  9A47                      ; drives differ: reject as a bad command
2402  9A47                      ; malformed old-name spec: bad-command error
2403  9A47 C2 73 9A             JP NZ,REN_ERROR
2404  9A4A                      ; recover the new name's drive prefix saved by REN_CMD (into A, then B)
2405  9A4A F1                   POP AF
2406  9A4B 47                   LD B,A
2407  9A4C                      ; CCP_FCB_DRIVE_PREFIX = the old name's explicit drive prefix
2408  9A4C 21 F0 9B             LD HL,CCP_FCB_DRIVE_PREFIX
2409  9A4F 7E                   LD A,(HL)
2410  9A50 B7                   OR A
2411  9A51                      ; old name has no explicit drive: accept and proceed
2412  9A51 CA 59 9A             JP Z,REN_DO_RENAME
2413  9A54                      ; the two filenames must reference the same drive
2414  9A54 B8                   CP B
2415  9A55 70                   LD (HL),B
2416  9A56 C2 73 9A             JP NZ,REN_ERROR
2417  9A59              ; ----------------------------------------------------------------------
2418  9A59              ; REN_DO_RENAME -- Locate the old file and perform the directory rename.
2419  9A59              ;   In: the CCP command FCB holds old name at +0 (CCP_FCB) and new name at +16 (CCP_FCB_SECOND); HL
2420  9A59              ;       -> the drive-prefix cell CCP_FCB_DRIVE_PREFIX; B = the agreed drive prefix.
2421  9A59              ;   Out: searches for the old name; if not found branches to NO-FILE; otherwise renames it and
2422  9A59              ;        returns to the CCP exit.
2423  9A59              ;   Clobbers: A, B, DE, HL, flags.
2424  9A59              ;   Algorithm: store the agreed prefix B into CCP_FCB_DRIVE_PREFIX; zero the FCB drive byte (CCP_FCB
2425  9A59              ;              = default drive); search-first for the old name (F_SFIRST fn 17) -- if absent jump to
2426  9A59              ;              REN_OLD_NOT_FOUND; else call F_RENAME_HND (fn 23) on the old/new FCB pair and finish.
2427  9A59              ; [RE] REN rename step. [DOC CPMREF: CCP REN]
2428  9A59              ; ----------------------------------------------------------------------
2429  9A59              REN_DO_RENAME:
2430  9A59                      ; store the agreed drive prefix B into the drive-prefix cell CCP_FCB_DRIVE_PREFIX (HL still
2431  9A59                      ; points there)
2432  9A59 70                   LD (HL),B
2433  9A5A AF                   XOR A
2434  9A5B                      ; zero the FCB drive byte (0 = default drive) before the search
2435  9A5B 32 CD 9B             LD (CCP_FCB),A
2436  9A5E                      ; BDOS F_SFIRST (fn 17): search the directory for the OLD name
2437  9A5E CD E9 94             CALL CCP_SEARCH_FIRST_SUBMIT
2438  9A61                      ; old file not found: report NO FILE
2439  9A61 CA 6D 9A             JP Z,REN_OLD_NOT_FOUND
2440  9A64 11 CD 9B             LD DE,CCP_FCB
2441  9A67                      ; BDOS F_RENAME_HND (fn 23): rename old -> new using the paired FCB
2442  9A67 CD 0E 95             CALL BDOS_F_RENAME
2443  9A6A                      ; rename done: return to the CCP command-complete exit
2444  9A6A C3 86 9B             JP CCP_RETURN_OK
2445  9A6D              ; ----------------------------------------------------------------------
2446  9A6D              ; REN_OLD_NOT_FOUND -- REN error: the source file to rename does not exist.
2447  9A6D              ;   In: none.
2448  9A6D              ;   Out: prints "NO FILE" and returns to the CCP command-complete exit.
2449  9A6D              ;   Clobbers: A, BC, flags.
2450  9A6D              ;   Algorithm: call the "NO FILE" message printer (PRINT_NO_FILE), then jump to the command-complete
2451  9A6D              ;              exit.
2452  9A6D              ; [RE] REN missing-source error. [DOC CPMREF: CCP REN]
2453  9A6D              ; ----------------------------------------------------------------------
2454  9A6D              REN_OLD_NOT_FOUND:
2455  9A6D                      ; print the "NO FILE" message (rename source not found)
2456  9A6D CD EA 97             CALL PRINT_NO_FILE
2457  9A70                      ; return to the CCP command-complete exit
2458  9A70 C3 86 9B             JP CCP_RETURN_OK
2459  9A73              ; ----------------------------------------------------------------------
2460  9A73              ; REN_ERROR -- REN bad-command tail: restore the drive and echo the offending command.
2461  9A73              ;   In: none (entered on a missing/invalid separator, an old-name parse error, or a drive mismatch).
2462  9A73              ;   Out: restores the default drive and jumps to the bad-command echo path; does not return.
2463  9A73              ;   Clobbers: A, HL, flags.
2464  9A73              ;   Algorithm: call CCP_RESTORE_DEFAULT_DRIVE to restore the user's drive, then jump to
2465  9A73              ;              CCP_ECHO_TOKEN which re-emits the command word with a '?'.
2466  9A73              ; [RE] Shared REN syntax-error exit. [DOC CPMREF: CCP REN]
2467  9A73              ; ----------------------------------------------------------------------
2468  9A73              REN_ERROR:
2469  9A73                      ; restore the user's original/default drive selection
2470  9A73 CD 66 98             CALL CCP_RESTORE_DEFAULT_DRIVE
2471  9A76                      ; echo the malformed command token with a '?' and re-prompt
2472  9A76 C3 09 96             JP CCP_ECHO_TOKEN
2473  9A79              ; ----------------------------------------------------------------------
2474  9A79              ; REN_FILE_EXISTS -- REN error: the requested new name already exists on disk.
2475  9A79              ;   In: none.
2476  9A79              ;   Out: prints "FILE EXISTS" and returns to the CCP command-complete exit.
2477  9A79              ;   Clobbers: A, BC, flags.
2478  9A79              ;   Algorithm: load BC with the "FILE EXISTS" message address, print it (CR/LF + string via
2479  9A79              ;              CCP_CRLF_MSG), then jump to the command-complete exit.
2480  9A79              ; [RE] REN destination-collision error; new name found by the earlier F_SFIRST. [DOC CPMREF: CCP
2481  9A79              ; REN]
2482  9A79              ; ----------------------------------------------------------------------
2483  9A79              REN_FILE_EXISTS:
2484  9A79                      ; address of the "FILE EXISTS" message string
2485  9A79 01 82 9A             LD BC,CCP_MSG_FILE_EXISTS
2486  9A7C                      ; print CR/LF then the NUL-terminated message
2487  9A7C CD A7 94             CALL CCP_CRLF_MSG
2488  9A7F                      ; return to the CCP command-complete exit
2489  9A7F C3 86 9B             JP CCP_RETURN_OK
2490  9A82              ; ----------------------------------------------------------------------
2491  9A82              ; CCP_MSG_FILE_EXISTS -- ASCIIZ console message "FILE EXISTS".
2492  9A82              ;   In: -- (data, addressed by REN_FILE_EXISTS in BC as the error text)
2493  9A82              ;   Out: -- (zero-terminated string)
2494  9A82              ;   Clobbers: --
2495  9A82              ;   Algorithm: 11 bytes "FILE EXISTS" followed by a $00 terminator; loaded into BC
2496  9A82              ;     by REN_FILE_EXISTS and printed by CCP_CRLF_MSG when the REN built-in finds the new
2497  9A82              ;     name already on disk.
2498  9A82              ;   [RE] string literal observed in the CCP image (OBSERVED bytes).
2499  9A82              ; ----------------------------------------------------------------------
2500  9A82              CCP_MSG_FILE_EXISTS:
2501  9A82 46 49 4C 45          DEFB    "FILE EXISTS"            ; string
2501  9A86 20 45 58 49
2501  9A8A 53 54 53
2502  9A8D 00                   DEFB    $00                      ; terminator
2503  9A8E              ; ----------------------------------------------------------------------
2504  9A8E              ; CCP_CMD_USER -- built-in USER command: select the user-number area (0..15).
2505  9A8E              ;   In: command FCB at CCP_FCB; the numeric argument sits in the FCB name field.
2506  9A8E              ;   Out: BDOS user number set to the parsed value; joins CCP_RETURN_OK_NOCRLF.
2507  9A8E              ;   Clobbers: A, E, and the BDOS-call registers.
2508  9A8E              ;   Algorithm: dispatch table entry 5 (keyword "USER"). PARSE_FCB_DECIMAL parses a decimal
2509  9A8E              ;     number from the command FCB into A; if it is $10 (16) or more it is out of the
2510  9A8E              ;     0..15 user range, so abort to CCP_ECHO_TOKEN. Move the value to E, then call
2511  9A8E              ;     BDOS_USERNUM (BDOS function 32, Set/Get User Number, C=$20) to set the user area.
2512  9A8E              ;     The CP $20 test on the FCB name byte rejects a missing argument. Join the
2513  9A8E              ;     no-CR/LF return tail CCP_RETURN_OK_NOCRLF.
2514  9A8E              ;   [RE] standard CP/M 2.2 CCP USER built-in; identity from keyword table
2515  9A8E              ;     "DIR ERA TYPESAVEREN USER" index 5 -> dispatch entry CCP_CMD_USER.
2516  9A8E              ; ----------------------------------------------------------------------
2517  9A8E              CCP_CMD_USER:
2518  9A8E                      ; parse the decimal user number from the command FCB name field into A
2519  9A8E CD F8 97             CALL PARSE_FCB_DECIMAL
2520  9A91                      ; user numbers are 0..15; reject $10 (16) or more as out of range
2521  9A91 FE 10                CP $10
2522  9A93                      ; number too large: echo the bad token and abort
2523  9A93 D2 09 96             JP NC,CCP_ECHO_TOKEN
2524  9A96                      ; E = user number, the argument for the Set-User BDOS call
2525  9A96 5F                   LD E,A
2526  9A97                      ; fetch first byte of the FCB name field
2527  9A97 3A CE 9B             LD A,(CCP_FCB_NAME)
2528  9A9A                      ; a blank here means no argument was supplied, reject
2529  9A9A FE 20                CP $20
2530  9A9C                      ; no argument: abort to the bad-command echo
2531  9A9C CA 09 96             JP Z,CCP_ECHO_TOKEN
2532  9A9F                      ; BDOS function 32 (C=$20): set the user number to E
2533  9A9F CD 15 95             CALL BDOS_USERNUM
2534  9AA2                      ; join the return tail that does not emit a leading CR/LF
2535  9AA2 C3 89 9B             JP CCP_RETURN_OK_NOCRLF
2536  9AA5              ; ----------------------------------------------------------------------
2537  9AA5              ; CCP_DRIVE_SELECT -- handle a drive-prefixed command word: bare "d:" (change
2538  9AA5              ;   default drive) or "d:NAME" (drive-prefixed transient).
2539  9AA5              ;   In: command FCB; CCP_FCB_DRIVE_PREFIX (CCP_FCB_DRIVE_PREFIX) non-zero (a "d:" was typed).
2540  9AA5              ;   Out: if no command word followed the prefix, the default drive is changed and
2541  9AA5              ;     control joins CCP_RETURN_OK_NOCRLF; if a name followed, control falls to the
2542  9AA5              ;     transient loader CCP_CMD_TRANSIENT.
2543  9AA5              ;   Clobbers: A, and the BDOS-call registers.
2544  9AA5              ;   Algorithm: reached from CCP_PARSE_AND_DISPATCH when CCP_FCB_DRIVE_PREFIX != 0 (it is NOT in
2545  9AA5              ;     the keyword dispatch table). First CCP_CHECK_SERIAL verifies the CCP and BDOS serial
2546  9AA5              ;     numbers still match (integrity check). If the FCB name field is non-blank a
2547  9AA5              ;     command word follows the drive letter -> jump to CCP_CMD_TRANSIENT (transient load).
2548  9AA5              ;     Otherwise (bare "d:") if the drive-prefix flag is zero there is nothing to do
2549  9AA5              ;     (return OK); else DEC it to a 0-based drive number, store it as the current
2550  9AA5              ;     drive (CCP_CUR_DRIVE), write it to page zero (CCP_SET_DRIVE_ONLY) and issue BDOS
2551  9AA5              ;     Select-Disk (BDOS_DRV_SET), then return OK.
2552  9AA5              ;   [RE] CP/M 2.2 CCP default-drive change / drive-prefix entry. NOT the keyword
2553  9AA5              ;     USER built-in (that is CCP_CMD_USER); this is dispatch slot 6, reachable only
2554  9AA5              ;     via the drive-prefix branch.
2555  9AA5              ; ----------------------------------------------------------------------
2556  9AA5              CCP_DRIVE_SELECT:
2557  9AA5                      ; verify the CCP and BDOS serial numbers still match (integrity check)
2558  9AA5 CD F5 95             CALL CCP_CHECK_SERIAL
2559  9AA8                      ; first byte of the FCB name field
2560  9AA8 3A CE 9B             LD A,(CCP_FCB_NAME)
2561  9AAB                      ; blank name = bare "d:" with no command word after the drive letter
2562  9AAB FE 20                CP $20
2563  9AAD                      ; a name follows the drive prefix: treat as a transient program load
2564  9AAD C2 C4 9A             JP NZ,CCP_CMD_TRANSIENT
2565  9AB0                      ; load the explicit drive-prefix flag (0 = none, else drive#+1)
2566  9AB0 3A F0 9B             LD A,(CCP_FCB_DRIVE_PREFIX)
2567  9AB3                      ; was a drive actually supplied?
2568  9AB3 B7                   OR A
2569  9AB4                      ; no drive value: nothing to change, finish via the OK tail
2570  9AB4 CA 89 9B             JP Z,CCP_RETURN_OK_NOCRLF
2571  9AB7                      ; convert the 1-based prefix to a 0-based drive number
2572  9AB7 3D                   DEC A
2573  9AB8                      ; commit it as the CCP current default drive
2574  9AB8 32 EF 9B             LD (CCP_CUR_DRIVE),A
2575  9ABB                      ; write the current drive to page-zero default-drive byte $0004
2576  9ABB CD 29 95             CALL CCP_SET_DRIVE_ONLY
2577  9ABE                      ; issue BDOS Select-Disk (function 14) for the new drive
2578  9ABE CD BD 94             CALL BDOS_DRV_SET
2579  9AC1                      ; finish via the OK return tail (no leading CR/LF)
2580  9AC1 C3 89 9B             JP CCP_RETURN_OK_NOCRLF
2581  9AC4              ; ----------------------------------------------------------------------
2582  9AC4              ; CCP_CMD_TRANSIENT -- load and run a transient (.COM) program from disk.
2583  9AC4              ;   In: parsed command FCB (CCP_FCB) holding the command name; command tail.
2584  9AC4              ;   Out: on success transfers control to the loaded program at the TPA ($0100); on
2585  9AC4              ;     error joins CCP_BAD_LOAD / CCP_NO_FILE; never returns normally.
2586  9AC4              ;   Clobbers: all registers; rebuilds the TPA and page-zero command tail.
2587  9AC4              ;   Algorithm: verify the FCB extension is blank (no explicit type) -- if not, the
2588  9AC4              ;     command is rejected (CCP_ECHO_TOKEN). Select the command's drive prefix, force
2589  9AC4              ;     the extension to "COM" (CCP_COM_EXT), open the file; if not found jump to the
2590  9AC4              ;     no-file handler. Then loop reading $80-byte records sequentially into the TPA
2591  9AC4              ;     starting at $0100, advancing $80 bytes each record, until either the load
2592  9AC4              ;     address would reach the CCP base ($9400 = CCP_ENTRY, abort = BAD LOAD) or EOF.
2593  9AC4              ;     On clean EOF, build the page-zero command tail and JP $0100 (done in the
2594  9AC4              ;     routines that follow).
2595  9AC4              ;   [RE] CP/M 2.2 CCP transient program loader.
2596  9AC4              ; ----------------------------------------------------------------------
2597  9AC4              CCP_CMD_TRANSIENT:
2598  9AC4                      ; point at the FCB extension (type) field
2599  9AC4 11 D6 9B             LD DE,CCP_FCB_EXT
2600  9AC7                      ; fetch first byte of the file extension
2601  9AC7 1A                   LD A,(DE)
2602  9AC8                      ; extension must be blank: a typed extension is not a bare command
2603  9AC8 FE 20                CP $20
2604  9ACA                      ; explicit extension given: not a transient command, echo+abort
2605  9ACA C2 09 96             JP NZ,CCP_ECHO_TOKEN
2606  9ACD D5                   PUSH DE
2607  9ACE                      ; select the drive named by the command's drive prefix
2608  9ACE CD 54 98             CALL RESOLVE_DRIVE_PREFIX
2609  9AD1 D1                   POP DE
2610  9AD2                      ; source = the constant "COM" extension text
2611  9AD2 21 83 9B             LD HL,CCP_COM_EXT
2612  9AD5                      ; force the FCB type field to COM
2613  9AD5 CD 40 98             CALL COPY_3_BYTES
2614  9AD8                      ; open the .COM file via BDOS
2615  9AD8 CD D0 94             CALL CCP_OPEN_SUBMIT
2616  9ADB                      ; open failed (file not found): go to the no-file handler
2617  9ADB CA 6B 9B             JP Z,CCP_NO_FILE
2618  9ADE                      ; load address starts at the base of the TPA
2619  9ADE 21 00 01             LD HL,$0100
2620  9AE1              ; ----------------------------------------------------------------------
2621  9AE1              ; CCP_LOAD_LOOP -- read the .COM file record-by-record into the TPA.
2622  9AE1              ;   In: HL = next TPA load address; FCB already open at CCP_FCB.
2623  9AE1              ;   Out: loops until EOF (-> CCP_LOAD_DONE) or until the load pointer reaches the
2624  9AE1              ;     CCP base (-> CCP_BAD_LOAD).
2625  9AE1              ;   Clobbers: A, DE, HL.
2626  9AE1              ;   Algorithm: push the load address, set the BDOS DMA to it (BDOS_F_DMAOFF), do a
2627  9AE1              ;     sequential read (BDOS_F_READ) of one $80-byte record; on a non-zero (EOF/error)
2628  9AE1              ;     read result branch to CCP_LOAD_DONE. Otherwise advance HL by $80 and compare
2629  9AE1              ;     it against CCP_ENTRY ($9400 = CCP base) via a 16-bit subtract: if HL >= base the
2630  9AE1              ;     program is too big -> CCP_BAD_LOAD; else loop for the next record.
2631  9AE1              ;   [RE] transient-load inner loop.
2632  9AE1              ; ----------------------------------------------------------------------
2633  9AE1              CCP_LOAD_LOOP:
2634  9AE1                      ; save the current TPA load pointer across the read
2635  9AE1 E5                   PUSH HL
2636  9AE2 EB                   EX DE,HL
2637  9AE3                      ; set the BDOS DMA address (function 26) to the load pointer
2638  9AE3 CD D8 95             CALL BDOS_F_DMAOFF
2639  9AE6                      ; DE = the open command FCB
2640  9AE6 11 CD 9B             LD DE,CCP_FCB
2641  9AE9                      ; BDOS sequential read (function 20) of one 128-byte record
2642  9AE9 CD F9 94             CALL BDOS_F_READ
2643  9AEC                      ; non-zero = EOF or read error: finish the load
2644  9AEC C2 01 9B             JP NZ,CCP_LOAD_DONE
2645  9AEF E1                   POP HL
2646  9AF0                      ; record size = 128 bytes
2647  9AF0 11 80 00             LD DE,$0080
2648  9AF3                      ; advance the load pointer to the next record slot
2649  9AF3 19                   ADD HL,DE
2650  9AF4                      ; compare against the CCP base -- the ceiling the program must not reach
2651  9AF4 11 00 94             LD DE,CCP_ENTRY
2652  9AF7 7D                   LD A,L
2653  9AF8 93                   SUB E
2654  9AF9 7C                   LD A,H
2655  9AFA 9A                   SBC A,D
2656  9AFB                      ; load reached the CCP: program too large -> BAD LOAD
2657  9AFB D2 71 9B             JP NC,CCP_BAD_LOAD
2658  9AFE C3 E1 9A             JP CCP_LOAD_LOOP
2659  9B01              ; ----------------------------------------------------------------------
2660  9B01              ; CCP_LOAD_DONE -- finish a transient load and launch the program.
2661  9B01              ;   In: the BDOS read returned non-zero (A); stacked TPA load pointer on entry.
2662  9B01              ;   Out: if the read result was true EOF (A becomes 0 after DEC) builds page zero
2663  9B01              ;     and proceeds to the launch; otherwise -> CCP_BAD_LOAD.
2664  9B01              ;   Clobbers: all registers.
2665  9B01              ;   Algorithm: pop the saved load pointer; DEC A -- a sequential-read return of 1
2666  9B01              ;     means clean EOF (now 0); anything else is an error (-> CCP_BAD_LOAD). Reselect
2667  9B01              ;     the command's drive (CCP_RESTORE_DEFAULT_DRIVE), rebuild the command FCB (CCP_PARSE_FCB1),
2668  9B01              ;     then build a second FCB from the command tail at offset $10 into CCP_FCB
2669  9B01              ;     (CCP_BUILD_FCB with A=$10) so the program gets two default FCBs. Zero the FCB CR
2670  9B01              ;     field, copy a $21-byte FCB image down to TFCB ($005C), then fall through to the
2671  9B01              ;     tail-copy routines that build the command tail at TBUFF and launch.
2672  9B01              ;   [RE] transient launch / page-zero setup, standard CP/M 2.2 CCP.
2673  9B01              ; ----------------------------------------------------------------------
2674  9B01              CCP_LOAD_DONE:
2675  9B01                      ; discard the saved load pointer
2676  9B01 E1                   POP HL
2677  9B02                      ; sequential-read return 1 = clean EOF -> 0; any other value is a load error
2678  9B02 3D                   DEC A
2679  9B03                      ; non-EOF read result: report BAD LOAD
2680  9B03 C2 71 9B             JP NZ,CCP_BAD_LOAD
2681  9B06                      ; reselect the drive named by the command prefix
2682  9B06 CD 66 98             CALL CCP_RESTORE_DEFAULT_DRIVE
2683  9B09 CD 5E 96             CALL CCP_PARSE_FCB1
2684  9B0C                      ; point at the drive-prefix flag (saved across the FCB rebuild)
2685  9B0C 21 F0 9B             LD HL,CCP_FCB_DRIVE_PREFIX
2686  9B0F E5                   PUSH HL
2687  9B10 7E                   LD A,(HL)
2688  9B11                      ; seed the command FCB drive byte before the second-FCB parse
2689  9B11 32 CD 9B             LD (CCP_FCB),A
2690  9B14                      ; offset $10 = build the second filename into FCB+16
2691  9B14 3E 10                LD A,$10
2692  9B16                      ; parse a second command-tail filename into the alternate FCB
2693  9B16 CD 60 96             CALL CCP_BUILD_FCB
2694  9B19 E1                   POP HL
2695  9B1A 7E                   LD A,(HL)
2696  9B1B                      ; store the second-FCB drive prefix byte
2697  9B1B 32 DD 9B             LD (CCP_FCB_SECOND),A
2698  9B1E                      ; zero the FCB current-record field before launch
2699  9B1E AF                   XOR A
2700  9B1F                      ; clear the command FCB CR byte
2701  9B1F 32 ED 9B             LD (CCP_FCB_CR),A
2702  9B22                      ; destination = the default FCB at page zero TFCB ($005C)
2703  9B22 11 5C 00             LD DE,$005C
2704  9B25                      ; source = the CCP-built command FCB
2705  9B25 21 CD 9B             LD HL,CCP_FCB
2706  9B28                      ; copy $21 (33) bytes = one full FCB image
2707  9B28 06 21                LD B,$21
2708  9B2A                      ; copy the FCB image down to TFCB
2709  9B2A CD 42 98             CALL COPY_N_BYTES
2710  9B2D                      ; source for the tail = the CCP command-line buffer
2711  9B2D 21 08 94             LD HL,CCP_CMDTEXT
2712  9B30              ; ----------------------------------------------------------------------
2713  9B30              ; CCP_TAIL_SKIP_NAME -- scan past the program name to the start of the tail.
2714  9B30              ;   In: HL = pointer into the CCP command-line buffer (CCP_CMDTEXT).
2715  9B30              ;   Out: HL points at the first blank or the NUL terminator following the command
2716  9B30              ;     word; falls through to CCP_TAIL_COPY.
2717  9B30              ;   Clobbers: A, HL.
2718  9B30              ;   Algorithm: walk forward over name characters until a $00 (end of line) or a $20
2719  9B30              ;     (blank, start of the argument tail) is found.
2720  9B30              ;   [RE] command-tail scanner.
2721  9B30              ; ----------------------------------------------------------------------
2722  9B30              CCP_TAIL_SKIP_NAME:
2723  9B30                      ; fetch the next command-line character
2724  9B30 7E                   LD A,(HL)
2725  9B31                      ; end of line?
2726  9B31 B7                   OR A
2727  9B32                      ; no tail: jump to copy an empty tail
2728  9B32 CA 3E 9B             JP Z,CCP_TAIL_COPY
2729  9B35                      ; blank separates the command word from its tail
2730  9B35 FE 20                CP $20
2731  9B37                      ; found the blank: HL now at the tail, go copy it
2732  9B37 CA 3E 9B             JP Z,CCP_TAIL_COPY
2733  9B3A                      ; advance past this name character
2734  9B3A 23                   INC HL
2735  9B3B C3 30 9B             JP CCP_TAIL_SKIP_NAME
2736  9B3E              ; ----------------------------------------------------------------------
2737  9B3E              ; CCP_TAIL_COPY -- begin copying the command tail to TBUFF and counting its length.
2738  9B3E              ;   In: HL = first character of the command tail (blank or NUL).
2739  9B3E              ;   Out: sets DE = $0081 (TBUFF+1) and B = 0 (length), then falls into the copy
2740  9B3E              ;     loop CCP_TAIL_COPY_LOOP.
2741  9B3E              ;   Clobbers: B, DE.
2742  9B3E              ;   Algorithm: initialize the length accumulator B to 0 and the destination pointer
2743  9B3E              ;     DE to TBUFF+1 ($0081); $0080 (TBUFF) will hold the final length byte.
2744  9B3E              ;   [RE] page-zero command-tail builder setup, standard CP/M 2.2 CCP.
2745  9B3E              ; ----------------------------------------------------------------------
2746  9B3E              CCP_TAIL_COPY:
2747  9B3E                      ; tail length accumulator starts at 0
2748  9B3E 06 00                LD B,$00
2749  9B40                      ; destination = TBUFF+1 ($0080 holds the length byte)
2750  9B40 11 81 00             LD DE,$0081
2751  9B43              ; ----------------------------------------------------------------------
2752  9B43              ; CCP_TAIL_COPY_LOOP -- per-character copy loop of the command tail.
2753  9B43              ;   In: HL = source char, DE = TBUFF dest, B = running length.
2754  9B43              ;   Out: on the NUL terminator branches to CCP_TAIL_SETLEN with B = length.
2755  9B43              ;   Clobbers: A, B, DE, HL.
2756  9B43              ;   Algorithm: load (HL), store to (DE); if it was $00 the tail is done; else bump
2757  9B43              ;     the length B and advance both pointers and loop.
2758  9B43              ;   [RE] inner copy loop of CCP_TAIL_COPY.
2759  9B43              ; ----------------------------------------------------------------------
2760  9B43              CCP_TAIL_COPY_LOOP:
2761  9B43                      ; next tail character
2762  9B43 7E                   LD A,(HL)
2763  9B44                      ; store into the TBUFF command-tail buffer
2764  9B44 12                   LD (DE),A
2765  9B45                      ; NUL terminator ends the tail
2766  9B45 B7                   OR A
2767  9B46                      ; tail done: go store the final length
2768  9B46 CA 4F 9B             JP Z,CCP_TAIL_SETLEN
2769  9B49                      ; count this character
2770  9B49 04                   INC B
2771  9B4A 23                   INC HL
2772  9B4B 13                   INC DE
2773  9B4C C3 43 9B             JP CCP_TAIL_COPY_LOOP
2774  9B4F              ; ----------------------------------------------------------------------
2775  9B4F              ; CCP_TAIL_SETLEN -- finalize page zero and launch the transient at $0100.
2776  9B4F              ;   In: B = command-tail length; FCBs and TBUFF text already built.
2777  9B4F              ;   Out: stores the tail length at TBUFF ($0080), sets the default DMA, and CALLs
2778  9B4F              ;     the program at $0100; on its return rejoins the CCP loop.
2779  9B4F              ;   Clobbers: all registers.
2780  9B4F              ;   Algorithm: store B at $0080 (TBUFF length byte); emit the pending CR/LF
2781  9B4F              ;     (CCP_CRLF); reset the default DMA to $0080 (CCP_SET_DMA_TBUFF); rebuild the page-zero
2782  9B4F              ;     default drive/user byte at $0004 (CCP_SET_USERDRIVE); CALL $0100 to run the program.
2783  9B4F              ;     After it returns, restore the CCP private stack (SP = CCP_SUBMIT_FLAG), restore the
2784  9B4F              ;     current drive (CCP_SET_DRIVE_ONLY) and reselect it (BDOS_DRV_SET), then JP to the CCP
2785  9B4F              ;     warm-restart point CCP_PROMPT_AND_READ.
2786  9B4F              ;   [RE] transient launch finalizer, standard CP/M 2.2 CCP.
2787  9B4F              ; ----------------------------------------------------------------------
2788  9B4F              CCP_TAIL_SETLEN:
2789  9B4F                      ; tail character count
2790  9B4F 78                   LD A,B
2791  9B50                      ; store as the TBUFF length byte ($0080 = TBUFF)
2792  9B50 32 80 00             LD ($0080),A
2793  9B53                      ; emit the pending CR/LF before running the program
2794  9B53 CD 98 94             CALL CCP_CRLF
2795  9B56                      ; reset the BDOS DMA address to the default ($0080)
2796  9B56 CD D5 95             CALL CCP_SET_DMA_TBUFF
2797  9B59                      ; rebuild the page-zero default drive/user byte at $0004
2798  9B59 CD 1A 95             CALL CCP_SET_USERDRIVE
2799  9B5C                      ; run the loaded transient program in the TPA
2800  9B5C CD 00 01             CALL $0100
2801  9B5F                      ; restore the CCP private stack after the program returns
2802  9B5F 31 AB 9B             LD SP,CCP_SUBMIT_FLAG
2803  9B62                      ; restore the current drive in page zero
2804  9B62 CD 29 95             CALL CCP_SET_DRIVE_ONLY
2805  9B65                      ; reselect the current drive via BDOS
2806  9B65 CD BD 94             CALL BDOS_DRV_SET
2807  9B68                      ; rejoin the CCP command loop (warm restart)
2808  9B68 C3 82 97             JP CCP_PROMPT_AND_READ
2809  9B6B              ; ----------------------------------------------------------------------
2810  9B6B              ; CCP_NO_FILE -- handle a transient whose .COM file was not found.
2811  9B6B              ;   In: -- (entered when BDOS open returned not-found in CCP_CMD_TRANSIENT).
2812  9B6B              ;   Out: reselects the drive then echoes the offending token and aborts; does not
2813  9B6B              ;     return.
2814  9B6B              ;   Clobbers: A, and the echo/BDOS registers.
2815  9B6B              ;   Algorithm: reselect the command's drive prefix (CCP_RESTORE_DEFAULT_DRIVE), then jump
2816  9B6B              ;     to CCP_ECHO_TOKEN which prints the command word with a trailing '?' and warm-
2817  9B6B              ;     restarts the CCP.
2818  9B6B              ;   [RE] file-not-found path of the transient loader.
2819  9B6B              ; ----------------------------------------------------------------------
2820  9B6B              CCP_NO_FILE:
2821  9B6B                      ; reselect the drive the command named
2822  9B6B CD 66 98             CALL CCP_RESTORE_DEFAULT_DRIVE
2823  9B6E                      ; echo the bad command name with '?' and restart
2824  9B6E C3 09 96             JP CCP_ECHO_TOKEN
2825  9B71              ; ----------------------------------------------------------------------
2826  9B71              ; CCP_BAD_LOAD -- report a transient that would not fit / had a read error.
2827  9B71              ;   In: -- (entered on TPA overflow or a non-EOF read error).
2828  9B71              ;   Out: prints "BAD LOAD" then joins the return tail CCP_RETURN_OK; does not return.
2829  9B71              ;   Clobbers: BC and the print/BDOS registers.
2830  9B71              ;   Algorithm: load BC with the CCP_MSG_BAD_LOAD ("BAD LOAD") text and call CCP_CRLF_MSG (CR/LF +
2831  9B71              ;     message printer), then JP to the drive-restore return tail CCP_RETURN_OK.
2832  9B71              ;   [RE] over-size / read-error path of the transient loader.
2833  9B71              ; ----------------------------------------------------------------------
2834  9B71              CCP_BAD_LOAD:
2835  9B71                      ; point at the "BAD LOAD" message text
2836  9B71 01 7A 9B             LD BC,CCP_MSG_BAD_LOAD
2837  9B74                      ; print CR/LF + the message
2838  9B74 CD A7 94             CALL CCP_CRLF_MSG
2839  9B77                      ; join the drive-restore return tail
2840  9B77 C3 86 9B             JP CCP_RETURN_OK
2841  9B7A              ; ----------------------------------------------------------------------
2842  9B7A              ; CCP_MSG_BAD_LOAD -- ASCIIZ console message "BAD LOAD".
2843  9B7A              ;   In: -- (data, addressed by CCP_BAD_LOAD as the message in BC)
2844  9B7A              ;   Out: -- (zero-terminated string)
2845  9B7A              ;   Clobbers: --
2846  9B7A              ;   Algorithm: 8 bytes "BAD LOAD" followed by a $00 terminator.
2847  9B7A              ;   [RE] string literal observed in the CCP image (OBSERVED bytes).
2848  9B7A              ; ----------------------------------------------------------------------
2849  9B7A              CCP_MSG_BAD_LOAD:
2850  9B7A 42 41 44 20          DEFB    "BAD LOAD"               ; string
2850  9B7E 4C 4F 41 44
2851  9B82 00                   DEFB    $00                      ; terminator
2852  9B83              ; ----------------------------------------------------------------------
2853  9B83              ; CCP_COM_EXT -- the constant file-extension text "COM" for transient loads.
2854  9B83              ;   In: -- (data, source for COPY_3_BYTES in CCP_CMD_TRANSIENT)
2855  9B83              ;   Out: -- (3 bytes, no terminator)
2856  9B83              ;   Clobbers: --
2857  9B83              ;   Algorithm: the three ASCII bytes "COM" copied into the FCB type field so the
2858  9B83              ;     CCP opens the command word as NAME.COM.
2859  9B83              ;   [RE] CP/M 2.2 CCP default transient extension.
2860  9B83              ; ----------------------------------------------------------------------
2861  9B83              CCP_COM_EXT:
2862  9B83 43 4F 4D             DEFB    "COM"
2863  9B86              ; ----------------------------------------------------------------------
2864  9B86              ; CCP_RETURN_OK -- normal CCP return tail: restore the drive then check for leftover.
2865  9B86              ;   In: -- (joined after a built-in or error completes).
2866  9B86              ;   Out: reselects the command's drive prefix, then falls into CCP_RETURN_OK_NOCRLF.
2867  9B86              ;   Clobbers: A, HL, and BDOS registers.
2868  9B86              ;   Algorithm: call CCP_RESTORE_DEFAULT_DRIVE to reselect the drive named by the
2869  9B86              ;     command, then fall through to CCP_RETURN_OK_NOCRLF (CCP_RETURN_OK_NOCRLF).
2870  9B86              ;   [RE] CCP command epilogue.
2871  9B86              ; ----------------------------------------------------------------------
2872  9B86              CCP_RETURN_OK:
2873  9B86                      ; reselect the drive named in the command prefix
2874  9B86 CD 66 98             CALL CCP_RESTORE_DEFAULT_DRIVE
2875  9B89              ; ----------------------------------------------------------------------
2876  9B89              ; CCP_RETURN_OK_NOCRLF -- verify the whole command was consumed, then restart CCP.
2877  9B89              ;   In: command FCB name first byte (CCP_FCB_NAME); drive-prefix flag (CCP_FCB_DRIVE_PREFIX).
2878  9B89              ;   Out: if there is unparsed trailing text it is echoed as a bad command; otherwise
2879  9B89              ;     the CCP warm-restarts. Does not return to the caller.
2880  9B89              ;   Clobbers: A, HL, and the print/BDOS registers.
2881  9B89              ;   Algorithm: rebuild the command FCB once more (CCP_PARSE_FCB1), then test whether the
2882  9B89              ;     FCB name field was blank ($20) AND no drive prefix remained: SUB the blank from
2883  9B89              ;     the name byte, OR with the drive-prefix flag -- if the result is non-zero there
2884  9B89              ;     is leftover input, so echo the bad token (CCP_ECHO_TOKEN); else JP to the CCP
2885  9B89              ;     warm restart (CCP_PROMPT_AND_READ).
2886  9B89              ;   [RE] CCP command epilogue (no leading CR/LF).
2887  9B89              ; ----------------------------------------------------------------------
2888  9B89              CCP_RETURN_OK_NOCRLF:
2889  9B89                      ; re-parse the command FCB to test for leftover text
2890  9B89 CD 5E 96             CALL CCP_PARSE_FCB1
2891  9B8C                      ; first FCB name byte
2892  9B8C 3A CE 9B             LD A,(CCP_FCB_NAME)
2893  9B8F                      ; subtract a blank: zero means the name field was empty
2894  9B8F D6 20                SUB $20
2895  9B91                      ; point at the drive-prefix flag
2896  9B91 21 F0 9B             LD HL,CCP_FCB_DRIVE_PREFIX
2897  9B94                      ; combine: nonzero if either a name or a drive prefix is left over
2898  9B94 B6                   OR (HL)
2899  9B95                      ; leftover token: echo it as a bad command
2900  9B95 C2 09 96             JP NZ,CCP_ECHO_TOKEN
2901  9B98                      ; command fully consumed: warm-restart the CCP
2902  9B98 C3 82 97             JP CCP_PROMPT_AND_READ
2903  9B9B 00 00 00...          DEFS    16, $00                  ; fill
2904  9BAB              ; ----------------------------------------------------------------------
2905  9BAB              ; CCP_SUBMIT_FLAG -- SUBMIT/batch-active flag; also the base of the CCP stack.
2906  9BAB              ;   In/Out: a single byte. Non-zero while the CCP is feeding commands from a
2907  9BAB              ;     $$$.SUB batch file; the CCP private stack is loaded with SP = this address
2908  9BAB              ;     (LD SP,CCP_SUBMIT_FLAG) at every warm start and after a transient returns.
2909  9BAB              ;   Clobbers: --
2910  9BAB              ;   Algorithm: set non-zero when a $$$.SUB batch line is delivered (CCP_GETCMD
2911  9BAB              ;     region), cleared by CCP_DISCARD_SUBMIT when batch input ends; doubles as the CCP stack
2912  9BAB              ;     top.
2913  9BAB              ;   [RE] CP/M 2.2 CCP batch flag / stack base.
2914  9BAB              ; ----------------------------------------------------------------------
2915  9BAB              CCP_SUBMIT_FLAG:
2916  9BAB 00                   DEFB    "\0"
2917  9BAC              ; ----------------------------------------------------------------------
2918  9BAC              ; CCP_SUB_FCB -- the FCB for the $$$.SUB batch (SUBMIT) file.
2919  9BAC              ;   In/Out: 33-byte FCB; drive byte at this address, name/ext set to "$$$    SUB".
2920  9BAC              ;   Clobbers: --
2921  9BAC              ;   Algorithm: opened/read/deleted by the CCP batch logic (CCP_GETCMD / CCP_DISCARD_SUBMIT) to
2922  9BAC              ;     source successive command lines from the $$$.SUB file; its name/extension
2923  9BAC              ;     constant follows here.
2924  9BAC              ;   [RE] CP/M 2.2 CCP SUBMIT FCB.
2925  9BAC              ; ----------------------------------------------------------------------
2926  9BAC              CCP_SUB_FCB:
2927  9BAC 00                   DEFB    "\0"
2928  9BAD 24 24 24 20          DEFB    "$$$     SUB"            ; string
2928  9BB1 20 20 20 20
2928  9BB5 53 55 42
2929  9BB8 00                   DEFB    $00                      ; terminator
2930  9BB9 00                   DEFB    "\0"
2931  9BBA              ; ----------------------------------------------------------------------
2932  9BBA              ; CCP_SUB_FCB_S2 -- the S2 (extent-high) field of the $$$.SUB FCB.
2933  9BBA              ;   In/Out: 1 byte at CCP_SUB_FCB+$0E; cleared to 0 before reading the next batch
2934  9BBA              ;     record (CCP_GETCMD writes CCP_SUB_FCB_S2 = 0 then DECs the CR field below it).
2935  9BBA              ;   Clobbers: --
2936  9BBA              ;   Algorithm: part of CCP_SUB_FCB; written 0 so the extent is reset before the
2937  9BBA              ;     reverse read positions the CR field.
2938  9BBA              ;   [RE] FCB S2 byte of the SUBMIT FCB.
2939  9BBA              ; ----------------------------------------------------------------------
2940  9BBA              CCP_SUB_FCB_S2:
2941  9BBA 00                   DEFB    "\0"
2942  9BBB              ; ----------------------------------------------------------------------
2943  9BBB              ; CCP_SUB_FCB_CR -- the current-record (CR) field of the $$$.SUB FCB.
2944  9BBB              ;   In/Out: 1 byte at CCP_SUB_FCB+$0F; holds the next batch record to read.
2945  9BBB              ;   Clobbers: --
2946  9BBB              ;   Algorithm: read by CCP_GETCMD, decremented, and stored as the new record index in
2947  9BBB              ;     CCP_SUB_PREV_REC (the SUBMIT file is consumed in reverse).
2948  9BBB              ;   [RE] FCB CR byte of the SUBMIT FCB.
2949  9BBB              ; ----------------------------------------------------------------------
2950  9BBB              CCP_SUB_FCB_CR:
2951  9BBB 00 00 00...          DEFS    17, $00                  ; fill
2952  9BCC              ; ----------------------------------------------------------------------
2953  9BCC              ; CCP_SUB_PREV_REC -- previous batch record index (cell just below the command FCB).
2954  9BCC              ;   In/Out: 1 byte immediately below CCP_FCB; receives CCP_SUB_FCB_CR-1, the record
2955  9BCC              ;     to read next from the $$$.SUB file (CCP_GETCMD: DEC A / LD (CCP_SUB_PREV_REC),A).
2956  9BCC              ;   Clobbers: --
2957  9BCC              ;   Algorithm: SUBMIT reads records back-to-front; this cell carries the decremented
2958  9BCC              ;     record number used to position the next read.
2959  9BCC              ;   [RE] SUBMIT reverse-read record holder.
2960  9BCC              ; ----------------------------------------------------------------------
2961  9BCC              CCP_SUB_PREV_REC:
2962  9BCC 00                   DEFB    "\0"
2963  9BCD              ; ----------------------------------------------------------------------
2964  9BCD              ; CCP_FCB -- the command-line FCB the CCP builds from the typed command.
2965  9BCD              ;   In/Out: 33-byte FCB; this byte is the drive field, the 8-char name follows at
2966  9BCD              ;     CCP_FCB_NAME, the 3-char type at CCP_FCB_EXT. Copied to TFCB ($005C) before a
2967  9BCD              ;     transient runs.
2968  9BCD              ;   Clobbers: --
2969  9BCD              ;   Algorithm: filled by CCP_BUILD_FCB from the command tail; the built-in search
2970  9BCD              ;     (SEARCH_BUILTIN) compares its name field against the keyword table and the transient
2971  9BCD              ;     loader opens it as NAME.COM.
2972  9BCD              ;   [RE] CP/M 2.2 CCP command FCB.
2973  9BCD              ; ----------------------------------------------------------------------
2974  9BCD              CCP_FCB:
2975  9BCD 00                   DEFB    "\0"
2976  9BCE              ; ----------------------------------------------------------------------
2977  9BCE              ; CCP_FCB_NAME -- the 8-character filename field of the command FCB.
2978  9BCE              ;   In/Out: 8 bytes at CCP_FCB+1; the parsed command word (blank-padded).
2979  9BCE              ;   Clobbers: --
2980  9BCE              ;   Algorithm: matched 4 chars at a time against the keyword table
2981  9BCE              ;     "DIR ERA TYPESAVEREN USER" (SEARCH_BUILTIN) and used as the .COM filename for
2982  9BCE              ;     transient loads; a leading blank means no command word was given.
2983  9BCE              ;   [RE] FCB name field.
2984  9BCE              ; ----------------------------------------------------------------------
2985  9BCE              CCP_FCB_NAME:
2986  9BCE 00 00 00...          DEFS    8, $00                   ; fill
2987  9BD6              ; ----------------------------------------------------------------------
2988  9BD6              ; CCP_FCB_EXT -- the 3-character extension (type) field of the command FCB.
2989  9BD6              ;   In/Out: 3 bytes at CCP_FCB+9.
2990  9BD6              ;   Clobbers: --
2991  9BD6              ;   Algorithm: must be blank for a bare command word; the transient loader overwrites
2992  9BD6              ;     it with "COM" before opening the file.
2993  9BD6              ;   [RE] FCB type field.
2994  9BD6              ; ----------------------------------------------------------------------
2995  9BD6              CCP_FCB_EXT:
2996  9BD6 00 00 00 00          DEFB    "\0\0\0\0\0\0\0"
2996  9BDA 00 00 00
2997  9BDD              ; ----------------------------------------------------------------------
2998  9BDD              ; CCP_FCB_SECOND -- the second filename built into the command FCB at offset $10.
2999  9BDD              ;   In/Out: starts at CCP_FCB+$10; a second command-tail filename is parsed here so
3000  9BDD              ;     the transient receives two default FCBs (at $005C and $006C after the copy).
3001  9BDD              ;   Clobbers: --
3002  9BDD              ;   Algorithm: CCP_BUILD_FCB called with A=$10 fills this; its drive prefix byte is
3003  9BDD              ;     stored here, and the $21-byte copy to TFCB carries both FCB images to page zero.
3004  9BDD              ;   [RE] CP/M 2.2 CCP second default FCB.
3005  9BDD              ; ----------------------------------------------------------------------
3006  9BDD              CCP_FCB_SECOND:
3007  9BDD 00 00 00...          DEFS    16, $00                  ; fill
3008  9BED              ; ----------------------------------------------------------------------
3009  9BED              ; CCP_FCB_CR -- the current-record (CR) field of the command FCB.
3010  9BED              ;   In/Out: 1 byte at CCP_FCB+$20; zeroed before each open/read so loads start at
3011  9BED              ;     record 0.
3012  9BED              ;   Clobbers: --
3013  9BED              ;   Algorithm: cleared by the open helper (CCP_OPEN_SUBMIT) and before launching a transient.
3014  9BED              ;   [RE] FCB CR byte of the command FCB.
3015  9BED              ; ----------------------------------------------------------------------
3016  9BED              CCP_FCB_CR:
3017  9BED 00                   DEFB    "\0"
3018  9BEE              ; ----------------------------------------------------------------------
3019  9BEE              ; CCP_BDOS_RESULT -- saved A return code from the most recent BDOS file call.
3020  9BEE              ;   In/Out: 1 byte; written with the BDOS return value by the file-call wrapper
3021  9BEE              ;     BDOS_FCB_OP (open/close/search/delete) right after CALL $0005.
3022  9BEE              ;   Clobbers: --
3023  9BEE              ;   Algorithm: the wrapper saves A here, then INC A so the caller can test for the
3024  9BEE              ;     $FF (not-found) directory code as zero.
3025  9BEE              ;   [RE] CCP scratch for the last BDOS directory-code.
3026  9BEE              ; ----------------------------------------------------------------------
3027  9BEE              CCP_BDOS_RESULT:
3028  9BEE 00                   DEFB    "\0"
3029  9BEF              ; ----------------------------------------------------------------------
3030  9BEF              ; CCP_CUR_DRIVE -- the CCP's current default drive number (0=A, 1=B, ...).
3031  9BEF              ;   In/Out: 1 byte; the active drive the CCP selects and writes to the low nibble of
3032  9BEF              ;     page-zero $0004.
3033  9BEF              ;   Clobbers: --
3034  9BEF              ;   Algorithm: set from the BDOS current-disk value at warm start (low nibble of the
3035  9BEF              ;     boot C register) and updated by the drive-select path (CCP_DRIVE_SELECT). CCP_SET_DRIVE_ONLY
3036  9BEF              ;     writes it straight to $0004; CCP_SET_USERDRIVE merges it with the user number (in the
3037  9BEF              ;     high nibble) and stores the combined byte at $0004. Reselected after every
3038  9BEF              ;     transient runs. NOTE: this is the DRIVE, not the user number (the user number
3039  9BEF              ;     lives in the BDOS, set via function 32).
3040  9BEF              ;   [RE] CP/M 2.2 CCP current default-drive byte.
3041  9BEF              ; ----------------------------------------------------------------------
3042  9BEF              CCP_CUR_DRIVE:
3043  9BEF 00                   DEFB    "\0"
3044  9BF0              ; ----------------------------------------------------------------------
3045  9BF0              ; CCP_FCB_DRIVE_PREFIX -- explicit drive-prefix flag for the parsed command.
3046  9BF0              ;   In/Out: 1 byte; 0 means no "d:" prefix was typed, otherwise drive#+1 (A=1,B=2,..).
3047  9BF0              ;   Clobbers: --
3048  9BF0              ;   Algorithm: set by CCP_BUILD_FCB when it sees a "d:" before the name; used to select
3049  9BF0              ;     the right drive for the command and to decide leftover-token handling. A
3050  9BF0              ;     non-zero value also routes the dispatcher to CCP_DRIVE_SELECT (drive-select path).
3051  9BF0              ;   [RE] CP/M 2.2 CCP command drive-prefix flag.
3052  9BF0              ; ----------------------------------------------------------------------
3053  9BF0              CCP_FCB_DRIVE_PREFIX:
3054  9BF0 00                   DEFB    "\0"
3055  9BF1              ; ----------------------------------------------------------------------
3056  9BF1              ; CCP_FCB_TAIL -- trailing bytes of the command FCB record / data page.
3057  9BF1              ;   In/Out: 15 bytes following the drive-prefix flag, completing the FCB-sized
3058  9BF1              ;     record region the CCP keeps in its data page.
3059  9BF1              ;   Clobbers: --
3060  9BF1              ;   Algorithm: reserved scratch / FCB-tail bytes; no code in this cluster reads them
3061  9BF1              ;     meaningfully. Exact use beyond padding the FCB record is UNKNOWN.
3062  9BF1              ;   [?] purpose beyond reserved FCB-tail padding is UNKNOWN.
3063  9BF1              ; ----------------------------------------------------------------------
3064  9BF1              CCP_FCB_TAIL:
3065  9BF1 00 00 00...          DEFS    15, $00                  ; fill
3066  9C00              ; ----------------------------------------------------------------------
3067  9C00              ; BDOS_FBASE -- BDOS image header at FBASE ($9C00): 6 serial/header bytes, then the FDOS
3068  9C00              ; entry jump.
3069  9C00              ;   In: none (static image bytes at the BDOS run base).
3070  9C00              ;   Out: bytes +0..+5 are the per-copy serial/header cells (not code); the JP at +6 (BDOS_ENTRY) is
3071  9C00              ;        the actual entry.
3072  9C00              ;   Clobbers: n/a (data + one jump).
3073  9C00              ;   Algorithm: OBSERVED -- the six bytes here are DEFB $BD,$16,$00,$00,$16,$DF, the standard CP/M
3074  9C00              ;              FBASE serial-number / header cells. The disassembler renders them as spurious
3075  9C00              ;              SBC/AND/XOR/OR instructions further on, but these +0..+5 bytes are DATA. The byte at
3076  9C00              ;              +6 is the JP BDOS_ENTRY/dispatcher that the page-zero BDOS=$0005 jump-vector lands
3077  9C00              ;              on. [RE] standard CP/M 2.2 FBASE header layout.
3078  9C00              ; ----------------------------------------------------------------------
3079  9C00                  IFNDEF CPM_LINK
3080  9C00                  SAVEBIN "{out_bin}", $9400, $0800
3081  9C00                  ENDIF
3082  9C00
# file closed: CPM_CCP.asm

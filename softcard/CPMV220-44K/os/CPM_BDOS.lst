# file opened: CPM_BDOS.asm
   1  0000              ; ============================================================================
   2  0000              ; Microsoft SoftCard CP/M 2.20 (44K) -- BDOS (Basic Disk Operating System)
   3  0000              ; ----------------------------------------------------------------------------
   4  0000              ; Runtime-addressed (de-skewed): ORG $9C00 (FBASE), runs $9C00-$A9FF. An independent
   5  0000              ; compilation: $9C00 image header (serial + JP $9C06 entry), the 41-entry function
   6  0000              ; dispatch table ($9C47), console/line-edit, FCB/directory/allocation, disk record
   7  0000              ; deblock + RWTS, the variable page ($A9xx). References the CCP base once (CCP_ENTRY,
   8  0000              ; warm boot). The 44K system tracks store this sector-interleaved; the disk producer
   9  0000              ; re-applies the skew (cpm_pipeline/deskew.py). See ../../docs/CPM_Skew_Findings.md.
  10  0000              ; ============================================================================
  11  0000
  12  0000                  IFNDEF CPM_LINK
  13  0000                  DEVICE NOSLOT64K
  14  0000                  INCLUDE "cpm22.inc"
# file opened: cpm22.inc
   1+ 0000              ; cpm22.inc -- canonical Digital Research CP/M 2.2 definitions shared by SoftCard
   2+ 0000              ; CP/M sources.  Defined ONCE here and INCLUDEd by each source rather than re-deriving
   3+ 0000              ; magic numbers per file.  EQUs are zero-width, so including this is byte-identical.
   4+ 0000              ; This is the OS/ABI counterpart to apple_softcard.inc (which holds the Apple/SoftCard
   5+ 0000              ; HARDWARE externals); keep the two concerns separate.
   6+ 0000              ;
   7+ 0000              ; Source: CP/M 2.2 Interface Guide / "CP/M Reference Manual" [DOC CPMREF] (in the
   8+ 0000              ; archive at softcard/reference/softcard-cpm-archive/manuals/transcribed/).
   9+ 0000              ;
  10+ 0000              ; NOTE on the base page: $0000 (warm-boot JP) and $0005 (BDOS JP) are implementation
  11+ 0000              ; LABELS inside the BIOS/CCP/BDOS modules but CALL TARGETS in transient programs.  The
  12+ 0000              ; cell EQUs below are for the transient-program (caller) view; an OS module that DEFINES
  13+ 0000              ; these vectors as its own labels should not also pull in this base-page section.
  14+ 0000
  15+ 0000              ; ---- base page (transient-program view) ----------------------------------------
  16+ 0000              WBOOTV      EQU $0000      ; warm-boot vector: JP WBOOT (a CALL/JP $0000 restarts CP/M)
  17+ 0000              IOBYTE_ADDR EQU $0003      ; logical<->physical device map (STAT / fns 7,8)
  18+ 0000              CDISK_ADDR  EQU $0004      ; current drive (low nibble) / user (high nibble)
  19+ 0000              BDOS        EQU $0005      ; BDOS entry vector: CALL BDOS with C=function, DE=arg
  20+ 0000              RST2_VEC    EQU $0010      ; Z-80 RST 2 ($10) restart vector (8 bytes); CP/M leaves it for the app/debugger
  21+ 0000              RST4_VEC    EQU $0020      ; Z-80 RST 4 ($20) restart vector (8 bytes); CP/M leaves it for the app/debugger
  22+ 0000              TFCB        EQU $005C      ; default FCB parsed from the command tail
  23+ 0000              TFCB2       EQU $006C      ; second parsed FCB (overlaps TFCB+16)
  24+ 0000              TBUFF       EQU $0080      ; default DMA buffer (128 B); also the command-tail buffer
  25+ 0000              CMDLINE     EQU $0081      ; command-tail characters (TBUFF+1): $0080 = length, $0081+ = the upper-cased tail
  26+ 0000              TPA         EQU $0100      ; transient program area / load address
  27+ 0000
  28+ 0000              ; ---- BDOS function numbers (register C) ----------------------------------------
  29+ 0000              P_TERMCPM   EQU 0          ; system reset (return to CCP)
  30+ 0000              C_READ      EQU 1          ; console input (echoed) -> A
  31+ 0000              C_WRITE     EQU 2          ; console output (E = char)
  32+ 0000              A_READ      EQU 3          ; reader (AUX) input -> A
  33+ 0000              A_WRITE     EQU 4          ; punch (AUX) output (E = char)
  34+ 0000              L_WRITE     EQU 5          ; list (printer) output (E = char)
  35+ 0000              C_RAWIO     EQU 6          ; direct console I/O (E=$FF read / else write)
  36+ 0000              A_STATIN    EQU 7          ; get IOBYTE -> A
  37+ 0000              A_STATOUT   EQU 8          ; set IOBYTE (E = value)
  38+ 0000              C_WRITESTR  EQU 9          ; print '$'-terminated string (DE -> string)
  39+ 0000              C_READSTR   EQU 10         ; buffered console line input (DE -> buffer)
  40+ 0000              C_STAT      EQU 11         ; console status -> A (0 = none ready)
  41+ 0000              S_BDOSVER   EQU 12         ; return BDOS version -> HL
  42+ 0000              DRV_ALLRESET EQU 13        ; reset disk system
  43+ 0000              DRV_SET     EQU 14         ; select drive (E = 0=A..15=P)
  44+ 0000              F_OPEN      EQU 15         ; open file (DE -> FCB)
  45+ 0000              F_CLOSE     EQU 16         ; close file (DE -> FCB)
  46+ 0000              F_SFIRST    EQU 17         ; search for first (DE -> FCB)
  47+ 0000              F_SNEXT     EQU 18         ; search for next
  48+ 0000              F_DELETE    EQU 19         ; delete file (DE -> FCB)
  49+ 0000              F_READ      EQU 20         ; read sequential (DE -> FCB)
  50+ 0000              F_WRITE     EQU 21         ; write sequential (DE -> FCB)
  51+ 0000              F_MAKE      EQU 22         ; create file (DE -> FCB)
  52+ 0000              F_RENAME    EQU 23         ; rename file (DE -> FCB)
  53+ 0000              DRV_LOGINVEC EQU 24        ; return login vector -> HL
  54+ 0000              DRV_GET     EQU 25         ; return current drive -> A
  55+ 0000              F_DMAOFF    EQU 26         ; set DMA address (DE)
  56+ 0000              DRV_ALLOCVEC EQU 27        ; return allocation vector -> HL
  57+ 0000              DRV_SETRO   EQU 28         ; write-protect current drive
  58+ 0000              DRV_ROVEC   EQU 29         ; return read-only vector -> HL
  59+ 0000              F_ATTRIB    EQU 30         ; set file attributes (DE -> FCB)
  60+ 0000              DRV_DPB     EQU 31         ; return DPB address -> HL
  61+ 0000              F_USERNUM   EQU 32         ; get/set user number (E=$FF get / else set)
  62+ 0000              F_READRAND  EQU 33         ; read random (DE -> FCB)
  63+ 0000              F_WRITERAND EQU 34         ; write random (DE -> FCB)
  64+ 0000              F_SIZE      EQU 35         ; compute file size (DE -> FCB)
  65+ 0000              F_RANDREC   EQU 36         ; set random record (DE -> FCB)
  66+ 0000              DRV_RESET   EQU 37         ; reset drives (DE = drive vector)
  67+ 0000              F_WRITEZF   EQU 40         ; write random with zero fill (DE -> FCB)
  68+ 0000
  69+ 0000              ; ---- FCB field offsets (from the start of a 36-byte FCB) ------------------------
  70+ 0000              FCB_DR      EQU 0          ; drive code (0 = default, 1..16 = A..P)
  71+ 0000              FCB_F       EQU 1          ; filename (8 bytes, space-padded)
  72+ 0000              FCB_T       EQU 9          ; filetype (3 bytes; hi bits = R/O, SYS, archive)
  73+ 0000              FCB_EX      EQU 12         ; current extent
  74+ 0000              FCB_S1      EQU 13         ; reserved
  75+ 0000              FCB_S2      EQU 14         ; reserved (extent high)
  76+ 0000              FCB_RC      EQU 15         ; record count for the current extent (0..128)
  77+ 0000              FCB_CR      EQU 32         ; current record within the extent
  78+ 0000              FCB_R0      EQU 33         ; random record number, low byte
  79+ 0000              FCB_R1      EQU 34         ; random record number, middle byte
  80+ 0000              FCB_R2      EQU 35         ; random record number, high byte (overflow)
  81+ 0000
# file closed: cpm22.inc
  15  0000                  INCLUDE "cpm_system_220.inc"
# file opened: cpm_system_220.inc
   1+ 0000              ; ============================================================================
   2+ 0000              ; cpm_system_220.inc -- CP/M 2.20 (44K) cross-module system contract
   3+ 0000              ; ----------------------------------------------------------------------------
   4+ 0000              ; The de-skewed 2.20-44K system image is TWO independent compilations -- the CCP
   5+ 0000              ; ($9400-$9BFF) and the BDOS ($9C00-$A9FF) -- decoded at their true RUNTIME
   6+ 0000              ; addresses (see ../docs/CPM_Skew_Findings.md). On the correctly-addressed source
   7+ 0000              ; the two are almost decoupled: the CCP calls the BDOS only through the page-zero
   8+ 0000              ; $0005 ABI (cpm22.inc :: BDOS), and the ONLY direct cross-module symbols are the
   9+ 0000              ; two module bases below. They are defined ONCE here and INCLUDEd by both modules
  10+ 0000              ; (never duplicated -- feedback_no_duplicate_symbol_definitions). The earlier
  11+ 0000              ; "59 CCP->BDOS cross-refs" were sector-skew artifacts and do not exist on the
  12+ 0000              ; de-skewed source.
  13+ 0000              ; ============================================================================
  14+ 0000
  15+ 0000              CCP_ENTRY  EQU $9400      ; CBASE: CCP cold entry (JP cold-start); BDOS fn 0 / warm boot returns here
  16+ 0000              BDOS_FBASE EQU $9C00      ; FBASE: BDOS image base (6-byte serial + JP $9C06 entry); top-of-TPA marker the CCP loads
  17+ 0000
# file closed: cpm_system_220.inc
  16  0000                  ORG $9C00
  17  9C00                  ENDIF
  18  9C00              ; (BDOS_IMAGE_HEADER == module base; defined in cpm_system_220.inc)
  19  9C00 BD 16 00 00          DEFB    $BD,$16,$00,$00,$16,$DF
  19  9C04 16 DF
  20  9C06              ; ----------------------------------------------------------------------
  21  9C06              ; BDOS_ENTRY -- the BDOS=$0005-vector landing point (FBASE+6); jumps to the function dispatcher.
  22  9C06              ;   In: C = BDOS function number, DE = info address (or single-byte arg in E) -- the standard $0005
  23  9C06              ;       call ABI.
  24  9C06              ;   Out: jumps to BDOS_DISPATCH; never returns here (the handler RETs through the common BDOS exit).
  25  9C06              ;   Clobbers: none of its own (single JP).
  26  9C06              ;   Algorithm: OBSERVED -- one JP BDOS_DISPATCH. The page-zero $0005 jump-vector targets this
  27  9C06              ;              address ($9C06), so every BDOS call enters here. [RE]
  28  9C06              ; ----------------------------------------------------------------------
  29  9C06              BDOS_ENTRY:
  30  9C06                      ; enter the function dispatcher; reached from the page-zero BDOS=$0005 jump vector
  31  9C06 C3 11 9C             JP BDOS_DISPATCH
  32  9C09              ; ----------------------------------------------------------------------
  33  9C09              ; BDOS_ERR_VECTORS -- DATA: first entry of a 4-word table of BDOS disk-error reporter addresses.
  34  9C09              ;   In: a caller does LD HL,<one of these 4 word slots> then falls into the reporter helper at
  35  9C09              ;       $9F4A, which does LD E,(HL)/INC HL/LD D,(HL)/EX DE,HL/JP (HL) to enter the selected
  36  9C09              ;       reporter.
  37  9C09              ;   Out: this slot's word is the run address of the Bad-Sector (permanent disk) error reporter.
  38  9C09              ;   Clobbers: n/a (data).
  39  9C09              ;   Algorithm: OBSERVED -- two DATA bytes ($99 $9C) forming the address of the Bad-Sector reporter;
  40  9C09              ;              mis-decoded as SBC A,C / SBC A,H. This slot is loaded by the random-record path (the
  41  9C09              ;              caller at $9FBD: LD HL,BDOS_ERR_VECTORS). The four reporters print 'Bdos Err On d:'
  42  9C09              ;              then a '$'-terminated cause string ('Bad Sector' / 'Select' / 'R/O' / 'File R/O').
  43  9C09              ;              [RE]
  44  9C09              ; ----------------------------------------------------------------------
  45  9C09              BDOS_ERR_VECTORS:
  46  9C09                      ; DATA: low byte of the Bad-Sector (permanent disk-error) reporter address -- mis-decoded as
  47  9C09                      ;       SBC A,C
  48  9C09 99                   SBC A,C
  49  9C0A                      ; DATA: high byte ($9C) of the Bad-Sector reporter address
  50  9C0A 9C                   SBC A,H
  51  9C0B              ; ----------------------------------------------------------------------
  52  9C0B              ; BDOS_ERRVEC_SELECT -- DATA: word for the Select-error reporter in the BDOS error-vector table.
  53  9C0B              ;   In: n/a (data; this label's address is loaded into HL by the helper-front-end at $9F47 (LD
  54  9C0B              ;       HL,BDOS_ERRVEC_SELECT) before falling into the $9F4A reporter dispatch).
  55  9C0B              ;   Out: n/a (the word here is the run address of the 'Select' error reporter, which prints the
  56  9C0B              ;        message then warm-boots).
  57  9C0B              ;   Clobbers: n/a (data).
  58  9C0B              ;   Algorithm: OBSERVED -- two DATA bytes ($A5 $9C) forming the Select-error reporter address;
  59  9C0B              ;              mis-decoded as AND L / SBC A,H. [RE]
  60  9C0B              ; ----------------------------------------------------------------------
  61  9C0B              BDOS_ERRVEC_SELECT:
  62  9C0B                      ; DATA: low byte of the Select-error reporter address -- mis-decoded as AND L
  63  9C0B A5                   AND L
  64  9C0C                      ; DATA: high byte ($9C) of the Select-error reporter address
  65  9C0C 9C                   SBC A,H
  66  9C0D              ; ----------------------------------------------------------------------
  67  9C0D              ; BDOS_ERRVEC_RODISK -- DATA: word for the R/O-disk error reporter in the BDOS error-vector table.
  68  9C0D              ;   In: n/a (data; loaded into HL by the caller at $A158 (LD HL,BDOS_ERRVEC_RODISK), reached when a
  69  9C0D              ;       write is attempted to a read-only-flagged drive).
  70  9C0D              ;   Out: n/a (the word here is the run address of the reporter that prints 'R/O').
  71  9C0D              ;   Clobbers: n/a (data).
  72  9C0D              ;   Algorithm: OBSERVED -- two DATA bytes ($AB $9C) forming the R/O-disk reporter address;
  73  9C0D              ;              mis-decoded as XOR E / SBC A,H. The exact CP/M error sub-class ('R/O disk' vs 'disk
  74  9C0D              ;              changed to R/O') is UNKNOWN from these bytes; the reported cause string is 'R/O'.
  75  9C0D              ;              [RE]
  76  9C0D              ; ----------------------------------------------------------------------
  77  9C0D              BDOS_ERRVEC_RODISK:
  78  9C0D                      ; DATA: low byte of the R/O-disk reporter address -- mis-decoded as XOR E
  79  9C0D AB                   XOR E
  80  9C0E                      ; DATA: high byte ($9C) of the R/O-disk reporter address
  81  9C0E 9C                   SBC A,H
  82  9C0F              ; ----------------------------------------------------------------------
  83  9C0F              ; BDOS_ERRVEC_FILERO -- DATA: word for the File-R/O error reporter in the BDOS error-vector table.
  84  9C0F              ;   In: n/a (data; loaded into HL by the caller at $A14E (LD HL,BDOS_ERRVEC_FILERO), reached on a
  85  9C0F              ;       write to a read-only file).
  86  9C0F              ;   Out: n/a (the word here is the run address of the reporter that prints 'File R/O').
  87  9C0F              ;   Clobbers: n/a (data).
  88  9C0F              ;   Algorithm: OBSERVED -- two DATA bytes ($B1 $9C) forming the File-R/O reporter address;
  89  9C0F              ;              mis-decoded as OR C / SBC A,H. This is the last of the 4 error-vector words;
  90  9C0F              ;              BDOS_DISPATCH begins immediately after. [RE]
  91  9C0F              ; ----------------------------------------------------------------------
  92  9C0F              BDOS_ERRVEC_FILERO:
  93  9C0F                      ; DATA: low byte of the File-R/O reporter address -- mis-decoded as OR C
  94  9C0F B1                   OR C
  95  9C10                      ; DATA: high byte ($9C) of the File-R/O reporter address
  96  9C10 9C                   SBC A,H
  97  9C11              ; ----------------------------------------------------------------------
  98  9C11              ; BDOS_DISPATCH -- the CP/M 2.2 FDOS dispatcher: set up the BDOS frame and vector to the function
  99  9C11              ; handler.
 100  9C11              ;   In: C = BDOS function number (valid 0..40); DE = info address (single-byte arg also in E);
 101  9C11              ;       caller's SP live.
 102  9C11              ;   Out: control transfers (JP (HL)) to the selected handler with HL = the caller's info-address; on
 103  9C11              ;        out-of-range C (>= 41) it RETs straight to the just-pushed common exit, returning the
 104  9C11              ;        default 0 result.
 105  9C11              ;   Clobbers: A, BC, DE, HL, SP (switches to the private BDOS stack).
 106  9C11              ;   Algorithm: OBSERVED -- save caller DE (the info-address) into BDOS_PARAM_PTR; copy low byte E
 107  9C11              ;              into the requested-drive/byte-param cell DRV_SELECT_ARG; default the word result
 108  9C11              ;              (BDOS_RETVAL) to 0; capture caller SP into BDOS_SAVED_SP and switch SP to the private
 109  9C11              ;              BDOS stack top (BDOS_STACK_TOP); clear two per-call state cells (DRV_SAVED_FCB_BYTE, DRV_RESTORE_FLAG) to
 110  9C11              ;              0; push the common BDOS exit (FCB_AUTO_DRIVE_RESTORE = $A974) so every handler RETs
 111  9C11              ;              through it; range-check the function number A (=C) against $29 (41) -- CP $29 / RET
 112  9C11              ;              NC returns to the exit when A >= 41. Then move byte-arg E into C for the handler, set
 113  9C11              ;              the index DE = function number (LD E,A / LD D,0), index BDOS_DISPATCH_TBL by 2*A (two
 114  9C11              ;              ADD HL,DE), fetch the handler word into DE, reload the saved info-address into HL, EX
 115  9C11              ;              DE,HL, and JP (HL). Dispatch is static-indexed: function N selects table entry N.
 116  9C11              ;              [RE]
 117  9C11              ; ----------------------------------------------------------------------
 118  9C11              BDOS_DISPATCH:
 119  9C11 EB                   EX DE,HL
 120  9C12                      ; save the caller's DE info-address (reloaded into HL just before JP (HL) to the handler)
 121  9C12 22 43 9F             LD (BDOS_PARAM_PTR),HL
 122  9C15 EB                   EX DE,HL
 123  9C16 7B                   LD A,E
 124  9C17                      ; stash the low arg byte E as the requested drive / byte parameter
 125  9C17 32 D6 A9             LD (DRV_SELECT_ARG),A
 126  9C1A                      ; default the BDOS word result to 0 before dispatch
 127  9C1A 21 00 00             LD HL,$0000
 128  9C1D                      ; clear the BDOS word-result cell (read back by the common exit)
 129  9C1D 22 45 9F             LD (BDOS_RETVAL),HL
 130  9C20                      ; HL was 0, so HL := caller's SP
 131  9C20 39                   ADD HL,SP
 132  9C21                      ; save the caller's stack pointer for the common exit to restore
 133  9C21 22 0F 9F             LD (BDOS_SAVED_SP),HL
 134  9C24                      ; switch to the private BDOS internal stack
 135  9C24 31 41 9F             LD SP,BDOS_STACK_TOP
 136  9C27 AF                   XOR A
 137  9C28                      ; clear a per-call disk/reselect state cell (A=0 from XOR A)
 138  9C28 32 E0 A9             LD (DRV_SAVED_FCB_BYTE),A
 139  9C2B                      ; clear a second per-call state cell (A=0)
 140  9C2B 32 DE A9             LD (DRV_RESTORE_FLAG),A
 141  9C2E                      ; load the common BDOS exit/return-result address ($A974)
 142  9C2E 21 74 A9             LD HL,FCB_AUTO_DRIVE_RESTORE
 143  9C31                      ; push the common exit so every handler RETs back through it
 144  9C31 E5                   PUSH HL
 145  9C32                      ; A := function number for the range check and the table index
 146  9C32 79                   LD A,C
 147  9C33                      ; range-check: function number 41 ($29) or higher is out of range
 148  9C33 FE 29                CP $29
 149  9C35                      ; out-of-range -> return to the common exit with the default (0) result
 150  9C35 D0                   RET NC
 151  9C36                      ; move the byte argument (E) into C for the handler (C is now free since A holds the func
 152  9C36                      ; number)
 153  9C36 4B                   LD C,E
 154  9C37                      ; base of the 41-entry handler table
 155  9C37 21 47 9C             LD HL,BDOS_DISPATCH_TBL
 156  9C3A                      ; DE := function number (E=A, D=0) as the table index
 157  9C3A 5F                   LD E,A
 158  9C3B                      ; high byte of the index = 0
 159  9C3B 16 00                LD D,$00
 160  9C3D                      ; index by 2*A: two ADD HL,DE advance HL by 2*function-number
 161  9C3D 19                   ADD HL,DE
 162  9C3E 19                   ADD HL,DE
 163  9C3F                      ; fetch handler address low byte
 164  9C3F 5E                   LD E,(HL)
 165  9C40 23                   INC HL
 166  9C41                      ; fetch handler address high byte
 167  9C41 56                   LD D,(HL)
 168  9C42                      ; reload the caller's info-address into HL for the handler
 169  9C42 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
 170  9C45 EB                   EX DE,HL
 171  9C46                      ; enter the selected BDOS function handler
 172  9C46 E9                   JP (HL)
 173  9C47              ; ----------------------------------------------------------------------
 174  9C47              ; BDOS_DISPATCH_TBL -- 41-entry BDOS function dispatch table (one handler address per function
 175  9C47              ; 0..40).
 176  9C47              ;   In: indexed by 2*A (the function number) in BDOS_DISPATCH.
 177  9C47              ;   Out: the selected word is fetched and entered via JP (HL).
 178  9C47              ;   Clobbers: n/a (data).
 179  9C47              ;   Algorithm: OBSERVED -- a table of 16-bit handler run addresses. In-image handlers ($9Cxx-$A8xx)
 180  9C47              ;              render as labels; handlers above this staged image render as raw $hex; functions
 181  9C47              ;              4..11 sit in the DEFB run at $9C4F that the disassembler did not split into DEFW.
 182  9C47              ;              Functions 0-36 ($00-$24) are the standard CP/M 2.2 set; slots 37-40 ($25-$28) are
 183  9C47              ;              SoftCard/2.2 extensions (37 = drive-login mask, 38/39 = RET no-op stubs, 40 = Write
 184  9C47              ;              Random Zero Fill). [RE]
 185  9C47              ; ----------------------------------------------------------------------
 186  9C47              BDOS_DISPATCH_TBL:
 187  9C47                      ; fn 0 ($00) System Reset (warm boot)
 188  9C47 03 AA                DEFW    $AA03
 189  9C49                      ; fn 1 ($01) Console Input -> A
 190  9C49 C8 9E                DEFW    F_CONIN_H
 191  9C4B                      ; fn 2 ($02) Console Output (E=char)
 192  9C4B 90 9D                DEFW    F_CONOUT_H
 193  9C4D                      ; fn 3 ($03) Reader Input -> A
 194  9C4D CE 9E                DEFW    F_READERIN_H
 195  9C4F                      ; fns 4-11 as little-endian words: 4=$AA12 Punch Out, 5=$AA0F List Out, 6=$9ED4 Direct
 196  9C4F                      ; Console I/O, 7=$9EED Get IOBYTE, 8=$9EF3 Set IOBYTE, 9=$9EF8 Print String, 10=$9DE1 Read
 197  9C4F                      ; Console Buffer, 11=$9EFE Get Console Status
 198  9C4F 12 AA 0F AA          DEFB    $12,$AA,$0F,$AA,$D4,$9E,$ED,$9E,$F3,$9E,$F8,$9E,$E1,$9D,$FE,$9E
 198  9C53 D4 9E ED 9E
 198  9C57 F3 9E F8 9E
 198  9C5B E1 9D FE 9E
 199  9C5F                      ; fn 12 ($0C) Return Version Number -> HL
 200  9C5F 7E A8                DEFW    S_BDOSVER_H
 201  9C61                      ; fn 13 ($0D) Reset Disk System
 202  9C61 83 A8                DEFW    DRV_ALLRESET_H
 203  9C63                      ; fn 14 ($0E) Select Disk
 204  9C63 45 A8                DEFW    DRV_SET_H
 205  9C65                      ; fn 15 ($0F) Open File
 206  9C65 9C A8                DEFW    F_OPEN_H
 207  9C67                      ; fn 16 ($10) Close File
 208  9C67 A5 A8                DEFW    F_CLOSE_H
 209  9C69                      ; fn 17 ($11) Search for First
 210  9C69 AB A8                DEFW    F_SFIRST_H
 211  9C6B                      ; fn 18 ($12) Search for Next
 212  9C6B C8 A8                DEFW    F_SNEXT_H
 213  9C6D                      ; fn 19 ($13) Delete File
 214  9C6D D7 A8                DEFW    F_DELETE_H
 215  9C6F                      ; fn 20 ($14) Read Sequential
 216  9C6F E0 A8                DEFW    F_READ_H
 217  9C71                      ; fn 21 ($15) Write Sequential
 218  9C71 E6 A8                DEFW    F_WRITE_H
 219  9C73                      ; fn 22 ($16) Make File
 220  9C73 EC A8                DEFW    F_MAKE_H
 221  9C75                      ; fn 23 ($17) Rename File
 222  9C75 F5 A8                DEFW    F_RENAME_H
 223  9C77                      ; fn 24 ($18) Return Login Vector -> HL
 224  9C77 FE A8                DEFW    DRV_LOGINVEC_H
 225  9C79                      ; fn 25 ($19) Return Current Disk -> A
 226  9C79 04 A9                DEFW    DRV_GET_H
 227  9C7B                      ; fn 26 ($1A) Set DMA Address (DE)
 228  9C7B 0A A9                DEFW    F_DMAOFF_H
 229  9C7D                      ; fn 27 ($1B) Get Allocation Vector -> HL
 230  9C7D 11 A9                DEFW    DRV_ALLOCVEC_H
 231  9C7F                      ; fn 28 ($1C) Write Protect Disk
 232  9C7F 2C A1                DEFW    DRV_SETRO_H
 233  9C81                      ; fn 29 ($1D) Get R/O Vector -> HL
 234  9C81 17 A9                DEFW    DRV_ROVEC_H
 235  9C83                      ; fn 30 ($1E) Set File Attributes
 236  9C83 1D A9                DEFW    F_ATTRIB_H
 237  9C85                      ; fn 31 ($1F) Get Disk Parameter Block addr -> HL
 238  9C85 26 A9                DEFW    DRV_DPB_H
 239  9C87                      ; fn 32 ($20) Get/Set User Number
 240  9C87 2D A9                DEFW    F_USERNUM_H
 241  9C89                      ; fn 33 ($21) Read Random
 242  9C89 41 A9                DEFW    F_READRAND_H
 243  9C8B                      ; fn 34 ($22) Write Random
 244  9C8B 47 A9                DEFW    F_WRITERAND_H
 245  9C8D                      ; fn 35 ($23) Compute File Size
 246  9C8D 4D A9                DEFW    F_SIZE_H
 247  9C8F                      ; fn 36 ($24) Set Random Record
 248  9C8F 0E A8                DEFW    F_RANDREC_H
 249  9C91                      ; fn 37 ($25) SoftCard extension: drive-login-vector mask (handler at $A953)
 250  9C91 53 A9                DEFW    DRV_RESET_H
 251  9C93                      ; fn 38 ($26) SoftCard extension: RET no-op stub
 252  9C93 04 9F                DEFW    BDOS_RET_NOP
 253  9C95                      ; fn 39 ($27) SoftCard extension: RET no-op stub (same handler)
 254  9C95 04 9F                DEFW    BDOS_RET_NOP
 255  9C97                      ; fn 40 ($28) Write Random with Zero Fill
 256  9C97 9B A9                DEFW    F_WRITEZF_H
 257  9C99 21 CA                DEFW    $CA21
 258  9C9B 9C CD                DEFW    $CD9C
 259  9C9D E5 9C                DEFW    BDOS_ERR_PRINT
 260  9C9F FE 03                DEFW    $03FE
 261  9CA1 CA 00                DEFW    $00CA
 262  9CA3 00 C9                DEFW    $C900
 263  9CA5 21 D5                DEFW    $D521
 264  9CA7 9C C3                DEFW    $C39C
 265  9CA9 B4 9C                DEFW    BDOS_ERR_TRAP
 266  9CAB 21 E1                DEFW    $E121
 267  9CAD 9C C3                DEFW    $C39C
 268  9CAF B4 9C                DEFW    BDOS_ERR_TRAP
 269  9CB1 21 DC                DEFW    $DC21
 270  9CB3 9C                   DEFB    $9C
 271  9CB4              ; ----------------------------------------------------------------------
 272  9CB4              ; BDOS_ERR_TRAP -- Print a BDOS disk error message and warm-boot.
 273  9CB4              ;   In: HL = pointer to the '$'-terminated reason string (set by the calling error
 274  9CB4              ;       stub, e.g. 'Bad Sector$'/'Select$'/'File R/O$'); BDOS_CUR_DRIVE = current drive index
 275  9CB4              ;       (0=A), used only to form the banner's drive letter.
 276  9CB4              ;   Out: does not return -- transfers to warm boot (JP 0).
 277  9CB4              ;   Clobbers: AF, BC, HL (irrelevant -- system restarts).
 278  9CB4              ;   Algorithm: call BDOS_ERR_PRINT to emit 'Bdos Err On d: <reason>', then JP 0000
 279  9CB4              ;              (CP/M warm-boot vector) to reload the CCP.
 280  9CB4              ;   [RE] Standard CP/M 2.2 BDOS fatal-disk-error trap. Reached via JP from the disk-error
 281  9CB4              ;        stubs just below the dispatch table, each of which loads HL with its reason string.
 282  9CB4              ; ----------------------------------------------------------------------
 283  9CB4              BDOS_ERR_TRAP:
 284  9CB4                      ; Emit 'Bdos Err On d: <reason>$' to the console
 285  9CB4 CD E5 9C             CALL BDOS_ERR_PRINT
 286  9CB7                      ; Warm boot (vector at 0000) -- reload CCP, never returns
 287  9CB7 C3 00 00             JP $0000
 288  9CBA              ; ----------------------------------------------------------------------
 289  9CBA              ; BDOS_ERR_MSG_HEAD -- '$'-terminated head of the BDOS error banner: 'Bdos Err On '.
 290  9CBA              ;   [RE] Printed by BDOS_ERR_PRINT; the drive letter is patched into the byte that follows.
 291  9CBA              ; ----------------------------------------------------------------------
 292  9CBA              BDOS_ERR_MSG_HEAD:
 293  9CBA 42 64 6F 73          DEFB    "Bdos Err On "           ; string
 293  9CBE 20 45 72 72
 293  9CC2 20 4F 6E 20
 294  9CC6              ; ----------------------------------------------------------------------
 295  9CC6              ; BDOS_ERR_MSG_DRIVE -- drive-letter slot plus the four '$'-delimited error reasons.
 296  9CC6              ;   Layout: 1 patched drive-letter byte, then ' : $', 'Bad Sector$', 'Select$', 'File R/O$'.
 297  9CC6              ;   [RE] BDOS_ERR_PRINT overwrites the first byte with 'A'+drive, then prints from here;
 298  9CC6              ;        the selected reason string ('Bad Sector$' at +4, 'Select$' at +15, 'File R/O$'
 299  9CC6              ;        at +22) is pointed to by HL on entry to the trap (moved into BC inside
 300  9CC6              ;        BDOS_ERR_PRINT via PUSH HL / POP BC).
 301  9CC6              ; ----------------------------------------------------------------------
 302  9CC6              BDOS_ERR_MSG_DRIVE:
 303  9CC6 20 3A 20 24          DEFB    " : $Bad Sector$Select$File R/O$" ; string
 303  9CCA 42 61 64 20
 303  9CCE 53 65 63 74
 303  9CD2 6F 72 24 53
 303  9CD6 65 6C 65 63
 303  9CDA 74 24 46 69
 303  9CDE 6C 65 20 52
 303  9CE2 2F 4F 24
 304  9CE5              ; ----------------------------------------------------------------------
 305  9CE5              ; BDOS_ERR_PRINT -- print the 'Bdos Err On d: <reason>' banner to the console.
 306  9CE5              ;   In: HL = pointer to the trailing reason string ('$'-terminated); BDOS_CUR_DRIVE = drive index.
 307  9CE5              ;   Out: banner echoed via the console-output path; the entry HL is consumed (PUSH/POP).
 308  9CE5              ;   Clobbers: AF, BC, HL.
 309  9CE5              ;   Algorithm: save the reason pointer (PUSH HL); print CR/LF (CON_CRLF); form drive
 310  9CE5              ;              letter 'A'+BDOS_CUR_DRIVE and patch it into BDOS_ERR_MSG_DRIVE; print the fixed head
 311  9CE5              ;              'Bdos Err On ' via BC; then POP the saved reason pointer into BC and print it,
 312  9CE5              ;              each through the '$'-terminated string printer (CON_PRINT_STR).
 313  9CE5              ;   [RE] Standard CP/M 2.2 BDOS error reporter.
 314  9CE5              ; ----------------------------------------------------------------------
 315  9CE5              BDOS_ERR_PRINT:
 316  9CE5 E5                   PUSH HL
 317  9CE6                      ; Emit CR/LF before the banner
 318  9CE6 CD C9 9D             CALL CON_CRLF
 319  9CE9                      ; Current drive index (0=A)
 320  9CE9 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
 321  9CEC                      ; Convert to drive letter 'A'+n
 322  9CEC C6 41                ADD A,$41
 323  9CEE                      ; Patch the drive-letter slot in the message
 324  9CEE 32 C6 9C             LD (BDOS_ERR_MSG_DRIVE),A
 325  9CF1                      ; Point at the fixed head 'Bdos Err On '
 326  9CF1 01 BA 9C             LD BC,BDOS_ERR_MSG_HEAD
 327  9CF4                      ; Print head + ' d: ' up to the '$'
 328  9CF4 CD D3 9D             CALL CON_PRINT_STR
 329  9CF7                      ; Recover the reason-string pointer (PUSHed from HL on entry)
 330  9CF7 C1                   POP BC
 331  9CF8                      ; Print the selected reason string
 332  9CF8 CD D3 9D             CALL CON_PRINT_STR
 333  9CFB              ; ----------------------------------------------------------------------
 334  9CFB              ; CON_GETC_OR_RAW -- return the 1-char type-ahead if present, else read raw console input.
 335  9CFB              ;   In: CON_PENDING_CHAR = pending look-ahead char (0 if none).
 336  9CFB              ;   Out: A = next console character; CON_PENDING_CHAR cleared if it supplied the byte.
 337  9CFB              ;   Clobbers: AF, HL.
 338  9CFB              ;   Algorithm: if CON_PENDING_CHAR nonzero, consume and return it; otherwise call the BIOS
 339  9CFB              ;              console-input vector (BDOS variable-page entry $AA09) for a fresh key.
 340  9CFB              ;   [RE] Single-byte console un-get buffer used by the line editor and CONIN.
 341  9CFB              ; ----------------------------------------------------------------------
 342  9CFB              CON_GETC_OR_RAW:
 343  9CFB                      ; Point at the 1-char type-ahead buffer
 344  9CFB 21 0E 9F             LD HL,CON_PENDING_CHAR
 345  9CFE 7E                   LD A,(HL)
 346  9CFF                      ; Clear it -- the held char (if any) is consumed
 347  9CFF 36 00                LD (HL),$00
 348  9D01 B7                   OR A
 349  9D02                      ; A held char was present: return it
 350  9D02 C0                   RET NZ
 351  9D03                      ; Else fall through to the BIOS CONIN vector
 352  9D03 C3 09 AA             JP $AA09
 353  9D06              ; ----------------------------------------------------------------------
 354  9D06              ; F_CONIN_RAW -- read one console char, echoing it unless it is a control char.
 355  9D06              ;   In: none.
 356  9D06              ;   Out: A = character read (7-bit not masked here).
 357  9D06              ;   Clobbers: AF, BC, HL.
 358  9D06              ;   Algorithm: fetch a char (CON_GETC_OR_RAW); if it is a printable/handled control
 359  9D06              ;              (IS_CTRL_CHAR sets carry for the unechoed set) skip echo; otherwise echo
 360  9D06              ;              it via F_CONOUT_H, preserving the char across the call.
 361  9D06              ;   [RE] Backs BDOS function 1 (Console Input with echo).
 362  9D06              ; ----------------------------------------------------------------------
 363  9D06              F_CONIN_RAW:
 364  9D06                      ; Get next console char (type-ahead or raw)
 365  9D06 CD FB 9C             CALL CON_GETC_OR_RAW
 366  9D09                      ; Carry set => do not echo (control char)
 367  9D09 CD 14 9D             CALL IS_CTRL_CHAR
 368  9D0C                      ; Control char: return without echo
 369  9D0C D8                   RET C
 370  9D0D F5                   PUSH AF
 371  9D0E 4F                   LD C,A
 372  9D0F                      ; Echo the character
 373  9D0F CD 90 9D             CALL F_CONOUT_H
 374  9D12 F1                   POP AF
 375  9D13 C9                   RET
 376  9D14              ; ----------------------------------------------------------------------
 377  9D14              ; IS_CTRL_CHAR -- classify a char as a special/control code for echo suppression.
 378  9D14              ;   In: A = character.
 379  9D14              ;   Out: Z set if A is CR/LF/TAB/BS (those return early with Z); CARRY reflects A<' '
 380  9D14              ;        from the final CP $20 (carry set => below space, i.e. an unhandled control char).
 381  9D14              ;   Clobbers: AF.
 382  9D14              ;   Algorithm: compare A against CR(0D), LF(0A), TAB(09), BS(08) returning Z on a hit;
 383  9D14              ;              else fall through to CP ' ' so carry tells printable-vs-control.
 384  9D14              ;   [RE] Helper used by the console echo/expansion paths.
 385  9D14              ; ----------------------------------------------------------------------
 386  9D14              IS_CTRL_CHAR:
 387  9D14                      ; Carriage return?
 388  9D14 FE 0D                CP $0D
 389  9D16 C8                   RET Z
 390  9D17                      ; Line feed?
 391  9D17 FE 0A                CP $0A
 392  9D19 C8                   RET Z
 393  9D1A                      ; Tab?
 394  9D1A FE 09                CP $09
 395  9D1C C8                   RET Z
 396  9D1D                      ; Backspace?
 397  9D1D FE 08                CP $08
 398  9D1F C8                   RET Z
 399  9D20                      ; Set carry if below space (control char)
 400  9D20 FE 20                CP $20
 401  9D22 C9                   RET
 402  9D23              ; ----------------------------------------------------------------------
 403  9D23              ; CON_POLL_STATUS -- console-status poll that also traps Ctrl-S/Ctrl-C while idle.
 404  9D23              ;   In: CON_PENDING_CHAR = type-ahead char (nonzero => a key is already pending).
 405  9D23              ;   Out: A = 1 if a character is ready, 0 if not.
 406  9D23              ;   Clobbers: AF.
 407  9D23              ;   Algorithm: if a char is already buffered, report ready; else ask the BIOS console
 408  9D23              ;              status vector ($AA06). If a key is down, peek it ($AA09): Ctrl-S (13h)
 409  9D23              ;              stalls (then Ctrl-C warm-boots via JP 0); any other key is stashed in
 410  9D23              ;              CON_PENDING_CHAR as type-ahead and reported ready.
 411  9D23              ;   [RE] Backs the BDOS console-status / flow-control behaviour.
 412  9D23              ; ----------------------------------------------------------------------
 413  9D23              CON_POLL_STATUS:
 414  9D23                      ; Already have a buffered char?
 415  9D23 3A 0E 9F             LD A,(CON_PENDING_CHAR)
 416  9D26 B7                   OR A
 417  9D27                      ; Yes -> report 'ready' (A=1)
 418  9D27 C2 45 9D             JP NZ,CON_STATUS_READY
 419  9D2A                      ; BIOS console status vector
 420  9D2A CD 06 AA             CALL $AA06
 421  9D2D                      ; Bit0 = key available?
 422  9D2D E6 01                AND $01
 423  9D2F                      ; No key -> return A=0 (not ready)
 424  9D2F C8                   RET Z
 425  9D30                      ; Read the pending key
 426  9D30 CD 09 AA             CALL $AA09
 427  9D33                      ; Ctrl-S (stop/flow-control)?
 428  9D33 FE 13                CP $13
 429  9D35                      ; No -> buffer it as type-ahead
 430  9D35 C2 42 9D             JP NZ,CON_POLL_STASH
 431  9D38                      ; After Ctrl-S, wait for the resume/abort key
 432  9D38 CD 09 AA             CALL $AA09
 433  9D3B                      ; Ctrl-C while paused?
 434  9D3B FE 03                CP $03
 435  9D3D                      ; Ctrl-C -> warm boot
 436  9D3D CA 00 00             JP Z,$0000
 437  9D40                      ; Otherwise resume: report 'no key' (A=0)
 438  9D40 AF                   XOR A
 439  9D41 C9                   RET
 440  9D42              ; ----------------------------------------------------------------------
 441  9D42              ; CON_POLL_STASH -- stash the just-read key as type-ahead and report 'ready'.
 442  9D42              ;   In: A = key character to hold.
 443  9D42              ;   Out: A = 1 (ready).
 444  9D42              ;   Clobbers: none beyond A.
 445  9D42              ;   Algorithm: store A into the 1-char type-ahead cell, then fall into the A:=1 tail.
 446  9D42              ; ----------------------------------------------------------------------
 447  9D42              CON_POLL_STASH:
 448  9D42                      ; Hold the key in the type-ahead buffer
 449  9D42 32 0E 9F             LD (CON_PENDING_CHAR),A
 450  9D45              ; ----------------------------------------------------------------------
 451  9D45              ; CON_STATUS_READY -- return A=1, the 'character is ready' status result.
 452  9D45              ;   In: none. Out: A=1. Clobbers: A.
 453  9D45              ;   [RE] Shared tail of CON_POLL_STATUS.
 454  9D45              ; ----------------------------------------------------------------------
 455  9D45              CON_STATUS_READY:
 456  9D45                      ; Status = ready
 457  9D45 3E 01                LD A,$01
 458  9D47 C9                   RET
 459  9D48              ; ----------------------------------------------------------------------
 460  9D48              ; CON_PUT_COL -- output one char to the console, tracking column and honouring Ctrl-S.
 461  9D48              ;   In: C = character to print.
 462  9D48              ;   Out: char sent to console (and to the list device if echo flag set); column counter
 463  9D48              ;        CON_COL updated for printables; BS/LF adjust it.
 464  9D48              ;   Clobbers: AF, HL (BC preserved across the BIOS calls).
 465  9D48              ;   Algorithm: unless a redisplay-suppress flag (CON_SAVED_COL) is set, poll for Ctrl-S/Ctrl-C
 466  9D48              ;              then send C to the BIOS conout vector ($AA0C) and, if the printer-echo
 467  9D48              ;              flag CON_LIST_ECHO is set, to the list vector ($AA0F). Then update the column:
 468  9D48              ;              DEL(7F) leaves it; printable >=' ' increments; BS decrements; LF zeroes it.
 469  9D48              ;   [RE] Core character-output + column bookkeeping for the console writer.
 470  9D48              ; ----------------------------------------------------------------------
 471  9D48              CON_PUT_COL:
 472  9D48                      ; Redisplay-in-progress? skip status poll/echo if so
 473  9D48 3A 0A 9F             LD A,(CON_SAVED_COL)
 474  9D4B B7                   OR A
 475  9D4C                      ; Suppressed: go straight to column tracking
 476  9D4C C2 62 9D             JP NZ,CON_TRACK_COL
 477  9D4F C5                   PUSH BC
 478  9D50                      ; Poll for Ctrl-S/Ctrl-C before output
 479  9D50 CD 23 9D             CALL CON_POLL_STATUS
 480  9D53 C1                   POP BC
 481  9D54 C5                   PUSH BC
 482  9D55                      ; BIOS console-output vector
 483  9D55 CD 0C AA             CALL $AA0C
 484  9D58 C1                   POP BC
 485  9D59 C5                   PUSH BC
 486  9D5A                      ; Printer (list) echo enabled?
 487  9D5A 3A 0D 9F             LD A,(CON_LIST_ECHO)
 488  9D5D B7                   OR A
 489  9D5E                      ; Also send to the list device
 490  9D5E C4 0F AA             CALL NZ,$AA0F
 491  9D61 C1                   POP BC
 492  9D62              ; ----------------------------------------------------------------------
 493  9D62              ; CON_TRACK_COL -- update the output column counter for the char just sent.
 494  9D62              ;   In: C = the char emitted; CON_COL = current column.
 495  9D62              ;   Out: CON_COL adjusted (DEL no-op, printable +1, BS -1 if nonzero, LF -> 0).
 496  9D62              ;   Clobbers: AF, HL.
 497  9D62              ;   Algorithm: DEL(7F) -> return; >=' ' -> increment column; control chars -> if column
 498  9D62              ;              is already 0 return; BS(08) -> decrement; LF(0A) -> zero the column.
 499  9D62              ;   [RE] Column bookkeeping shared by CON_PUT_COL.
 500  9D62              ; ----------------------------------------------------------------------
 501  9D62              CON_TRACK_COL:
 502  9D62 79                   LD A,C
 503  9D63                      ; HL -> current output column
 504  9D63 21 0C 9F             LD HL,CON_COL
 505  9D66                      ; DELETE: no column change
 506  9D66 FE 7F                CP $7F
 507  9D68 C8                   RET Z
 508  9D69                      ; Tentatively advance the column
 509  9D69 34                   INC (HL)
 510  9D6A                      ; Printable (>= space)? keep the increment
 511  9D6A FE 20                CP $20
 512  9D6C D0                   RET NC
 513  9D6D                      ; Control char: undo the increment
 514  9D6D 35                   DEC (HL)
 515  9D6E 7E                   LD A,(HL)
 516  9D6F B7                   OR A
 517  9D70 C8                   RET Z
 518  9D71 79                   LD A,C
 519  9D72                      ; Backspace?
 520  9D72 FE 08                CP $08
 521  9D74 C2 79 9D             JP NZ,CON_TRACK_COL_LF
 522  9D77 35                   DEC (HL)
 523  9D78 C9                   RET
 524  9D79              ; ----------------------------------------------------------------------
 525  9D79              ; CON_TRACK_COL_LF -- handle the line-feed case of column tracking.
 526  9D79              ;   In: A = the control char; HL -> column cell.
 527  9D79              ;   Out: column zeroed if A was LF; unchanged otherwise.
 528  9D79              ;   Clobbers: AF.
 529  9D79              ;   [RE] LF tail of CON_TRACK_COL.
 530  9D79              ; ----------------------------------------------------------------------
 531  9D79              CON_TRACK_COL_LF:
 532  9D79                      ; Line feed?
 533  9D79 FE 0A                CP $0A
 534  9D7B C0                   RET NZ
 535  9D7C                      ; LF resets the column to 0
 536  9D7C 36 00                LD (HL),$00
 537  9D7E C9                   RET
 538  9D7F              ; ----------------------------------------------------------------------
 539  9D7F              ; CON_PUT_VISIBLE -- output a char, expanding non-tab control codes as '^X'.
 540  9D7F              ;   In: C = character.
 541  9D7F              ;   Out: char(s) sent via CON_PUT_COL; TAB handled by F_CONOUT_H expansion.
 542  9D7F              ;   Clobbers: AF.
 543  9D7F              ;   Algorithm: if the char is a handled control (IS_CTRL_CHAR, carry clear) print it
 544  9D7F              ;              normally through F_CONOUT_H; otherwise emit '^' then the char OR'd with
 545  9D7F              ;              40h (control-to-letter), so e.g. Ctrl-A shows as '^A'.
 546  9D7F              ;   [RE] Visible-control echo used by the line editor's buffer redisplay.
 547  9D7F              ; ----------------------------------------------------------------------
 548  9D7F              CON_PUT_VISIBLE:
 549  9D7F 79                   LD A,C
 550  9D80                      ; Classify; carry clear => print as-is
 551  9D80 CD 14 9D             CALL IS_CTRL_CHAR
 552  9D83                      ; Ordinary char/tab: normal output
 553  9D83 D2 90 9D             JP NC,F_CONOUT_H
 554  9D86 F5                   PUSH AF
 555  9D87                      ; '^' caret prefix for a control char
 556  9D87 0E 5E                LD C,$5E
 557  9D89                      ; Print the caret
 558  9D89 CD 48 9D             CALL CON_PUT_COL
 559  9D8C F1                   POP AF
 560  9D8D                      ; Map control code to its display letter
 561  9D8D F6 40                OR $40
 562  9D8F 4F                   LD C,A
 563  9D90              ; ----------------------------------------------------------------------
 564  9D90              ; F_CONOUT_H -- BDOS console-output handler (function 2) with tab expansion.
 565  9D90              ;   In: C = character to print.
 566  9D90              ;   Out: character emitted; TAB expands to spaces to the next 8-column stop.
 567  9D90              ;   Clobbers: AF.
 568  9D90              ;   Algorithm: if C != TAB(09) just print it via CON_PUT_COL; if TAB, emit spaces
 569  9D90              ;              through CON_PUT_COL until the column counter (CON_COL) is a multiple of 8.
 570  9D90              ;   [RE] BDOS function 2 (Console Output) backing routine.
 571  9D90              ; ----------------------------------------------------------------------
 572  9D90              F_CONOUT_H:
 573  9D90 79                   LD A,C
 574  9D91                      ; Tab character?
 575  9D91 FE 09                CP $09
 576  9D93                      ; Non-tab: print directly
 577  9D93 C2 48 9D             JP NZ,CON_PUT_COL
 578  9D96              ; ----------------------------------------------------------------------
 579  9D96              ; CONOUT_TAB_FILL -- emit spaces until the column reaches the next 8-stop (tab expand).
 580  9D96              ;   In: CON_COL = current column.
 581  9D96              ;   Out: spaces printed until (column & 7)==0.
 582  9D96              ;   Clobbers: AF, C.
 583  9D96              ;   Algorithm: output a space via CON_PUT_COL, re-read the column, loop while low 3 bits
 584  9D96              ;              are nonzero.
 585  9D96              ;   [RE] Tab-expansion loop of F_CONOUT_H.
 586  9D96              ; ----------------------------------------------------------------------
 587  9D96              CONOUT_TAB_FILL:
 588  9D96                      ; Space to fill the tab
 589  9D96 0E 20                LD C,$20
 590  9D98 CD 48 9D             CALL CON_PUT_COL
 591  9D9B 3A 0C 9F             LD A,(CON_COL)
 592  9D9E                      ; At an 8-column tab stop yet?
 593  9D9E E6 07                AND $07
 594  9DA0                      ; Not yet -> emit another space
 595  9DA0 C2 96 9D             JP NZ,CONOUT_TAB_FILL
 596  9DA3 C9                   RET
 597  9DA4              ; ----------------------------------------------------------------------
 598  9DA4              ; CON_BACKSPACE -- erase the last echoed character (BS, space, BS).
 599  9DA4              ;   In: none. Out: cursor moved left one cell, char blanked on screen.
 600  9DA4              ;   Clobbers: AF, C.
 601  9DA4              ;   Algorithm: emit BS (via CON_BS_OUT), then space, then BS again through the BIOS
 602  9DA4              ;              conout vector so the previous glyph is overwritten with a blank.
 603  9DA4              ;   [RE] Destructive backspace used by the line editor on rubout.
 604  9DA4              ; ----------------------------------------------------------------------
 605  9DA4              CON_BACKSPACE:
 606  9DA4                      ; Send a backspace
 607  9DA4 CD AC 9D             CALL CON_BS_OUT
 608  9DA7                      ; Overwrite the char with a space
 609  9DA7 0E 20                LD C,$20
 610  9DA9                      ; BIOS conout: print the blanking space
 611  9DA9 CD 0C AA             CALL $AA0C
 612  9DAC              ; ----------------------------------------------------------------------
 613  9DAC              ; CON_BS_OUT -- send a single backspace (08) to the console.
 614  9DAC              ;   In: none. Out: BS emitted via the BIOS conout vector.
 615  9DAC              ;   Clobbers: C.
 616  9DAC              ;   [RE] Tail-call helper; also used as the leading BS of CON_BACKSPACE.
 617  9DAC              ; ----------------------------------------------------------------------
 618  9DAC              CON_BS_OUT:
 619  9DAC                      ; Backspace character
 620  9DAC 0E 08                LD C,$08
 621  9DAE                      ; BIOS conout (tail call)
 622  9DAE C3 0C AA             JP $AA0C
 623  9DB1              ; ----------------------------------------------------------------------
 624  9DB1              ; CON_RETYPE_LINE -- echo '#' + CR/LF and reprint the current edit buffer (Ctrl-R).
 625  9DB1              ;   In: CON_COL = total chars in the line; the edit buffer follows BDOS_PARAM_PTR's pointer.
 626  9DB1              ;   Out: a fresh copy of the typed line shown on a new line.
 627  9DB1              ;   Clobbers: AF, C, HL.
 628  9DB1              ;   Algorithm: print '#', CR/LF (CON_CRLF), then loop re-emitting characters with
 629  9DB1              ;              CON_PUT_COL until the echoed count CON_LINE_START_COL reaches CON_COL.
 630  9DB1              ;   [RE] Implements the line editor's Ctrl-R (retype) function.
 631  9DB1              ; ----------------------------------------------------------------------
 632  9DB1              CON_RETYPE_LINE:
 633  9DB1                      ; '#' marker shown for a retype
 634  9DB1 0E 23                LD C,$23
 635  9DB3                      ; Print the '#'
 636  9DB3 CD 48 9D             CALL CON_PUT_COL
 637  9DB6                      ; CR/LF onto a fresh line
 638  9DB6 CD C9 9D             CALL CON_CRLF
 639  9DB9              ; ----------------------------------------------------------------------
 640  9DB9              ; CON_RETYPE_LOOP -- reprint buffered characters until the column matches the count.
 641  9DB9              ;   In: CON_LINE_START_COL = chars already re-echoed; CON_COL = target count.
 642  9DB9              ;   Out: remaining buffered chars emitted as spaces (placeholder re-echo).
 643  9DB9              ;   Clobbers: AF, C, HL.
 644  9DB9              ;   Algorithm: while column (CON_COL) >= the running CON_LINE_START_COL counter is false, emit a
 645  9DB9              ;              space via CON_PUT_COL and loop.
 646  9DB9              ;   [RE] Re-echo loop of CON_RETYPE_LINE.
 647  9DB9              ;   [?] The compared cells are the editor's column vs echoed-count; exact pairing UNKNOWN
 648  9DB9              ;       beyond 'advance until equal'.
 649  9DB9              ; ----------------------------------------------------------------------
 650  9DB9              CON_RETYPE_LOOP:
 651  9DB9                      ; Current column / line length
 652  9DB9 3A 0C 9F             LD A,(CON_COL)
 653  9DBC                      ; HL -> echoed-count cell
 654  9DBC 21 0B 9F             LD HL,CON_LINE_START_COL
 655  9DBF                      ; Reached the end of the buffer?
 656  9DBF BE                   CP (HL)
 657  9DC0                      ; Done re-echoing
 658  9DC0 D0                   RET NC
 659  9DC1                      ; Emit a space placeholder
 660  9DC1 0E 20                LD C,$20
 661  9DC3 CD 48 9D             CALL CON_PUT_COL
 662  9DC6 C3 B9 9D             JP CON_RETYPE_LOOP
 663  9DC9              ; ----------------------------------------------------------------------
 664  9DC9              ; CON_CRLF -- output a carriage-return / line-feed pair to the console.
 665  9DC9              ;   In: none. Out: CR then LF emitted; column reset by the LF.
 666  9DC9              ;   Clobbers: AF, C.
 667  9DC9              ;   Algorithm: CON_PUT_COL with CR(0D), then tail-call CON_PUT_COL with LF(0A).
 668  9DC9              ;   [RE] Newline helper used throughout the console/error paths.
 669  9DC9              ; ----------------------------------------------------------------------
 670  9DC9              CON_CRLF:
 671  9DC9                      ; Carriage return
 672  9DC9 0E 0D                LD C,$0D
 673  9DCB                      ; Emit CR
 674  9DCB CD 48 9D             CALL CON_PUT_COL
 675  9DCE                      ; Line feed
 676  9DCE 0E 0A                LD C,$0A
 677  9DD0                      ; Emit LF (tail call)
 678  9DD0 C3 48 9D             JP CON_PUT_COL
 679  9DD3              ; ----------------------------------------------------------------------
 680  9DD3              ; CON_PRINT_STR -- print a '$'-terminated string to the console.
 681  9DD3              ;   In: BC = pointer to the string; terminated by '$' (24h).
 682  9DD3              ;   Out: each char emitted via F_CONOUT_H until '$' is reached.
 683  9DD3              ;   Clobbers: AF, BC, C.
 684  9DD3              ;   Algorithm: load (BC); if '$' return; else advance BC, output the char through
 685  9DD3              ;              F_CONOUT_H (preserving BC), and loop.
 686  9DD3              ;   [RE] The '$'-terminated string writer; backs BDOS function 9 and the error printer.
 687  9DD3              ; ----------------------------------------------------------------------
 688  9DD3              CON_PRINT_STR:
 689  9DD3                      ; Fetch next string byte
 690  9DD3 0A                   LD A,(BC)
 691  9DD4                      ; '$' string terminator?
 692  9DD4 FE 24                CP $24
 693  9DD6                      ; End of string
 694  9DD6 C8                   RET Z
 695  9DD7 03                   INC BC
 696  9DD8 C5                   PUSH BC
 697  9DD9 4F                   LD C,A
 698  9DDA                      ; Print the character
 699  9DDA CD 90 9D             CALL F_CONOUT_H
 700  9DDD C1                   POP BC
 701  9DDE                      ; Next character
 702  9DDE C3 D3 9D             JP CON_PRINT_STR
 703  9DE1              ; ----------------------------------------------------------------------
 704  9DE1              ; F_READCONBUF_H -- BDOS buffered console line input (function 10) with editing.
 705  9DE1              ;   In: BDOS_PARAM_PTR -> the read buffer (byte0 = max length, byte1 = returned count, data...).
 706  9DE1              ;   Out: the buffer filled with the edited line; byte1 set to the char count.
 707  9DE1              ;   Clobbers: AF, BC, DE, HL.
 708  9DE1              ;   Algorithm: seed the echoed-count from the current column; read chars one at a time
 709  9DE1              ;              (CON_GETC_OR_RAW, masked to 7 bits) and dispatch the editing controls:
 710  9DE1              ;              CR/LF terminate; BS/DEL delete; Ctrl-E new line; Ctrl-P printer toggle;
 711  9DE1              ;              Ctrl-X erase line; Ctrl-U abandon (#); Ctrl-R retype; other chars are
 712  9DE1              ;              stored (full buffer rings). Terminates by writing the count and CR.
 713  9DE1              ;   [RE] Classic CP/M 2.2 line editor (Read Console Buffer).
 714  9DE1              ; ----------------------------------------------------------------------
 715  9DE1              F_READCONBUF_H:
 716  9DE1                      ; Start echoed-count at the current column
 717  9DE1 3A 0C 9F             LD A,(CON_COL)
 718  9DE4 32 0B 9F             LD (CON_LINE_START_COL),A
 719  9DE7                      ; HL -> caller's input buffer descriptor
 720  9DE7 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
 721  9DEA                      ; C = buffer maximum length
 722  9DEA 4E                   LD C,(HL)
 723  9DEB                      ; Skip to the data area (past max/count bytes)
 724  9DEB 23                   INC HL
 725  9DEC E5                   PUSH HL
 726  9DED                      ; B = current character count (starts 0)
 727  9DED 06 00                LD B,$00
 728  9DEF              ; ----------------------------------------------------------------------
 729  9DEF              ; READBUF_NEXT -- top of the line-editor read loop: save state and fetch a char.
 730  9DEF              ;   In: B = count so far, HL -> buffer position.
 731  9DEF              ;   Out: falls into READBUF_GETC with BC/HL preserved on the stack.
 732  9DEF              ;   Clobbers: stack.
 733  9DEF              ;   [RE] Per-keystroke loop head of F_READCONBUF_H.
 734  9DEF              ; ----------------------------------------------------------------------
 735  9DEF              READBUF_NEXT:
 736  9DEF C5                   PUSH BC
 737  9DF0 E5                   PUSH HL
 738  9DF1              ; ----------------------------------------------------------------------
 739  9DF1              ; READBUF_GETC -- read and classify the next edit character.
 740  9DF1              ;   In: stacked BC/HL = saved count and buffer pointer.
 741  9DF1              ;   Out: A = 7-bit char; control codes dispatched to the appropriate editor handler.
 742  9DF1              ;   Clobbers: AF, BC, HL.
 743  9DF1              ;   Algorithm: CON_GETC_OR_RAW, mask to 7 bits, restore BC/HL, then chain CP/JP tests:
 744  9DF1              ;              CR/LF -> finish; BS -> delete; the remaining tests fall through to the
 745  9DF1              ;              DEL / control-key handlers.
 746  9DF1              ;   [RE] Keystroke dispatcher inside F_READCONBUF_H.
 747  9DF1              ; ----------------------------------------------------------------------
 748  9DF1              READBUF_GETC:
 749  9DF1                      ; Read next raw/type-ahead char
 750  9DF1 CD FB 9C             CALL CON_GETC_OR_RAW
 751  9DF4                      ; Strip the high bit (7-bit ASCII)
 752  9DF4 E6 7F                AND $7F
 753  9DF6 E1                   POP HL
 754  9DF7 C1                   POP BC
 755  9DF8                      ; CR -> end of line
 756  9DF8 FE 0D                CP $0D
 757  9DFA CA C1 9E             JP Z,READBUF_DONE
 758  9DFD                      ; LF -> end of line
 759  9DFD FE 0A                CP $0A
 760  9DFF CA C1 9E             JP Z,READBUF_DONE
 761  9E02                      ; Backspace -> delete char
 762  9E02 FE 08                CP $08
 763  9E04 C2 16 9E             JP NZ,READBUF_DEL
 764  9E07 78                   LD A,B
 765  9E08 B7                   OR A
 766  9E09                      ; Buffer empty: nothing to delete, re-loop
 767  9E09 CA EF 9D             JP Z,READBUF_NEXT
 768  9E0C 05                   DEC B
 769  9E0D 3A 0C 9F             LD A,(CON_COL)
 770  9E10 32 0A 9F             LD (CON_SAVED_COL),A
 771  9E13 C3 70 9E             JP READBUF_REDISPLAY
 772  9E16              ; ----------------------------------------------------------------------
 773  9E16              ; READBUF_DEL -- handle DEL (7F) as a destructive rubout of the previous char.
 774  9E16              ;   In: A = char (7F), B = count, HL -> buffer position.
 775  9E16              ;   Out: if buffer nonempty, last char fetched for re-echo handling and pointer/count
 776  9E16              ;        backed up; empty buffer just re-loops.
 777  9E16              ;   Clobbers: AF, B, HL.
 778  9E16              ;   [RE] DELETE key path of the line editor.
 779  9E16              ; ----------------------------------------------------------------------
 780  9E16              READBUF_DEL:
 781  9E16                      ; DELETE key?
 782  9E16 FE 7F                CP $7F
 783  9E18                      ; No -> try the next control
 784  9E18 C2 26 9E             JP NZ,READBUF_CTRL_E
 785  9E1B 78                   LD A,B
 786  9E1C B7                   OR A
 787  9E1D                      ; Empty buffer: ignore, re-loop
 788  9E1D CA EF 9D             JP Z,READBUF_NEXT
 789  9E20 7E                   LD A,(HL)
 790  9E21 05                   DEC B
 791  9E22                      ; Back up the buffer pointer
 792  9E22 2B                   DEC HL
 793  9E23 C3 A9 9E             JP READBUF_STORE_ECHO
 794  9E26              ; ----------------------------------------------------------------------
 795  9E26              ; READBUF_CTRL_E -- handle Ctrl-E (05): physical CR/LF without ending the line.
 796  9E26              ;   In: A = char, BC/HL = editor state.
 797  9E26              ;   Out: cursor moved to a new line, echoed-count reset; editing continues.
 798  9E26              ;   Clobbers: AF.
 799  9E26              ;   Algorithm: on Ctrl-E print CR/LF (CON_CRLF), zero the echoed-count CON_LINE_START_COL, and
 800  9E26              ;              resume reading; otherwise fall through to the next control test.
 801  9E26              ; ----------------------------------------------------------------------
 802  9E26              READBUF_CTRL_E:
 803  9E26                      ; Ctrl-E -> physical new line
 804  9E26 FE 05                CP $05
 805  9E28                      ; No -> try Ctrl-P
 806  9E28 C2 37 9E             JP NZ,READBUF_CTRL_P
 807  9E2B C5                   PUSH BC
 808  9E2C E5                   PUSH HL
 809  9E2D                      ; Emit CR/LF
 810  9E2D CD C9 9D             CALL CON_CRLF
 811  9E30 AF                   XOR A
 812  9E31                      ; Reset the echoed-count to 0
 813  9E31 32 0B 9F             LD (CON_LINE_START_COL),A
 814  9E34 C3 F1 9D             JP READBUF_GETC
 815  9E37              ; ----------------------------------------------------------------------
 816  9E37              ; READBUF_CTRL_P -- handle Ctrl-P (10): toggle the printer (list-device) echo flag.
 817  9E37              ;   In: A = char.
 818  9E37              ;   Out: CON_LIST_ECHO flipped between 0 and 1; editing continues.
 819  9E37              ;   Clobbers: AF, HL.
 820  9E37              ;   Algorithm: on Ctrl-P compute 1 - CON_LIST_ECHO to toggle the printer-echo flag, then loop;
 821  9E37              ;              otherwise fall through to the Ctrl-X test.
 822  9E37              ; ----------------------------------------------------------------------
 823  9E37              READBUF_CTRL_P:
 824  9E37                      ; Ctrl-P -> toggle printer echo
 825  9E37 FE 10                CP $10
 826  9E39                      ; No -> try Ctrl-X
 827  9E39 C2 48 9E             JP NZ,READBUF_CTRL_X
 828  9E3C E5                   PUSH HL
 829  9E3D                      ; HL -> printer-echo flag
 830  9E3D 21 0D 9F             LD HL,CON_LIST_ECHO
 831  9E40 3E 01                LD A,$01
 832  9E42                      ; 1 - flag => toggle 0<->1
 833  9E42 96                   SUB (HL)
 834  9E43 77                   LD (HL),A
 835  9E44 E1                   POP HL
 836  9E45 C3 EF 9D             JP READBUF_NEXT
 837  9E48              ; ----------------------------------------------------------------------
 838  9E48              ; READBUF_CTRL_X -- handle Ctrl-X (18): erase the whole input line.
 839  9E48              ;   In: A = char; CON_COL = column; CON_LINE_START_COL = start column.
 840  9E48              ;   Out: all echoed chars backspaced away and the buffer emptied; editing restarts.
 841  9E48              ;   Clobbers: AF, HL.
 842  9E48              ;   Algorithm: on Ctrl-X loop CON_BACKSPACE while the column exceeds the line-start,
 843  9E48              ;              then restart the read with an empty buffer; else fall to the Ctrl-U test.
 844  9E48              ; ----------------------------------------------------------------------
 845  9E48              READBUF_CTRL_X:
 846  9E48                      ; Ctrl-X -> erase entire line
 847  9E48 FE 18                CP $18
 848  9E4A                      ; No -> try Ctrl-U
 849  9E4A C2 5F 9E             JP NZ,READBUF_CTRL_U
 850  9E4D E1                   POP HL
 851  9E4E              ; ----------------------------------------------------------------------
 852  9E4E              ; READBUF_ERASE_LOOP -- backspace-erase characters back to the line start.
 853  9E4E              ;   In: CON_LINE_START_COL = start column, CON_COL = current column.
 854  9E4E              ;   Out: console column reduced to the start; chars visually erased.
 855  9E4E              ;   Clobbers: AF, HL.
 856  9E4E              ;   Algorithm: while current column > start column, decrement it and CON_BACKSPACE.
 857  9E4E              ;   [RE] Erase loop shared by Ctrl-X.
 858  9E4E              ; ----------------------------------------------------------------------
 859  9E4E              READBUF_ERASE_LOOP:
 860  9E4E                      ; Line-start column
 861  9E4E 3A 0B 9F             LD A,(CON_LINE_START_COL)
 862  9E51 21 0C 9F             LD HL,CON_COL
 863  9E54                      ; Reached the start?
 864  9E54 BE                   CP (HL)
 865  9E55                      ; Yes -> restart with an empty buffer
 866  9E55 D2 E1 9D             JP NC,F_READCONBUF_H
 867  9E58 35                   DEC (HL)
 868  9E59                      ; Backspace-erase one cell
 869  9E59 CD A4 9D             CALL CON_BACKSPACE
 870  9E5C C3 4E 9E             JP READBUF_ERASE_LOOP
 871  9E5F              ; ----------------------------------------------------------------------
 872  9E5F              ; READBUF_CTRL_U -- handle Ctrl-U (15): abandon the line, show '#', restart.
 873  9E5F              ;   In: A = char.
 874  9E5F              ;   Out: '#' printed, fresh line started, buffer reset.
 875  9E5F              ;   Clobbers: AF, HL.
 876  9E5F              ;   Algorithm: on Ctrl-U mark the abandoned line (CON_RETYPE_LINE prints '#'+CRLF) and
 877  9E5F              ;              restart the read; otherwise fall to the Ctrl-R test.
 878  9E5F              ; ----------------------------------------------------------------------
 879  9E5F              READBUF_CTRL_U:
 880  9E5F                      ; Ctrl-U -> abandon line (#)
 881  9E5F FE 15                CP $15
 882  9E61                      ; No -> try Ctrl-R
 883  9E61 C2 6B 9E             JP NZ,READBUF_CTRL_R
 884  9E64                      ; Mark '#' and CR/LF
 885  9E64 CD B1 9D             CALL CON_RETYPE_LINE
 886  9E67 E1                   POP HL
 887  9E68                      ; Restart input with an empty buffer
 888  9E68 C3 E1 9D             JP F_READCONBUF_H
 889  9E6B              ; ----------------------------------------------------------------------
 890  9E6B              ; READBUF_CTRL_R -- handle Ctrl-R (12): retype the current line, else store the char.
 891  9E6B              ;   In: A = char, B = count, HL -> buffer.
 892  9E6B              ;   Out: Ctrl-R reprints the buffer; any other char falls into the store path.
 893  9E6B              ;   Clobbers: AF.
 894  9E6B              ;   Algorithm: if char != Ctrl-R, jump to the FCB/store path (the dispatcher's default);
 895  9E6B              ;              on Ctrl-R fall into the retype-and-redisplay sequence.
 896  9E6B              ; ----------------------------------------------------------------------
 897  9E6B              READBUF_CTRL_R:
 898  9E6B                      ; Ctrl-R -> retype line
 899  9E6B FE 12                CP $12
 900  9E6D                      ; Other char -> store it in the buffer
 901  9E6D C2 A6 9E             JP NZ,READBUF_STORE
 902  9E70              ; ----------------------------------------------------------------------
 903  9E70              ; READBUF_REDISPLAY -- reprint the buffered line after a retype/delete.
 904  9E70              ;   In: B = char count; buffer on stack (HL).
 905  9E70              ;   Out: '#'/CRLF emitted then each buffered char re-echoed via CON_PUT_VISIBLE.
 906  9E70              ;   Clobbers: AF, BC, HL.
 907  9E70              ;   Algorithm: CON_RETYPE_LINE for the marker, then walk the buffer re-echoing each
 908  9E70              ;              stored char with CON_PUT_VISIBLE (so controls show as '^X').
 909  9E70              ;   [RE] Buffer redisplay used by Ctrl-R and after a backspace.
 910  9E70              ; ----------------------------------------------------------------------
 911  9E70              READBUF_REDISPLAY:
 912  9E70 C5                   PUSH BC
 913  9E71                      ; Print '#' + CR/LF before redisplay
 914  9E71 CD B1 9D             CALL CON_RETYPE_LINE
 915  9E74 C1                   POP BC
 916  9E75 E1                   POP HL
 917  9E76 E5                   PUSH HL
 918  9E77 C5                   PUSH BC
 919  9E78              ; ----------------------------------------------------------------------
 920  9E78              ; READBUF_REDISPLAY_LOOP -- re-echo each buffered character.
 921  9E78              ;   In: B = remaining count, HL -> buffer position.
 922  9E78              ;   Out: every buffered char emitted via CON_PUT_VISIBLE.
 923  9E78              ;   Clobbers: AF, BC, C, HL.
 924  9E78              ;   Algorithm: while B != 0, advance HL, load the char, CON_PUT_VISIBLE it, decrement B;
 925  9E78              ;              on exhaustion fall into the post-redisplay column fixup (READBUF_REPOS).
 926  9E78              ;   [RE] Redisplay loop of READBUF_REDISPLAY.
 927  9E78              ; ----------------------------------------------------------------------
 928  9E78              READBUF_REDISPLAY_LOOP:
 929  9E78 78                   LD A,B
 930  9E79 B7                   OR A
 931  9E7A                      ; All re-echoed -> fix up column
 932  9E7A CA 8A 9E             JP Z,READBUF_REPOS
 933  9E7D 23                   INC HL
 934  9E7E 4E                   LD C,(HL)
 935  9E7F 05                   DEC B
 936  9E80 C5                   PUSH BC
 937  9E81 E5                   PUSH HL
 938  9E82                      ; Re-echo char (controls as ^X)
 939  9E82 CD 7F 9D             CALL CON_PUT_VISIBLE
 940  9E85 E1                   POP HL
 941  9E86 C1                   POP BC
 942  9E87 C3 78 9E             JP READBUF_REDISPLAY_LOOP
 943  9E8A              ; ----------------------------------------------------------------------
 944  9E8A              ; READBUF_REPOS -- after redisplay, backspace the cursor to the edit position.
 945  9E8A              ;   In: CON_SAVED_COL = saved column to restore to, CON_COL = current column.
 946  9E8A              ;   Out: cursor moved back so further typing continues at the right spot.
 947  9E8A              ;   Clobbers: AF, HL.
 948  9E8A              ;   Algorithm: if no saved position (CON_SAVED_COL==0) resume reading; else compute how far past
 949  9E8A              ;              the target the cursor is (CON_SAVED_COL := saved - column) and fall into the
 950  9E8A              ;              backspace loop READBUF_REPOS_LOOP.
 951  9E8A              ;   [RE] Cursor-reposition step after a Ctrl-R / delete redisplay.
 952  9E8A              ;   [?] Auto-name 'READBUF_REPOS' was a stale/mislabel from the skewed source -- this is
 953  9E8A              ;       console line-editor code, NOT directory traversal.
 954  9E8A              ; ----------------------------------------------------------------------
 955  9E8A              READBUF_REPOS:
 956  9E8A E5                   PUSH HL
 957  9E8B                      ; Saved cursor column (0 = none)
 958  9E8B 3A 0A 9F             LD A,(CON_SAVED_COL)
 959  9E8E B7                   OR A
 960  9E8F                      ; Nothing to restore -> read next char
 961  9E8F CA F1 9D             JP Z,READBUF_GETC
 962  9E92 21 0C 9F             LD HL,CON_COL
 963  9E95                      ; saved - current column = cells to back up
 964  9E95 96                   SUB (HL)
 965  9E96 32 0A 9F             LD (CON_SAVED_COL),A
 966  9E99              ; ----------------------------------------------------------------------
 967  9E99              ; READBUF_REPOS_LOOP -- backspace the cursor by the computed cell count.
 968  9E99              ;   In: CON_SAVED_COL = number of cells to back up.
 969  9E99              ;   Out: cursor repositioned; loop ends and the editor reads the next char.
 970  9E99              ;   Clobbers: AF, HL.
 971  9E99              ;   Algorithm: CON_BACKSPACE, decrement CON_SAVED_COL, repeat until zero, then resume input.
 972  9E99              ;   [RE] Reposition loop of READBUF_REPOS.
 973  9E99              ; ----------------------------------------------------------------------
 974  9E99              READBUF_REPOS_LOOP:
 975  9E99                      ; Backspace one cell
 976  9E99 CD A4 9D             CALL CON_BACKSPACE
 977  9E9C 21 0A 9F             LD HL,CON_SAVED_COL
 978  9E9F 35                   DEC (HL)
 979  9EA0                      ; More cells to back up
 980  9EA0 C2 99 9E             JP NZ,READBUF_REPOS_LOOP
 981  9EA3                      ; Done -> read next char
 982  9EA3 C3 F1 9D             JP READBUF_GETC
 983  9EA6              ; ----------------------------------------------------------------------
 984  9EA6              ; READBUF_STORE -- store an ordinary character into the input buffer.
 985  9EA6              ;   In: A = char to store, B = count, HL -> next buffer slot.
 986  9EA6              ;   Out: char written, count incremented; falls into the echo/limit check.
 987  9EA6              ;   Clobbers: AF, B, HL.
 988  9EA6              ;   Algorithm: write the char at ++HL, bump B, then fall into READBUF_STORE_ECHO which
 989  9EA6              ;              echoes it and checks the buffer-full limit.
 990  9EA6              ;   [?] Auto-name 'READBUF_STORE' is a stale skew mislabel -- this is the line
 991  9EA6              ;       editor's character-store path, NOT an FCB/directory compare.
 992  9EA6              ; ----------------------------------------------------------------------
 993  9EA6              READBUF_STORE:
 994  9EA6 23                   INC HL
 995  9EA7                      ; Store the typed char in the buffer
 996  9EA7 77                   LD (HL),A
 997  9EA8                      ; Bump the character count
 998  9EA8 04                   INC B
 999  9EA9              ; ----------------------------------------------------------------------
1000  9EA9              ; READBUF_STORE_ECHO -- echo the stored char and enforce the buffer length limit.
1001  9EA9              ;   In: A = char, B = count, C = buffer max length.
1002  9EA9              ;   Out: char echoed; if count reached the max (or hit a hard limit) the line is
1003  9EA9              ;        terminated, otherwise reading continues.
1004  9EA9              ;   Clobbers: AF, BC, HL.
1005  9EA9              ;   Algorithm: echo via CON_PUT_VISIBLE; reload the buffer max; if the max byte is 1
1006  9EA9              ;              (degenerate) terminate immediately; if count == max terminate, else loop.
1007  9EA9              ;   [RE] Store-and-limit tail of the line editor.
1008  9EA9              ;   [?] The CP $03 then CP $01 sequence tests the buffer-descriptor max byte; exact
1009  9EA9              ;       degenerate-case semantics beyond 'terminate when full' are UNKNOWN.
1010  9EA9              ; ----------------------------------------------------------------------
1011  9EA9              READBUF_STORE_ECHO:
1012  9EA9 C5                   PUSH BC
1013  9EAA E5                   PUSH HL
1014  9EAB 4F                   LD C,A
1015  9EAC                      ; Echo the just-stored char
1016  9EAC CD 7F 9D             CALL CON_PUT_VISIBLE
1017  9EAF E1                   POP HL
1018  9EB0 C1                   POP BC
1019  9EB1 7E                   LD A,(HL)
1020  9EB2                      ; Inspect the buffer-max byte
1021  9EB2 FE 03                CP $03
1022  9EB4 78                   LD A,B
1023  9EB5 C2 BD 9E             JP NZ,READBUF_LIMIT
1024  9EB8                      ; Degenerate max of 1 -> terminate
1025  9EB8 FE 01                CP $01
1026  9EBA                      ; Terminate (warm-boot guard path)
1027  9EBA CA 00 00             JP Z,$0000
1028  9EBD              ; ----------------------------------------------------------------------
1029  9EBD              ; READBUF_LIMIT -- compare the count to the buffer max and continue or finish.
1030  9EBD              ;   In: A = count (B), C = buffer maximum length.
1031  9EBD              ;   Out: if count < max keep reading, else fall into the line-terminate path.
1032  9EBD              ;   Clobbers: AF.
1033  9EBD              ;   Algorithm: CP C; if count < max (carry) loop back to READBUF_NEXT, else finish.
1034  9EBD              ;   [RE] Buffer-full check of the line editor.
1035  9EBD              ; ----------------------------------------------------------------------
1036  9EBD              READBUF_LIMIT:
1037  9EBD                      ; count vs buffer max
1038  9EBD B9                   CP C
1039  9EBE                      ; Room left -> read another char
1040  9EBE DA EF 9D             JP C,READBUF_NEXT
1041  9EC1              ; ----------------------------------------------------------------------
1042  9EC1              ; READBUF_DONE -- finish the input line: store the count and emit a CR.
1043  9EC1              ;   In: stacked HL -> buffer count byte; B = final character count.
1044  9EC1              ;   Out: count written into the buffer; CR echoed; returns to the BDOS caller.
1045  9EC1              ;   Clobbers: AF, C, HL.
1046  9EC1              ;   Algorithm: pop the buffer pointer, store B as the returned char count, then output
1047  9EC1              ;              CR via CON_PUT_COL (tail call) to close the input line.
1048  9EC1              ;   [RE] Line-editor termination, reached on CR/LF/buffer-full.
1049  9EC1              ; ----------------------------------------------------------------------
1050  9EC1              READBUF_DONE:
1051  9EC1 E1                   POP HL
1052  9EC2                      ; Write the final character count into the buffer
1053  9EC2 70                   LD (HL),B
1054  9EC3                      ; Carriage return to close the line
1055  9EC3 0E 0D                LD C,$0D
1056  9EC5                      ; Emit CR and return to caller
1057  9EC5 C3 48 9D             JP CON_PUT_COL
1058  9EC8              ; ----------------------------------------------------------------------
1059  9EC8              ; F_CONIN_H -- BDOS function 1 handler: console input with echo, returned in A.
1060  9EC8              ;   In: none.
1061  9EC8              ;   Out: BDOS result (BDOS_RETVAL) = char read.
1062  9EC8              ;   Clobbers: AF, BC, HL.
1063  9EC8              ;   Algorithm: read+echo via F_CONIN_RAW, then store the char as the BDOS return value.
1064  9EC8              ;   [RE] Dispatch-table entry for function 1.
1065  9EC8              ; ----------------------------------------------------------------------
1066  9EC8              F_CONIN_H:
1067  9EC8                      ; Read one char (with echo)
1068  9EC8 CD 06 9D             CALL F_CONIN_RAW
1069  9ECB                      ; Store as the BDOS return value
1070  9ECB C3 01 9F             JP BDOS_RET_RESULT
1071  9ECE              ; ----------------------------------------------------------------------
1072  9ECE              ; F_READERIN_H -- BDOS function 3 handler: read from the reader (AUX/RDR) device.
1073  9ECE              ;   In: none.
1074  9ECE              ;   Out: BDOS result (BDOS_RETVAL) = byte from the BIOS reader vector.
1075  9ECE              ;   Clobbers: AF.
1076  9ECE              ;   Algorithm: call the BIOS reader-input vector ($AA15), store the byte as the result.
1077  9ECE              ;   [RE] Dispatch entry for function 3 (Reader Input).
1078  9ECE              ; ----------------------------------------------------------------------
1079  9ECE              F_READERIN_H:
1080  9ECE                      ; BIOS reader-input vector
1081  9ECE CD 15 AA             CALL $AA15
1082  9ED1                      ; Store as the BDOS return value
1083  9ED1 C3 01 9F             JP BDOS_RET_RESULT
1084  9ED4              ; ----------------------------------------------------------------------
1085  9ED4              ; F_DIRECTIO_H -- BDOS function 6 handler: direct console I/O.
1086  9ED4              ;   In: C = subfunction (FF = input/status, FE = status only, else = output char).
1087  9ED4              ;   Out: input/status results returned via BDOS_RET_RESULT; output sent to console.
1088  9ED4              ;   Clobbers: AF.
1089  9ED4              ;   Algorithm: C==FF -> direct input branch; C==FE -> raw BIOS console-status ($AA06);
1090  9ED4              ;              otherwise treat C as a character and send it to the BIOS conout ($AA0C),
1091  9ED4              ;              bypassing the editor and flow control.
1092  9ED4              ;   [RE] Dispatch entry for function 6 (Direct Console I/O).
1093  9ED4              ; ----------------------------------------------------------------------
1094  9ED4              F_DIRECTIO_H:
1095  9ED4 79                   LD A,C
1096  9ED5                      ; C==FE? (status-only subfunction)
1097  9ED5                      ; C==FF? (test for direct-input subfunction)
1098  9ED5 3C                   INC A
1099  9ED6                      ; FF -> direct console input
1100  9ED6 CA E0 9E             JP Z,DIRECTIO_INPUT
1101  9ED9 3C                   INC A
1102  9EDA                      ; FE -> raw BIOS console status
1103  9EDA CA 06 AA             JP Z,$AA06
1104  9EDD                      ; Else output C directly via BIOS conout
1105  9EDD C3 0C AA             JP $AA0C
1106  9EE0              ; ----------------------------------------------------------------------
1107  9EE0              ; DIRECTIO_INPUT -- direct console input subfunction of function 6.
1108  9EE0              ;   In: none.
1109  9EE0              ;   Out: BDOS result = char if one is ready, else 0; no echo, no flow control.
1110  9EE0              ;   Clobbers: AF.
1111  9EE0              ;   Algorithm: poll raw BIOS console status ($AA06); if no key, return 0 (A=0 result);
1112  9EE0              ;              if a key is ready, read it raw ($AA09) and store as the result.
1113  9EE0              ;   [?] Auto-name carries a stale 'READBUF_STORE' skew prefix -- this is direct
1114  9EE0              ;       console input, NOT an FCB/directory routine.
1115  9EE0              ; ----------------------------------------------------------------------
1116  9EE0              DIRECTIO_INPUT:
1117  9EE0                      ; Raw BIOS console status
1118  9EE0 CD 06 AA             CALL $AA06
1119  9EE3 B7                   OR A
1120  9EE4                      ; No key -> return 0 result
1121  9EE4 CA 91 A9             JP Z,BDOS_RETURN_RESULT
1122  9EE7                      ; Read the key raw (no echo)
1123  9EE7 CD 09 AA             CALL $AA09
1124  9EEA                      ; Store as the BDOS return value
1125  9EEA C3 01 9F             JP BDOS_RET_RESULT
1126  9EED              ; ----------------------------------------------------------------------
1127  9EED              ; F_GETIOB_H -- BDOS function 7 handler: get the I/O byte (IOBYTE).
1128  9EED              ;   In: none.
1129  9EED              ;   Out: BDOS result = the IOBYTE at fixed address 0003.
1130  9EED              ;   Clobbers: AF.
1131  9EED              ;   Algorithm: load (0003) and return it as the result.
1132  9EED              ;   [RE] Dispatch entry for function 7 (Get IOBYTE).
1133  9EED              ; ----------------------------------------------------------------------
1134  9EED              F_GETIOB_H:
1135  9EED                      ; IOBYTE lives at page-zero 0003
1136  9EED 3A 03 00             LD A,($0003)
1137  9EF0                      ; Return it as the BDOS result
1138  9EF0 C3 01 9F             JP BDOS_RET_RESULT
1139  9EF3              ; ----------------------------------------------------------------------
1140  9EF3              ; F_SETIOB_H -- BDOS function 8 handler: set the I/O byte (IOBYTE).
1141  9EF3              ;   In: C = new IOBYTE value.
1142  9EF3              ;   Out: (0003) = C.
1143  9EF3              ;   Clobbers: HL.
1144  9EF3              ;   Algorithm: store C into the fixed IOBYTE cell at 0003 and return.
1145  9EF3              ;   [RE] Dispatch entry for function 8 (Set IOBYTE).
1146  9EF3              ; ----------------------------------------------------------------------
1147  9EF3              F_SETIOB_H:
1148  9EF3                      ; Page-zero IOBYTE address
1149  9EF3 21 03 00             LD HL,$0003
1150  9EF6                      ; Write the new IOBYTE
1151  9EF6 71                   LD (HL),C
1152  9EF7 C9                   RET
1153  9EF8              ; ----------------------------------------------------------------------
1154  9EF8              ; F_PRINTSTR_H -- BDOS function 9 handler: print a '$'-terminated string.
1155  9EF8              ;   In: DE = pointer to the string.
1156  9EF8              ;   Out: string echoed to the console up to the '$'.
1157  9EF8              ;   Clobbers: AF, BC.
1158  9EF8              ;   Algorithm: move DE into BC and tail-call CON_PRINT_STR.
1159  9EF8              ;   [RE] Dispatch entry for function 9 (Print String).
1160  9EF8              ; ----------------------------------------------------------------------
1161  9EF8              F_PRINTSTR_H:
1162  9EF8 EB                   EX DE,HL
1163  9EF9                      ; BC := string pointer (from DE via EX)
1164  9EF9 4D                   LD C,L
1165  9EFA 44                   LD B,H
1166  9EFB                      ; Print '$'-terminated string
1167  9EFB C3 D3 9D             JP CON_PRINT_STR
1168  9EFE              ; ----------------------------------------------------------------------
1169  9EFE              ; F_CONSTAT_H -- BDOS function 11 handler: get console status.
1170  9EFE              ;   In: none.
1171  9EFE              ;   Out: BDOS result = 1 if a console char is ready, else 0.
1172  9EFE              ;   Clobbers: AF.
1173  9EFE              ;   Algorithm: CON_POLL_STATUS to test readiness (handling Ctrl-S/Ctrl-C), then fall
1174  9EFE              ;              into BDOS_RET_RESULT to store the 0/1 status.
1175  9EFE              ;   [RE] Dispatch entry for function 11 (Get Console Status).
1176  9EFE              ; ----------------------------------------------------------------------
1177  9EFE              F_CONSTAT_H:
1178  9EFE                      ; Poll console readiness (0/1)
1179  9EFE CD 23 9D             CALL CON_POLL_STATUS
1180  9F01              ; ----------------------------------------------------------------------
1181  9F01              ; BDOS_RET_RESULT -- store A as the BDOS function return value and return.
1182  9F01              ;   In: A = result byte.
1183  9F01              ;   Out: BDOS_RETVAL (BDOS return cell) = A.
1184  9F01              ;   Clobbers: none beyond the result cell.
1185  9F01              ;   Algorithm: write A to the return-value cell; common tail of many handlers.
1186  9F01              ;   [RE] The BDOS result sink read back by BDOS_DISPATCH on exit.
1187  9F01              ; ----------------------------------------------------------------------
1188  9F01              BDOS_RET_RESULT:
1189  9F01                      ; Save A as the BDOS return value
1190  9F01 32 45 9F             LD (BDOS_RETVAL),A
1191  9F04              ; ----------------------------------------------------------------------
1192  9F04              ; BDOS_RET_NOP -- bare RET; the no-op result tail shared by status handlers.
1193  9F04              ;   In: none. Out: none. Clobbers: none.
1194  9F04              ;   [RE] Fall-through return after BDOS_RET_RESULT; also a dispatch-table target for
1195  9F04              ;        functions that simply return.
1196  9F04              ; ----------------------------------------------------------------------
1197  9F04              BDOS_RET_NOP:
1198  9F04 C9                   RET
1199  9F05              ; ----------------------------------------------------------------------
1200  9F05              ; BDOS_RET_ONE -- set the BDOS return value to 1 and exit.
1201  9F05              ;   In: none.
1202  9F05              ;   Out: BDOS result (BDOS_RETVAL) = 1.
1203  9F05              ;   Clobbers: AF.
1204  9F05              ;   Algorithm: load A=1 and join BDOS_RET_RESULT.
1205  9F05              ;   [RE] Used by handlers that report a fixed 'true'/error-code-1 result.
1206  9F05              ; ----------------------------------------------------------------------
1207  9F05              BDOS_RET_ONE:
1208  9F05                      ; Result code 1
1209  9F05 3E 01                LD A,$01
1210  9F07                      ; Store and return
1211  9F07 C3 01 9F             JP BDOS_RET_RESULT
1212  9F0A              ; ----------------------------------------------------------------------
1213  9F0A              ; CON_SAVED_COL -- saved cursor column for line-editor redisplay/reposition.
1214  9F0A              ;   Also doubles as a 'suppress status-poll/echo' flag inside CON_PUT_COL.
1215  9F0A              ;   [RE] BDOS console state byte; zero when not repositioning.
1216  9F0A              ; ----------------------------------------------------------------------
1217  9F0A              CON_SAVED_COL:
1218  9F0A 00                   DEFB    "\0"
1219  9F0B              ; ----------------------------------------------------------------------
1220  9F0B              ; CON_LINE_START_COL -- column at the start of the current input line (echoed-count base).
1221  9F0B              ;   [RE] Used by the line editor to know how far back Ctrl-X / DEL may erase.
1222  9F0B              ; ----------------------------------------------------------------------
1223  9F0B              CON_LINE_START_COL:
1224  9F0B 00                   DEFB    "\0"
1225  9F0C              ; ----------------------------------------------------------------------
1226  9F0C              ; CON_COL -- current console output column counter.
1227  9F0C              ;   [RE] Incremented per printable char, reset by LF; drives tab expansion and editing.
1228  9F0C              ; ----------------------------------------------------------------------
1229  9F0C              CON_COL:
1230  9F0C 00                   DEFB    "\0"
1231  9F0D              ; ----------------------------------------------------------------------
1232  9F0D              ; CON_LIST_ECHO -- printer (list device) echo flag; nonzero => mirror console output.
1233  9F0D              ;   [RE] Toggled by the line editor's Ctrl-P.
1234  9F0D              ; ----------------------------------------------------------------------
1235  9F0D              CON_LIST_ECHO:
1236  9F0D 00                   DEFB    "\0"
1237  9F0E              ; ----------------------------------------------------------------------
1238  9F0E              ; CON_PENDING_CHAR -- 1-byte console type-ahead / un-get buffer (0 = empty).
1239  9F0E              ;   [RE] Filled by CON_POLL_STATUS, consumed by CON_GETC_OR_RAW.
1240  9F0E              ; ----------------------------------------------------------------------
1241  9F0E              CON_PENDING_CHAR:
1242  9F0E 00                   DEFB    "\0"
1243  9F0F              ; ----------------------------------------------------------------------
1244  9F0F              ; BDOS_SAVED_SP -- caller's stack pointer saved on BDOS entry (51-byte cell + slack).
1245  9F0F              ;   [RE] BDOS_DISPATCH saves SP here and switches to the BDOS-local stack; restored on
1246  9F0F              ;        exit. The trailing DEFS reserves the BDOS local stack space below BDOS_STACK_TOP.
1247  9F0F              ; ----------------------------------------------------------------------
1248  9F0F              BDOS_SAVED_SP:
1249  9F0F 00 00 00...          DEFS    50, $00                  ; fill
1250  9F41              ; ----------------------------------------------------------------------
1251  9F41              ; BDOS_STACK_TOP -- top of the BDOS private stack (SP loaded here on entry).
1252  9F41              ;   [RE] BDOS_DISPATCH does LD SP,BDOS_STACK_TOP before dispatching a function.
1253  9F41              ; ----------------------------------------------------------------------
1254  9F41              BDOS_STACK_TOP:
1255  9F41 00                   DEFB    "\0"
1256  9F42              ; ----------------------------------------------------------------------
1257  9F42              ; BDOS_CUR_DRIVE -- current selected drive index (0=A) for error reporting and disk ops.
1258  9F42              ;   [RE] Used to form the error-banner drive letter and as the drive arg in random-record
1259  9F42              ;        / DPB setup.
1260  9F42              ; ----------------------------------------------------------------------
1261  9F42              BDOS_CUR_DRIVE:
1262  9F42 00                   DEFB    "\0"
1263  9F43              ; ----------------------------------------------------------------------
1264  9F43              ; BDOS_PARAM_PTR -- saved DE parameter pointer from the BDOS call (FCB / DMA / buffer).
1265  9F43              ;   [RE] BDOS_DISPATCH stashes the incoming DE here; consumers (file ops, line input)
1266  9F43              ;        reload it as the operand pointer. 16-bit cell.
1267  9F43              ; ----------------------------------------------------------------------
1268  9F43              BDOS_PARAM_PTR:
1269  9F43 00 00                DEFB    "\0\0"
1270  9F45              ; ----------------------------------------------------------------------
1271  9F45              ; BDOS_RETVAL -- BDOS function return value (16-bit: low byte = A result, high = B).
1272  9F45              ;   [RE] Cleared on entry; written by BDOS_RET_RESULT; read back by the dispatcher's exit.
1273  9F45              ; ----------------------------------------------------------------------
1274  9F45              BDOS_RETVAL:
1275  9F45 00 00                DEFB    "\0\0"
1276  9F47              ; ----------------------------------------------------------------------
1277  9F47              ; BDOS_ERR_SELECT -- enter the BDOS disk-error handler via the error-vector table.
1278  9F47              ;   In: none (uses the fixed error-vector list at BDOS_ERR_VECTORS).
1279  9F47              ;   Out: transfers to the indexed error routine (does not return normally).
1280  9F47              ;   Clobbers: HL, DE.
1281  9F47              ;   Algorithm: point HL at the error-vector table entry (BDOS_ERRVEC_SELECT) and fall into the
1282  9F47              ;              dispatch-by-pointer tail BDOS_VECTOR_JUMP.
1283  9F47              ;   [RE] One of the BDOS_ERR_VECTORS table dispatch entry points.
1284  9F47              ;   [?] Exact reason-code mapping is encoded by which vector slot the caller chose;
1285  9F47              ;       semantics beyond 'jump through the error-vector table' are inferred.
1286  9F47              ; ----------------------------------------------------------------------
1287  9F47              BDOS_ERR_SELECT:
1288  9F47                      ; Point at the error-vector table slot
1289  9F47 21 0B 9C             LD HL,BDOS_ERRVEC_SELECT
1290  9F4A              ; ----------------------------------------------------------------------
1291  9F4A              ; BDOS_VECTOR_JUMP -- jump through a 2-byte pointer pointed to by HL.
1292  9F4A              ;   In: HL -> a little-endian routine pointer.
1293  9F4A              ;   Out: control transferred to (HL); does not return here.
1294  9F4A              ;   Clobbers: DE, HL.
1295  9F4A              ;   Algorithm: load DE from (HL), EX DE,HL, JP (HL) -- an indirect call/jump.
1296  9F4A              ;   [RE] Shared indirect-dispatch tail used by the BDOS error/random-record paths.
1297  9F4A              ; ----------------------------------------------------------------------
1298  9F4A              BDOS_VECTOR_JUMP:
1299  9F4A                      ; Low byte of the target pointer
1300  9F4A 5E                   LD E,(HL)
1301  9F4B 23                   INC HL
1302  9F4C                      ; High byte of the target pointer
1303  9F4C 56                   LD D,(HL)
1304  9F4D EB                   EX DE,HL
1305  9F4E                      ; Jump to the resolved routine
1306  9F4E E9                   JP (HL)
1307  9F4F              ; ----------------------------------------------------------------------
1308  9F4F              ; BLOCK_COPY_INCC -- copy (C+1) bytes from (DE) to (HL); pre-increment entry.
1309  9F4F              ;   In: C = count-1, DE = source, HL = destination.
1310  9F4F              ;   Out: bytes copied; DE/HL advanced past the block.
1311  9F4F              ;   Clobbers: AF, C, DE, HL.
1312  9F4F              ;   Algorithm: INC C so the following DEC-C-test loop runs C+1 times, copying one byte
1313  9F4F              ;              per pass.
1314  9F4F              ;   [RE] Small memory-copy helper used by the BDOS DPB / random-record setup.
1315  9F4F              ; ----------------------------------------------------------------------
1316  9F4F              BLOCK_COPY_INCC:
1317  9F4F                      ; Bump count so the loop runs (C+1) times
1318  9F4F 0C                   INC C
1319  9F50              ; ----------------------------------------------------------------------
1320  9F50              ; BLOCK_COPY_LOOP -- byte-copy loop body for BLOCK_COPY_INCC.
1321  9F50              ;   In: C = remaining count, DE = source, HL = destination.
1322  9F50              ;   Out: copies bytes until C decrements to zero.
1323  9F50              ;   Clobbers: AF, C, DE, HL.
1324  9F50              ;   Algorithm: DEC C; if zero return; copy (DE)->(HL); INC DE; INC HL; loop.
1325  9F50              ;   [RE] Loop of the BDOS block-copy helper.
1326  9F50              ; ----------------------------------------------------------------------
1327  9F50              BLOCK_COPY_LOOP:
1328  9F50                      ; One fewer byte to copy
1329  9F50 0D                   DEC C
1330  9F51                      ; Count exhausted
1331  9F51 C8                   RET Z
1332  9F52                      ; Read source byte
1333  9F52 1A                   LD A,(DE)
1334  9F53                      ; Store to destination
1335  9F53 77                   LD (HL),A
1336  9F54 13                   INC DE
1337  9F55 23                   INC HL
1338  9F56                      ; Next byte
1339  9F56 C3 50 9F             JP BLOCK_COPY_LOOP
1340  9F59              ; ----------------------------------------------------------------------
1341  9F59              ; DRV_SELECT_DPB -- select the current drive and copy its Disk Parameter Block into BDOS work cells.
1342  9F59              ;   In: BDOS_CUR_DRIVE = drive index.
1343  9F59              ;   Out: BDOS DPB/work pointers (DPB_WORK_PTR0, DEBLOCK_HSTREC_PTR0/B7, DPB_XLT_PTR, dir/alloc fields,
1344  9F59              ;        MAX_BLOCK_DSM, BLOCK_WIDTH_FLAG) populated for the selected drive; A=FF success.
1345  9F59              ;   Clobbers: AF, BC, DE, HL.
1346  9F59              ;   Algorithm: ask the BIOS SELDSK vector ($AA1B) for the selected drive's DPH; if null
1347  9F59              ;              return; chase the DPH to the DPB, copy the translation/allocation pointers
1348  9F59              ;              and the parameter block into the BDOS working cells (via BLOCK_COPY_INCC),
1349  9F59              ;              then set BLOCK_WIDTH_FLAG from the max-block-number high byte (single- vs
1350  9F59              ;              multi-byte block addressing).
1351  9F59              ;   [RE] Standard CP/M 2.2 drive-select / DPB extraction sequence.
1352  9F59              ;   [?] Individual A9xx work-cell roles are inferred from the canonical DPB layout.
1353  9F59              ; ----------------------------------------------------------------------
1354  9F59              BDOS_RANDREC_3:
1355  9F59                      ; Current drive index
1356  9F59 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
1357  9F5C 4F                   LD C,A
1358  9F5D                      ; BIOS SELDSK -> DPH pointer in HL
1359  9F5D CD 1B AA             CALL $AA1B
1360  9F60 7C                   LD A,H
1361  9F61                      ; DPH pointer null? (no such drive)
1362  9F61 B5                   OR L
1363  9F62                      ; Null -> bail out
1364  9F62 C8                   RET Z
1365  9F63 5E                   LD E,(HL)
1366  9F64 23                   INC HL
1367  9F65 56                   LD D,(HL)
1368  9F66 23                   INC HL
1369  9F67                      ; Save the DPB-derived work pointer
1370  9F67 22 B3 A9             LD (DPB_WORK_PTR0),HL
1371  9F6A 23                   INC HL
1372  9F6B 23                   INC HL
1373  9F6C 22 B5 A9             LD (DEBLOCK_HSTREC_PTR0),HL
1374  9F6F 23                   INC HL
1375  9F70 23                   INC HL
1376  9F71 22 B7 A9             LD (DEBLOCK_HSTREC_PTR1),HL
1377  9F74 23                   INC HL
1378  9F75 23                   INC HL
1379  9F76 EB                   EX DE,HL
1380  9F77 22 D0 A9             LD (DPB_XLT_PTR),HL
1381  9F7A 21 B9 A9             LD HL,DIRBUF_PTR
1382  9F7D 0E 08                LD C,$08
1383  9F7F CD 4F 9F             CALL BLOCK_COPY_INCC
1384  9F82 2A BB A9             LD HL,(DPB_PTR)
1385  9F85 EB                   EX DE,HL
1386  9F86 21 C1 A9             LD HL,DPB_SPT
1387  9F89 0E 0F                LD C,$0F
1388  9F8B CD 4F 9F             CALL BLOCK_COPY_INCC
1389  9F8E                      ; Max block number (DSM) for this drive
1390  9F8E 2A C6 A9             LD HL,(MAX_BLOCK_DSM)
1391  9F91 7C                   LD A,H
1392  9F92                      ; Flag: 1- vs 2-byte block addressing
1393  9F92 21 DD A9             LD HL,BLOCK_WIDTH_FLAG
1394  9F95 36 FF                LD (HL),$FF
1395  9F97 B7                   OR A
1396  9F98                      ; DSM high byte 0 => single-byte block map
1397  9F98 CA 9D 9F             JP Z,DRV_SELECT_OK
1398  9F9B 36 00                LD (HL),$00
1399  9F9D              ; ----------------------------------------------------------------------
1400  9F9D              ; DRV_SELECT_OK -- success tail of the drive-select / DPB-setup path: pick the allocation-map width,
1401  9F9D              ; then return the 'drive selected' status.
1402  9F9D              ;   In: MAX_BLOCK_DSM (the DPB's DSM = highest block number) already loaded; BLOCK_WIDTH_FLAG cell
1403  9F9D              ;       about to be set.
1404  9F9D              ;   Out: A = $FF with flags NZ (OR A leaves A non-zero) -- the non-NULL 'drive selected' indicator
1405  9F9D              ;        returned to the SELDSK caller. BLOCK_WIDTH_FLAG = $FF if DSM < 256 (1-byte allocation
1406  9F9D              ;        entries) or $00 if DSM >= 256 (2-byte entries).
1407  9F9D              ;   Clobbers: A, F (HL was used by the caller just above to address BLOCK_WIDTH_FLAG).
1408  9F9D              ;   Algorithm: this label is the join of two paths. When DSM's high byte is zero (small disk) the
1409  9F9D              ;              caller's 'JP Z' lands here directly, leaving BLOCK_WIDTH_FLAG at its preset $FF;
1410  9F9D              ;              otherwise the caller falls through after first storing $00 into BLOCK_WIDTH_FLAG.
1411  9F9D              ;              Both paths then load A=$FF and OR A so the routine returns a non-zero 'selected'
1412  9F9D              ;              status.
1413  9F9D              ; [RE] Verified from the byte sequence (3E FF / B7 / C9) and from the preceding test of
1414  9F9D              ; MAX_BLOCK_DSM's high byte that selects BLOCK_WIDTH_FLAG. The $FF return is the SELDSK-path success
1415  9F9D              ; value.
1416  9F9D              ; ----------------------------------------------------------------------
1417  9F9D              DRV_SELECT_OK:
1418  9F9D                      ; A = $FF: non-zero 'drive selected / parameters valid' status.
1419  9F9D 3E FF                LD A,$FF
1420  9F9F                      ; Set flags from A (NZ) so the caller sees a non-zero result.
1421  9F9F B7                   OR A
1422  9FA0 C9                   RET
1423  9FA1              ; ----------------------------------------------------------------------
1424  9FA1              ; DISK_HOME_CLEAR_SCAN -- seek the drive to track 0 and reset the two BDOS record-scan accumulator
1425  9FA1              ; cells.
1426  9FA1              ;   In: DEBLOCK_HSTREC_PTR0 and DEBLOCK_HSTREC_PTR1 each hold the ADDRESS of a 16-bit scratch word (set up by the drive-select
1427  9FA1              ;       path).
1428  9FA1              ;   Out: BIOS HOME has positioned the head at track 0; the 16-bit word pointed to by (DEBLOCK_HSTREC_PTR0) and
1429  9FA1              ;        the 16-bit word pointed to by (DEBLOCK_HSTREC_PTR1) are both zeroed; A = 0.
1430  9FA1              ;   Clobbers: A, HL, F.
1431  9FA1              ;   Algorithm: CALL the BIOS HOME vector ($AA18, jump-table entry 8) to seek to track 0, then store
1432  9FA1              ;              0 into the two bytes of the word at (DEBLOCK_HSTREC_PTR0) and the two bytes of the word at
1433  9FA1              ;              (DEBLOCK_HSTREC_PTR1). This re-bases the record->track/sector walk at the start of the disk for a
1434  9FA1              ;              fresh scan.
1435  9FA1              ; [RE] $AA18 is jump-table entry 8 = HOME (verified against the BIOS jump table at $AA00). A=0 (XOR
1436  9FA1              ; A) is written through the two stored pointers, two bytes each.
1437  9FA1              ; ----------------------------------------------------------------------
1438  9FA1              DISK_HOME_CLEAR_SCAN:
1439  9FA1                      ; BIOS HOME (jump-table entry 8): seek the head to track 0.
1440  9FA1 CD 18 AA             CALL $AA18
1441  9FA4                      ; A = 0, the fill value for the scan-accumulator cells.
1442  9FA4 AF                   XOR A
1443  9FA5                      ; HL = address of the first 16-bit scan accumulator; zero its two bytes.
1444  9FA5 2A B5 A9             LD HL,(DEBLOCK_HSTREC_PTR0)
1445  9FA8 77                   LD (HL),A
1446  9FA9 23                   INC HL
1447  9FAA 77                   LD (HL),A
1448  9FAB                      ; HL = address of the second 16-bit scan accumulator; zero its two bytes.
1449  9FAB 2A B7 A9             LD HL,(DEBLOCK_HSTREC_PTR1)
1450  9FAE 77                   LD (HL),A
1451  9FAF 23                   INC HL
1452  9FB0 77                   LD (HL),A
1453  9FB1 C9                   RET
1454  9FB2              ; ----------------------------------------------------------------------
1455  9FB2              ; DISK_READ_CHECKED -- issue a BIOS sector READ and convert a non-zero BIOS status into a BDOS disk
1456  9FB2              ; error.
1457  9FB2              ;   In: BIOS disk parameters (drive/track/sector/DMA) already set by the caller.
1458  9FB2              ;   Out: returns normally if the read succeeded (BIOS A = 0); otherwise does not return -- transfers
1459  9FB2              ;        into the BDOS disk-error dispatcher.
1460  9FB2              ;   Clobbers: A, F (and whatever the BIOS read consumes).
1461  9FB2              ;   Algorithm: CALL the BIOS READ vector ($AA27, jump-table entry 13), then JP to the shared status
1462  9FB2              ;              check (DISK_STATUS_CHECK), which raises a BDOS disk error when A is non-zero.
1463  9FB2              ; [RE] $AA27 is jump-table entry 13 = READ (verified against the BIOS jump table at $AA00); the
1464  9FB2              ; shared tail tests A and dispatches through BDOS_ERR_VECTORS.
1465  9FB2              ; ----------------------------------------------------------------------
1466  9FB2              DISK_READ_CHECKED:
1467  9FB2                      ; BIOS READ (jump-table entry 13): read the selected sector into the DMA buffer; A=0 on
1468  9FB2                      ; success.
1469  9FB2 CD 27 AA             CALL $AA27
1470  9FB5 C3 BB 9F             JP DISK_STATUS_CHECK
1471  9FB8              ; ----------------------------------------------------------------------
1472  9FB8              ; DISK_WRITE_CHECKED -- issue a BIOS sector WRITE and convert a non-zero BIOS status into a BDOS
1473  9FB8              ; disk error.
1474  9FB8              ;   In: BIOS disk parameters (drive/track/sector/DMA) already set by the caller.
1475  9FB8              ;   Out: returns normally if the write succeeded (BIOS A = 0); otherwise does not return --
1476  9FB8              ;        transfers into the BDOS disk-error dispatcher.
1477  9FB8              ;   Clobbers: A, F (and whatever the BIOS write consumes).
1478  9FB8              ;   Algorithm: CALL the BIOS WRITE vector ($AA2A, jump-table entry 14), then fall through into the
1479  9FB8              ;              shared status check (DISK_STATUS_CHECK), which raises a BDOS disk error when A is
1480  9FB8              ;              non-zero.
1481  9FB8              ; [RE] $AA2A is jump-table entry 14 = WRITE (verified against the BIOS jump table at $AA00); shares
1482  9FB8              ; the error tail with DISK_READ_CHECKED.
1483  9FB8              ; ----------------------------------------------------------------------
1484  9FB8              DISK_WRITE_CHECKED:
1485  9FB8                      ; BIOS WRITE (jump-table entry 14): write the DMA buffer to the selected sector; A=0 on
1486  9FB8                      ; success.
1487  9FB8 CD 2A AA             CALL $AA2A
1488  9FBB              ; ----------------------------------------------------------------------
1489  9FBB              ; DISK_STATUS_CHECK -- shared BIOS-status check used by the READ/WRITE wrappers; raise a BDOS disk
1490  9FBB              ; error on failure.
1491  9FBB              ;   In: A = BIOS read/write status (0 = success, non-zero = hardware/select error).
1492  9FBB              ;   Out: returns to the wrapper's caller if A = 0; otherwise points HL at the BDOS error-vector
1493  9FBB              ;        table and jumps into the indirect error dispatcher (does not return).
1494  9FBB              ;   Clobbers: HL, F (on the error path control transfers away).
1495  9FBB              ;   Algorithm: OR A; RET Z on success. On failure load HL with BDOS_ERR_VECTORS and JP to the
1496  9FBB              ;              indirect dispatcher (BDOS_VECTOR_JUMP), which reads a 16-bit handler address from the
1497  9FBB              ;              table and jumps to it (the first entry = disk-I/O error).
1498  9FBB              ; [RE] HL is set to the BDOS_ERR_VECTORS table (its first entry, the disk-I/O error handler) before
1499  9FBB              ; the indirect dispatch through BDOS_VECTOR_JUMP.
1500  9FBB              ; ----------------------------------------------------------------------
1501  9FBB              DISK_STATUS_CHECK:
1502  9FBB                      ; Test BIOS status: zero = success.
1503  9FBB B7                   OR A
1504  9FBC                      ; Success: return to the READ/WRITE wrapper's caller.
1505  9FBC C8                   RET Z
1506  9FBD                      ; Failure: point at the BDOS disk-error vector table (first entry).
1507  9FBD 21 09 9C             LD HL,BDOS_ERR_VECTORS
1508  9FC0                      ; Dispatch indirectly through the error-vector table (does not return).
1509  9FC0 C3 4A 9F             JP BDOS_VECTOR_JUMP
1510  9FC3              ; ----------------------------------------------------------------------
1511  9FC3              ; REC_DIV4_SETUP -- divide the current record number by 4 and stage it as the target for the
1512  9FC3              ; record->track/sector walk.
1513  9FC3              ;   In: CUR_RECORD holds the current logical record number (read here as a 16-bit value).
1514  9FC3              ;   Out: HL = CUR_RECORD >> 2; that value is stored into both CUR_BLOCK_NUMBER (the walk target) and the start
1515  9FC3              ;        of REC_CACHE.
1516  9FC3              ;   Clobbers: A, C, HL, F.
1517  9FC3              ;   Algorithm: load HL from CUR_RECORD, set C = 2, call the logical-shift-right-by-C helper
1518  9FC3              ;              (DRV_INSTALL_RWTS_10) to compute HL = HL >> 2, then save the result to CUR_BLOCK_NUMBER
1519  9FC3              ;              (consumed by RECORD_TO_TRACK as the search target) and cache it at REC_CACHE.
1520  9FC3              ; [RE] DRV_INSTALL_RWTS_10 verified as a 'shift HL logically right C times' helper (OR A clears
1521  9FC3              ; carry, then RRA on H and L, C iterations); C=2 -> divide by 4. The exact meaning of the /4 is
1522  9FC3              ; UNKNOWN; it is the quantity the subsequent track/sector resolver searches for.
1523  9FC3              ; ----------------------------------------------------------------------
1524  9FC3              REC_DIV4_SETUP:
1525  9FC3                      ; HL = current logical record number (16-bit load).
1526  9FC3 2A EA A9             LD HL,(CUR_RECORD)
1527  9FC6                      ; Shift count = 2 (logical shift right by 2 = divide by 4).
1528  9FC6 0E 02                LD C,$02
1529  9FC8                      ; HL >>= 2 via the shift-right-by-C helper.
1530  9FC8 CD EA A0             CALL DRV_INSTALL_RWTS_10
1531  9FCB                      ; Store as the search target for the record->track/sector walk.
1532  9FCB 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
1533  9FCE                      ; Also cache the value at the start of REC_CACHE.
1534  9FCE 22 EC A9             LD (REC_CACHE),HL
1535  9FD1              ; ----------------------------------------------------------------------
1536  9FD1              ; RECORD_TO_TRACK -- entry of the loop that maps a logical record number to its physical track by
1537  9FD1              ; stepping in sectors-per-track units.
1538  9FD1              ;   In: CUR_BLOCK_NUMBER = 16-bit search target (record/4, set by REC_DIV4_SETUP); (DEBLOCK_HSTREC_PTR1) -> a 16-bit
1539  9FD1              ;       running record-boundary accumulator; (DEBLOCK_HSTREC_PTR0) -> the current track number; DPB_SPT = SPT
1540  9FD1              ;       (sectors per track, low word of the copied DPB).
1541  9FD1              ;   Out: loads BC = target, DE = current boundary accumulator, HL = current track number, then
1542  9FD1              ;        enters the search loop (RECORD_TO_TRACK_BACK). On a match it branches to
1543  9FD1              ;        DISK_STORE_SEC_TRK_1, which sets the BIOS track/sector.
1544  9FD1              ;   Clobbers: A, BC, DE, HL, F.
1545  9FD1              ;   Algorithm: load the target into BC (via CUR_BLOCK_NUMBER), the boundary accumulator into DE (dereferenced
1546  9FD1              ;              through (DEBLOCK_HSTREC_PTR1)), and the current track number into HL (dereferenced through
1547  9FD1              ;              (DEBLOCK_HSTREC_PTR0)), then fall into the back/forward search that walks the accumulator by SPT
1548  9FD1              ;              until the target record falls inside one track.
1549  9FD1              ; [RE] DPB_SPT is the first word of the 15-byte DPB copied at $9F86 = SPT (sectors per track);
1550  9FD1              ; MAX_BLOCK_DSM/$A9C6 is DSM at DPB offset 5, DPB_OFF is OFF at offset 13. The exit
1551  9FD1              ; DISK_STORE_SEC_TRK_1 adds DPB_OFF (OFF) and calls the BIOS SETTRK vector ($AA1E), confirming the
1552  9FD1              ; walked quantity is a track, not an allocation block.
1553  9FD1              ; ----------------------------------------------------------------------
1554  9FD1              RECORD_TO_TRACK:
1555  9FD1                      ; HL -> the 16-bit search-target cell (record/4).
1556  9FD1 21 E5 A9             LD HL,CUR_BLOCK_NUMBER
1557  9FD4                      ; BC = search target (low byte then high).
1558  9FD4 4E                   LD C,(HL)
1559  9FD5 23                   INC HL
1560  9FD6 46                   LD B,(HL)
1561  9FD7                      ; Dereference the boundary-accumulator pointer; load DE = current boundary.
1562  9FD7 2A B7 A9             LD HL,(DEBLOCK_HSTREC_PTR1)
1563  9FDA 5E                   LD E,(HL)
1564  9FDB 23                   INC HL
1565  9FDC 56                   LD D,(HL)
1566  9FDD                      ; Dereference the track-number pointer; load HL = current track number.
1567  9FDD 2A B5 A9             LD HL,(DEBLOCK_HSTREC_PTR0)
1568  9FE0 7E                   LD A,(HL)
1569  9FE1 23                   INC HL
1570  9FE2 66                   LD H,(HL)
1571  9FE3 6F                   LD L,A
1572  9FE4              ; ----------------------------------------------------------------------
1573  9FE4              ; RECORD_TO_TRACK_BACK -- 'overshoot' branch: step the track number back while the boundary
1574  9FE4              ; accumulator exceeds the target.
1575  9FE4              ;   In: BC = target; DE = current boundary accumulator; HL = current track number; DPB_SPT = SPT
1576  9FE4              ;       (sectors per track).
1577  9FE4              ;   Out: loops, or when target >= accumulator falls into RECORD_TO_TRACK_FWD (forward branch).
1578  9FE4              ;   Clobbers: A, DE, HL, F.
1579  9FE4              ;   Algorithm: compute target - accumulator (BC - DE) via SUB E / SBC A,D; if no borrow (target >=
1580  9FE4              ;              accumulator) branch forward to RECORD_TO_TRACK_FWD. Otherwise subtract one track's
1581  9FE4              ;              worth of sectors (SPT in DPB_SPT) from DE and decrement the track number HL, then
1582  9FE4              ;              repeat.
1583  9FE4              ; [RE] The SUB E / SBC A,D pattern is a 16-bit compare of BC against DE through A; the borrow
1584  9FE4              ; (carry-out) selects the direction. The subtraction of DPB_SPT from DE backs the boundary down by
1585  9FE4              ; one track.
1586  9FE4              ; ----------------------------------------------------------------------
1587  9FE4              RECORD_TO_TRACK_BACK:
1588  9FE4 79                   LD A,C
1589  9FE5                      ; 16-bit compare: low byte of (target - accumulator).
1590  9FE5 93                   SUB E
1591  9FE6 78                   LD A,B
1592  9FE7                      ; ...high byte; borrow (carry set) means target < accumulator (overshot).
1593  9FE7 9A                   SBC A,D
1594  9FE8                      ; target >= accumulator: switch to the forward search.
1595  9FE8 D2 FA 9F             JP NC,RECORD_TO_TRACK_FWD
1596  9FEB E5                   PUSH HL
1597  9FEC                      ; HL = SPT (sectors per track); back the boundary accumulator down by one track.
1598  9FEC 2A C1 A9             LD HL,(DPB_SPT)
1599  9FEF 7B                   LD A,E
1600  9FF0 95                   SUB L
1601  9FF1 5F                   LD E,A
1602  9FF2 7A                   LD A,D
1603  9FF3 9C                   SBC A,H
1604  9FF4 57                   LD D,A
1605  9FF5 E1                   POP HL
1606  9FF6                      ; Step the track number down by one.
1607  9FF6 2B                   DEC HL
1608  9FF7                      ; Repeat the overshoot test for the previous track.
1609  9FF7 C3 E4 9F             JP RECORD_TO_TRACK_BACK
1610  9FFA              ; ----------------------------------------------------------------------
1611  9FFA              ; RECORD_TO_TRACK_FWD -- 'forward' branch: step the track number ahead one track until the target
1612  9FFA              ; record falls inside it.
1613  9FFA              ;   In: BC = target; DE = boundary accumulator; HL = current track number; DPB_SPT = SPT (sectors per
1614  9FFA              ;       track).
1615  9FFA              ;   Out: when the target lies within the current track, branches to DISK_STORE_SEC_TRK_1 to set the
1616  9FFA              ;        BIOS track and compute the sector within it; otherwise loops.
1617  9FFA              ;   Clobbers: A, BC, DE, HL, F.
1618  9FFA              ;   Algorithm: add one SPT (DPB_SPT) to the boundary DE; if that addition carries, the target is in
1619  9FFA              ;              this track -> exit. Else compare the target (BC) against the new boundary; if the
1620  9FFA              ;              boundary now exceeds the target, exit; otherwise commit the new boundary into DE,
1621  9FFA              ;              advance the track number HL, and repeat.
1622  9FFA              ; [RE] The two SUB L / SBC A,H comparisons test BC against the advanced boundary in HL; either
1623  9FFA              ; carry-out routes to DISK_STORE_SEC_TRK_1, which sets the BIOS track via SETTRK ($AA1E).
1624  9FFA              ; ----------------------------------------------------------------------
1625  9FFA              RECORD_TO_TRACK_FWD:
1626  9FFA E5                   PUSH HL
1627  9FFB                      ; HL = SPT (sectors per track).
1628  9FFB 2A C1 A9             LD HL,(DPB_SPT)
1629  9FFE                      ; Advance the boundary accumulator by one track's sectors.
1630  9FFE 19                   ADD HL,DE
1631  9FFF                      ; Carry: target is inside this track -> resolve to track/sector.
1632  9FFF DA 0F A0             JP C,DISK_STORE_SEC_TRK_1
1633  A002 79                   LD A,C
1634  A003                      ; Compare target (BC) low byte against the advanced boundary.
1635  A003 95                   SUB L
1636  A004 78                   LD A,B
1637  A005                      ; ...high byte; carry means the boundary now passes the target -> done.
1638  A005 9C                   SBC A,H
1639  A006                      ; Boundary now exceeds target: resolve this track to track/sector.
1640  A006 DA 0F A0             JP C,DISK_STORE_SEC_TRK_1
1641  A009                      ; Commit the advanced boundary into DE.
1642  A009 EB                   EX DE,HL
1643  A00A E1                   POP HL
1644  A00B                      ; Advance the track number forward.
1645  A00B 23                   INC HL
1646  A00C                      ; Repeat the forward search for the next track.
1647  A00C C3 FA 9F             JP RECORD_TO_TRACK_FWD
1648  A00F              ; ----------------------------------------------------------------------
1649  A00F              ; BDOS_DEBLOCK_XFER_LOOP -- transfer a record span through the BIOS-bridge helper, then advance.
1650  A00F              ;   In: BC = record count, DE = record offset within the buffer span, HL on the stack;
1651  A00F              ;       DPB_OFF = a base address/pointer set from the selected-disk header (role UNKNOWN);
1652  A00F              ;       DEBLOCK_HSTREC_PTR0/DEBLOCK_HSTREC_PTR1 = pointer cells (set from the selected-disk header).
1653  A00F              ;   Out: DEBLOCK_HSTREC_PTR0 and DEBLOCK_HSTREC_PTR1 each updated to the value DE returned by the helper; BC = BC - DE.
1654  A00F              ;   Clobbers: A,BC,DE,HL.
1655  A00F              ;   Algorithm: pop the saved pointer, add the DPB_OFF base to DE to form the helper request in BC,
1656  A00F              ;       CALL the BIOS-bridge helper $AA1E; store its returned DE into both [DEBLOCK_HSTREC_PTR0] and [DEBLOCK_HSTREC_PTR1];
1657  A00F              ;       recompute BC = BC - DE; load the advance vector (DPB_XLT_PTR) into DE, CALL the advance helper
1658  A00F              ;       $AA30, then JP back into the bridge at $AA21.
1659  A00F              ;   [RE] part of the BDOS deblocking transfer path; the $AAxx targets are BIOS-bridge helpers above
1660  A00F              ;       this cluster. [?] transfer DIRECTION (read vs write) and the exact buffer/pointer semantics
1661  A00F              ;       UNKNOWN -- not determinable from these bytes alone.
1662  A00F              ; ----------------------------------------------------------------------
1663  A00F              DISK_STORE_SEC_TRK_1:
1664  A00F E1                   POP HL
1665  A010 C5                   PUSH BC
1666  A011 D5                   PUSH DE
1667  A012 E5                   PUSH HL
1668  A013 EB                   EX DE,HL
1669  A014                      ; add the DPB_OFF base (from the selected-disk header) to the record offset
1670  A014 2A CE A9             LD HL,(DPB_OFF)
1671  A017 19                   ADD HL,DE
1672  A018 44                   LD B,H
1673  A019 4D                   LD C,L
1674  A01A                      ; BIOS-bridge transfer helper for the assembled span
1675  A01A CD 1E AA             CALL $AA1E
1676  A01D D1                   POP DE
1677  A01E 2A B5 A9             LD HL,(DEBLOCK_HSTREC_PTR0)
1678  A021 73                   LD (HL),E
1679  A022 23                   INC HL
1680  A023 72                   LD (HL),D
1681  A024 D1                   POP DE
1682  A025 2A B7 A9             LD HL,(DEBLOCK_HSTREC_PTR1)
1683  A028 73                   LD (HL),E
1684  A029 23                   INC HL
1685  A02A 72                   LD (HL),D
1686  A02B C1                   POP BC
1687  A02C 79                   LD A,C
1688  A02D                      ; begin BC = BC - DE: records remaining after this span
1689  A02D 93                   SUB E
1690  A02E 4F                   LD C,A
1691  A02F 78                   LD A,B
1692  A030 9A                   SBC A,D
1693  A031 47                   LD B,A
1694  A032 2A D0 A9             LD HL,(DPB_XLT_PTR)
1695  A035 EB                   EX DE,HL
1696  A036                      ; BIOS-bridge advance helper for the next span
1697  A036 CD 30 AA             CALL $AA30
1698  A039 4D                   LD C,L
1699  A03A 44                   LD B,H
1700  A03B                      ; re-enter the bridge to continue the transfer loop
1701  A03B C3 21 AA             JP $AA21
1702  A03E              ; ----------------------------------------------------------------------
1703  A03E              ; FCB_RECORD_TO_BLOCKMAP_INDEX -- derive the FCB disk-map index for the current record/extent.
1704  A03E              ;   In: DPB_BSH = BSH (block-shift, records-per-block log2); FCB_CURREC = CR (current record, low half);
1705  A03E              ;       FCB_EXTENT_MASKED = the masked extent value ((FCB extent) AND EXM).
1706  A03E              ;   Out: A = the index (0..15) into the FCB allocation map for the block holding the current record.
1707  A03E              ;   Clobbers: A,B,C,HL.
1708  A03E              ;   Algorithm: C = BSH; rotate FCB_CURREC right BSH times (loop FCB_BLOCKMAP_INDEX_SHR) to drop the
1709  A03E              ;              within-block
1710  A03E              ;       record bits, keep the result in B; then C = 8 - BSH and rotate FCB_EXTENT_MASKED left (8-BSH) times
1711  A03E              ;       (loop FCB_BLOCKMAP_INDEX_SHL) to bring the extent bits up; finally ADD A,B at
1712  A03E              ;       DISK_STORE_SEC_TRK_9.
1713  A03E              ;   [RE] maps (record,extent) -> which d0..d15 entry of the FCB disk-allocation map; its output A is
1714  A03E              ;       used directly as the BC index into GET_ALLOC_BLOCK_ENTRY by DISK_STORE_SEC_TRK_14. [?] exact
1715  A03E              ;       bit packing partially inferred.
1716  A03E              ; ----------------------------------------------------------------------
1717  A03E              DISK_STORE_SEC_TRK_6:
1718  A03E                      ; DPB_BSH = DPB block-shift factor (BSH), records-per-block log2
1719  A03E 21 C3 A9             LD HL,DPB_BSH
1720  A041 4E                   LD C,(HL)
1721  A042 3A E3 A9             LD A,(FCB_CURREC)
1722  A045              FCB_BLOCKMAP_INDEX_SHR:
1723  A045 B7                   OR A
1724  A046 1F                   RRA
1725  A047 0D                   DEC C
1726  A048 C2 45 A0             JP NZ,FCB_BLOCKMAP_INDEX_SHR
1727  A04B 47                   LD B,A
1728  A04C                      ; complement the shift: 8 - BSH
1729  A04C 3E 08                LD A,$08
1730  A04E                      ; C = 8 - BSH = left-rotate count for the extent half
1731  A04E 96                   SUB (HL)
1732  A04F 4F                   LD C,A
1733  A050 3A E2 A9             LD A,(FCB_EXTENT_MASKED)
1734  A053              FCB_BLOCKMAP_INDEX_SHL:
1735  A053 0D                   DEC C
1736  A054 CA 5C A0             JP Z,DISK_STORE_SEC_TRK_9
1737  A057 B7                   OR A
1738  A058 17                   RLA
1739  A059 C3 53 A0             JP FCB_BLOCKMAP_INDEX_SHL
1740  A05C              ; ----------------------------------------------------------------------
1741  A05C              ; FCB_BLOCKMAP_INDEX_MERGE -- tail of DISK_STORE_SEC_TRK_6: combine the two shifted halves.
1742  A05C              ;   In: A = the left-shifted extent half; B = the right-shifted record half.
1743  A05C              ;   Out: A = combined disk-map index (A + B).
1744  A05C              ;   Clobbers: A.
1745  A05C              ;   Algorithm: ADD A,B and return.
1746  A05C              ;   [RE] continuation/exit label of the index computation.
1747  A05C              ; ----------------------------------------------------------------------
1748  A05C              DISK_STORE_SEC_TRK_9:
1749  A05C                      ; combine the extent and record halves into the disk-map index
1750  A05C 80                   ADD A,B
1751  A05D C9                   RET
1752  A05E              ; ----------------------------------------------------------------------
1753  A05E              ; GET_ALLOC_BLOCK_ENTRY -- read a block number from the current FCB's disk-allocation map, indexed
1754  A05E              ; by BC.
1755  A05E              ;   In: BC = entry index; BDOS_PARAM_PTR = the current FCB pointer (the BDOS call's DE parameter);
1756  A05E              ;       BLOCK_WIDTH_FLAG selects 8-bit (nonzero) vs 16-bit (zero) map entries.
1757  A05E              ;   Out: HL = the indexed block number (zero-extended byte if 8-bit, else the full 16-bit word).
1758  A05E              ;   Clobbers: A,DE,HL.
1759  A05E              ;   Algorithm: HL = [BDOS_PARAM_PTR] + $0010 + BC (FCB+$10 = the d0..d15 disk-allocation map); if
1760  A05E              ;       BLOCK_WIDTH_FLAG==0 fall through to the word path (DISK_STORE_SEC_TRK_13), otherwise read
1761  A05E              ;       a single byte into L with H=0.
1762  A05E              ;   [RE] the DSM>255 vs <=255 entry-width branch (standard CP/M big/small-disk map handling).
1763  A05E              ;       FCB offset $10 is the on-disk allocation map. [?]
1764  A05E              ; ----------------------------------------------------------------------
1765  A05E              DISK_STORE_SEC_TRK_10:
1766  A05E                      ; current FCB pointer (BDOS DE parameter)
1767  A05E 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
1768  A061                      ; FCB+$10 = the disk-allocation map (d0..d15)
1769  A061 11 10 00             LD DE,$0010
1770  A064 19                   ADD HL,DE
1771  A065 09                   ADD HL,BC
1772  A066                      ; 0 = 16-bit map entries (big disk, DSM>255); nonzero = 8-bit
1773  A066 3A DD A9             LD A,(BLOCK_WIDTH_FLAG)
1774  A069 B7                   OR A
1775  A06A CA 71 A0             JP Z,DISK_STORE_SEC_TRK_13
1776  A06D                      ; 8-bit entry path: zero-extend the byte into HL
1777  A06D 6E                   LD L,(HL)
1778  A06E 26 00                LD H,$00
1779  A070 C9                   RET
1780  A071              ; ----------------------------------------------------------------------
1781  A071              ; GET_ALLOC_BLOCK_ENTRY_WORD -- 16-bit-entry tail of GET_ALLOC_BLOCK_ENTRY.
1782  A071              ;   In: HL = FCB map base + index (one stride short of the word entry); BC = entry index.
1783  A071              ;   Out: HL = the 16-bit block number fetched from the map.
1784  A071              ;   Clobbers: DE,HL.
1785  A071              ;   Algorithm: ADD HL,BC a second time (word stride), load low/high bytes into DE, EX DE,HL.
1786  A071              ;   [RE] big-disk word-entry fetch.
1787  A071              ; ----------------------------------------------------------------------
1788  A071              DISK_STORE_SEC_TRK_13:
1789  A071                      ; second add: word-sized stride into the allocation map
1790  A071 09                   ADD HL,BC
1791  A072 5E                   LD E,(HL)
1792  A073 23                   INC HL
1793  A074 56                   LD D,(HL)
1794  A075 EB                   EX DE,HL
1795  A076 C9                   RET
1796  A077              ; ----------------------------------------------------------------------
1797  A077              ; FCB_GET_CURRENT_BLOCK -- look up the FCB allocation-map block number for the current
1798  A077              ; record/extent.
1799  A077              ;   In: the current FCB and the FCB_CURREC/FCB_EXTENT_MASKED position cells (set by DRV_INSTALL_RWTS_3).
1800  A077              ;   Out: HL and CUR_BLOCK_NUMBER = the resolved block number from the FCB allocation map.
1801  A077              ;   Clobbers: A,BC,DE,HL.
1802  A077              ;   Algorithm: CALL DISK_STORE_SEC_TRK_6 to get the map index in A, move it to BC (C=A, B=0),
1803  A077              ;       CALL GET_ALLOC_BLOCK_ENTRY to fetch the block number, then cache it in CUR_BLOCK_NUMBER.
1804  A077              ;   [RE] composes the index computation and the map lookup to get the current block number. [?]
1805  A077              ; ----------------------------------------------------------------------
1806  A077              DISK_STORE_SEC_TRK_14:
1807  A077                      ; derive the allocation-map index for this record/extent
1808  A077 CD 3E A0             CALL DISK_STORE_SEC_TRK_6
1809  A07A 4F                   LD C,A
1810  A07B 06 00                LD B,$00
1811  A07D                      ; fetch the block number from the FCB allocation map
1812  A07D CD 5E A0             CALL DISK_STORE_SEC_TRK_10
1813  A080                      ; cache the resolved block number
1814  A080 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
1815  A083 C9                   RET
1816  A084              ; ----------------------------------------------------------------------
1817  A084              ; BLOCK_IS_ZERO -- test whether the cached block number (CUR_BLOCK_NUMBER) is zero (unallocated).
1818  A084              ;   In: CUR_BLOCK_NUMBER = cached block number.
1819  A084              ;   Out: HL = the block number; Z set if it is zero (no block allocated -- a hole).
1820  A084              ;   Clobbers: A,HL.
1821  A084              ;   Algorithm: load CUR_BLOCK_NUMBER; LD A,L / OR H to set Z when both halves are zero.
1822  A084              ;   [RE] standard 'block 0 means unallocated' test.
1823  A084              ; ----------------------------------------------------------------------
1824  A084              DISK_STORE_SEC_TRK_16:
1825  A084 2A E5 A9             LD HL,(CUR_BLOCK_NUMBER)
1826  A087 7D                   LD A,L
1827  A088                      ; Z set when the 16-bit block number is zero (unallocated)
1828  A088 B4                   OR H
1829  A089 C9                   RET
1830  A08A              ; ----------------------------------------------------------------------
1831  A08A              ; BLOCK_TO_FIRST_RECORD -- expand a block number into the absolute record number it maps to.
1832  A08A              ;   In: CUR_BLOCK_NUMBER = block number; DPB_BSH = BSH (records-per-block log2); DPB_BLM = BLM (block mask);
1833  A08A              ;       FCB_CURREC = CR (current record, low half).
1834  A08A              ;   Out: BLOCK_BASE_RECORD = block<<BSH (the block's base record); CUR_BLOCK_NUMBER = (block base) OR (CR AND BLM).
1835  A08A              ;   Clobbers: A,C,HL.
1836  A08A              ;   Algorithm: shift CUR_BLOCK_NUMBER left BSH times (loop BLOCK_TO_FIRST_RECORD_SHL) to get the block base
1837  A08A              ;              record, store
1838  A08A              ;       it in BLOCK_BASE_RECORD; then OR in the within-block record bits (FCB_CURREC AND DPB_BLM) and store the
1839  A08A              ;       full record number back into CUR_BLOCK_NUMBER.
1840  A08A              ;   [RE] canonical record = (block << BSH) | (record AND BLM). [?]
1841  A08A              ; ----------------------------------------------------------------------
1842  A08A              DISK_STORE_SEC_TRK_17:
1843  A08A                      ; BSH = number of left shifts (records-per-block log2)
1844  A08A 3A C3 A9             LD A,(DPB_BSH)
1845  A08D 2A E5 A9             LD HL,(CUR_BLOCK_NUMBER)
1846  A090              BLOCK_TO_FIRST_RECORD_SHL:
1847  A090 29                   ADD HL,HL
1848  A091 3D                   DEC A
1849  A092 C2 90 A0             JP NZ,BLOCK_TO_FIRST_RECORD_SHL
1850  A095                      ; save the block's base record number
1851  A095 22 E7 A9             LD (BLOCK_BASE_RECORD),HL
1852  A098                      ; BLM = block mask for the within-block record bits
1853  A098 3A C4 A9             LD A,(DPB_BLM)
1854  A09B 4F                   LD C,A
1855  A09C 3A E3 A9             LD A,(FCB_CURREC)
1856  A09F                      ; isolate the within-block record bits (CR AND BLM)
1857  A09F A1                   AND C
1858  A0A0                      ; merge the block base and the within-block offset
1859  A0A0 B5                   OR L
1860  A0A1 6F                   LD L,A
1861  A0A2 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
1862  A0A5 C9                   RET
1863  A0A6              ; ----------------------------------------------------------------------
1864  A0A6              ; FCB_FIELD_PTR_0C -- point HL at offset $0C (the EX / extent field) of the current FCB.
1865  A0A6              ;   In: BDOS_PARAM_PTR = current FCB pointer.
1866  A0A6              ;   Out: HL = [BDOS_PARAM_PTR] + $000C (FCB+12 = EX, the current-extent byte).
1867  A0A6              ;   Clobbers: DE,HL.
1868  A0A6              ;   Algorithm: load the FCB base, add $000C.
1869  A0A6              ;   [RE] accessor for FCB byte 12 (EX). [DOC CP/M 2.2 FCB]
1870  A0A6              ; ----------------------------------------------------------------------
1871  A0A6              DRV_INSTALL_RWTS_1:
1872  A0A6 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
1873  A0A9                      ; FCB+$0C = the EX (current extent) field
1874  A0A9 11 0C 00             LD DE,$000C
1875  A0AC 19                   ADD HL,DE
1876  A0AD C9                   RET
1877  A0AE              ; ----------------------------------------------------------------------
1878  A0AE              ; FCB_FIELD_PTRS_0F_20 -- compute pointers to FCB offsets $0F (RC) and $20 (CR).
1879  A0AE              ;   In: BDOS_PARAM_PTR = current FCB pointer.
1880  A0AE              ;   Out: DE = [BDOS_PARAM_PTR] + $0F (FCB+15 = RC, record count); HL = DE + $11 = [BDOS_PARAM_PTR] +
1881  A0AE              ;        $20
1882  A0AE              ;        (FCB+32 = CR, current record).
1883  A0AE              ;   Clobbers: DE,HL.
1884  A0AE              ;   Algorithm: HL = base + $0F, move to DE, HL = DE + $11.
1885  A0AE              ;   [RE] paired accessor for the RC and CR FCB fields, used by DRV_INSTALL_RWTS_3/_6. [DOC CP/M 2.2
1886  A0AE              ;   FCB]
1887  A0AE              ; ----------------------------------------------------------------------
1888  A0AE              DRV_INSTALL_RWTS_2:
1889  A0AE 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
1890  A0B1                      ; FCB+$0F = the RC (record count) field
1891  A0B1 11 0F 00             LD DE,$000F
1892  A0B4 19                   ADD HL,DE
1893  A0B5 EB                   EX DE,HL
1894  A0B6                      ; CR (FCB+$20) is $11 bytes past RC
1895  A0B6 21 11 00             LD HL,$0011
1896  A0B9 19                   ADD HL,DE
1897  A0BA C9                   RET
1898  A0BB              ; ----------------------------------------------------------------------
1899  A0BB              ; LOAD_FCB_POSITION -- copy the current FCB's position fields into the BDOS scratch cells.
1900  A0BB              ;   In: the current FCB (via DRV_INSTALL_RWTS_2 / _1); DPB_EXM = EXM (extent mask).
1901  A0BB              ;   Out: FCB_CURREC = CR (FCB+$20); FCB_RECCOUNT = RC (FCB+$0F); FCB_EXTENT_MASKED = EX (FCB+$0C) AND EXM.
1902  A0BB              ;   Clobbers: A,DE,HL.
1903  A0BB              ;   Algorithm: via DRV_INSTALL_RWTS_2 read CR into FCB_CURREC and RC into FCB_RECCOUNT; via
1904  A0BB              ;       DRV_INSTALL_RWTS_1 read EX, mask it with EXM (DPB_EXM), store in FCB_EXTENT_MASKED.
1905  A0BB              ;   [RE] loads the file's current record / record-count / masked-extent into the deblock scratch
1906  A0BB              ;   cells. [DOC CP/M 2.2 FCB]
1907  A0BB              ; ----------------------------------------------------------------------
1908  A0BB              DRV_INSTALL_RWTS_3:
1909  A0BB CD AE A0             CALL DRV_INSTALL_RWTS_2
1910  A0BE 7E                   LD A,(HL)
1911  A0BF                      ; stash CR (current record, FCB+$20)
1912  A0BF 32 E3 A9             LD (FCB_CURREC),A
1913  A0C2 EB                   EX DE,HL
1914  A0C3 7E                   LD A,(HL)
1915  A0C4                      ; stash RC (record count, FCB+$0F)
1916  A0C4 32 E1 A9             LD (FCB_RECCOUNT),A
1917  A0C7 CD A6 A0             CALL DRV_INSTALL_RWTS_1
1918  A0CA                      ; EXM (extent mask) applied to the EX byte
1919  A0CA 3A C5 A9             LD A,(DPB_EXM)
1920  A0CD A6                   AND (HL)
1921  A0CE                      ; store EX AND EXM (the in-extent bits)
1922  A0CE 32 E2 A9             LD (FCB_EXTENT_MASKED),A
1923  A0D1 C9                   RET
1924  A0D2              ; ----------------------------------------------------------------------
1925  A0D2              ; STORE_FCB_POSITION -- write the (possibly adjusted) position values back into the current FCB.
1926  A0D2              ;   In: WRITE_TYPE_FLAG (mode/adjust selector), FCB_CURREC, FCB_RECCOUNT scratch cells; the current FCB.
1927  A0D2              ;   Out: FCB+$20 (CR) = FCB_CURREC + adjust; FCB+$0F (RC) = FCB_RECCOUNT.
1928  A0D2              ;   Clobbers: A,C,DE,HL.
1929  A0D2              ;   Algorithm: get the RC/CR pointers; if WRITE_TYPE_FLAG != 2 then C = WRITE_TYPE_FLAG else C = 0; write
1930  A0D2              ;       (FCB_CURREC + C) into CR and FCB_RECCOUNT into RC.
1931  A0D2              ;   [RE] inverse of LOAD_FCB_POSITION with a special case when WRITE_TYPE_FLAG == 2 (the adjustment is
1932  A0D2              ;       zeroed). [?] meaning of the WRITE_TYPE_FLAG selector values UNKNOWN.
1933  A0D2              ; ----------------------------------------------------------------------
1934  A0D2              DRV_INSTALL_RWTS_6:
1935  A0D2 CD AE A0             CALL DRV_INSTALL_RWTS_2
1936  A0D5                      ; mode/adjust selector; value 2 zeroes the adjustment
1937  A0D5 3A D5 A9             LD A,(WRITE_TYPE_FLAG)
1938  A0D8                      ; special-case selector value 2
1939  A0D8 FE 02                CP $02
1940  A0DA C2 DE A0             JP NZ,STORE_FCB_POSITION_2
1941  A0DD AF                   XOR A
1942  A0DE              STORE_FCB_POSITION_2:
1943  A0DE 4F                   LD C,A
1944  A0DF 3A E3 A9             LD A,(FCB_CURREC)
1945  A0E2                      ; apply the selector-dependent adjustment to CR
1946  A0E2 81                   ADD A,C
1947  A0E3 77                   LD (HL),A
1948  A0E4 EB                   EX DE,HL
1949  A0E5 3A E1 A9             LD A,(FCB_RECCOUNT)
1950  A0E8 77                   LD (HL),A
1951  A0E9 C9                   RET
1952  A0EA              ; ----------------------------------------------------------------------
1953  A0EA              ; SHR_HL_C -- logical-shift HL right by C bit positions.
1954  A0EA              ;   In: HL = value; C = shift count (0 leaves HL unchanged).
1955  A0EA              ;   Out: HL >>= C (logical).
1956  A0EA              ;   Clobbers: A,C,HL (C decremented to 0).
1957  A0EA              ;   Algorithm: INC C / loop { DEC C; ret if zero; OR A to clear carry, RRA H, then RRA L feeding
1958  A0EA              ;       H's carried-out bit 0 into L's top }.
1959  A0EA              ;   [RE] generic unsigned right-shift helper used to scale block/drive-bit values.
1960  A0EA              ; ----------------------------------------------------------------------
1961  A0EA              DRV_INSTALL_RWTS_10:
1962  A0EA 0C                   INC C
1963  A0EB              SHR_HL_C_LOOP:
1964  A0EB 0D                   DEC C
1965  A0EC C8                   RET Z
1966  A0ED 7C                   LD A,H
1967  A0EE                      ; clear carry before the rotate (logical, not arithmetic, shift)
1968  A0EE B7                   OR A
1969  A0EF                      ; shift H right; its bit 0 is carried into L below
1970  A0EF 1F                   RRA
1971  A0F0 67                   LD H,A
1972  A0F1 7D                   LD A,L
1973  A0F2 1F                   RRA
1974  A0F3 6F                   LD L,A
1975  A0F4 C3 EB A0             JP SHR_HL_C_LOOP
1976  A0F7              ; ----------------------------------------------------------------------
1977  A0F7              ; DIR_CHECKSUM -- compute the 128-byte additive checksum of the directory buffer.
1978  A0F7              ;   In: DIRBUF_PTR -> 128-byte directory sector buffer.
1979  A0F7              ;   Out: A = 8-bit sum of the 128 bytes.
1980  A0F7              ;   Clobbers: A,C,HL.
1981  A0F7              ;   Algorithm: C=$80 count, HL=DIRBUF_PTR, A=0; loop ADD A,(HL)/INC HL/DEC C until C==0.
1982  A0F7              ;   [RE] canonical CP/M directory-checksum routine (detects media swap). [DOC CP/M 2.2 ALG]
1983  A0F7              ; ----------------------------------------------------------------------
1984  A0F7              DIR_CHECKSUM:
1985  A0F7                      ; 128 bytes = one directory sector
1986  A0F7 0E 80                LD C,$80
1987  A0F9                      ; directory sector buffer base
1988  A0F9 2A B9 A9             LD HL,(DIRBUF_PTR)
1989  A0FC AF                   XOR A
1990  A0FD              DIR_CHECKSUM_LOOP:
1991  A0FD                      ; accumulate the 8-bit additive checksum
1992  A0FD 86                   ADD A,(HL)
1993  A0FE 23                   INC HL
1994  A0FF 0D                   DEC C
1995  A100 C2 FD A0             JP NZ,DIR_CHECKSUM_LOOP
1996  A103 C9                   RET
1997  A104              ; ----------------------------------------------------------------------
1998  A104              ; SHL_HL_C -- logical-shift HL left by C bit positions.
1999  A104              ;   In: HL = value; C = shift count (0 leaves HL unchanged).
2000  A104              ;   Out: HL <<= C.
2001  A104              ;   Clobbers: C,HL (C decremented to 0).
2002  A104              ;   Algorithm: INC C / loop { DEC C; ret if zero; ADD HL,HL }.
2003  A104              ;   [RE] generic unsigned left-shift helper (e.g. building a 1<<n drive-bit mask).
2004  A104              ; ----------------------------------------------------------------------
2005  A104              CMD_EXEC_11:
2006  A104 0C                   INC C
2007  A105              SHL_HL_C_LOOP:
2008  A105 0D                   DEC C
2009  A106 C8                   RET Z
2010  A107                      ; one left shift of HL
2011  A107 29                   ADD HL,HL
2012  A108 C3 05 A1             JP SHL_HL_C_LOOP
2013  A10B              ; ----------------------------------------------------------------------
2014  A10B              ; DRIVE_BIT_OR_INTO_VECTOR -- OR the current drive's single-bit mask into a 16-bit vector.
2015  A10B              ;   In: BC = the existing 16-bit vector (preserved across the call); BDOS_CUR_DRIVE = current drive
2016  A10B              ;       (0-based).
2017  A10B              ;       (HL on entry is IGNORED -- it is overwritten with $0001.)
2018  A10B              ;   Out: HL = BC OR (1 << current_drive).
2019  A10B              ;   Clobbers: A,HL (BC saved/restored).
2020  A10B              ;   Algorithm: PUSH BC; C = current drive; HL = 1; CALL SHL_HL_C to form 1<<drive; POP BC;
2021  A10B              ;       L = C OR L (low byte), H = B OR H (high byte).
2022  A10B              ;   [RE] sets the current drive's bit in whatever vector the caller passes in BC (used by both the
2023  A10B              ;       R/O vector and the login vector setters). [?]
2024  A10B              ; ----------------------------------------------------------------------
2025  A10B              CMD_EXEC_12:
2026  A10B C5                   PUSH BC
2027  A10C                      ; current drive number = bit position
2028  A10C 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
2029  A10F 4F                   LD C,A
2030  A110 21 01 00             LD HL,$0001
2031  A113                      ; HL = 1 << current_drive
2032  A113 CD 04 A1             CALL CMD_EXEC_11
2033  A116 C1                   POP BC
2034  A117 79                   LD A,C
2035  A118                      ; low byte: OR the existing vector (C) with the new drive bit
2036  A118 B5                   OR L
2037  A119 6F                   LD L,A
2038  A11A 78                   LD A,B
2039  A11B                      ; high byte: OR the existing vector (B) with the new drive bit
2040  A11B B4                   OR H
2041  A11C 67                   LD H,A
2042  A11D C9                   RET
2043  A11E              ; ----------------------------------------------------------------------
2044  A11E              ; TEST_DRIVE_RO_BIT -- test whether the current drive's bit is set in the read-only drive vector.
2045  A11E              ;   In: the 16-bit R/O vector at $A9AD (NOTE: the var-page cell is mislabeled DRV_LOGIN_VECTOR;
2046  A11E              ;       it is the read-only vector set by the Write-Protect-Disk handler DRV_SETRO_H);
2047  A11E              ;       BDOS_CUR_DRIVE = drive.
2048  A11E              ;   Out: A = 1 if the current drive's R/O bit is set, else 0; Z reflects the result.
2049  A11E              ;   Clobbers: A,C,HL.
2050  A11E              ;   Algorithm: load the vector, SHR_HL_C by the drive number to bring its bit to bit 0, AND $01.
2051  A11E              ;   [RE] CMD_EXEC_20 (CHECK_DRIVE_READONLY) uses this and raises the R/O error when the bit is set,
2052  A11E              ;       which proves this vector is the read-only vector, not the login vector. [?] cell-name fix
2053  A11E              ;       deferred.
2054  A11E              ; ----------------------------------------------------------------------
2055  A11E              DRIVE_BIT_TEST:
2056  A11E                      ; the read-only drive vector (cell mislabeled DRV_LOGIN_VECTOR)
2057  A11E 2A AD A9             LD HL,(DRV_LOGIN_VECTOR)
2058  A121 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
2059  A124 4F                   LD C,A
2060  A125                      ; shift the wanted drive's bit down to bit 0
2061  A125 CD EA A0             CALL DRV_INSTALL_RWTS_10
2062  A128 7D                   LD A,L
2063  A129                      ; isolate the current drive's R/O bit
2064  A129 E6 01                AND $01
2065  A12B C9                   RET
2066  A12C              ; ----------------------------------------------------------------------
2067  A12C              ; SET_DRIVE_READONLY -- BDOS function 28 (Write Protect Disk): set the current drive's R/O bit.
2068  A12C              ;   In: the R/O drive vector at $A9AD (cell mislabeled DRV_LOGIN_VECTOR); BDOS_CUR_DRIVE = current
2069  A12C              ;       drive;
2070  A12C              ;       DPB_REC_PTR (a directory record-count limit); DPB_WORK_PTR0 -> a 16-bit working cell.
2071  A12C              ;   Out: the R/O vector has the current drive's bit set; the word at [DPB_WORK_PTR0] = DPB_REC_PTR +
2072  A12C              ;        1.
2073  A12C              ;   Clobbers: A,BC,DE,HL.
2074  A12C              ;   Algorithm: load the R/O vector into BC, set the current-drive bit via DRIVE_BIT_OR_INTO_VECTOR,
2075  A12C              ;       store it back; then store (DPB_REC_PTR + 1) into the 16-bit cell pointed to by
2076  A12C              ;       DPB_WORK_PTR0.
2077  A12C              ;   [RE] this label is the fn-28 entry in the dispatch table at $9C7F, confirming
2078  A12C              ;   Write-Protect-Disk;
2079  A12C              ;       the existing label DRV_SETRO_H ('set read-only') agrees. [?] purpose of caching
2080  A12C              ;       DPB_REC_PTR+1 UNKNOWN.
2081  A12C              ; ----------------------------------------------------------------------
2082  A12C              DRV_SETRO_H:
2083  A12C 21 AD A9             LD HL,DRV_LOGIN_VECTOR
2084  A12F 4E                   LD C,(HL)
2085  A130 23                   INC HL
2086  A131 46                   LD B,(HL)
2087  A132                      ; set the current drive's bit in the R/O vector
2088  A132 CD 0B A1             CALL CMD_EXEC_12
2089  A135                      ; store the updated R/O vector (cell mislabeled DRV_LOGIN_VECTOR)
2090  A135 22 AD A9             LD (DRV_LOGIN_VECTOR),HL
2091  A138                      ; directory record-count limit for this drive
2092  A138 2A C8 A9             LD HL,(DPB_REC_PTR)
2093  A13B 23                   INC HL
2094  A13C EB                   EX DE,HL
2095  A13D 2A B3 A9             LD HL,(DPB_WORK_PTR0)
2096  A140 73                   LD (HL),E
2097  A141 23                   INC HL
2098  A142                      ; save (DPB_REC_PTR + 1) into the cell at [DPB_WORK_PTR0]
2099  A142 72                   LD (HL),D
2100  A143 C9                   RET
2101  A144              ; ----------------------------------------------------------------------
2102  A144              ; CHECK_DIRENT_READONLY -- raise the file-R/O error if the matched directory entry is read-only.
2103  A144              ;   In: DIRBUF_PTR / DEBLOCK_BYTE_OFF locate the matched directory entry (via
2104  A144              ;       FCB_BUF_PTR_ADD_OFFSET).
2105  A144              ;   Out: returns normally if writable; otherwise jumps to the BDOS error vector (no return).
2106  A144              ;   Clobbers: A,DE,HL.
2107  A144              ;   Algorithm: point at the entry, advance to byte +9 (the first type byte t1', whose bit 7 is the
2108  A144              ;       R/O attribute), RLA to shift bit 7 into carry; RET NC if clear, else load the file-R/O
2109  A144              ;       error vector (BDOS_ERRVEC_FILERO at $9C0F) and dispatch via BDOS_VECTOR_JUMP.
2110  A144              ;   [RE] CP/M file R/O attribute = bit 7 of directory-entry byte 9 (t1'). [DOC CP/M 2.2 FCB]
2111  A144              ; ----------------------------------------------------------------------
2112  A144              FCB_RO_FLAG_TEST:
2113  A144 CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2114  A147              CHECK_DIRENT_READONLY_INNER:
2115  A147                      ; offset to dir-entry byte 9 (t1'; bit 7 = R/O attribute)
2116  A147 11 09 00             LD DE,$0009
2117  A14A 19                   ADD HL,DE
2118  A14B 7E                   LD A,(HL)
2119  A14C                      ; shift attribute bit 7 into carry
2120  A14C 17                   RLA
2121  A14D                      ; carry clear: entry is writable, continue
2122  A14D D0                   RET NC
2123  A14E                      ; file-read-only error vector ($9C0F)
2124  A14E 21 0F 9C             LD HL,BDOS_ERRVEC_FILERO
2125  A151 C3 4A 9F             JP BDOS_VECTOR_JUMP
2126  A154              ; ----------------------------------------------------------------------
2127  A154              ; CHECK_DRIVE_READONLY -- raise the disk-R/O error if the current drive is write-protected.
2128  A154              ;   In: the current drive context (DRIVE_BIT_TEST reads the R/O drive vector).
2129  A154              ;   Out: returns if writable; otherwise jumps to the BDOS error vector (no return).
2130  A154              ;   Clobbers: A,C,HL.
2131  A154              ;   Algorithm: CALL DRIVE_BIT_TEST (current drive's R/O bit); RET Z if clear (writable), else load
2132  A154              ;       the disk-R/O error vector (BDOS_ERRVEC_RODISK at $9C0D) and dispatch via BDOS_VECTOR_JUMP.
2133  A154              ;   [RE] guards writes against a write-protected disk. [?]
2134  A154              ; ----------------------------------------------------------------------
2135  A154              CMD_EXEC_20:
2136  A154                      ; test the current drive's read-only bit
2137  A154 CD 1E A1             CALL DRIVE_BIT_TEST
2138  A157                      ; writable: nothing to raise
2139  A157 C8                   RET Z
2140  A158                      ; disk-read-only error vector ($9C0D)
2141  A158 21 0D 9C             LD HL,BDOS_ERRVEC_RODISK
2142  A15B C3 4A 9F             JP BDOS_VECTOR_JUMP
2143  A15E              ; ----------------------------------------------------------------------
2144  A15E              ; DIRENT_PTR -- compute a pointer to the matched directory entry inside the directory buffer.
2145  A15E              ;   In: DIRBUF_PTR -> directory sector buffer; DEBLOCK_BYTE_OFF = byte offset of the entry.
2146  A15E              ;   Out: HL = DIRBUF_PTR + DEBLOCK_BYTE_OFF.
2147  A15E              ;   Clobbers: A,HL.
2148  A15E              ;   Algorithm: load the buffer base, load the 8-bit entry offset, add it to L with carry into H
2149  A15E              ;              (DIRENT_PTR_ADD).
2150  A15E              ;   [RE] locates the directory entry just matched by a BDOS directory search. [?]
2151  A15E              ; ----------------------------------------------------------------------
2152  A15E              FCB_BUF_PTR_ADD_OFFSET:
2153  A15E                      ; directory sector buffer base
2154  A15E 2A B9 A9             LD HL,(DIRBUF_PTR)
2155  A161                      ; byte offset of the matched entry within the buffer
2156  A161 3A E9 A9             LD A,(DEBLOCK_BYTE_OFF)
2157  A164              DIRENT_PTR_ADD:
2158  A164 85                   ADD A,L
2159  A165 6F                   LD L,A
2160  A166 D0                   RET NC
2161  A167 24                   INC H
2162  A168 C9                   RET
2163  A169              ; ----------------------------------------------------------------------
2164  A169              ; GET_FCB_S2_PTR -- point HL at FCB byte 14 (the S2 / extent-high field) of the current FCB.
2165  A169              ;   In: BDOS_PARAM_PTR = current FCB pointer.
2166  A169              ;   Out: HL = [BDOS_PARAM_PTR] + $000E (FCB+14, the S2 byte); A = its current value.
2167  A169              ;   Clobbers: A,DE,HL.
2168  A169              ;   Algorithm: HL = base + $0E, read (HL) into A.
2169  A169              ;   [RE] FCB byte 14 = S2 (extent-high / module count) per CP/M 2.2 FCB layout. [DOC CP/M 2.2 FCB]
2170  A169              ; ----------------------------------------------------------------------
2171  A169              FCB_GET_S2:
2172  A169 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2173  A16C                      ; offset to FCB byte 14 (the S2 field)
2174  A16C 11 0E 00             LD DE,$000E
2175  A16F 19                   ADD HL,DE
2176  A170 7E                   LD A,(HL)
2177  A171 C9                   RET
2178  A172              ; ----------------------------------------------------------------------
2179  A172              ; CLEAR_FCB_S2 -- zero the S2 (byte 14) field of the current FCB.
2180  A172              ;   In: the current FCB (via GET_FCB_S2_PTR).
2181  A172              ;   Out: FCB byte 14 = 0.
2182  A172              ;   Clobbers: A,DE,HL.
2183  A172              ;   Algorithm: get the S2 pointer, store 0.
2184  A172              ;   [RE] resets the extent-high/S2 field. [DOC CP/M 2.2 FCB]
2185  A172              ; ----------------------------------------------------------------------
2186  A172              CLEAR_FCB_S2:
2187  A172 CD 69 A1             CALL FCB_GET_S2
2188  A175                      ; clear the FCB S2 field
2189  A175 36 00                LD (HL),$00
2190  A177 C9                   RET
2191  A178              ; ----------------------------------------------------------------------
2192  A178              ; MARK_FCB_S2_HIGHBIT -- set bit 7 of the FCB S2 (byte 14) field.
2193  A178              ;   In: the current FCB (via GET_FCB_S2_PTR, which also returns A = the current S2 value).
2194  A178              ;   Out: FCB byte 14 |= $80.
2195  A178              ;   Clobbers: A,DE,HL.
2196  A178              ;   Algorithm: get the S2 pointer (A = current S2), OR $80, store back.
2197  A178              ;   [RE] in CP/M 2.2 the high bit of S2 flags the FCB as written/needing a directory update at
2198  A178              ;   close. [DOC CP/M 2.2 FCB]
2199  A178              ; ----------------------------------------------------------------------
2200  A178              MARK_FCB_S2_HIGHBIT:
2201  A178 CD 69 A1             CALL FCB_GET_S2
2202  A17B                      ; set S2 bit 7 (the write/close flag)
2203  A17B F6 80                OR $80
2204  A17D 77                   LD (HL),A
2205  A17E C9                   RET
2206  A17F              ; ----------------------------------------------------------------------
2207  A17F              ; CMP_CURREC_VS_WORKPTR -- compare the current record number against the working record cell.
2208  A17F              ;   In: CUR_RECORD = 16-bit current record; DPB_WORK_PTR0 -> a 16-bit working record value.
2209  A17F              ;   Out: HL = address of the working value's high byte; flags = (CUR_RECORD - working value);
2210  A17F              ;        CARRY SET when CUR_RECORD < the working value (i.e. no extension needed).
2211  A17F              ;   Clobbers: A,DE,HL.
2212  A17F              ;   Algorithm: DE = CUR_RECORD, HL = (DPB_WORK_PTR0); subtract low byte (SUB), then high byte (SBC),
2213  A17F              ;       leaving HL pointing at the high byte; no value is stored.
2214  A17F              ;   [RE] RECPTR_INC_STORE uses this: on NC (CUR_RECORD >= working) it bumps and stores CUR_RECORD+1,
2215  A17F              ;       extending the high-water record count. [?]
2216  A17F              ; ----------------------------------------------------------------------
2217  A17F              CMP_CURREC_VS_WORKPTR:
2218  A17F                      ; current logical record number
2219  A17F 2A EA A9             LD HL,(CUR_RECORD)
2220  A182 EB                   EX DE,HL
2221  A183                      ; pointer to the working record-count value
2222  A183 2A B3 A9             LD HL,(DPB_WORK_PTR0)
2223  A186 7B                   LD A,E
2224  A187 96                   SUB (HL)
2225  A188 23                   INC HL
2226  A189 7A                   LD A,D
2227  A18A                      ; 16-bit compare; carry => current record is BELOW the stored value
2228  A18A 9E                   SBC A,(HL)
2229  A18B C9                   RET
2230  A18C              ; ----------------------------------------------------------------------
2231  A18C              ; RECPTR_INC_STORE -- If the current record is at or past the stored high-water count, bump the
2232  A18C              ; count to one past it.
2233  A18C              ;   In: CUR_RECORD = the record number just processed; DPB_WORK_PTR0 holds a pointer to a 16-bit
2234  A18C              ;       record-count cell.
2235  A18C              ;   Out: If CUR_RECORD >= (count cell), the cell is set to CUR_RECORD+1. Otherwise unchanged. DE =
2236  A18C              ;        CUR_RECORD (then +1 if updated); HL left pointing into the count cell.
2237  A18C              ;   Clobbers: A, DE, HL, flags.
2238  A18C              ;   Algorithm: Call CMP_CURREC_VS_WORKPTR, which computes CUR_RECORD - (count cell) and leaves DE =
2239  A18C              ;              CUR_RECORD, HL -> the cell's high byte. RET C (carry = borrow = CUR_RECORD < count,
2240  A18C              ;              so the stored count is already larger -> leave it). Otherwise DE := CUR_RECORD+1 and
2241  A18C              ;              write it back HIGH byte first (LD (HL),D), DEC HL, then LOW byte (LD (HL),E).
2242  A18C              ;   [RE] Classic CP/M 2.2 BDOS extent record-count bump; keeps the FCB's high-water record one past
2243  A18C              ;   the last accessed.
2244  A18C              ; ----------------------------------------------------------------------
2245  A18C              RECPTR_INC_STORE:
2246  A18C                      ; compute CUR_RECORD - (count cell); carry => CUR_RECORD below the stored count; leaves HL
2247  A18C                      ; -> cell high byte, DE = CUR_RECORD
2248  A18C CD 7F A1             CALL CMP_CURREC_VS_WORKPTR
2249  A18F                      ; CUR_RECORD < stored count -- count is already ahead, nothing to advance
2250  A18F D8                   RET C
2251  A190                      ; DE = CUR_RECORD + 1 (one past the record just used)
2252  A190 13                   INC DE
2253  A191                      ; HL points at the count cell high byte (left there by CMP_CURREC_VS_WORKPTR); write new
2254  A191                      ; high byte
2255  A191 72                   LD (HL),D
2256  A192                      ; step back to the count cell low byte
2257  A192 2B                   DEC HL
2258  A193                      ; write new count low byte
2259  A193 73                   LD (HL),E
2260  A194 C9                   RET
2261  A195              ; ----------------------------------------------------------------------
2262  A195              ; SUB16_DE_HL -- 16-bit subtract HL := DE - HL.
2263  A195              ;   In: DE = minuend, HL = subtrahend.
2264  A195              ;   Out: HL = DE - HL; carry set on borrow (DE < HL unsigned). A holds the high-byte result.
2265  A195              ;   Clobbers: A, HL, flags. DE preserved.
2266  A195              ;   Algorithm: Subtract low bytes (E - L) -> L, then high bytes with borrow (D - H) -> H.
2267  A195              ;   [RE] General BDOS 16-bit compare/difference helper used by the record scan and seek logic.
2268  A195              ; ----------------------------------------------------------------------
2269  A195              SUB16_DE_HL:
2270  A195 7B                   LD A,E
2271  A196                      ; low byte: E - L
2272  A196 95                   SUB L
2273  A197                      ; store low result
2274  A197 6F                   LD L,A
2275  A198 7A                   LD A,D
2276  A199                      ; high byte: D - H with borrow; carry out = unsigned borrow
2277  A199 9C                   SBC A,H
2278  A19A                      ; store high result; HL = DE - HL
2279  A19A 67                   LD H,A
2280  A19B C9                   RET
2281  A19C              ; ----------------------------------------------------------------------
2282  A19C              ; RECORD_SCAN_INIT -- Enter the directory-record scan in store mode (write A into the located byte
2283  A19C              ; rather than compare it).
2284  A19C              ;   In: see RECORD_SCAN_BODY.
2285  A19C              ;   Out: see RECORD_SCAN_BODY.
2286  A19C              ;   Clobbers: A, BC, DE, HL, flags.
2287  A19C              ;   Algorithm: Set C = $FF so the INC C inside RECORD_SCAN_BODY wraps to 0 (Z) and takes the store
2288  A19C              ;              branch (FCB_STORE_A_ORPHAN), then fall through into RECORD_SCAN_BODY.
2289  A19C              ;   [RE] Thin mode-selecting entry to the shared directory-record scan.
2290  A19C              ; ----------------------------------------------------------------------
2291  A19C              RECORD_SCAN_INIT:
2292  A19C                      ; C=$FF -> INC C in scan body wraps to 0 (Z) -> take the store branch
2293  A19C 0E FF                LD C,$FF
2294  A19E              ; ----------------------------------------------------------------------
2295  A19E              ; RECORD_SCAN_BODY -- Scan to the target byte in the cached directory record, then either store A
2296  A19E              ; there or compare A against it.
2297  A19E              ;   In: C = mode (INC C wraps to 0 => store mode, else compare mode); REC_CACHE = cached record
2298  A19E              ;       cursor; REC_SCAN_PTR = scan limit; REC_BYTE_OFFSET = byte offset within the record; A = byte
2299  A19E              ;       to store/compare; DIRBUF (via DIRBUF_PTR) holds the loaded directory record.
2300  A19E              ;   Out: store mode writes A and returns via FCB_STORE_A_ORPHAN. Compare mode: returns Z on a match;
2301  A19E              ;        if no match and CUR_RECORD is past the stored count it flags the drive read-only
2302  A19E              ;        (DRV_SETRO_H). If REC_CACHE - REC_SCAN_PTR did not borrow, returns NC (nothing to do).
2303  A19E              ;   Clobbers: A, BC, DE, HL, flags.
2304  A19E              ;   Algorithm: DE := REC_CACHE, HL := REC_SCAN_PTR; SUB16_DE_HL (HL = REC_CACHE - REC_SCAN_PTR); RET
2305  A19E              ;              NC if no borrow. Else checksum the directory buffer (DIR_CHECKSUM), add REC_BYTE_OFFSET
2306  A19E              ;              to REC_CACHE to address the target byte. INC C: if it wrapped to 0, store A there.
2307  A19E              ;              Otherwise CP (HL); RET Z on match. On mismatch CMP_CURREC_VS_WORKPTR; RET NC if
2308  A19E              ;              within the record count, else DRV_SETRO_H.
2309  A19E              ;   [RE] Heart of the directory record scan/checksum loop in the BDOS deblocking layer.
2310  A19E              ; ----------------------------------------------------------------------
2311  A19E              RECORD_SCAN_BODY:
2312  A19E                      ; DE := cached record cursor (after the following EX DE,HL)
2313  A19E 2A EC A9             LD HL,(REC_CACHE)
2314  A1A1 EB                   EX DE,HL
2315  A1A2                      ; HL := scan limit pointer
2316  A1A2 2A CC A9             LD HL,(REC_SCAN_PTR)
2317  A1A5                      ; HL = REC_CACHE - REC_SCAN_PTR; carry (borrow) => still in range
2318  A1A5 CD 95 A1             CALL SUB16_DE_HL
2319  A1A8                      ; no borrow (cursor at/past limit) -> return, caller sees not-found
2320  A1A8 D0                   RET NC
2321  A1A9 C5                   PUSH BC
2322  A1AA                      ; sum the 128-byte directory buffer (DIRBUF) -- the change-detect checksum
2323  A1AA CD F7 A0             CALL DIR_CHECKSUM
2324  A1AD                      ; DE := byte offset within the record (after the following EX DE,HL)
2325  A1AD 2A BD A9             LD HL,(REC_BYTE_OFFSET)
2326  A1B0 EB                   EX DE,HL
2327  A1B1 2A EC A9             LD HL,(REC_CACHE)
2328  A1B4                      ; HL -> the target byte inside the cached record
2329  A1B4 19                   ADD HL,DE
2330  A1B5 C1                   POP BC
2331  A1B6                      ; advance mode; if it wraps to 0 this is store mode
2332  A1B6 0C                   INC C
2333  A1B7                      ; store mode: write A into the directory byte and return
2334  A1B7 CA C4 A1             JP Z,FCB_STORE_A_ORPHAN
2335  A1BA                      ; compare mode: compare A with the directory byte
2336  A1BA BE                   CP (HL)
2337  A1BB                      ; match found -> return Z
2338  A1BB C8                   RET Z
2339  A1BC                      ; no match: is CUR_RECORD within the stored record count?
2340  A1BC CD 7F A1             CALL CMP_CURREC_VS_WORKPTR
2341  A1BF                      ; within the record count -> just return
2342  A1BF D0                   RET NC
2343  A1C0                      ; past end with a mismatch -> set the drive read-only (protect)
2344  A1C0 CD 2C A1             CALL DRV_SETRO_H
2345  A1C3 C9                   RET
2346  A1C4              ; ----------------------------------------------------------------------
2347  A1C4              ; FCB_STORE_A_ORPHAN -- Store the accumulator into the directory byte addressed by HL (scan
2348  A1C4              ; store-mode tail).
2349  A1C4              ;   In: HL -> target directory byte; A = value to store.
2350  A1C4              ;   Out: (HL) = A.
2351  A1C4              ;   Clobbers: nothing (memory only).
2352  A1C4              ;   Algorithm: LD (HL),A; RET.
2353  A1C4              ;   [RE] Store-mode terminator branched to from RECORD_SCAN_BODY when INC C wrapped to 0.
2354  A1C4              ; ----------------------------------------------------------------------
2355  A1C4              FCB_STORE_A_ORPHAN:
2356  A1C4                      ; write the byte into the directory record
2357  A1C4 77                   LD (HL),A
2358  A1C5 C9                   RET
2359  A1C6              ; ----------------------------------------------------------------------
2360  A1C6              ; DIR_RECORD_WRITE -- Checksum-verify then write the directory buffer to disk as a record, and
2361  A1C6              ; refresh the user buffer.
2362  A1C6              ;   In: directory buffer (DIRBUF) and the BDOS deblock state set up by the caller.
2363  A1C6              ;   Out: the record is written to disk (with the R/O-on-tamper check); user DMA restored; errors
2364  A1C6              ;        raised via DISK_WRITE_CHECKED.
2365  A1C6              ;   Clobbers: A, BC, DE, HL, flags.
2366  A1C6              ;   Algorithm: RECORD_SCAN_INIT runs the scan in store mode (re-checksums the directory buffer and
2367  A1C6              ;              sets the drive R/O on a tamper mismatch). SET_DMA_TO_DISK_BUF aims the BIOS DMA at
2368  A1C6              ;              DIRBUF; C=1 selects the directory write type; DISK_WRITE_CHECKED issues the BIOS
2369  A1C6              ;              WRITE and raises on error; JP RESTORE_USER_DMA restores the user DMA.
2370  A1C6              ;   [RE] Directory-record write path; C=1 is the CP/M deblock directory-write code (BIOS WRITE
2371  A1C6              ;   vector $AA2A).
2372  A1C6              ; ----------------------------------------------------------------------
2373  A1C6              DIR_RECORD_WRITE:
2374  A1C6                      ; re-checksum the directory buffer / set R/O on a tamper mismatch before writing
2375  A1C6 CD 9C A1             CALL RECORD_SCAN_INIT
2376  A1C9                      ; point BIOS DMA at the directory buffer (DIRBUF)
2377  A1C9 CD E0 A1             CALL SET_DMA_TO_DISK_BUF
2378  A1CC                      ; deblock write type 1 = directory write
2379  A1CC 0E 01                LD C,$01
2380  A1CE                      ; BIOS sector WRITE ($AA2A) + raise on error
2381  A1CE CD B8 9F             CALL DISK_WRITE_CHECKED
2382  A1D1                      ; restore the user DMA address and return
2383  A1D1 C3 DA A1             JP RESTORE_USER_DMA
2384  A1D4              ; ----------------------------------------------------------------------
2385  A1D4              ; DIR_RECORD_READ -- Read a directory record from disk into the directory buffer, then restore the
2386  A1D4              ; user DMA.
2387  A1D4              ;   In: BDOS deblock state set up by the caller.
2388  A1D4              ;   Out: DIRBUF filled from disk; user DMA restored; errors raised via DISK_READ_CHECKED.
2389  A1D4              ;   Clobbers: A, BC, DE, HL, flags.
2390  A1D4              ;   Algorithm: SET_DMA_TO_DISK_BUF (aim BIOS DMA at DIRBUF), DISK_READ_CHECKED (BIOS READ vector
2391  A1D4              ;              $AA27 + error check), then fall through into RESTORE_USER_DMA to restore the user DMA
2392  A1D4              ;              address.
2393  A1D4              ;   [RE] Directory-record read path; pairs with DIR_RECORD_WRITE.
2394  A1D4              ; ----------------------------------------------------------------------
2395  A1D4              DIR_RECORD_READ:
2396  A1D4                      ; point BIOS DMA at the directory buffer (DIRBUF)
2397  A1D4 CD E0 A1             CALL SET_DMA_TO_DISK_BUF
2398  A1D7                      ; BIOS sector READ ($AA27) + raise on error
2399  A1D7 CD B2 9F             CALL DISK_READ_CHECKED
2400  A1DA              ; ----------------------------------------------------------------------
2401  A1DA              ; RESTORE_USER_DMA -- Restore the BIOS DMA address to the user's DMA buffer.
2402  A1DA              ;   In: DMA_ADDR cell holds the user DMA address.
2403  A1DA              ;   Out: BIOS DMA set to (DMA_ADDR) via the BIOS SETDMA vector.
2404  A1DA              ;   Clobbers: BC, HL, flags.
2405  A1DA              ;   Algorithm: HL := address of the DMA_ADDR cell, then JP SET_DMA_FROM_CELL which loads BC from the
2406  A1DA              ;              cell and jumps to the BIOS SETDMA vector ($AA24).
2407  A1DA              ;   [RE] Used after directory I/O to put DMA back to the application buffer.
2408  A1DA              ; ----------------------------------------------------------------------
2409  A1DA              RESTORE_USER_DMA:
2410  A1DA                      ; HL -> the saved user DMA address cell
2411  A1DA 21 B1 A9             LD HL,DMA_ADDR
2412  A1DD                      ; load BC from the cell and call BIOS SETDMA
2413  A1DD C3 E3 A1             JP SET_DMA_FROM_CELL
2414  A1E0              ; ----------------------------------------------------------------------
2415  A1E0              ; SET_DMA_TO_DISK_BUF -- Point the BIOS DMA at the directory/disk buffer (DIRBUF).
2416  A1E0              ;   In: DIRBUF_PTR cell holds the directory buffer address.
2417  A1E0              ;   Out: BIOS DMA set to (DIRBUF_PTR) via the BIOS SETDMA vector.
2418  A1E0              ;   Clobbers: BC, HL, flags.
2419  A1E0              ;   Algorithm: HL := address of the DIRBUF_PTR cell, fall into SET_DMA_FROM_CELL: load BC from (HL)
2420  A1E0              ;              and jump to the BIOS SETDMA vector ($AA24).
2421  A1E0              ;   [RE] Companion to RESTORE_USER_DMA; aims I/O at the OS directory buffer.
2422  A1E0              ; ----------------------------------------------------------------------
2423  A1E0              SET_DMA_TO_DISK_BUF:
2424  A1E0                      ; HL -> the directory buffer pointer cell
2425  A1E0 21 B9 A9             LD HL,DIRBUF_PTR
2426  A1E3              ; ----------------------------------------------------------------------
2427  A1E3              ; SET_DMA_FROM_CELL -- Load a DMA address from a 16-bit cell and hand it to the BIOS SETDMA vector.
2428  A1E3              ;   In: HL -> a 2-byte little-endian DMA address cell.
2429  A1E3              ;   Out: BIOS DMA set to (HL); tail-jumps into the BIOS SETDMA jump vector at $AA24.
2430  A1E3              ;   Clobbers: BC, HL.
2431  A1E3              ;   Algorithm: C := (HL), INC HL, B := (HL) so BC = the 16-bit address; JP $AA24 (BIOS SETDMA entry
2432  A1E3              ;              in the BDOS->BIOS jump-vector page).
2433  A1E3              ;   [RE] Shared tail of SET_DMA_TO_DISK_BUF and RESTORE_USER_DMA. $AA24 is the BIOS SETDMA jump cell
2434  A1E3              ;   (13th jump-table entry).
2435  A1E3              ; ----------------------------------------------------------------------
2436  A1E3              SET_DMA_FROM_CELL:
2437  A1E3                      ; BC low byte := DMA address low from the cell
2438  A1E3 4E                   LD C,(HL)
2439  A1E4 23                   INC HL
2440  A1E5                      ; BC high byte := DMA address high (HL advanced by the preceding INC HL)
2441  A1E5 46                   LD B,(HL)
2442  A1E6                      ; tail-jump to the BIOS SETDMA jump vector
2443  A1E6 C3 24 AA             JP $AA24
2444  A1E9              ; ----------------------------------------------------------------------
2445  A1E9              ; DISK_BUF_MOVE -- Copy the 128-byte directory buffer into the user DMA buffer.
2446  A1E9              ;   In: DIRBUF_PTR -> source (directory buffer); DMA_ADDR -> destination (user DMA).
2447  A1E9              ;   Out: 128 bytes copied DIRBUF -> user DMA.
2448  A1E9              ;   Clobbers: A, BC, DE, HL, flags.
2449  A1E9              ;   Algorithm: DE := (DIRBUF_PTR) source, HL := (DMA_ADDR) destination, C := $80 (128), JP
2450  A1E9              ;              BLOCK_COPY_INCC (the byte-copy loop moving C bytes from DE to HL).
2451  A1E9              ;   [RE] Deblock read-back: surfaces a directory-sector record to the application buffer.
2452  A1E9              ; ----------------------------------------------------------------------
2453  A1E9              DISK_BUF_MOVE:
2454  A1E9                      ; DE := directory buffer source (after the following EX DE,HL)
2455  A1E9 2A B9 A9             LD HL,(DIRBUF_PTR)
2456  A1EC EB                   EX DE,HL
2457  A1ED                      ; HL := user DMA buffer (copy destination)
2458  A1ED 2A B1 A9             LD HL,(DMA_ADDR)
2459  A1F0                      ; 128 bytes = one CP/M record
2460  A1F0 0E 80                LD C,$80
2461  A1F2                      ; tail-call the C-byte memory copy loop (DE->HL)
2462  A1F2 C3 4F 9F             JP BLOCK_COPY_INCC
2463  A1F5              ; ----------------------------------------------------------------------
2464  A1F5              ; CUR_RECORD_BYTES_EQUAL -- Test whether the low and high bytes of the 16-bit CUR_RECORD cell are
2465  A1F5              ; equal.
2466  A1F5              ;   In: CUR_RECORD = a 16-bit cell ($A9EA low, $A9EB high).
2467  A1F5              ;   Out: If the two bytes differ, returns NZ with A = the low byte unchanged. If they are equal,
2468  A1F5              ;        returns A = low byte + 1 (and Z cleared by the INC).
2469  A1F5              ;   Clobbers: A, HL, flags.
2470  A1F5              ;   Algorithm: HL -> CUR_RECORD low byte; A := (HL); INC HL (-> high byte); CP (HL); RET NZ if they
2471  A1F5              ;              differ; else INC A and RET.
2472  A1F5              ;   [RE] Deblock helper that compares the two halves of CUR_RECORD; called widely across the BDOS
2473  A1F5              ;   read/write deblock paths. The exact role of the equal/INC result is UNKNOWN from these bytes
2474  A1F5              ;   alone (the callers consume A/the Z flag).
2475  A1F5              ; ----------------------------------------------------------------------
2476  A1F5              CUR_RECORD_BYTES_EQUAL:
2477  A1F5                      ; HL -> CUR_RECORD low byte ($A9EA)
2478  A1F5 21 EA A9             LD HL,CUR_RECORD
2479  A1F8                      ; A := CUR_RECORD low byte
2480  A1F8 7E                   LD A,(HL)
2481  A1F9 23                   INC HL
2482  A1FA                      ; compare low byte against the high byte (HL advanced by the preceding INC HL)
2483  A1FA BE                   CP (HL)
2484  A1FB                      ; bytes differ -> return NZ, A = low byte
2485  A1FB C0                   RET NZ
2486  A1FC                      ; bytes equal -> A = low byte + 1 (also clears Z)
2487  A1FC 3C                   INC A
2488  A1FD C9                   RET
2489  A1FE              ; ----------------------------------------------------------------------
2490  A1FE              ; INVALIDATE_CUR_RECORD -- Mark the cached record pointer invalid (CUR_RECORD := $FFFF).
2491  A1FE              ;   In: none.
2492  A1FE              ;   Out: CUR_RECORD cell = $FFFF.
2493  A1FE              ;   Clobbers: HL.
2494  A1FE              ;   Algorithm: HL := $FFFF; store to CUR_RECORD; RET.
2495  A1FE              ;   [RE] Forces the next deblock access to reload, since $FFFF can never equal a real record number.
2496  A1FE              ; ----------------------------------------------------------------------
2497  A1FE              INVALIDATE_CUR_RECORD:
2498  A1FE                      ; sentinel: no record cached
2499  A1FE 21 FF FF             LD HL,$FFFF
2500  A201                      ; invalidate the cached current-record value
2501  A201 22 EA A9             LD (CUR_RECORD),HL
2502  A204 C9                   RET
2503  A205              ; ----------------------------------------------------------------------
2504  A205              ; DIR_READ_NEXT -- Advance the directory record pointer and read the next directory record.
2505  A205              ;   In: CUR_RECORD = last directory record index processed; DPB_REC_PTR = total directory records on
2506  A205              ;       this drive.
2507  A205              ;   Out: CY/A set per DIR_RECORD_DEBLOCK if a record remains; CUR_RECORD invalidated ($FFFF) when
2508  A205              ;        the directory is exhausted.
2509  A205              ;   Clobbers: A, DE, HL, flags.
2510  A205              ;   Algorithm: increment CUR_RECORD; if it has not passed the directory record count (DPB_REC_PTR)
2511  A205              ;              fall through to DIR_RECORD_DEBLOCK to position on the next 32-byte entry, else mark
2512  A205              ;              end-of-directory via DIR_INVALIDATE_RECORD.
2513  A205              ; [RE] Canonical CP/M 2.2 BDOS read-next-directory-entry sequencer.
2514  A205              ; ----------------------------------------------------------------------
2515  A205              CMD_EXEC_53:
2516  A205                      ; DE = number of directory records on the selected drive (from the DPB).
2517  A205 2A C8 A9             LD HL,(DPB_REC_PTR)
2518  A208 EB                   EX DE,HL
2519  A209 2A EA A9             LD HL,(CUR_RECORD)
2520  A20C                      ; Step to the next directory record index.
2521  A20C 23                   INC HL
2522  A20D 22 EA A9             LD (CUR_RECORD),HL
2523  A210                      ; Compare CUR_RECORD against the directory record count.
2524  A210 CD 95 A1             CALL SUB16_DE_HL
2525  A213                      ; Records remain: deblock and read the next directory record.
2526  A213 D2 19 A2             JP NC,CMD_EXEC_54
2527  A216                      ; Directory exhausted: invalidate CUR_RECORD and return end-of-directory.
2528  A216 C3 FE A1             JP INVALIDATE_CUR_RECORD
2529  A219              ; ----------------------------------------------------------------------
2530  A219              ; DIR_RECORD_DEBLOCK -- Position on the current 32-byte directory entry within its 128-byte record,
2531  A219              ; reading the record from disk on a record boundary.
2532  A219              ;   In: CUR_RECORD = current directory record index.
2533  A219              ;   Out: DEBLOCK_BYTE_OFF = byte offset (0/32/64/96) of this entry inside the directory buffer; on a
2534  A219              ;        fresh record the directory record has been read into the disk buffer.
2535  A219              ;   Clobbers: A, BC, DE, HL, flags.
2536  A219              ;   Algorithm: entries-per-record offset = (CUR_RECORD & 3) << 5; store it; if the offset is
2537  A219              ;              non-zero the entry is already in the buffer so return; on a record boundary (offset
2538  A219              ;              0) compute the absolute disk record and read it into the directory buffer.
2539  A219              ; [RE] CP/M packs four 32-byte directory entries per 128-byte record; this is the BDOS deblocking
2540  A219              ; step.
2541  A219              ; ----------------------------------------------------------------------
2542  A219              CMD_EXEC_54:
2543  A219 3A EA A9             LD A,(CUR_RECORD)
2544  A21C                      ; Index of this entry within its 4-entry directory record.
2545  A21C E6 03                AND $03
2546  A21E                      ; Shift count: multiply by 32 to get the byte offset of the entry.
2547  A21E 06 05                LD B,$05
2548  A220              DIR_DEBLOCK_SHIFT:
2549  A220 87                   ADD A,A
2550  A221 05                   DEC B
2551  A222 C2 20 A2             JP NZ,DIR_DEBLOCK_SHIFT
2552  A225                      ; Byte offset (0/32/64/96) of this entry within the 128-byte directory buffer.
2553  A225 32 E9 A9             LD (DEBLOCK_BYTE_OFF),A
2554  A228 B7                   OR A
2555  A229                      ; Entry not on a record boundary: the record is already buffered, done.
2556  A229 C0                   RET NZ
2557  A22A C5                   PUSH BC
2558  A22B                      ; Resolve the directory record's physical disk location (block/record math).
2559  A22B CD C3 9F             CALL REC_DIV4_SETUP
2560  A22E                      ; Read the directory record into the disk buffer.
2561  A22E CD D4 A1             CALL DIR_RECORD_READ
2562  A231 C1                   POP BC
2563  A232                      ; Re-evaluate the record-scan state after the read.
2564  A232 C3 9E A1             JP RECORD_SCAN_BODY
2565  A235              ; ----------------------------------------------------------------------
2566  A235              ; ALLOC_BIT_GET -- Fetch the allocation-vector bit for a given disk block, returning it in carry.
2567  A235              ;   In: BC = block (group) number.
2568  A235              ;   Out: carry/high bit of A = current allocation state of that block; A = the allocation byte
2569  A235              ;        rotated so the wanted bit is in the MSB; HL = address of that byte in the allocation
2570  A235              ;        vector; D = E = bit index (rotate count).
2571  A235              ;   Clobbers: A, BC, DE, HL, flags.
2572  A235              ;   Algorithm: D=E=(block & 7)+1 = bit index (1-based) used as a rotate count; byte index = block >>
2573  A235              ;              3; add to ALLOC_VEC_PTR; load the byte and rotate left by the bit index so the
2574  A235              ;              selected bit ends up in carry/MSB.
2575  A235              ; [RE] Canonical CP/M 2.2 getmod: read one allocation bit from the bit-vector.
2576  A235              ; ----------------------------------------------------------------------
2577  A235              CMD_EXEC_56:
2578  A235 79                   LD A,C
2579  A236                      ; Low 3 bits = bit position of the block within its allocation byte.
2580  A236 E6 07                AND $07
2581  A238                      ; 1-based rotate count to bring the wanted bit into the MSB.
2582  A238 3C                   INC A
2583  A239                      ; Save the bit index in both D and E (E consumed here; D consumed by ALLOC_BIT_SET on the
2584  A239                      ; way back).
2585  A239 5F                   LD E,A
2586  A23A 57                   LD D,A
2587  A23B 79                   LD A,C
2588  A23C 0F                   RRCA
2589  A23D 0F                   RRCA
2590  A23E 0F                   RRCA
2591  A23F                      ; Form the byte index (block >> 3), low half of the 16-bit offset.
2592  A23F E6 1F                AND $1F
2593  A241 4F                   LD C,A
2594  A242 78                   LD A,B
2595  A243 87                   ADD A,A
2596  A244 87                   ADD A,A
2597  A245 87                   ADD A,A
2598  A246 87                   ADD A,A
2599  A247 87                   ADD A,A
2600  A248                      ; Combine high/low pieces of the (block>>3) byte offset.
2601  A248 B1                   OR C
2602  A249 4F                   LD C,A
2603  A24A 78                   LD A,B
2604  A24B 0F                   RRCA
2605  A24C 0F                   RRCA
2606  A24D 0F                   RRCA
2607  A24E E6 1F                AND $1F
2608  A250 47                   LD B,A
2609  A251                      ; Base of the in-memory allocation bit-vector for this drive.
2610  A251 2A BF A9             LD HL,(ALLOC_VEC_PTR)
2611  A254                      ; HL -> the allocation byte holding this block's bit.
2612  A254 09                   ADD HL,BC
2613  A255                      ; Load that allocation byte.
2614  A255 7E                   LD A,(HL)
2615  A256              ALLOC_BIT_ROTATE:
2616  A256 07                   RLCA
2617  A257 1D                   DEC E
2618  A258 C2 56 A2             JP NZ,ALLOC_BIT_ROTATE
2619  A25B C9                   RET
2620  A25C              ; ----------------------------------------------------------------------
2621  A25C              ; ALLOC_BIT_SET -- Mark a disk block as allocated in the allocation vector.
2622  A25C              ;   In: BC = block (group) number.
2623  A25C              ;   Out: the allocation byte for that block is updated in place with its bit forced to 1.
2624  A25C              ;   Clobbers: A, BC, DE, HL, flags.
2625  A25C              ;   Algorithm: call ALLOC_BIT_GET to read the byte (left-rotated so the bit is in the MSB) and
2626  A25C              ;              return the bit index in D; clear the rotated LSB and OR in 1 to set the target bit;
2627  A25C              ;              rotate right D times to restore byte alignment; store it back via HL.
2628  A25C              ; [RE] Canonical CP/M 2.2 setmod: set one allocation bit in the bit-vector.
2629  A25C              ; ----------------------------------------------------------------------
2630  A25C              CMD_EXEC_60:
2631  A25C D5                   PUSH DE
2632  A25D                      ; Read the allocation byte rotated so the target bit is in the MSB (D = bit index).
2633  A25D CD 35 A2             CALL CMD_EXEC_56
2634  A260                      ; Clear the rotated LSB; the following OR C forces this block's bit to 1.
2635  A260 E6 FE                AND $FE
2636  A262                      ; Recover the saved bit value (in C) to OR into the rotated byte.
2637  A262 C1                   POP BC
2638  A263                      ; Set the target allocation bit.
2639  A263 B1                   OR C
2640  A264              ALLOC_BIT_RESTORE:
2641  A264 0F                   RRCA
2642  A265 15                   DEC D
2643  A266 C2 64 A2             JP NZ,ALLOC_BIT_RESTORE
2644  A269                      ; Store the updated allocation byte back into the bit-vector.
2645  A269 77                   LD (HL),A
2646  A26A C9                   RET
2647  A26B              ; ----------------------------------------------------------------------
2648  A26B              ; ALLOC_FROM_FCB -- Mark every disk block referenced by a directory entry's block map as allocated.
2649  A26B              ;   In: DEBLOCK_BYTE_OFF positions HL on the current 32-byte directory entry; BLOCK_WIDTH_FLAG
2650  A26B              ;       selects 8-bit (non-zero, DSM<256) vs 16-bit (zero) block numbers; entry contains a 16-byte
2651  A26B              ;       block-pointer map at offset $10.
2652  A26B              ;   Out: the allocation vector has every non-zero, in-range block of this entry marked used.
2653  A26B              ;   Clobbers: A, BC, DE, HL, flags.
2654  A26B              ;   Algorithm: point HL at the block map (entry+$10); iterate 16 (8-bit) or 8 (16-bit) pointers;
2655  A26B              ;              read each block number; if non-zero and <= MAX_BLOCK_DSM, mark it allocated via
2656  A26B              ;              ALLOC_BIT_SET.
2657  A26B              ; [RE] Canonical CP/M 2.2 directory-entry allocation-map application used when rebuilding the
2658  A26B              ; allocation vector.
2659  A26B              ; ----------------------------------------------------------------------
2660  A26B              CMD_EXEC_61:
2661  A26B                      ; HL -> start of the current 32-byte directory entry in the buffer.
2662  A26B CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2663  A26E                      ; Skip to the 16-byte block-pointer map at offset $10 of the entry.
2664  A26E 11 10 00             LD DE,$0010
2665  A271 19                   ADD HL,DE
2666  A272 C5                   PUSH BC
2667  A273                      ; Loop counter: 16 block pointers plus one (decremented before each iteration).
2668  A273 0E 11                LD C,$11
2669  A275              ALLOC_FROM_FCB_LOOP:
2670  A275 D1                   POP DE
2671  A276 0D                   DEC C
2672  A277 C8                   RET Z
2673  A278 D5                   PUSH DE
2674  A279                      ; Non-zero => 8-bit block numbers (DSM<256); zero => 16-bit block numbers.
2675  A279 3A DD A9             LD A,(BLOCK_WIDTH_FLAG)
2676  A27C B7                   OR A
2677  A27D CA 88 A2             JP Z,ALLOC_FROM_FCB_WIDE
2678  A280 C5                   PUSH BC
2679  A281 E5                   PUSH HL
2680  A282                      ; Read one block-pointer byte (low byte of the block number; 8-bit path).
2681  A282 4E                   LD C,(HL)
2682  A283 06 00                LD B,$00
2683  A285 C3 8E A2             JP ALLOC_FROM_FCB_CHECK
2684  A288              ALLOC_FROM_FCB_WIDE:
2685  A288 0D                   DEC C
2686  A289 C5                   PUSH BC
2687  A28A 4E                   LD C,(HL)
2688  A28B 23                   INC HL
2689  A28C 46                   LD B,(HL)
2690  A28D E5                   PUSH HL
2691  A28E              ALLOC_FROM_FCB_CHECK:
2692  A28E 79                   LD A,C
2693  A28F B0                   OR B
2694  A290 CA 9D A2             JP Z,ALLOC_FROM_FCB_NEXT
2695  A293                      ; DSM = highest valid block number for this drive.
2696  A293 2A C6 A9             LD HL,(MAX_BLOCK_DSM)
2697  A296 7D                   LD A,L
2698  A297                      ; Range-check the block number against DSM (16-bit subtract: LD A,L/SUB C then LD A,H/SBC
2699  A297                      ; A,B).
2700  A297 91                   SUB C
2701  A298 7C                   LD A,H
2702  A299 98                   SBC A,B
2703  A29A                      ; In range and non-zero: mark this block allocated.
2704  A29A D4 5C A2             CALL NC,CMD_EXEC_60
2705  A29D              ALLOC_FROM_FCB_NEXT:
2706  A29D E1                   POP HL
2707  A29E 23                   INC HL
2708  A29F C1                   POP BC
2709  A2A0 C3 75 A2             JP ALLOC_FROM_FCB_LOOP
2710  A2A3              ; ----------------------------------------------------------------------
2711  A2A3              ; ALLOC_VECTOR_BUILD -- Rebuild the drive's allocation bit-vector by scanning the entire directory.
2712  A2A3              ;   In: selected drive's DPB fields (MAX_BLOCK_DSM, directory-reserved-blocks word at ALLOC_END_PTR,
2713  A2A3              ;       ALLOC_VEC_PTR) set up.
2714  A2A3              ;   Out: allocation vector fully populated: reserved directory blocks plus every block referenced by
2715  A2A3              ;        a non-deleted directory entry are marked used.
2716  A2A3              ;   Clobbers: A, BC, DE, HL, flags.
2717  A2A3              ;   Algorithm: zero the allocation vector across its whole length ((DSM+1)/8 bytes); seed the
2718  A2A3              ;              directory's reserved blocks; reset the scan workspace to read the directory from the
2719  A2A3              ;              start; for each directory entry skip deleted ($E5) entries, run a special-entry check
2720  A2A3              ;              against the BDOS default-FCB byte / '$' name byte, and call ALLOC_FROM_FCB to mark
2721  A2A3              ;              its blocks; advance to the next entry until the directory is exhausted.
2722  A2A3              ; [RE] Canonical CP/M 2.2 drive-init allocation-vector builder, invoked on drive selection / reset.
2723  A2A3              ; [?] The compare against ($9F41) (BDOS default-FCB area) followed by the $24 ('$') name-byte test
2724  A2A3              ; and the ($9F45) flag store is a special-entry path; its exact intent is UNKNOWN.
2725  A2A3              ; ----------------------------------------------------------------------
2726  A2A3              CMD_EXEC_65:
2727  A2A3                      ; DSM = highest block number; +1 gives the block count to clear.
2728  A2A3 2A C6 A9             LD HL,(MAX_BLOCK_DSM)
2729  A2A6                      ; Shift count 3: (DSM+1)/8 = number of bytes in the allocation vector.
2730  A2A6 0E 03                LD C,$03
2731  A2A8                      ; HL >>= 3 to convert block count into allocation-byte count.
2732  A2A8 CD EA A0             CALL DRV_INSTALL_RWTS_10
2733  A2AB 23                   INC HL
2734  A2AC 44                   LD B,H
2735  A2AD 4D                   LD C,L
2736  A2AE                      ; Start of the allocation vector to be cleared.
2737  A2AE 2A BF A9             LD HL,(ALLOC_VEC_PTR)
2738  A2B1              ALLOC_VECTOR_CLEAR_LOOP:
2739  A2B1                      ; Zero one allocation byte.
2740  A2B1 36 00                LD (HL),$00
2741  A2B3 23                   INC HL
2742  A2B4 0B                   DEC BC
2743  A2B5 78                   LD A,B
2744  A2B6 B1                   OR C
2745  A2B7 C2 B1 A2             JP NZ,ALLOC_VECTOR_CLEAR_LOOP
2746  A2BA                      ; Reserved-blocks mask word: the directory's pre-allocated blocks.
2747  A2BA 2A CA A9             LD HL,(ALLOC_END_PTR)
2748  A2BD EB                   EX DE,HL
2749  A2BE 2A BF A9             LD HL,(ALLOC_VEC_PTR)
2750  A2C1                      ; Seed the allocation vector with the reserved (directory) blocks.
2751  A2C1 73                   LD (HL),E
2752  A2C2 23                   INC HL
2753  A2C3 72                   LD (HL),D
2754  A2C4                      ; Reset the directory scan state to the beginning.
2755  A2C4 CD A1 9F             CALL DISK_HOME_CLEAR_SCAN
2756  A2C7 2A B3 A9             LD HL,(DPB_WORK_PTR0)
2757  A2CA                      ; Initialise the scan record-count workspace.
2758  A2CA 36 03                LD (HL),$03
2759  A2CC 23                   INC HL
2760  A2CD 36 00                LD (HL),$00
2761  A2CF                      ; Invalidate CUR_RECORD so the first read positions at directory start.
2762  A2CF CD FE A1             CALL INVALIDATE_CUR_RECORD
2763  A2D2              ALLOC_VECTOR_SCAN_LOOP:
2764  A2D2                      ; Search-all sentinel: advance unconditionally through every directory record.
2765  A2D2 0E FF                LD C,$FF
2766  A2D4                      ; Advance to and deblock the next directory entry.
2767  A2D4 CD 05 A2             CALL CMD_EXEC_53
2768  A2D7                      ; Test for end-of-directory; Z => done scanning.
2769  A2D7 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2770  A2DA                      ; Whole directory scanned: allocation vector is complete.
2771  A2DA C8                   RET Z
2772  A2DB                      ; HL -> the current directory entry's first byte (user/status code).
2773  A2DB CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2774  A2DE                      ; $E5 = deleted/empty directory entry marker.
2775  A2DE 3E E5                LD A,$E5
2776  A2E0                      ; Skip deleted entries; they own no blocks.
2777  A2E0 BE                   CP (HL)
2778  A2E1                      ; Deleted entry: move to the next directory entry.
2779  A2E1 CA D2 A2             JP Z,ALLOC_VECTOR_SCAN_LOOP
2780  A2E4                      ; Special-entry check: compare the entry's first byte against the BDOS default-FCB byte
2781  A2E4                      ; ($9F41); exact purpose UNKNOWN.
2782  A2E4 3A 41 9F             LD A,(BDOS_STACK_TOP)
2783  A2E7 BE                   CP (HL)
2784  A2E8 C2 F6 A2             JP NZ,ALLOC_VECTOR_SCAN_MARK
2785  A2EB 23                   INC HL
2786  A2EC 7E                   LD A,(HL)
2787  A2ED                      ; Test the entry's name byte against '$' ($24); part of the special-entry path.
2788  A2ED D6 24                SUB $24
2789  A2EF C2 F6 A2             JP NZ,ALLOC_VECTOR_SCAN_MARK
2790  A2F2 3D                   DEC A
2791  A2F3                      ; Record the special-entry result flag ($9F45); role UNKNOWN.
2792  A2F3 32 45 9F             LD (BDOS_RETVAL),A
2793  A2F6              ALLOC_VECTOR_SCAN_MARK:
2794  A2F6                      ; Select 8-bit-block-map width (BLOCK_WIDTH_FLAG non-zero) for the allocation pass.
2795  A2F6 0E 01                LD C,$01
2796  A2F8                      ; Mark every block this directory entry references as allocated.
2797  A2F8 CD 6B A2             CALL CMD_EXEC_61
2798  A2FB                      ; Advance the directory record/scan pointer to the next entry.
2799  A2FB CD 8C A1             CALL RECPTR_INC_STORE
2800  A2FE                      ; Continue the directory scan.
2801  A2FE C3 D2 A2             JP ALLOC_VECTOR_SCAN_LOOP
2802  A301              ; ----------------------------------------------------------------------
2803  A301              ; DIR_RETURN_MATCH_FLAG -- return the saved directory-search match status as the BDOS result.
2804  A301              ;   In: DIR_MATCH_FLAG ($A9D4) holds the result of the last directory scan ($FF=no match, else the
2805  A301              ;       0..3 entry index).
2806  A301              ;   Out: A = DIR_MATCH_FLAG; stored to the BDOS result byte ($9F45) via BDOS_RET_RESULT.
2807  A301              ;   Clobbers: A
2808  A301              ;   Algorithm: load the cached search-match flag and tail-jump into the common result-store path.
2809  A301              ;              Used as the common return tail of F_DELETE_HND/F_RENAME_HND/F_ATTRIB_HND.
2810  A301              ;   [RE]
2811  A301              ; ----------------------------------------------------------------------
2812  A301              DIR_RETURN_MATCH_FLAG:
2813  A301                      ; fetch the directory-search match flag saved by the scan
2814  A301 3A D4 A9             LD A,(DIR_MATCH_FLAG)
2815  A304                      ; store A as the BDOS function result and return
2816  A304 C3 01 9F             JP BDOS_RET_RESULT
2817  A307              ; ----------------------------------------------------------------------
2818  A307              ; FCB_EXTENT_COMPARE -- compare two FCB extent bytes under the drive's extent mask.
2819  A307              ;   In: C = one extent byte; A = the other extent byte; EXTENT_MASK ($A9C5) = DPB EXM.
2820  A307              ;   Out: A,flags = ((A & ~mask) - (C & ~mask)) & $1F; Z set when the high extent fields match.
2821  A307              ;   Clobbers: A (BC/AF saved+restored across the call).
2822  A307              ;   Algorithm: complement EXM, AND it into both extent bytes (dropping the masked low bits),
2823  A307              ;              subtract, keep five bits, and test for equality. BC and AF are pushed/popped, so only
2824  A307              ;              A and flags effectively change.
2825  A307              ;   [RE]
2826  A307              ; ----------------------------------------------------------------------
2827  A307              FCB_EXTENT_COMPARE:
2828  A307 C5                   PUSH BC
2829  A308 F5                   PUSH AF
2830  A309                      ; load the drive extent mask (DPB EXM)
2831  A309 3A C5 A9             LD A,(DPB_EXM)
2832  A30C                      ; complement mask: keep the extent bits, drop the EXM-masked low bits
2833  A30C 2F                   CPL
2834  A30D 47                   LD B,A
2835  A30E 79                   LD A,C
2836  A30F                      ; mask one extent byte (C) with ~EXM
2837  A30F A0                   AND B
2838  A310 4F                   LD C,A
2839  A311 F1                   POP AF
2840  A312                      ; mask the other extent byte (A) the same way
2841  A312 A0                   AND B
2842  A313                      ; compare the two masked extents
2843  A313 91                   SUB C
2844  A314                      ; keep the 5-bit extent field; Z means the extents match
2845  A314 E6 1F                AND $1F
2846  A316 C1                   POP BC
2847  A317 C9                   RET
2848  A318              ; ----------------------------------------------------------------------
2849  A318              ; DIR_SEARCH_FIRST -- begin a directory scan for the current FCB, comparing C bytes per entry.
2850  A318              ;   In: C = number of FCB bytes to match (e.g. $0C=name+type, $0F=incl. extent); FCB pointer in
2851  A318              ;       CURFCB_PTR ($9F43).
2852  A318              ;   Out: falls straight through into BDOS_DIR_SCAN_NEXT, which returns the within-record entry index
2853  A318              ;        0..3 or $FF.
2854  A318              ;   Clobbers: A,B,C,D,E,H,L,flags
2855  A318              ;   Algorithm: set DIR_MATCH_FLAG=$FF, store the compare length ($A9D8) and the search-FCB pointer
2856  A318              ;              ($A9D9), reset the record counter to -1 (INVALIDATE_CUR_RECORD), rewind/clear the
2857  A318              ;              directory scan state (DISK_HOME_CLEAR_SCAN), then run the first search-next pass.
2858  A318              ;   [RE]
2859  A318              ; ----------------------------------------------------------------------
2860  A318              DIR_SEARCH_FIRST:
2861  A318 3E FF                LD A,$FF
2862  A31A                      ; DIR_MATCH_FLAG = $FF (no match yet)
2863  A31A 32 D4 A9             LD (DIR_MATCH_FLAG),A
2864  A31D 21 D8 A9             LD HL,DIR_CMP_LEN
2865  A320                      ; save number of FCB bytes to compare per entry
2866  A320 71                   LD (HL),C
2867  A321                      ; current FCB pointer
2868  A321 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
2869  A324                      ; save the search-FCB pointer for the scan loop
2870  A324 22 D9 A9             LD (DIR_FCB_PTR),HL
2871  A327                      ; reset the directory record counter to -1
2872  A327 CD FE A1             CALL INVALIDATE_CUR_RECORD
2873  A32A                      ; rewind directory scan state / clear the record pointers
2874  A32A CD A1 9F             CALL DISK_HOME_CLEAR_SCAN
2875  A32D              ; ----------------------------------------------------------------------
2876  A32D              ; BDOS_DIR_SCAN_NEXT -- advance through directory entries until one matches the search FCB.
2877  A32D              ;   In: search-FCB pointer in DIR_FCB_PTR ($A9D9); compare length in DIR_CMP_LEN ($A9D8).
2878  A32D              ;   Out: A=matching entry index (0..3) on success (via DIR_MATCH_DONE); not-found via DIR_NO_MATCH
2879  A32D              ;        ($FF result).
2880  A32D              ;   Clobbers: A,B,C,D,E,H,L,flags
2881  A32D              ;   Algorithm: step to the next directory record (CMD_EXEC_53); if the record counter passed the
2882  A32D              ;              directory limit -> not found; otherwise treat erased ($E5) entries specially and
2883  A32D              ;              bound-check the record (CMP_CURREC_VS_WORKPTR), then fall into the per-entry compare;
2884  A32D              ;              on full match -> DIR_MATCH_DONE, else loop to the next entry/record.
2885  A32D              ;   [RE] standard CP/M 2.2 directory search-next with '?' wildcards
2886  A32D              ; ----------------------------------------------------------------------
2887  A32D              BDOS_DIR_SCAN_NEXT:
2888  A32D                      ; scan mode: plain search-next (no special return)
2889  A32D 0E 00                LD C,$00
2890  A32F                      ; advance to the next directory record
2891  A32F CD 05 A2             CALL CMD_EXEC_53
2892  A332 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
2893  A335                      ; record counter passed the directory limit -> not found
2894  A335 CA 94 A3             JP Z,DIR_NO_MATCH
2895  A338                      ; DE := search-FCB pointer
2896  A338 2A D9 A9             LD HL,(DIR_FCB_PTR)
2897  A33B EB                   EX DE,HL
2898  A33C 1A                   LD A,(DE)
2899  A33D                      ; first byte $E5 = empty/erased directory slot
2900  A33D FE E5                CP $E5
2901  A33F CA 4A A3             JP Z,BDOS_DIR_SCAN_NEXT_CMP
2902  A342 D5                   PUSH DE
2903  A343                      ; have we run past the active directory extent?
2904  A343 CD 7F A1             CALL CMP_CURREC_VS_WORKPTR
2905  A346 D1                   POP DE
2906  A347                      ; past end-of-directory -> not found
2907  A347 D2 94 A3             JP NC,DIR_NO_MATCH
2908  A34A              ; ----------------------------------------------------------------------
2909  A34A              ; BDOS_DIR_SCAN_NEXT_CMP -- set up the per-entry compare loop for BDOS_DIR_SCAN_NEXT.
2910  A34A              ;   In: DE -> directory entry; FCB bytes located via FCB_BUF_PTR_ADD_OFFSET; DIR_CMP_LEN ($A9D8)
2911  A34A              ;       bytes to compare.
2912  A34A              ;   Out: B=0 (index), C=compare count; falls into DIR_CMP_BYTE_LOOP.
2913  A34A              ;   Clobbers: A,B,C,H,L,flags
2914  A34A              ;   Algorithm: point HL at the FCB bytes to compare (FCB_BUF_PTR_ADD_OFFSET), load the compare
2915  A34A              ;              length into C, zero the byte index B, then enter the byte-compare loop.
2916  A34A              ;   [RE]
2917  A34A              ; ----------------------------------------------------------------------
2918  A34A              BDOS_DIR_SCAN_NEXT_CMP:
2919  A34A                      ; HL -> FCB bytes to compare against the entry
2920  A34A CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
2921  A34D                      ; load number of bytes to compare per entry
2922  A34D 3A D8 A9             LD A,(DIR_CMP_LEN)
2923  A350 4F                   LD C,A
2924  A351 06 00                LD B,$00
2925  A353              ; ----------------------------------------------------------------------
2926  A353              ; DIR_CMP_BYTE_LOOP -- compare one FCB byte against the directory entry, honoring wildcards.
2927  A353              ;   In: C = bytes remaining; B = byte index within the entry; DE -> entry byte; HL -> FCB byte.
2928  A353              ;   Out: on count exhausted -> DIR_MATCH_FOUND; on mismatch -> restart BDOS_DIR_SCAN_NEXT; else step
2929  A353              ;        via DIR_CMP_ADVANCE.
2930  A353              ;   Clobbers: A,flags (DE,HL,B,C advanced by DIR_CMP_ADVANCE)
2931  A353              ;   Algorithm: count==0 ends the entry as a match; entry byte '?' ($3F) is a wildcard; index 13
2932  A353              ;              ($0D, S1) is skipped; index 12 ($0C) is the extent field (DIR_CMP_EXTENT); otherwise
2933  A353              ;              the two bytes must match in the low 7 bits.
2934  A353              ;   [RE]
2935  A353              ; ----------------------------------------------------------------------
2936  A353              DIR_CMP_BYTE_LOOP:
2937  A353 79                   LD A,C
2938  A354 B7                   OR A
2939  A355                      ; all bytes compared equal -> directory entry matches
2940  A355 CA 83 A3             JP Z,DIR_MATCH_FOUND
2941  A358 1A                   LD A,(DE)
2942  A359                      ; '?' wildcard in the entry byte matches any FCB byte
2943  A359 FE 3F                CP $3F
2944  A35B CA 7C A3             JP Z,DIR_CMP_ADVANCE
2945  A35E 78                   LD A,B
2946  A35F                      ; byte index 13 (S1) is ignored in the compare
2947  A35F FE 0D                CP $0D
2948  A361 CA 7C A3             JP Z,DIR_CMP_ADVANCE
2949  A364                      ; byte index 12 is the extent byte -> special compare
2950  A364 FE 0C                CP $0C
2951  A366 1A                   LD A,(DE)
2952  A367 CA 73 A3             JP Z,DIR_CMP_EXTENT
2953  A36A                      ; ordinary byte: entry byte minus the FCB byte
2954  A36A 96                   SUB (HL)
2955  A36B                      ; mask the attribute high bit; non-zero -> mismatch, rescan
2956  A36B E6 7F                AND $7F
2957  A36D C2 2D A3             JP NZ,BDOS_DIR_SCAN_NEXT
2958  A370 C3 7C A3             JP DIR_CMP_ADVANCE
2959  A373              ; ----------------------------------------------------------------------
2960  A373              ; DIR_CMP_EXTENT -- compare the extent byte during the directory match.
2961  A373              ;   In: HL -> FCB extent byte; A = entry extent byte; B/C preserved across the call.
2962  A373              ;   Out: equal -> DIR_CMP_ADVANCE; unequal -> restart BDOS_DIR_SCAN_NEXT.
2963  A373              ;   Clobbers: A,flags (BC saved+restored)
2964  A373              ;   Algorithm: load the FCB extent byte into C, call FCB_EXTENT_COMPARE on the entry extent (A) and
2965  A373              ;              the FCB extent under the EXM mask; Z continues the compare, NZ rejects this entry.
2966  A373              ;   [RE]
2967  A373              ; ----------------------------------------------------------------------
2968  A373              DIR_CMP_EXTENT:
2969  A373 C5                   PUSH BC
2970  A374 4E                   LD C,(HL)
2971  A375                      ; compare entry vs FCB extents under the EXM mask
2972  A375 CD 07 A3             CALL FCB_EXTENT_COMPARE
2973  A378 C1                   POP BC
2974  A379                      ; extent differs -> reject entry, continue search
2975  A379 C2 2D A3             JP NZ,BDOS_DIR_SCAN_NEXT
2976  A37C              ; ----------------------------------------------------------------------
2977  A37C              ; DIR_CMP_ADVANCE -- step to the next byte of the entry/FCB compare.
2978  A37C              ;   In: DE -> entry byte, HL -> FCB byte, B = index, C = count remaining.
2979  A37C              ;   Out: DE,HL incremented; B incremented; C decremented; loops back to DIR_CMP_BYTE_LOOP.
2980  A37C              ;   Clobbers: B,C,D,E,H,L
2981  A37C              ;   Algorithm: advance both pointers, bump the index, drop the remaining count, re-enter the byte
2982  A37C              ;              loop.
2983  A37C              ;   [RE]
2984  A37C              ; ----------------------------------------------------------------------
2985  A37C              DIR_CMP_ADVANCE:
2986  A37C 13                   INC DE
2987  A37D 23                   INC HL
2988  A37E 04                   INC B
2989  A37F 0D                   DEC C
2990  A380                      ; compare the next byte of the entry
2991  A380 C3 53 A3             JP DIR_CMP_BYTE_LOOP
2992  A383              ; ----------------------------------------------------------------------
2993  A383              ; DIR_MATCH_FOUND -- record a successful directory match and return its index.
2994  A383              ;   In: CUR_RECORD ($A9EA) = current directory record number.
2995  A383              ;   Out: BDOS result byte ($9F45) = record & 3 (entry index 0..3); DIR_MATCH_FLAG cleared to 0 if it
2996  A383              ;        was still negative.
2997  A383              ;   Clobbers: A,H,L,flags
2998  A383              ;   Algorithm: compute the within-record entry index (record mod 4) into the result byte; if
2999  A383              ;              DIR_MATCH_FLAG still has its sign bit set (=$FF, not yet matched), zero it to mark
3000  A383              ;              'matched'.
3001  A383              ;   [RE]
3002  A383              ; ----------------------------------------------------------------------
3003  A383              DIR_MATCH_FOUND:
3004  A383 3A EA A9             LD A,(CUR_RECORD)
3005  A386                      ; entry index within the 128-byte record (4 entries)
3006  A386 E6 03                AND $03
3007  A388                      ; store entry index as the search result
3008  A388 32 45 9F             LD (BDOS_RETVAL),A
3009  A38B                      ; point at DIR_MATCH_FLAG
3010  A38B 21 D4 A9             LD HL,DIR_MATCH_FLAG
3011  A38E 7E                   LD A,(HL)
3012  A38F                      ; test the flag's high bit (still $FF == not yet matched)
3013  A38F 17                   RLA
3014  A390                      ; flag already cleared -> keep it
3015  A390 D0                   RET NC
3016  A391 AF                   XOR A
3017  A392 77                   LD (HL),A
3018  A393 C9                   RET
3019  A394              ; ----------------------------------------------------------------------
3020  A394              ; DIR_NO_MATCH -- terminate a directory scan with 'not found'.
3021  A394              ;   In: none.
3022  A394              ;   Out: BDOS result byte ($9F45) = $FF; record counter reset to -1.
3023  A394              ;   Clobbers: A,H,L,flags
3024  A394              ;   Algorithm: reset the record counter (INVALIDATE_CUR_RECORD) and store $FF as the BDOS result.
3025  A394              ;   [RE]
3026  A394              ; ----------------------------------------------------------------------
3027  A394              DIR_NO_MATCH:
3028  A394                      ; reset the directory record counter to -1
3029  A394 CD FE A1             CALL INVALIDATE_CUR_RECORD
3030  A397                      ; $FF = directory entry not found
3031  A397 3E FF                LD A,$FF
3032  A399                      ; store $FF as the BDOS result
3033  A399 C3 01 9F             JP BDOS_RET_RESULT
3034  A39C              ; ----------------------------------------------------------------------
3035  A39C              ; F_DELETE_HND -- delete every directory entry matching the FCB (BDOS function 19).
3036  A39C              ;   In: CURFCB_PTR ($9F43) -> FCB (may contain '?' wildcards). Reached from F_DELETE_H (dispatch fn
3037  A39C              ;       19).
3038  A39C              ;   Out: matching directory entries marked erased ($E5) and written back; result via the search
3039  A39C              ;        tail.
3040  A39C              ;   Clobbers: A,B,C,D,E,H,L,flags
3041  A39C              ;   Algorithm: log in the drive (CMD_EXEC_20), search-first on 12 FCB bytes (name+type), then fall
3042  A39C              ;              into F_DELETE_LOOP to erase each match.
3043  A39C              ;   [RE] CP/M 2.2 F_DELETE_HND
3044  A39C              ; ----------------------------------------------------------------------
3045  A39C              F_DELETE_HND:
3046  A39C                      ; verify/log in the selected drive
3047  A39C CD 54 A1             CALL CMD_EXEC_20
3048  A39F                      ; compare 12 FCB bytes (name + type, ignore extent)
3049  A39F 0E 0C                LD C,$0C
3050  A3A1                      ; search-first for a matching directory entry
3051  A3A1 CD 18 A3             CALL DIR_SEARCH_FIRST
3052  A3A4              ; ----------------------------------------------------------------------
3053  A3A4              ; F_DELETE_LOOP -- erase-and-write each matching directory entry, then search the next.
3054  A3A4              ;   In: a pending search result from DIR_SEARCH_FIRST/NEXT.
3055  A3A4              ;   Out: returns when no further matches remain.
3056  A3A4              ;   Clobbers: A,B,C,D,E,H,L,flags
3057  A3A4              ;   Algorithm: stop when CUR_RECORD_BYTES_EQUAL reports no match; reject if read-only
3058  A3A4              ;              (FCB_RO_FLAG_TEST); point at the matched entry, set its first byte to $E5, clear the
3059  A3A4              ;              entry's allocation map (CMD_EXEC_61), write the directory record (DIR_RECORD_WRITE),
3060  A3A4              ;              search-next, repeat.
3061  A3A4              ;   [RE]
3062  A3A4              ; ----------------------------------------------------------------------
3063  A3A4              F_DELETE_LOOP:
3064  A3A4                      ; did the previous search find an entry?
3065  A3A4 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3066  A3A7                      ; no more matches -> done
3067  A3A7 C8                   RET Z
3068  A3A8                      ; reject deletion if the file is read-only
3069  A3A8 CD 44 A1             CALL FCB_RO_FLAG_TEST
3070  A3AB CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
3071  A3AE                      ; mark the directory entry as erased
3072  A3AE 36 E5                LD (HL),$E5
3073  A3B0 0E 00                LD C,$00
3074  A3B2                      ; free this entry's allocation-map blocks
3075  A3B2 CD 6B A2             CALL CMD_EXEC_61
3076  A3B5                      ; write the modified directory record back to disk
3077  A3B5 CD C6 A1             CALL DIR_RECORD_WRITE
3078  A3B8                      ; advance to the next matching entry
3079  A3B8 CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
3080  A3BB C3 A4 A3             JP F_DELETE_LOOP
3081  A3BE              ; ----------------------------------------------------------------------
3082  A3BE              ; ALLOC_GET_BLOCK -- find/allocate a disk block near a starting block, marking it used.
3083  A3BE              ;   In: BC = starting block number (passed by the write core when extending a file).
3084  A3BE              ;   Out: HL = the block number actually claimed (0 if none free); its allocation-vector bit set.
3085  A3BE              ;   Clobbers: A,B,C,D,E,H,L,flags
3086  A3BE              ;   Algorithm: copy the start block to DE, scan downward then upward from it testing each block's
3087  A3BE              ;              allocation bit (CMD_EXEC_56 = BLOCK_BIT_TEST), bounded by MAX_BLOCK_DSM; mark the
3088  A3BE              ;              chosen block used (ALLOC_BIT_RESTORE = ALLOC_VEC_SETBIT) and return it, or 0 when no
3089  A3BE              ;              block can be allocated.
3090  A3BE              ;   [RE] allocation-vector block search/allocate
3091  A3BE              ; ----------------------------------------------------------------------
3092  A3BE              ALLOC_GET_BLOCK:
3093  A3BE                      ; copy the starting block number into DE
3094  A3BE 50                   LD D,B
3095  A3BF 59                   LD E,C
3096  A3C0              ; ----------------------------------------------------------------------
3097  A3C0              ; ALLOC_SCAN_DOWN -- scan downward for an in-use block in the run.
3098  A3C0              ;   In: BC = block counter; DE = candidate block; allocation vector via CMD_EXEC_56
3099  A3C0              ;       (BLOCK_BIT_TEST).
3100  A3C0              ;   Out: on an in-use block -> ALLOC_MARK_DONE; otherwise falls into ALLOC_SCAN_UP.
3101  A3C0              ;   Clobbers: A,B,C,D,E,flags
3102  A3C0              ;   Algorithm: while BC != 0, decrement, test the block's bit; if set (in use), finish; else keep
3103  A3C0              ;              scanning down.
3104  A3C0              ;   [RE]
3105  A3C0              ; ----------------------------------------------------------------------
3106  A3C0              ALLOC_SCAN_DOWN:
3107  A3C0 79                   LD A,C
3108  A3C1 B0                   OR B
3109  A3C2                      ; counter exhausted -> switch to upward scan
3110  A3C2 CA D1 A3             JP Z,ALLOC_SCAN_UP
3111  A3C5 0B                   DEC BC
3112  A3C6 D5                   PUSH DE
3113  A3C7 C5                   PUSH BC
3114  A3C8                      ; test this block's allocation-vector bit
3115  A3C8 CD 35 A2             CALL CMD_EXEC_56
3116  A3CB                      ; carry = the tested block's in-use bit
3117  A3CB 1F                   RRA
3118  A3CC                      ; block already in use -> mark and finish
3119  A3CC D2 EC A3             JP NC,ALLOC_MARK_DONE
3120  A3CF C1                   POP BC
3121  A3D0 D1                   POP DE
3122  A3D1              ; ----------------------------------------------------------------------
3123  A3D1              ; ALLOC_SCAN_UP -- scan upward (toward MAX_BLOCK_DSM) for an in-use block.
3124  A3D1              ;   In: DE = candidate block; MAX_BLOCK_DSM ($A9C6) = highest block number on the drive.
3125  A3D1              ;   Out: at/past the disk limit -> ALLOC_SCAN_FINISH; on an in-use block -> ALLOC_MARK_DONE.
3126  A3D1              ;   Clobbers: A,B,C,D,E,H,L,flags
3127  A3D1              ;   Algorithm: compare DE against DSM; if past it, stop; else increment and test the next block's
3128  A3D1              ;              allocation bit (CMD_EXEC_56), looping back to the downward scan.
3129  A3D1              ;   [RE]
3130  A3D1              ; ----------------------------------------------------------------------
3131  A3D1              ALLOC_SCAN_UP:
3132  A3D1                      ; highest valid block number (DSM)
3133  A3D1 2A C6 A9             LD HL,(MAX_BLOCK_DSM)
3134  A3D4 7B                   LD A,E
3135  A3D5 95                   SUB L
3136  A3D6 7A                   LD A,D
3137  A3D7 9C                   SBC A,H
3138  A3D8                      ; candidate beyond disk size -> stop scanning
3139  A3D8 D2 F4 A3             JP NC,ALLOC_SCAN_FINISH
3140  A3DB 13                   INC DE
3141  A3DC C5                   PUSH BC
3142  A3DD D5                   PUSH DE
3143  A3DE 42                   LD B,D
3144  A3DF 4B                   LD C,E
3145  A3E0                      ; test the next block's allocation bit
3146  A3E0 CD 35 A2             CALL CMD_EXEC_56
3147  A3E3                      ; carry = in-use bit
3148  A3E3 1F                   RRA
3149  A3E4                      ; in use -> mark and finish
3150  A3E4 D2 EC A3             JP NC,ALLOC_MARK_DONE
3151  A3E7 D1                   POP DE
3152  A3E8 C1                   POP BC
3153  A3E9 C3 C0 A3             JP ALLOC_SCAN_DOWN
3154  A3EC              ; ----------------------------------------------------------------------
3155  A3EC              ; ALLOC_MARK_DONE -- set the chosen block's allocation bit and return it.
3156  A3EC              ;   In: A = the block's current allocation byte (rotated by the scan); the block number tracked by
3157  A3EC              ;       ALLOC_BIT_RESTORE.
3158  A3EC              ;   Out: allocation vector updated; HL/DE restored from the stack; returns to ALLOC_GET_BLOCK's
3159  A3EC              ;        caller.
3160  A3EC              ;   Clobbers: A,H,L,D,E,flags
3161  A3EC              ;   Algorithm: rotate the in-use bit back into place, force it set (INC A), write it through
3162  A3EC              ;              ALLOC_BIT_RESTORE (ALLOC_VEC_SETBIT), restore the saved registers, and return.
3163  A3EC              ;   [RE]
3164  A3EC              ; ----------------------------------------------------------------------
3165  A3EC              ALLOC_MARK_DONE:
3166  A3EC                      ; rotate the bit back to its position in the allocation byte
3167  A3EC 17                   RLA
3168  A3ED                      ; force the block's bit to 'used'
3169  A3ED 3C                   INC A
3170  A3EE                      ; write the updated bit back into the allocation vector
3171  A3EE CD 64 A2             CALL ALLOC_BIT_RESTORE
3172  A3F1 E1                   POP HL
3173  A3F2 D1                   POP DE
3174  A3F3 C9                   RET
3175  A3F4              ; ----------------------------------------------------------------------
3176  A3F4              ; ALLOC_SCAN_FINISH -- end the block scan when the disk limit is reached.
3177  A3F4              ;   In: BC = remaining block counter; DE = candidate block.
3178  A3F4              ;   Out: if blocks remain -> back to ALLOC_SCAN_DOWN; else HL=0 (no block) and return.
3179  A3F4              ;   Clobbers: A,H,L,flags
3180  A3F4              ;   Algorithm: if the counter is non-zero, resume the downward scan; otherwise return zero meaning
3181  A3F4              ;              no allocatable block was found.
3182  A3F4              ;   [RE]
3183  A3F4              ; ----------------------------------------------------------------------
3184  A3F4              ALLOC_SCAN_FINISH:
3185  A3F4 79                   LD A,C
3186  A3F5 B0                   OR B
3187  A3F6                      ; blocks left to scan -> continue downward
3188  A3F6 C2 C0 A3             JP NZ,ALLOC_SCAN_DOWN
3189  A3F9                      ; no block found -> return 0
3190  A3F9 21 00 00             LD HL,$0000
3191  A3FC C9                   RET
3192  A3FD              ; ----------------------------------------------------------------------
3193  A3FD              ; FCB_WRITE_DIR_ENTRY -- copy the whole 32-byte FCB image into the matched directory entry and write
3194  A3FD              ; it.
3195  A3FD              ;   In: CURFCB_PTR ($9F43) -> FCB; sets C=0 (FCB offset 0), E=$20 (32 bytes).
3196  A3FD              ;   Out: directory record holding this entry written back to disk.
3197  A3FD              ;   Clobbers: A,B,C,D,E,H,L,flags
3198  A3FD              ;   Algorithm: set up a full-32-byte copy at FCB offset 0 and fall into FCB_COPY_TO_DIR, which moves
3199  A3FD              ;              the bytes and writes the directory record.
3200  A3FD              ;   [RE]
3201  A3FD              ; ----------------------------------------------------------------------
3202  A3FD              FCB_WRITE_DIR_ENTRY:
3203  A3FD                      ; FCB source offset 0
3204  A3FD 0E 00                LD C,$00
3205  A3FF                      ; copy length 32 = full directory entry
3206  A3FF 1E 20                LD E,$20
3207  A401              ; ----------------------------------------------------------------------
3208  A401              ; FCB_COPY_TO_DIR -- copy E FCB bytes (from offset C) into the matched directory entry.
3209  A401              ;   In: C = FCB byte offset; E = byte count; CURFCB_PTR ($9F43) -> FCB; current matched dir entry.
3210  A401              ;   Out: directory buffer updated, then the record written via FCB_FLUSH_DIR.
3211  A401              ;   Clobbers: A,B,C,D,E,H,L,flags
3212  A401              ;   Algorithm: form a source pointer at FCB+C, point HL at the directory entry slot
3213  A401              ;              (FCB_BUF_PTR_ADD_OFFSET), block-copy E bytes (BLOCK_COPY_INCC memcpy), then fall into
3214  A401              ;              FCB_FLUSH_DIR to commit the record.
3215  A401              ;   [RE]
3216  A401              ; ----------------------------------------------------------------------
3217  A401              FCB_COPY_TO_DIR:
3218  A401 D5                   PUSH DE
3219  A402 06 00                LD B,$00
3220  A404                      ; FCB base pointer
3221  A404 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3222  A407                      ; source := FCB + offset C
3223  A407 09                   ADD HL,BC
3224  A408 EB                   EX DE,HL
3225  A409                      ; HL -> destination slot in the directory buffer
3226  A409 CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
3227  A40C C1                   POP BC
3228  A40D                      ; copy E FCB bytes into the directory entry
3229  A40D CD 4F 9F             CALL BLOCK_COPY_INCC
3230  A410              ; ----------------------------------------------------------------------
3231  A410              ; FCB_FLUSH_DIR -- position to the directory record and write it back.
3232  A410              ;   In: current directory record state from the preceding match.
3233  A410              ;   Out: the directory record written to disk.
3234  A410              ;   Clobbers: A,B,C,D,E,H,L,flags
3235  A410              ;   Algorithm: run the directory record-position helper (REC_DIV4_SETUP) then tail-jump to
3236  A410              ;              DIR_RECORD_WRITE to commit the buffer to the directory sector.
3237  A410              ;   [RE]
3238  A410              ; ----------------------------------------------------------------------
3239  A410              FCB_FLUSH_DIR:
3240  A410                      ; position to the directory record's disk sector
3241  A410 CD C3 9F             CALL REC_DIV4_SETUP
3242  A413                      ; write the updated directory record to disk
3243  A413 C3 C6 A1             JP DIR_RECORD_WRITE
3244  A416              ; ----------------------------------------------------------------------
3245  A416              ; F_RENAME_HND -- rename a file: replace matching directory entries with the new name (BDOS fn 23).
3246  A416              ;   In: CURFCB_PTR ($9F43) -> FCB whose bytes 0..15 are the old name and bytes 16..31 the new name.
3247  A416              ;       Reached from F_RENAME_H (dispatch fn 23).
3248  A416              ;   Out: every matching directory entry rewritten with the new name; read-only entries rejected.
3249  A416              ;   Clobbers: A,B,C,D,E,H,L,flags
3250  A416              ;   Algorithm: log in the drive, search-first on 12 bytes of the old name, copy the FCB drive byte
3251  A416              ;              (offset 0) into the new-name half (offset 16) so both target the same drive, then run
3252  A416              ;              F_RENAME_LOOP over each match.
3253  A416              ;   [RE] CP/M 2.2 F_RENAME_HND
3254  A416              ; ----------------------------------------------------------------------
3255  A416              F_RENAME_HND:
3256  A416                      ; verify/log in the selected drive
3257  A416 CD 54 A1             CALL CMD_EXEC_20
3258  A419                      ; search on 12 FCB bytes (old name + type)
3259  A419 0E 0C                LD C,$0C
3260  A41B CD 18 A3             CALL DIR_SEARCH_FIRST
3261  A41E 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3262  A421 7E                   LD A,(HL)
3263  A422                      ; offset 16: start of the new-name half of the FCB
3264  A422 11 10 00             LD DE,$0010
3265  A425 19                   ADD HL,DE
3266  A426                      ; copy the FCB drive byte (offset 0) into the new-name half
3267  A426 77                   LD (HL),A
3268  A427              ; ----------------------------------------------------------------------
3269  A427              ; F_RENAME_LOOP -- rewrite each matched entry with the new name and write it back.
3270  A427              ;   In: a pending search result.
3271  A427              ;   Out: returns when no more matches.
3272  A427              ;   Clobbers: A,B,C,D,E,H,L,flags
3273  A427              ;   Algorithm: stop on no-match; reject read-only files; copy 12 bytes from FCB offset 16 (the new
3274  A427              ;              name+type) into the entry at offset 0 (via FCB_COPY_TO_DIR); write the directory
3275  A427              ;              record; search-next; repeat.
3276  A427              ;   [RE]
3277  A427              ; ----------------------------------------------------------------------
3278  A427              F_RENAME_LOOP:
3279  A427                      ; did the search find an entry?
3280  A427 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3281  A42A                      ; no more matches -> done
3282  A42A C8                   RET Z
3283  A42B                      ; reject rename of a read-only file
3284  A42B CD 44 A1             CALL FCB_RO_FLAG_TEST
3285  A42E                      ; source offset 16 = the new-name half of the FCB
3286  A42E 0E 10                LD C,$10
3287  A430                      ; copy 12 bytes (new name + type) over the entry
3288  A430 1E 0C                LD E,$0C
3289  A432                      ; overwrite the entry with the new name and flush
3290  A432 CD 01 A4             CALL FCB_COPY_TO_DIR
3291  A435                      ; advance to the next matching entry
3292  A435 CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
3293  A438 C3 27 A4             JP F_RENAME_LOOP
3294  A43B              ; ----------------------------------------------------------------------
3295  A43B              ; F_ATTRIB_HND -- set file attributes from the FCB into matching directory entries (BDOS fn 30).
3296  A43B              ;   In: CURFCB_PTR ($9F43) -> FCB carrying the attribute high bits in the name/type bytes. Reached
3297  A43B              ;       from F_ATTRIB_H (dispatch fn 30).
3298  A43B              ;   Out: every matching directory entry's first 12 bytes rewritten with the FCB's attribute bits.
3299  A43B              ;   Clobbers: A,B,C,D,E,H,L,flags
3300  A43B              ;   Algorithm: search-first on 12 bytes, then run F_ATTRIB_LOOP to copy the 12 name/type bytes (with
3301  A43B              ;              their attribute high bits) from FCB offset 0 into each matched entry and write the
3302  A43B              ;              record.
3303  A43B              ;   [RE] CP/M 2.2 F_ATTRIB_HND
3304  A43B              ; ----------------------------------------------------------------------
3305  A43B              F_ATTRIB_HND:
3306  A43B                      ; search on 12 FCB bytes (name + type)
3307  A43B 0E 0C                LD C,$0C
3308  A43D                      ; search-first for a matching entry
3309  A43D CD 18 A3             CALL DIR_SEARCH_FIRST
3310  A440              ; ----------------------------------------------------------------------
3311  A440              ; F_ATTRIB_LOOP -- write the FCB's attribute bytes into each matched entry.
3312  A440              ;   In: a pending search result.
3313  A440              ;   Out: returns when no more matches.
3314  A440              ;   Clobbers: A,B,C,D,E,H,L,flags
3315  A440              ;   Algorithm: stop on no-match; copy 12 bytes from FCB offset 0 (name/type with attribute bits)
3316  A440              ;              into the entry (FCB_COPY_TO_DIR); flush the directory record; search-next; repeat.
3317  A440              ;   [RE]
3318  A440              ; ----------------------------------------------------------------------
3319  A440              F_ATTRIB_LOOP:
3320  A440 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3321  A443                      ; no more matches -> done
3322  A443 C8                   RET Z
3323  A444                      ; source offset 0 = the FCB name/type bytes
3324  A444 0E 00                LD C,$00
3325  A446                      ; copy 12 bytes including the attribute high bits
3326  A446 1E 0C                LD E,$0C
3327  A448                      ; write the attribute bytes into the entry and flush
3328  A448 CD 01 A4             CALL FCB_COPY_TO_DIR
3329  A44B                      ; advance to the next matching entry
3330  A44B CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
3331  A44E C3 40 A4             JP F_ATTRIB_LOOP
3332  A451              ; ----------------------------------------------------------------------
3333  A451              ; FCB_OPEN_SEARCH -- search-first for the FCB's extent and merge the directory entry into the FCB.
3334  A451              ;   In: CURFCB_PTR ($9F43) -> FCB. Called as the core of F_OPEN (F_OPEN_H, dispatch fn 15) and from
3335  A451              ;       the random-record extent-positioning path.
3336  A451              ;   Out: on match, the matched entry is merged into the FCB (record-count fields filled,
3337  A451              ;        FILE_SIZE_FROM_EXTENT); on no match returns Z with no merge.
3338  A451              ;   Clobbers: A,B,C,D,E,H,L,flags
3339  A451              ;   Algorithm: search-first on 15 bytes (name+type+extent); if not found return Z; otherwise fall
3340  A451              ;              through into FILE_SIZE_FROM_EXTENT to copy the entry into the FCB and set the record
3341  A451              ;              count.
3342  A451              ;   [RE] CP/M 2.2 F_OPEN core / extent locate-and-merge
3343  A451              ; ----------------------------------------------------------------------
3344  A451              FCB_OPEN_SEARCH:
3345  A451                      ; search on 15 bytes (name + type + extent)
3346  A451 0E 0F                LD C,$0F
3347  A453                      ; search-first for the file's directory entry
3348  A453 CD 18 A3             CALL DIR_SEARCH_FIRST
3349  A456 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3350  A459                      ; extent not found -> caller sees the no-match result
3351  A459 C8                   RET Z
3352  A45A              ; ----------------------------------------------------------------------
3353  A45A              ; FILE_SIZE_FROM_EXTENT -- merge a matched directory entry into the FCB and update its record count.
3354  A45A              ;   In: HL -> matched directory entry; CURFCB_PTR ($9F43) -> the user FCB.
3355  A45A              ;   Out: the 32-byte entry copied into the FCB image; the FCB's record-count byte (offset 15)
3356  A45A              ;        updated per this extent.
3357  A45A              ;   Clobbers: A,B,C,D,E,H,L,flags
3358  A45A              ;   Algorithm: save the entry's first byte, copy the 32 directory bytes into the FCB image
3359  A45A              ;              (BLOCK_COPY_INCC), set the S2 'written' flag (MARK_FCB_S2_HIGHBIT), then from the
3360  A45A              ;              entry copy read offset 12 = EX (extent number) into C and offset 15 = RC (record
3361  A45A              ;              count) into B, and choose the new offset-15 value ($00 if this extent is below the
3362  A45A              ;              current one, RC if equal, $80 if above) and store it.  Used by both F_OPEN
3363  A45A              ;              (FCB_OPEN_SEARCH) and F_SIZE.
3364  A45A              ;   [RE]
3365  A45A              ; ----------------------------------------------------------------------
3366  A45A              FILE_SIZE_FROM_EXTENT:
3367  A45A                      ; HL -> matched entry; read its first (extent-low) byte
3368  A45A CD A6 A0             CALL DRV_INSTALL_RWTS_1
3369  A45D 7E                   LD A,(HL)
3370  A45E F5                   PUSH AF
3371  A45F E5                   PUSH HL
3372  A460 CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
3373  A463 EB                   EX DE,HL
3374  A464 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3375  A467                      ; copy the full 32-byte entry into the FCB image
3376  A467 0E 20                LD C,$20
3377  A469 D5                   PUSH DE
3378  A46A CD 4F 9F             CALL BLOCK_COPY_INCC
3379  A46D CD 78 A1             CALL MARK_FCB_S2_HIGHBIT
3380  A470 D1                   POP DE
3381  A471                      ; offset 12 = EX (extent number) of this entry
3382  A471 21 0C 00             LD HL,$000C
3383  A474 19                   ADD HL,DE
3384  A475 4E                   LD C,(HL)
3385  A476                      ; offset 15 = RC (record count) of this entry
3386  A476 21 0F 00             LD HL,$000F
3387  A479 19                   ADD HL,DE
3388  A47A 46                   LD B,(HL)
3389  A47B E1                   POP HL
3390  A47C F1                   POP AF
3391  A47D 77                   LD (HL),A
3392  A47E 79                   LD A,C
3393  A47F                      ; compare this extent's number against the FCB's
3394  A47F BE                   CP (HL)
3395  A480 78                   LD A,B
3396  A481 CA 8B A4             JP Z,FILE_SIZE_STORE
3397  A484 3E 00                LD A,$00
3398  A486 DA 8B A4             JP C,FILE_SIZE_STORE
3399  A489                      ; extent above current -> $80 (full 128-record) marker
3400  A489 3E 80                LD A,$80
3401  A48B              ; ----------------------------------------------------------------------
3402  A48B              ; FILE_SIZE_STORE -- write the computed record value into the FCB record-count field.
3403  A48B              ;   In: A = computed value ($00/$80/extent RC); CURFCB_PTR ($9F43) -> FCB.
3404  A48B              ;   Out: FCB offset 15 (RC) = A.
3405  A48B              ;   Clobbers: D,E,H,L
3406  A48B              ;   Algorithm: index the FCB to offset 15 and store the record-count byte.
3407  A48B              ;   [RE]
3408  A48B              ; ----------------------------------------------------------------------
3409  A48B              FILE_SIZE_STORE:
3410  A48B 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3411  A48E                      ; FCB offset 15 = record-count (RC) byte
3412  A48E 11 0F 00             LD DE,$000F
3413  A491 19                   ADD HL,DE
3414  A492                      ; store the computed record value
3415  A492 77                   LD (HL),A
3416  A493 C9                   RET
3417  A494              ; ----------------------------------------------------------------------
3418  A494              ; FCB_WORD_FILL_IF_ZERO -- copy a 16-bit word from (DE) to (HL) only when (HL) is currently zero.
3419  A494              ;   In: HL -> destination word; DE -> source word.
3420  A494              ;   Out: if the destination word was 0, it is overwritten with the source word; DE,HL preserved.
3421  A494              ;   Clobbers: A,flags
3422  A494              ;   Algorithm: OR the two destination bytes; if non-zero return unchanged; otherwise copy both
3423  A494              ;              source bytes across, restoring DE/HL to their entry values.
3424  A494              ;   [RE] allocation-word merge helper used during F_CLOSE_HND
3425  A494              ; ----------------------------------------------------------------------
3426  A494              FCB_WORD_FILL_IF_ZERO:
3427  A494 7E                   LD A,(HL)
3428  A495 23                   INC HL
3429  A496                      ; test whether the destination word is already non-zero
3430  A496 B6                   OR (HL)
3431  A497 2B                   DEC HL
3432  A498                      ; destination already set -> leave it alone
3433  A498 C0                   RET NZ
3434  A499 1A                   LD A,(DE)
3435  A49A                      ; copy low byte of the source word
3436  A49A 77                   LD (HL),A
3437  A49B 13                   INC DE
3438  A49C 23                   INC HL
3439  A49D 1A                   LD A,(DE)
3440  A49E                      ; copy high byte of the source word
3441  A49E 77                   LD (HL),A
3442  A49F 1B                   DEC DE
3443  A4A0 2B                   DEC HL
3444  A4A1 C9                   RET
3445  A4A2              ; ----------------------------------------------------------------------
3446  A4A2              ; F_CLOSE_HND -- close a file: merge the in-memory FCB into its directory entry (BDOS fn 16).
3447  A4A2              ;   In: CURFCB_PTR ($9F43) -> FCB. Reached from F_CLOSE_H (dispatch fn 16); also used internally to
3448  A4A2              ;       flush an extent.
3449  A4A2              ;   Out: directory entry updated with this FCB's allocation map / record count; result byte set.
3450  A4A2              ;   Clobbers: A,B,C,D,E,H,L,flags
3451  A4A2              ;   Algorithm: zero the result byte and record state, verify the drive is selected (DRIVE_BIT_TEST)
3452  A4A2              ;              and the FCB S2 high bit is clear; search-first on the extent (15 bytes); if found,
3453  A4A2              ;              merge the FCB's 16-byte allocation map into the entry (filling zero words via
3454  A4A2              ;              FCB_WORD_FILL_IF_ZERO, keeping the larger record count) then flush.
3455  A4A2              ;   [RE] CP/M 2.2 F_CLOSE_HND
3456  A4A2              ; ----------------------------------------------------------------------
3457  A4A2              F_CLOSE_HND:
3458  A4A2 AF                   XOR A
3459  A4A3 32 45 9F             LD (BDOS_RETVAL),A
3460  A4A6                      ; clear the directory record counter
3461  A4A6 32 EA A9             LD (CUR_RECORD),A
3462  A4A9 32 EB A9             LD (CUR_RECORD_HI),A
3463  A4AC                      ; is the drive logged in?
3464  A4AC CD 1E A1             CALL DRIVE_BIT_TEST
3465  A4AF                      ; no valid drive -> nothing to close
3466  A4AF C0                   RET NZ
3467  A4B0                      ; read the FCB S2 byte (offset 14)
3468  A4B0 CD 69 A1             CALL FCB_GET_S2
3469  A4B3                      ; high bit = FCB flagged not-to-be-written -> skip
3470  A4B3 E6 80                AND $80
3471  A4B5 C0                   RET NZ
3472  A4B6                      ; search on 15 bytes (name+type+extent)
3473  A4B6 0E 0F                LD C,$0F
3474  A4B8                      ; search-first for this extent's directory entry
3475  A4B8 CD 18 A3             CALL DIR_SEARCH_FIRST
3476  A4BB CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3477  A4BE C8                   RET Z
3478  A4BF 01 10 00             LD BC,$0010
3479  A4C2 CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
3480  A4C5 09                   ADD HL,BC
3481  A4C6 EB                   EX DE,HL
3482  A4C7 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3483  A4CA 09                   ADD HL,BC
3484  A4CB 0E 10                LD C,$10
3485  A4CD              ; ----------------------------------------------------------------------
3486  A4CD              ; FCB_MERGE_MAP_LOOP -- merge the FCB allocation map slot-by-slot into the directory entry.
3487  A4CD              ;   In: HL -> entry allocation slot; DE -> FCB allocation slot; C = slots remaining (16).
3488  A4CD              ;   Out: merged allocation map; jumps to FCB_MERGE_DIFF on an 8-bit conflict, else continues.
3489  A4CD              ;   Clobbers: A,B,C,D,E,H,L,flags
3490  A4CD              ;   Algorithm: per slot, if BLOCK_WIDTH_FLAG selects 16-bit block numbers go word-wise
3491  A4CD              ;              (FCB_MERGE_WORD); else handle an 8-bit block: when the entry slot is zero take the
3492  A4CD              ;              FCB's block, then fall into the byte reconciliation.
3493  A4CD              ;   [RE]
3494  A4CD              ; ----------------------------------------------------------------------
3495  A4CD              FCB_MERGE_MAP_LOOP:
3496  A4CD                      ; 0 = 16-bit block numbers, non-zero = 8-bit
3497  A4CD 3A DD A9             LD A,(BLOCK_WIDTH_FLAG)
3498  A4D0 B7                   OR A
3499  A4D1                      ; 16-bit blocks -> word-wise merge path
3500  A4D1 CA E8 A4             JP Z,FCB_MERGE_WORD
3501  A4D4 7E                   LD A,(HL)
3502  A4D5 B7                   OR A
3503  A4D6 1A                   LD A,(DE)
3504  A4D7 C2 DB A4             JP NZ,FCB_MERGE_BYTE_CHECK
3505  A4DA                      ; entry slot empty -> take the FCB's block number
3506  A4DA 77                   LD (HL),A
3507  A4DB              ; ----------------------------------------------------------------------
3508  A4DB              ; FCB_MERGE_BYTE_CHECK -- reconcile one 8-bit allocation slot between FCB and entry.
3509  A4DB              ;   In: A = FCB block byte; HL -> entry block byte; DE -> FCB block byte.
3510  A4DB              ;   Out: FCB block non-zero -> FCB_MERGE_DIFF (compare); else copy entry block into the FCB, then
3511  A4DB              ;        compare.
3512  A4DB              ;   Clobbers: A,flags
3513  A4DB              ;   Algorithm: if the FCB block byte is non-zero, jump to the compare; otherwise mirror the entry
3514  A4DB              ;              block byte into the FCB so both agree, then fall into the compare.
3515  A4DB              ;   [RE]
3516  A4DB              ; ----------------------------------------------------------------------
3517  A4DB              FCB_MERGE_BYTE_CHECK:
3518  A4DB B7                   OR A
3519  A4DC                      ; FCB block set -> compare with the entry
3520  A4DC C2 E1 A4             JP NZ,FCB_MERGE_DIFF
3521  A4DF 7E                   LD A,(HL)
3522  A4E0                      ; FCB block empty -> copy the entry's block into it
3523  A4E0 12                   LD (DE),A
3524  A4E1              ; ----------------------------------------------------------------------
3525  A4E1              ; FCB_MERGE_DIFF -- detect a block-map disagreement between FCB and directory entry.
3526  A4E1              ;   In: A = FCB block byte; HL -> entry block byte.
3527  A4E1              ;   Out: if they differ, FCB_DEC_RESULT flags the conflict; else continue (FCB_MERGE_NEXT).
3528  A4E1              ;   Clobbers: A,flags
3529  A4E1              ;   Algorithm: compare the FCB block byte with the entry's; unequal records an error via
3530  A4E1              ;              FCB_DEC_RESULT, otherwise advance to the next slot.
3531  A4E1              ;   [RE]
3532  A4E1              ; ----------------------------------------------------------------------
3533  A4E1              FCB_MERGE_DIFF:
3534  A4E1                      ; FCB block vs entry block
3535  A4E1 BE                   CP (HL)
3536  A4E2                      ; block maps disagree -> flag conflict
3537  A4E2 C2 1F A5             JP NZ,FCB_DEC_RESULT
3538  A4E5 C3 FD A4             JP FCB_MERGE_NEXT
3539  A4E8              ; ----------------------------------------------------------------------
3540  A4E8              ; FCB_MERGE_WORD -- merge/compare a 16-bit allocation word for double-byte-block drives.
3541  A4E8              ;   In: HL -> entry word; DE -> FCB word.
3542  A4E8              ;   Out: zero words filled across both directions; on a true word mismatch -> FCB_DEC_RESULT.
3543  A4E8              ;   Clobbers: A,D,E,H,L,flags
3544  A4E8              ;   Algorithm: fill the entry word from the FCB if it was zero, fill the FCB word from the entry if
3545  A4E8              ;              it was zero (FCB_WORD_FILL_IF_ZERO both ways, EX DE,HL between), then compare the two
3546  A4E8              ;              16-bit values byte-by-byte and flag a conflict on inequality.
3547  A4E8              ;   [RE]
3548  A4E8              ; ----------------------------------------------------------------------
3549  A4E8              FCB_MERGE_WORD:
3550  A4E8                      ; fill entry word from FCB if entry was zero
3551  A4E8 CD 94 A4             CALL FCB_WORD_FILL_IF_ZERO
3552  A4EB EB                   EX DE,HL
3553  A4EC                      ; fill FCB word from entry if FCB was zero
3554  A4EC CD 94 A4             CALL FCB_WORD_FILL_IF_ZERO
3555  A4EF EB                   EX DE,HL
3556  A4F0 1A                   LD A,(DE)
3557  A4F1                      ; compare low bytes of the two block words
3558  A4F1 BE                   CP (HL)
3559  A4F2 C2 1F A5             JP NZ,FCB_DEC_RESULT
3560  A4F5 13                   INC DE
3561  A4F6 23                   INC HL
3562  A4F7 1A                   LD A,(DE)
3563  A4F8                      ; compare high bytes of the two block words
3564  A4F8 BE                   CP (HL)
3565  A4F9 C2 1F A5             JP NZ,FCB_DEC_RESULT
3566  A4FC 0D                   DEC C
3567  A4FD              ; ----------------------------------------------------------------------
3568  A4FD              ; FCB_MERGE_NEXT -- step to the next allocation slot, then finalize the record count.
3569  A4FD              ;   In: DE,HL -> current FCB/entry block bytes; C = slot count remaining.
3570  A4FD              ;   Out: loops to FCB_MERGE_MAP_LOOP until C reaches 0, then reconciles the record-count field and
3571  A4FD              ;        continues to FCB_MERGE_FINISH.
3572  A4FD              ;   Clobbers: A,B,C,D,E,H,L,flags
3573  A4FD              ;   Algorithm: advance both pointers, decrement the count; while slots remain re-enter the merge
3574  A4FD              ;              loop; when done back up by 20 bytes ($FFEC) to the record-count field and keep the
3575  A4FD              ;              larger of the FCB/entry counts (and the matching S2/extent bytes), then fall into
3576  A4FD              ;              FCB_MERGE_FINISH.
3577  A4FD              ;   [RE]
3578  A4FD              ; ----------------------------------------------------------------------
3579  A4FD              FCB_MERGE_NEXT:
3580  A4FD 13                   INC DE
3581  A4FE 23                   INC HL
3582  A4FF 0D                   DEC C
3583  A500                      ; more allocation slots -> keep merging
3584  A500 C2 CD A4             JP NZ,FCB_MERGE_MAP_LOOP
3585  A503                      ; back up 20 bytes to the record-count field
3586  A503 01 EC FF             LD BC,$FFEC
3587  A506 09                   ADD HL,BC
3588  A507 EB                   EX DE,HL
3589  A508 09                   ADD HL,BC
3590  A509 1A                   LD A,(DE)
3591  A50A                      ; compare FCB record count with the entry's
3592  A50A BE                   CP (HL)
3593  A50B                      ; FCB count smaller -> keep the entry's count
3594  A50B DA 17 A5             JP C,FCB_MERGE_FINISH
3595  A50E                      ; FCB count larger -> store it into the entry
3596  A50E 77                   LD (HL),A
3597  A50F 01 03 00             LD BC,$0003
3598  A512 09                   ADD HL,BC
3599  A513 EB                   EX DE,HL
3600  A514 09                   ADD HL,BC
3601  A515 7E                   LD A,(HL)
3602  A516 12                   LD (DE),A
3603  A517              ; ----------------------------------------------------------------------
3604  A517              ; FCB_MERGE_FINISH -- mark the merged entry dirty and flush the directory record.
3605  A517              ;   In: merged directory entry in the buffer.
3606  A517              ;   Out: dir-changed flag ($A9D2) = $FF; directory record written via FCB_FLUSH_DIR.
3607  A517              ;   Clobbers: A,H,L,flags
3608  A517              ;   Algorithm: set the 'directory changed' flag and tail-jump to FCB_FLUSH_DIR to commit the record
3609  A517              ;              to disk.
3610  A517              ;   [RE]
3611  A517              ; ----------------------------------------------------------------------
3612  A517              FCB_MERGE_FINISH:
3613  A517 3E FF                LD A,$FF
3614  A519                      ; set the directory-changed flag ($FF)
3615  A519 32 D2 A9             LD (DIR_DIRTY_FLAG),A
3616  A51C                      ; flush the merged entry to the directory sector
3617  A51C C3 10 A4             JP FCB_FLUSH_DIR
3618  A51F              ; ----------------------------------------------------------------------
3619  A51F              ; FCB_DEC_RESULT -- record a directory-merge conflict by decrementing the result byte.
3620  A51F              ;   In: none (operates on the BDOS result byte $9F45).
3621  A51F              ;   Out: result byte decremented (toward the $FF error code).
3622  A51F              ;   Clobbers: H,L,flags
3623  A51F              ;   Algorithm: point at the result byte and decrement it in place to signal the close/merge
3624  A51F              ;              mismatch.
3625  A51F              ;   [RE]
3626  A51F              ; ----------------------------------------------------------------------
3627  A51F              FCB_DEC_RESULT:
3628  A51F                      ; point at the BDOS result byte
3629  A51F 21 45 9F             LD HL,BDOS_RETVAL
3630  A522                      ; decrement to flag the merge conflict
3631  A522 35                   DEC (HL)
3632  A523 C9                   RET
3633  A524              ; ----------------------------------------------------------------------
3634  A524              ; DIR_MAKE_ENTRY -- find a free directory slot and create a new (empty) entry for the FCB.
3635  A524              ;   In: CURFCB_PTR ($9F43) -> FCB. Also the core of F_MAKE (F_MAKE_H, dispatch fn 22).
3636  A524              ;   Out: a free directory slot located and initialized for this file; returns Z if no slot is free.
3637  A524              ;   Clobbers: A,B,C,D,E,H,L,flags
3638  A524              ;   Algorithm: log in the drive, temporarily redirect the FCB pointer to a scratch FCB ($A9AC) and
3639  A524              ;              search-first in mode 1 for an empty ($E5) slot, restore the FCB pointer; on success
3640  A524              ;              zero 17 bytes of the entry's record/allocation area (from offset 15), clear the S1
3641  A524              ;              byte (offset 13), advance the record pointer (RECPTR_INC_STORE), write the new entry
3642  A524              ;              (FCB_WRITE_DIR_ENTRY), and set the FCB S2 'written' flag (MARK_FCB_S2_HIGHBIT).
3643  A524              ;   [RE] make-directory-entry helper
3644  A524              ; ----------------------------------------------------------------------
3645  A524              DIR_MAKE_ENTRY:
3646  A524                      ; log in the drive
3647  A524 CD 54 A1             CALL CMD_EXEC_20
3648  A527 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3649  A52A E5                   PUSH HL
3650  A52B                      ; point at a scratch FCB used to find a free slot
3651  A52B 21 AC A9             LD HL,EMPTY_DIR_FCB
3652  A52E 22 43 9F             LD (BDOS_PARAM_PTR),HL
3653  A531                      ; search mode 1: locate a free ($E5) directory entry
3654  A531 0E 01                LD C,$01
3655  A533 CD 18 A3             CALL DIR_SEARCH_FIRST
3656  A536 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3657  A539 E1                   POP HL
3658  A53A 22 43 9F             LD (BDOS_PARAM_PTR),HL
3659  A53D C8                   RET Z
3660  A53E EB                   EX DE,HL
3661  A53F 21 0F 00             LD HL,$000F
3662  A542 19                   ADD HL,DE
3663  A543                      ; 17 bytes of record/allocation area to clear
3664  A543 0E 11                LD C,$11
3665  A545 AF                   XOR A
3666  A546              ; ----------------------------------------------------------------------
3667  A546              ; DIR_ZERO_ALLOC -- clear the record/allocation bytes of a freshly created directory entry.
3668  A546              ;   In: HL -> first byte to clear; C = byte count (17); A = 0.
3669  A546              ;   Out: C bytes at HL set to zero.
3670  A546              ;   Clobbers: C,H,L,flags
3671  A546              ;   Algorithm: store-zero / increment HL / decrement C until the count reaches zero.
3672  A546              ;   [RE]
3673  A546              ; ----------------------------------------------------------------------
3674  A546              DIR_ZERO_ALLOC:
3675  A546 77                   LD (HL),A
3676  A547 23                   INC HL
3677  A548 0D                   DEC C
3678  A549                      ; loop until all record/allocation bytes are zeroed
3679  A549 C2 46 A5             JP NZ,DIR_ZERO_ALLOC
3680  A54C 21 0D 00             LD HL,$000D
3681  A54F 19                   ADD HL,DE
3682  A550 77                   LD (HL),A
3683  A551 CD 8C A1             CALL RECPTR_INC_STORE
3684  A554 CD FD A3             CALL FCB_WRITE_DIR_ENTRY
3685  A557 C3 78 A1             JP MARK_FCB_S2_HIGHBIT
3686  A55A              ; ----------------------------------------------------------------------
3687  A55A              ; FCB_ADVANCE_RECORD -- advance the FCB to the next record/extent for sequential write.
3688  A55A              ;   In: CURFCB_PTR ($9F43) -> open FCB.
3689  A55A              ;   Out: FCB current-record / extent fields stepped; new extent opened or created as needed.
3690  A55A              ;   Clobbers: A,B,C,D,E,H,L,flags
3691  A55A              ;   Algorithm: clear the dir-changed flag, flush the current extent (F_CLOSE_HND via F_CLOSE_HND), bump the
3692  A55A              ;              FCB current-record byte (offset 12) and wrap it mod 32; on wrap go open the next
3693  A55A              ;              extent (FCB_NEXT_EXTENT); otherwise check the extent mask (EXM at $A9C5) and the
3694  A55A              ;              dir-changed flag to decide between re-opening the current extent or merging the
3695  A55A              ;              just-flushed one.
3696  A55A              ;   [RE] sequential-write record/extent advance
3697  A55A              ; ----------------------------------------------------------------------
3698  A55A              FCB_ADVANCE_RECORD:
3699  A55A AF                   XOR A
3700  A55B                      ; clear the directory-changed flag
3701  A55B 32 D2 A9             LD (DIR_DIRTY_FLAG),A
3702  A55E                      ; close/flush the current extent first
3703  A55E CD A2 A4             CALL F_CLOSE_HND
3704  A561 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3705  A564 C8                   RET Z
3706  A565 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3707  A568                      ; FCB offset 12 = current-record byte
3708  A568 01 0C 00             LD BC,$000C
3709  A56B 09                   ADD HL,BC
3710  A56C 7E                   LD A,(HL)
3711  A56D 3C                   INC A
3712  A56E                      ; wrap the current record mod 32 (128 records/extent)
3713  A56E E6 1F                AND $1F
3714  A570 77                   LD (HL),A
3715  A571                      ; record wrapped -> move to the next extent
3716  A571 CA 83 A5             JP Z,FCB_NEXT_EXTENT
3717  A574 47                   LD B,A
3718  A575                      ; load the extent mask (EXM)
3719  A575 3A C5 A9             LD A,(DPB_EXM)
3720  A578 A0                   AND B
3721  A579 21 D2 A9             LD HL,DIR_DIRTY_FLAG
3722  A57C A6                   AND (HL)
3723  A57D CA 8E A5             JP Z,FCB_OPEN_NEXT_EXTENT
3724  A580 C3 AC A5             JP FCB_MERGE_FOUND_EXTENT
3725  A583              ; ----------------------------------------------------------------------
3726  A583              ; FCB_NEXT_EXTENT -- step the FCB to the next extent when the record count wraps.
3727  A583              ;   In: HL -> FCB current-record byte; FCB extent fields follow.
3728  A583              ;   Out: extent byte (offset 14) incremented; low-nibble rollover branches to finish.
3729  A583              ;   Clobbers: A,B,C,H,L,flags
3730  A583              ;   Algorithm: advance HL by 2 to the extent byte (offset 14), increment it; if its low nibble is
3731  A583              ;              now zero a module of extents has rolled over and control goes to DISK_FINISH_OK;
3732  A583              ;              otherwise fall into the open-next-extent path.
3733  A583              ;   [RE]
3734  A583              ; ----------------------------------------------------------------------
3735  A583              FCB_NEXT_EXTENT:
3736  A583                      ; step from record byte (12) to the extent byte (14)
3737  A583 01 02 00             LD BC,$0002
3738  A586 09                   ADD HL,BC
3739  A587                      ; advance to the next extent
3740  A587 34                   INC (HL)
3741  A588 7E                   LD A,(HL)
3742  A589                      ; low nibble = extent within the current entry group
3743  A589 E6 0F                AND $0F
3744  A58B                      ; extent group rolled over -> finish
3745  A58B CA B6 A5             JP Z,DISK_FINISH_OK
3746  A58E              ; ----------------------------------------------------------------------
3747  A58E              ; FCB_OPEN_NEXT_EXTENT -- search the directory for the FCB's next extent, creating it if absent.
3748  A58E              ;   In: CURFCB_PTR ($9F43) -> FCB positioned at the next extent; the read/write direction flag in
3749  A58E              ;       $A9D3.
3750  A58E              ;   Out: the extent opened (merged into the FCB) or a new entry created; result set.
3751  A58E              ;   Clobbers: A,B,C,D,E,H,L,flags
3752  A58E              ;   Algorithm: search-first on 15 bytes for the extent; if found go merge it
3753  A58E              ;              (FCB_MERGE_FOUND_EXTENT); else, when the direction flag is not $FF (i.e. a write),
3754  A58E              ;              make a new directory entry (DIR_MAKE_ENTRY); on a read (or no free slot) take the
3755  A58E              ;              disk-finish/error path.
3756  A58E              ;   [RE]
3757  A58E              ; ----------------------------------------------------------------------
3758  A58E              FCB_OPEN_NEXT_EXTENT:
3759  A58E                      ; search on 15 bytes (name+type+extent)
3760  A58E 0E 0F                LD C,$0F
3761  A590                      ; search-first for the next extent
3762  A590 CD 18 A3             CALL DIR_SEARCH_FIRST
3763  A593 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3764  A596                      ; extent exists -> merge it into the FCB
3765  A596 C2 AC A5             JP NZ,FCB_MERGE_FOUND_EXTENT
3766  A599 3A D3 A9             LD A,(RW_DIRECTION_FLAG)
3767  A59C 3C                   INC A
3768  A59D CA B6 A5             JP Z,DISK_FINISH_OK
3769  A5A0                      ; no extent -> make a new directory entry
3770  A5A0 CD 24 A5             CALL DIR_MAKE_ENTRY
3771  A5A3 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
3772  A5A6 CA B6 A5             JP Z,DISK_FINISH_OK
3773  A5A9 C3 AF A5             JP FCB_FINISH_NEW_EXTENT
3774  A5AC              ; ----------------------------------------------------------------------
3775  A5AC              ; FCB_MERGE_FOUND_EXTENT -- merge a located directory extent back into the FCB.
3776  A5AC              ;   In: a successful search result for the extent; CURFCB_PTR ($9F43) -> FCB.
3777  A5AC              ;   Out: FCB's record/size fields updated from the entry; then falls into FCB_FINISH_NEW_EXTENT
3778  A5AC              ;        (refresh fields, return 0).
3779  A5AC              ;   Clobbers: A,B,C,D,E,H,L,flags
3780  A5AC              ;   Algorithm: merge the matched extent into the FCB (FILE_SIZE_FROM_EXTENT), then fall through into
3781  A5AC              ;              FCB_FINISH_NEW_EXTENT which refreshes the working fields and returns success.
3782  A5AC              ;   [RE]
3783  A5AC              ; ----------------------------------------------------------------------
3784  A5AC              FCB_MERGE_FOUND_EXTENT:
3785  A5AC                      ; merge the matched extent and set the FCB record count, then fall into
3786  A5AC                      ; FCB_FINISH_NEW_EXTENT
3787  A5AC CD 5A A4             CALL FILE_SIZE_FROM_EXTENT
3788  A5AF              ; ----------------------------------------------------------------------
3789  A5AF              ; FCB_FINISH_NEW_EXTENT -- finish opening a newly created extent and return OK.
3790  A5AF              ;   In: a new directory entry just made for the FCB.
3791  A5AF              ;   Out: FCB working fields refreshed; BDOS result = 0.
3792  A5AF              ;   Clobbers: A,B,C,D,E,H,L,flags
3793  A5AF              ;   Algorithm: refresh the FCB drive/extent fields (DRV_INSTALL_RWTS_3) and return success (0).
3794  A5AF              ;   [RE]
3795  A5AF              ; ----------------------------------------------------------------------
3796  A5AF              FCB_FINISH_NEW_EXTENT:
3797  A5AF                      ; refresh the FCB drive/extent working fields
3798  A5AF CD BB A0             CALL DRV_INSTALL_RWTS_3
3799  A5B2 AF                   XOR A
3800  A5B3                      ; return success (0)
3801  A5B3 C3 01 9F             JP BDOS_RET_RESULT
3802  A5B6              ; ----------------------------------------------------------------------
3803  A5B6              ; DISK_FINISH_OK -- finalize the BDOS result and set the FCB written flag.
3804  A5B6              ;   In: directory/record operation just completed.
3805  A5B6              ;   Out: BDOS result finalized (BDOS_RET_ONE); FCB S2 'written' bit set.
3806  A5B6              ;   Clobbers: A,H,L,flags
3807  A5B6              ;   Algorithm: run the common result-finalizer (BDOS_RET_ONE) then tail-jump to MARK_FCB_S2_HIGHBIT
3808  A5B6              ;              to set the FCB S2 high bit (mark written) and return.
3809  A5B6              ;   [RE]
3810  A5B6              ; ----------------------------------------------------------------------
3811  A5B6              DISK_FINISH_OK:
3812  A5B6                      ; finalize the BDOS result for the operation
3813  A5B6 CD 05 9F             CALL BDOS_RET_ONE
3814  A5B9                      ; set the FCB S2 'written' flag and return
3815  A5B9 C3 78 A1             JP MARK_FCB_S2_HIGHBIT
3816  A5BC              ; ----------------------------------------------------------------------
3817  A5BC              ; FILE_READ_SEQ -- sequential read of one record into the DMA buffer (BDOS fn 20).
3818  A5BC              ;   In: CURFCB_PTR ($9F43) -> open FCB. Reached from F_READ_H (dispatch fn 20).
3819  A5BC              ;   Out: requested record read; BDOS result reflects success/EOF.
3820  A5BC              ;   Clobbers: A,B,C,D,E,H,L,flags
3821  A5BC              ;   Algorithm: set the sequential/random mode flag $A9D5=1 (1 = sequential; the random-read path
3822  A5BC              ;              BDOS_SEEK_NOREAD sets it 0) then fall into the shared read core (FILE_READ_RECORD).
3823  A5BC              ;   [RE] CP/M 2.2 sequential read entry
3824  A5BC              ; ----------------------------------------------------------------------
3825  A5BC              FILE_READ_SEQ:
3826  A5BC                      ; mode = 1 (sequential read)
3827  A5BC 3E 01                LD A,$01
3828  A5BE                      ; store the sequential/random mode flag (1=sequential)
3829  A5BE 32 D5 A9             LD (WRITE_TYPE_FLAG),A
3830  A5C1              ; ----------------------------------------------------------------------
3831  A5C1              ; FILE_READ_RECORD -- read the FCB's current record into the DMA buffer (shared read core).
3832  A5C1              ;   In: CURFCB_PTR ($9F43) -> open FCB; record/extent fields set. Shared by sequential
3833  A5C1              ;       (FILE_READ_SEQ) and random read.
3834  A5C1              ;   Out: the record's sector read and de-blocked to the DMA address; result = 0/error.
3835  A5C1              ;   Clobbers: A,B,C,D,E,H,L,flags
3836  A5C1              ;   Algorithm: set the direction flag $A9D3=$FF (read), refresh the FCB working fields, compare the
3837  A5C1              ;              current record ($A9E3) against the extent's record count ($A9E1); if at the $80
3838  A5C1              ;              boundary advance to the next extent (FCB_ADVANCE_RECORD), else translate the record
3839  A5C1              ;              to a physical sector and read it.
3840  A5C1              ;   [RE] CP/M 2.2 read core
3841  A5C1              ; ----------------------------------------------------------------------
3842  A5C1              FILE_READ_RECORD:
3843  A5C1                      ; direction = read
3844  A5C1 3E FF                LD A,$FF
3845  A5C3                      ; store the read/write direction flag ($FF=read)
3846  A5C3 32 D3 A9             LD (RW_DIRECTION_FLAG),A
3847  A5C6                      ; refresh the FCB drive/extent working fields
3848  A5C6 CD BB A0             CALL DRV_INSTALL_RWTS_3
3849  A5C9 3A E3 A9             LD A,(FCB_CURREC)
3850  A5CC 21 E1 A9             LD HL,FCB_RECCOUNT
3851  A5CF BE                   CP (HL)
3852  A5D0 DA E6 A5             JP C,FILE_READ_DO_SECTOR
3853  A5D3                      ; record at the $80 boundary = extent boundary / EOF
3854  A5D3 FE 80                CP $80
3855  A5D5 C2 FB A5             JP NZ,FILE_READ_ERROR
3856  A5D8 CD 5A A5             CALL FCB_ADVANCE_RECORD
3857  A5DB AF                   XOR A
3858  A5DC 32 E3 A9             LD (FCB_CURREC),A
3859  A5DF 3A 45 9F             LD A,(BDOS_RETVAL)
3860  A5E2 B7                   OR A
3861  A5E3 C2 FB A5             JP NZ,FILE_READ_ERROR
3862  A5E6              ; ----------------------------------------------------------------------
3863  A5E6              ; FILE_READ_DO_SECTOR -- translate the record to a sector and read it into the DMA buffer.
3864  A5E6              ;   In: FCB working fields set; record within the current extent.
3865  A5E6              ;   Out: the physical sector read and de-blocked into the DMA address.
3866  A5E6              ;   Clobbers: A,B,C,D,E,H,L,flags
3867  A5E6              ;   Algorithm: compute block/sector/track from the record (DISK_STORE_SEC_TRK_14/16/17); if no block
3868  A5E6              ;              is allocated take the read-error path; otherwise read the sector through the
3869  A5E6              ;              deblocking buffer and return via the BIOS read tail (DRV_INSTALL_RWTS_6).
3870  A5E6              ;   [RE]
3871  A5E6              ; ----------------------------------------------------------------------
3872  A5E6              FILE_READ_DO_SECTOR:
3873  A5E6                      ; compute the block number for this record
3874  A5E6 CD 77 A0             CALL DISK_STORE_SEC_TRK_14
3875  A5E9 CD 84 A0             CALL DISK_STORE_SEC_TRK_16
3876  A5EC                      ; no allocated block -> read error / unwritten
3877  A5EC CA FB A5             JP Z,FILE_READ_ERROR
3878  A5EF                      ; compute the physical sector/track
3879  A5EF CD 8A A0             CALL DISK_STORE_SEC_TRK_17
3880  A5F2 CD D1 9F             CALL RECORD_TO_TRACK
3881  A5F5 CD B2 9F             CALL DISK_READ_CHECKED
3882  A5F8                      ; perform the BIOS sector read and return
3883  A5F8 C3 D2 A0             JP DRV_INSTALL_RWTS_6
3884  A5FB              ; ----------------------------------------------------------------------
3885  A5FB              ; FILE_READ_ERROR -- return a read error / unwritten-record result.
3886  A5FB              ;   In: none.
3887  A5FB              ;   Out: BDOS result set to the error code via BDOS_RET_ONE.
3888  A5FB              ;   Clobbers: A,flags
3889  A5FB              ;   Algorithm: tail-jump to the common error-result setter.
3890  A5FB              ;   [RE]
3891  A5FB              ; ----------------------------------------------------------------------
3892  A5FB              FILE_READ_ERROR:
3893  A5FB                      ; return the BDOS read error code
3894  A5FB C3 05 9F             JP BDOS_RET_ONE
3895  A5FE              ; ----------------------------------------------------------------------
3896  A5FE              ; FILE_WRITE_SEQ -- sequential write of one record from the DMA buffer (BDOS fn 21).
3897  A5FE              ;   In: CURFCB_PTR ($9F43) -> FCB; DMA buffer holds the record. Reached from F_WRITE_H (dispatch fn
3898  A5FE              ;       21).
3899  A5FE              ;   Out: enters the write core; record written, blocks allocated as needed; result set.
3900  A5FE              ;   Clobbers: A,B,C,D,E,H,L,flags
3901  A5FE              ;   Algorithm: set the sequential/random mode flag $A9D5=1 (1 = sequential) then fall into the
3902  A5FE              ;              shared write core (at $A603, which clears the direction flag, logs in, allocates a
3903  A5FE              ;              block when the record is new, translates to a sector, and writes).
3904  A5FE              ;   [RE] CP/M 2.2 sequential write entry
3905  A5FE              ; ----------------------------------------------------------------------
3906  A5FE              FILE_WRITE_SEQ:
3907  A5FE                      ; mode = 1 (sequential write)
3908  A5FE 3E 01                LD A,$01
3909  A600                      ; store the sequential/random mode flag (1=sequential)
3910  A600 32 D5 A9             LD (WRITE_TYPE_FLAG),A
3911  A603              ; ----------------------------------------------------------------------
3912  A603              ; BDOS_WRITE -- BDOS WRITE primitive (CP/M 2.2 fn 21 F_WRITE / fn 34 F_WRITERAND / fn 40 F_WRITEZF
3913  A603              ; target). Write the current record of the open file, allocating and deblocking disk blocks as
3914  A603              ; needed.
3915  A603              ;   In: CURFCB (BDOS_PARAM_PTR) -> active FCB; the BDOS work cells for current-record (FCB_CURREC) /
3916  A603              ;       record-count (FCB_RECCOUNT) have been primed from the FCB by DRV_INSTALL_RWTS_3; DMA holds the
3917  A603              ;       caller's record; WRITE_TYPE_FLAG = write type (1 = sequential, 2 = random); BDOS_RETVAL = seek
3918  A603              ;       create/extend mode flag.
3919  A603              ;   Out: A = BDOS return code (0 = OK, 2 = disk full); status returned through BDOS_RET_RESULT; FCB
3920  A603              ;        allocation map / record count updated; host sector written. (OBSERVED: only the disk-full=2
3921  A603              ;        path is taken here; other error codes come from sub-routines.)
3922  A603              ;   Clobbers: A, BC, DE, HL, flags.
3923  A603              ;   Algorithm: clear the directory-update flag (RW_DIRECTION_FLAG); fetch the current record index and reject
3924  A603              ;              it if >= 128 (extent full). Compute the FCB allocation-map SLOT for this record and
3925  A603              ;              read the block number already stored there: if it is non-zero the block is already
3926  A603              ;              allocated, so branch straight to the write phase. If it is zero, recompute the slot
3927  A603              ;              index, fetch the block stored in the PREVIOUS slot as an allocation hint, then call
3928  A603              ;              the disk-map allocator (ALLOC_GET_BLOCK) to grab a fresh block. Store the (new or
3929  A603              ;              existing) block number into the FCB allocation slot, then perform the physical write
3930  A603              ;              and update the extent record count. Mirrors the standard CP/M 2.2 BDOS write routine.
3931  A603              ;              [RE]
3932  A603              ; ----------------------------------------------------------------------
3933  A603              BDOS_WRITE:
3934  A603                      ; Clear the directory-update-needed flag (RW_DIRECTION_FLAG) before starting this write.
3935  A603 3E 00                LD A,$00
3936  A605 32 D3 A9             LD (RW_DIRECTION_FLAG),A
3937  A608                      ; Drive read-only / select check (raises a BDOS error overlay if the drive is not writable).
3938  A608 CD 54 A1             CALL CMD_EXEC_20
3939  A60B                      ; HL = pointer to the active FCB (CURFCB).
3940  A60B 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
3941  A60E CD 47 A1             CALL CHECK_DIRENT_READONLY_INNER
3942  A611 CD BB A0             CALL DRV_INSTALL_RWTS_3
3943  A614                      ; Load the current record number within the extent (primed from the FCB).
3944  A614 3A E3 A9             LD A,(FCB_CURREC)
3945  A617                      ; Record index 128 means the extent is full -> cannot write, report error.
3946  A617 FE 80                CP $80
3947  A619                      ; Extent full / index out of range: bail to the BDOS error path.
3948  A619 D2 05 9F             JP NC,BDOS_RET_ONE
3949  A61C CD 77 A0             CALL DISK_STORE_SEC_TRK_14
3950  A61F CD 84 A0             CALL DISK_STORE_SEC_TRK_16
3951  A622                      ; C = 0: existing-block write mode (no zero-fill); used only if the block is already
3952  A622                      ; allocated.
3953  A622 0E 00                LD C,$00
3954  A624                      ; Block already allocated (slot held a non-zero block) -> skip allocation, go to the write
3955  A624                      ; phase.
3956  A624 C2 6E A6             JP NZ,BDOS_WRITE_PHASE
3957  A627                      ; Recompute the FCB allocation-map slot index for the current record (A = slot index, NOT a
3958  A627                      ; disk block).
3959  A627 CD 3E A0             CALL DISK_STORE_SEC_TRK_6
3960  A62A                      ; Save the allocation-slot index for use when storing the new block number.
3961  A62A 32 D7 A9             LD (ALLOC_SLOT_INDEX),A
3962  A62D 01 00 00             LD BC,$0000
3963  A630 B7                   OR A
3964  A631                      ; Slot index 0 (first slot) -> skip the previous-slot fetch; go allocate a fresh block.
3965  A631 CA 3B A6             JP Z,BDOS_WRITE_ALLOCBLK
3966  A634 4F                   LD C,A
3967  A635 0B                   DEC BC
3968  A636                      ; Fetch the block stored in the PREVIOUS slot (BC = slot-1) as the allocation starting hint
3969  A636                      ; -> HL.
3970  A636 CD 5E A0             CALL DISK_STORE_SEC_TRK_10
3971  A639 44                   LD B,H
3972  A63A 4D                   LD C,L
3973  A63B              ; ----------------------------------------------------------------------
3974  A63B              ; BDOS_WRITE_ALLOCBLK -- allocate a fresh data block from the disk allocation vector, or return
3975  A63B              ; 'disk full'.
3976  A63B              ;   In: BC = allocation hint (block from the previous slot, or 0); CURFCB context valid.
3977  A63B              ;   Out: on success HL = newly allocated block number and control falls into BDOS_WRITE_STOREBLK; on
3978  A63B              ;        no free block, returns A=2 (disk full) via BDOS_RET_RESULT.
3979  A63B              ;   Clobbers: A, BC, DE, HL, flags.
3980  A63B              ;   Algorithm: call the disk-map allocator ALLOC_GET_BLOCK, which scans the drive allocation bitmap
3981  A63B              ;              (up to MAX_BLOCK_DSM), marks a free block in use and returns HL = its block number
3982  A63B              ;              (HL = 0 when the disk is full). If HL is zero, set A=2 and return the disk-full
3983  A63B              ;              status; otherwise fall through to record the new block in the FCB. [RE]
3984  A63B              ; ----------------------------------------------------------------------
3985  A63B              BDOS_WRITE_ALLOCBLK:
3986  A63B                      ; Allocate a fresh block from the drive allocation bitmap; HL = new block number (0 = disk
3987  A63B                      ; full).
3988  A63B CD BE A3             CALL ALLOC_GET_BLOCK
3989  A63E 7D                   LD A,L
3990  A63F                      ; Test HL for zero (no free block was found).
3991  A63F B4                   OR H
3992  A640                      ; Non-zero block: proceed to record it in the FCB.
3993  A640 C2 48 A6             JP NZ,BDOS_WRITE_STOREBLK
3994  A643                      ; A = 2: disk-full return code.
3995  A643 3E 02                LD A,$02
3996  A645                      ; Return disk-full status to the caller.
3997  A645 C3 01 9F             JP BDOS_RET_RESULT
3998  A648              ; ----------------------------------------------------------------------
3999  A648              ; BDOS_WRITE_STOREBLK -- store the (new or existing) block number into the FCB allocation slot for
4000  A648              ; the current record.
4001  A648              ;   In: HL = block number; CURFCB (BDOS_PARAM_PTR) = active FCB; ALLOC_SLOT_INDEX = allocation-slot index
4002  A648              ;       within the extent; BLOCK_WIDTH_FLAG selects 1-byte vs 2-byte block entries.
4003  A648              ;   Out: FCB allocation map updated with the block number at the computed slot.
4004  A648              ;   Clobbers: A, BC, DE, HL, flags.
4005  A648              ;   Algorithm: save the block number to CUR_BLOCK_NUMBER (for the write phase) into DE; point HL at the FCB
4006  A648              ;              allocation map (FCB+16); read the slot index. If BLOCK_WIDTH_FLAG selects 8-bit
4007  A648              ;              blocks, add the slot index to HL (via DIRENT_PTR_ADD) and store one byte; otherwise
4008  A648              ;              jump to the 16-bit store path. [RE]
4009  A648              ; ----------------------------------------------------------------------
4010  A648              BDOS_WRITE_STOREBLK:
4011  A648                      ; Save the block number for the write phase (host record/sector base).
4012  A648 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
4013  A64B EB                   EX DE,HL
4014  A64C 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4015  A64F                      ; Offset 16 = start of the allocation/disk-map area inside the FCB.
4016  A64F 01 10 00             LD BC,$0010
4017  A652 09                   ADD HL,BC
4018  A653                      ; Test whether the drive uses 8-bit (small disk) or 16-bit block numbers.
4019  A653 3A DD A9             LD A,(BLOCK_WIDTH_FLAG)
4020  A656 B7                   OR A
4021  A657                      ; A = allocation-slot index within the FCB extent.
4022  A657 3A D7 A9             LD A,(ALLOC_SLOT_INDEX)
4023  A65A                      ; 16-bit-block-number drive: store the block number as a 2-byte entry.
4024  A65A CA 64 A6             JP Z,BDOS_WRITE_STOREBLK16
4025  A65D                      ; Add the slot index to HL = address of the single-byte slot inside the FCB map.
4026  A65D CD 64 A1             CALL DIRENT_PTR_ADD
4027  A660                      ; Store the low byte (8-bit block number) into the FCB slot.
4028  A660 73                   LD (HL),E
4029  A661 C3 6C A6             JP BDOS_WRITE_NEWBLK
4030  A664              ; ----------------------------------------------------------------------
4031  A664              ; BDOS_WRITE_STOREBLK16 -- store a 16-bit block number into the FCB allocation map (large-disk
4032  A664              ; format).
4033  A664              ;   In: HL = FCB allocation-map base (FCB+16); A = slot index; DE = block number.
4034  A664              ;   Out: the 2-byte block number written at FCB+16 + slot*2 (low byte then high byte).
4035  A664              ;   Clobbers: A, BC, HL, flags.
4036  A664              ;   Algorithm: extend the slot index to BC, add it to HL twice (slot*2 byte offset), then store DE
4037  A664              ;              low/high. Falls through to the write phase. [RE]
4038  A664              ; ----------------------------------------------------------------------
4039  A664              BDOS_WRITE_STOREBLK16:
4040  A664                      ; BC = slot index.
4041  A664 4F                   LD C,A
4042  A665 06 00                LD B,$00
4043  A667                      ; Add slot index twice (this is the first add) => byte offset = slot*2 for 16-bit entries.
4044  A667 09                   ADD HL,BC
4045  A668 09                   ADD HL,BC
4046  A669                      ; Store block-number low byte.
4047  A669 73                   LD (HL),E
4048  A66A 23                   INC HL
4049  A66B                      ; Store block-number high byte.
4050  A66B 72                   LD (HL),D
4051  A66C              ; ----------------------------------------------------------------------
4052  A66C              ; BDOS_WRITE_NEWBLK -- mark this write as 'new block, must zero-fill' before the write phase.
4053  A66C              ;   In: control reaches here after a freshly allocated block was recorded in the FCB.
4054  A66C              ;   Out: C = 2, signalling the write phase to zero-fill the unwritten records of the new block.
4055  A66C              ;   Clobbers: C.
4056  A66C              ;   Algorithm: set C=2 (new-block write mode) and fall into the write phase. [RE]
4057  A66C              ; ----------------------------------------------------------------------
4058  A66C              BDOS_WRITE_NEWBLK:
4059  A66C                      ; C = 2: new-block write mode (the block was just allocated, zero-fill it).
4060  A66C 0E 02                LD C,$02
4061  A66E              ; ----------------------------------------------------------------------
4062  A66E              ; BDOS_WRITE_PHASE -- perform the physical write of the current record, honoring the
4063  A66E              ; deblocking/new-block mode.
4064  A66E              ;   In: C = write mode (0 = existing block, 2 = new block); CURFCB context valid; DMA holds the
4065  A66E              ;       caller's record; BDOS_RETVAL = seek create/extend mode flag (00 / FF); WRITE_TYPE_FLAG = BDOS write
4066  A66E              ;       type (1 = sequential, 2 = random).
4067  A66E              ;   Out: host sector updated on disk; control merges into the post-write record-count update;
4068  A66E              ;        returns early if the create/extend flag is set.
4069  A66E              ;   Clobbers: A, BC, DE, HL, flags.
4070  A66E              ;   Algorithm: load BDOS_RETVAL; if it is non-zero (a create/extend was flagged) return so the
4071  A66E              ;              caller can handle it. Otherwise save the mode, compute the host record/sector
4072  A66E              ;              (DISK_STORE_SEC_TRK_17), and branch on write type: random data writes (type 2) go
4073  A66E              ;              directly; sequential writes of a fresh block (mode 2) first zero-fill the
4074  A66E              ;              directory/work buffer and write its records up to the host-sector boundary.
4075  A66E              ;              (OBSERVED: BDOS_RETVAL is the same cell the seek code sets to its phase value;
4076  A66E              ;              calling it a 'host-buffer' flag is not supported -- it is the seek/create mode cell.)
4077  A66E              ;              [RE]
4078  A66E              ; ----------------------------------------------------------------------
4079  A66E              BDOS_WRITE_PHASE:
4080  A66E                      ; Load the seek create/extend mode flag (BDOS_RETVAL; 00 = normal, FF = create/extend
4081  A66E                      ; pending).
4082  A66E 3A 45 9F             LD A,(BDOS_RETVAL)
4083  A671 B7                   OR A
4084  A672                      ; Create/extend flagged (BDOS_RETVAL != 0) -> return to the caller without writing here.
4085  A672 C0                   RET NZ
4086  A673                      ; Preserve the write-mode byte (C) across the sector computation.
4087  A673 C5                   PUSH BC
4088  A674                      ; Compute the host physical record index/sector for the current logical record.
4089  A674 CD 8A A0             CALL DISK_STORE_SEC_TRK_17
4090  A677                      ; Load the BDOS write type (1 = sequential, 2 = random).
4091  A677 3A D5 A9             LD A,(WRITE_TYPE_FLAG)
4092  A67A 3D                   DEC A
4093  A67B 3D                   DEC A
4094  A67C                      ; Write type != 2 (sequential) -> may need the new-block zero-fill path.
4095  A67C C2 BB A6             JP NZ,BDOS_WRITE_DOWRITE
4096  A67F C1                   POP BC
4097  A680 C5                   PUSH BC
4098  A681                      ; A = write mode (was the block freshly allocated?).
4099  A681 79                   LD A,C
4100  A682 3D                   DEC A
4101  A683 3D                   DEC A
4102  A684                      ; Existing block (mode != 2): write directly, no zero-fill.
4103  A684 C2 BB A6             JP NZ,BDOS_WRITE_DOWRITE
4104  A687 E5                   PUSH HL
4105  A688                      ; HL = directory/work buffer to be zero-filled before the new-block write.
4106  A688 2A B9 A9             LD HL,(DIRBUF_PTR)
4107  A68B                      ; D = 0: byte counter for the 128-byte fill loop.
4108  A68B 57                   LD D,A
4109  A68C              ; ----------------------------------------------------------------------
4110  A68C              ; BDOS_WRITE_ZEROFILL -- zero-fill one 128-byte record buffer for a freshly allocated block.
4111  A68C              ;   In: HL = buffer start; A = 0 (fill value); D = 0 (loop counter).
4112  A68C              ;   Out: 128 bytes from HL cleared to 0; HL advanced past the buffer.
4113  A68C              ;   Clobbers: A(=0), D, HL, flags.
4114  A68C              ;   Algorithm: store 0, advance HL, INC D and loop while the sign flag stays clear (D < 128), i.e.
4115  A68C              ;              128 iterations (0..127). Clears the work buffer before writing fresh records into a
4116  A68C              ;              new block. [RE]
4117  A68C              ; ----------------------------------------------------------------------
4118  A68C              BDOS_WRITE_ZEROFILL:
4119  A68C                      ; Store 0 into the buffer byte.
4120  A68C 77                   LD (HL),A
4121  A68D 23                   INC HL
4122  A68E                      ; Advance the 0..127 fill counter.
4123  A68E 14                   INC D
4124  A68F                      ; Loop while D < 128 (sign clear): fill all 128 record bytes.
4125  A68F F2 8C A6             JP P,BDOS_WRITE_ZEROFILL
4126  A692                      ; Point the DMA at the deblocking/host buffer for the fill writes.
4127  A692 CD E0 A1             CALL SET_DMA_TO_DISK_BUF
4128  A695                      ; HL = base host record index for this block's fill.
4129  A695 2A E7 A9             LD HL,(BLOCK_BASE_RECORD)
4130  A698 0E 02                LD C,$02
4131  A69A              ; ----------------------------------------------------------------------
4132  A69A              ; BDOS_WRITE_FILLLOOP -- write the zero-filled records of a new block up to the host-sector
4133  A69A              ; boundary.
4134  A69A              ;   In: HL = current host record index; C = 2 (mode); deblock DMA already pointed at the fill
4135  A69A              ;       buffer.
4136  A69A              ;   Out: the records spanning the host sector written; loops until the record index crosses the
4137  A69A              ;        host-sector mask boundary.
4138  A69A              ;   Clobbers: A, BC, HL, flags.
4139  A69A              ;   Algorithm: save the record index (CUR_BLOCK_NUMBER), translate/seek the host sector (RECORD_TO_TRACK),
4140  A69A              ;              write it (DISK_WRITE_CHECKED), reload the index and mask it with the
4141  A69A              ;              records-per-host-sector mask (DPB_BLM); INC the index and loop until the masked value
4142  A69A              ;              differs (host-sector boundary reached). Then restore the saved record index and
4143  A69A              ;              finalize via RESTORE_USER_DMA. [RE]
4144  A69A              ; ----------------------------------------------------------------------
4145  A69A              BDOS_WRITE_FILLLOOP:
4146  A69A                      ; Save the working host-record index.
4147  A69A 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
4148  A69D C5                   PUSH BC
4149  A69E                      ; Translate/seek the host track+sector for this record.
4150  A69E CD D1 9F             CALL RECORD_TO_TRACK
4151  A6A1 C1                   POP BC
4152  A6A2                      ; Write the (zeroed) record to the host sector via the BIOS R/W call.
4153  A6A2 CD B8 9F             CALL DISK_WRITE_CHECKED
4154  A6A5 2A E5 A9             LD HL,(CUR_BLOCK_NUMBER)
4155  A6A8 0E 00                LD C,$00
4156  A6AA                      ; Load the records-per-host-sector mask.
4157  A6AA 3A C4 A9             LD A,(DPB_BLM)
4158  A6AD 47                   LD B,A
4159  A6AE                      ; Mask the record index to its position within the host sector.
4160  A6AE A5                   AND L
4161  A6AF                      ; Compare against the host-sector base value (still inside this host sector?).
4162  A6AF B8                   CP B
4163  A6B0 23                   INC HL
4164  A6B1                      ; Loop while still within the same host sector (fill all its records).
4165  A6B1 C2 9A A6             JP NZ,BDOS_WRITE_FILLLOOP
4166  A6B4 E1                   POP HL
4167  A6B5 22 E5 A9             LD (CUR_BLOCK_NUMBER),HL
4168  A6B8                      ; Restore the caller DMA and finalize the new-block fill.
4169  A6B8 CD DA A1             CALL RESTORE_USER_DMA
4170  A6BB              ; ----------------------------------------------------------------------
4171  A6BB              ; BDOS_WRITE_DOWRITE -- write the caller's current record to its host sector and bump the extent
4172  A6BB              ; record count.
4173  A6BB              ;   In: stack holds the mode byte; CURFCB context valid; DMA = caller record.
4174  A6BB              ;   Out: record written; FCB current-record-count cell (FCB_RECCOUNT) advanced when this record extends
4175  A6BB              ;        the extent; C=2 if the count grew; falls into the S2/extent-overflow update.
4176  A6BB              ;   Clobbers: A, BC, DE, HL, flags.
4177  A6BB              ;   Algorithm: translate/seek (RECORD_TO_TRACK) and write (DISK_WRITE_CHECKED) the record; compare
4178  A6BB              ;              the just-written record index (FCB_CURREC) against the extent's stored record count
4179  A6BB              ;              (FCB_RECCOUNT); if it is a new high-water record, store and increment the count and set C=2
4180  A6BB              ;              (extent grew). [RE]
4181  A6BB              ; ----------------------------------------------------------------------
4182  A6BB              BDOS_WRITE_DOWRITE:
4183  A6BB                      ; Translate/seek the host track+sector for the current record.
4184  A6BB CD D1 9F             CALL RECORD_TO_TRACK
4185  A6BE C1                   POP BC
4186  A6BF C5                   PUSH BC
4187  A6C0                      ; Write the caller's record to the host sector via the BIOS R/W call.
4188  A6C0 CD B8 9F             CALL DISK_WRITE_CHECKED
4189  A6C3 C1                   POP BC
4190  A6C4                      ; A = the record index just written within the extent.
4191  A6C4 3A E3 A9             LD A,(FCB_CURREC)
4192  A6C7                      ; HL -> the extent's current record-count cell (FCB_RECCOUNT).
4193  A6C7 21 E1 A9             LD HL,FCB_RECCOUNT
4194  A6CA                      ; Is the written record beyond the current record count?
4195  A6CA BE                   CP (HL)
4196  A6CB                      ; Record is within the existing count -> no count update needed.
4197  A6CB DA D2 A6             JP C,BDOS_WRITE_S2UPDATE
4198  A6CE                      ; Extent grew: store the new record index as the count...
4199  A6CE 77                   LD (HL),A
4200  A6CF                      ; ...and bump it (count = index + 1).
4201  A6CF 34                   INC (HL)
4202  A6D0                      ; C = 2: signal the extent record count was extended.
4203  A6D0 0E 02                LD C,$02
4204  A6D2              ; ----------------------------------------------------------------------
4205  A6D2              ; BDOS_WRITE_S2UPDATE -- refresh the FCB S2 byte and, at end-of-extent, advance the FCB to the next
4206  A6D2              ; extent.
4207  A6D2              ;   In: A = current record/extent state; CURFCB context valid; WRITE_TYPE_FLAG = write type.
4208  A6D2              ;   Out: FCB S2 byte stored with its high bit cleared; on extent rollover (record index 0x7F with
4209  A6D2              ;        sequential write) the record count is written back and the FCB moves to the next extent;
4210  A6D2              ;        otherwise takes the common return.
4211  A6D2              ;   Clobbers: A, BC, HL, flags.
4212  A6D2              ;   Algorithm: (two leading NOPs are padding). Fetch the FCB S2 byte (FCB_GET_S2), clear its high
4213  A6D2              ;              bit and store it back. If the just-written record was the last in the extent (0x7F)
4214  A6D2              ;              AND this is a sequential write (WRITE_TYPE_FLAG == 1), copy the working record count back into
4215  A6D2              ;              the FCB (DRV_INSTALL_RWTS_6) and advance to the next extent (FCB_ADVANCE_RECORD); if
4216  A6D2              ;              no host buffer write is pending, reset the current-record cell; else take the common
4217  A6D2              ;              return. (OBSERVED: the LD HL,$9400 at entry is immediately overwritten by FCB_GET_S2
4218  A6D2              ;              -- it loads no value that is used.) [RE]
4219  A6D2              ; ----------------------------------------------------------------------
4220  A6D2              BDOS_WRITE_S2UPDATE:
4221  A6D2 00                   NOP
4222  A6D3 00                   NOP
4223  A6D4                      ; Vestigial load of the BDOS base ($9400) -- HL is immediately overwritten by FCB_GET_S2
4224  A6D4                      ; below; value unused.
4225  A6D4 21 00 94             LD HL,CCP_ENTRY
4226  A6D7 F5                   PUSH AF
4227  A6D8                      ; HL -> the FCB S2 (extent-module) byte; A = its value.
4228  A6D8 CD 69 A1             CALL FCB_GET_S2
4229  A6DB                      ; Clear the high (modified/in-use) bit of the S2 byte.
4230  A6DB E6 7F                AND $7F
4231  A6DD                      ; Store the updated S2 byte back into the FCB.
4232  A6DD 77                   LD (HL),A
4233  A6DE F1                   POP AF
4234  A6DF                      ; Was the just-written record the last (index 0x7F) of the extent?
4235  A6DF FE 7F                CP $7F
4236  A6E1                      ; Not at end of extent -> done, take the common return.
4237  A6E1 C2 00 A7             JP NZ,BDOS_WRITE_RET
4238  A6E4                      ; Load the BDOS write type.
4239  A6E4 3A D5 A9             LD A,(WRITE_TYPE_FLAG)
4240  A6E7                      ; Only sequential writes (type 1) roll the extent forward here.
4241  A6E7 FE 01                CP $01
4242  A6E9                      ; Random write at extent end -> done, common return.
4243  A6E9 C2 00 A7             JP NZ,BDOS_WRITE_RET
4244  A6EC                      ; Copy the working record count (FCB_CURREC/FCB_RECCOUNT) back into the FCB before rolling over.
4245  A6EC CD D2 A0             CALL DRV_INSTALL_RWTS_6
4246  A6EF                      ; Advance the FCB to the next extent (increment EX, handle module overflow).
4247  A6EF CD 5A A5             CALL FCB_ADVANCE_RECORD
4248  A6F2 21 45 9F             LD HL,BDOS_RETVAL
4249  A6F5 7E                   LD A,(HL)
4250  A6F6 B7                   OR A
4251  A6F7 C2 FE A6             JP NZ,BDOS_WRITE_RESETREC
4252  A6FA 3D                   DEC A
4253  A6FB 32 E3 A9             LD (FCB_CURREC),A
4254  A6FE              ; ----------------------------------------------------------------------
4255  A6FE              ; BDOS_WRITE_RESETREC -- clear the seek/create-mode flag cell after an extent rollover.
4256  A6FE              ;   In: HL -> the BDOS_RETVAL flag cell.
4257  A6FE              ;   Out: that flag cell cleared to 0.
4258  A6FE              ;   Clobbers: (memory only).
4259  A6FE              ;   Algorithm: store 0 through HL to reset the BDOS_RETVAL flag, then fall into the common return.
4260  A6FE              ;              [RE]
4261  A6FE              ; ----------------------------------------------------------------------
4262  A6FE              BDOS_WRITE_RESETREC:
4263  A6FE                      ; Clear the BDOS_RETVAL seek/create-mode flag for the new extent.
4264  A6FE 36 00                LD (HL),$00
4265  A700              ; ----------------------------------------------------------------------
4266  A700              ; BDOS_WRITE_RET -- common exit of the WRITE primitive.
4267  A700              ;   In: write completed (or no further action needed).
4268  A700              ;   Out: tail-jumps to DRV_INSTALL_RWTS_6, which copies the working record/count back into the FCB
4269  A700              ;        and returns to the BDOS dispatcher.
4270  A700              ;   Clobbers: per the tail routine.
4271  A700              ;   Algorithm: tail-jump to the record-count writeback routine. [RE]
4272  A700              ; ----------------------------------------------------------------------
4273  A700              BDOS_WRITE_RET:
4274  A700                      ; Copy the working record/count back into the FCB and return via the shared tail.
4275  A700 C3 D2 A0             JP DRV_INSTALL_RWTS_6
4276  A703              ; ----------------------------------------------------------------------
4277  A703              ; BDOS_SEEK_NOREAD -- SEEK entry that clears the write-type cell, then computes/positions the target
4278  A703              ; extent.
4279  A703              ;   In: CURFCB (BDOS_PARAM_PTR) valid.
4280  A703              ;   Out: as for BDOS_SEEK_COMPUTE below.
4281  A703              ;   Clobbers: A, BC, DE, HL, flags.
4282  A703              ;   Algorithm: clear the write-type cell (WRITE_TYPE_FLAG = 0), then fall straight into BDOS_SEEK_COMPUTE.
4283  A703              ;              (OBSERVED: this entry is used by the random read/write callers
4284  A703              ;              FCB_EXTENT_TO_TRKSEC_8/9 after they set C; BDOS_SEEK_NOREAD itself does not consume C
4285  A703              ;              -- it is merely preserved on the stack across the seek and used by the caller
4286  A703              ;              afterward.) [RE]
4287  A703              ; ----------------------------------------------------------------------
4288  A703              BDOS_SEEK_NOREAD:
4289  A703 AF                   XOR A
4290  A704                      ; Write type = 0 (cleared before the seek).
4291  A704 32 D5 A9             LD (WRITE_TYPE_FLAG),A
4292  A707              ; ----------------------------------------------------------------------
4293  A707              ; BDOS_SEEK_COMPUTE -- compute the target extent/record from the FCB random-record field (R0/R1/R2)
4294  A707              ; and seek the directory to it.
4295  A707              ;   In: CURFCB (BDOS_PARAM_PTR) -> FCB whose random-record bytes (FCB+33..35 = R0/R1/R2) hold the
4296  A707              ;       desired record; BDOS_RETVAL = create/extend mode flag.
4297  A707              ;   Out: B = target S2 (module), C = target extent-within-entry; if the FCB is already positioned
4298  A707              ;        there, returns OK (A=0) via BDOS_RET_RESULT; else repositions the directory; on R2 != 0
4299  A707              ;        returns record-out-of-range. (OBSERVED: BC is also just preserved on the stack for the
4300  A707              ;        calling read/write routine.)
4301  A707              ;   Clobbers: A, BC, DE, HL, flags.
4302  A707              ;   Algorithm: read R0 and combine with R1 into the 16-bit record number. record-within-extent = R0
4303  A707              ;              & 0x7F; extent = ((R1 << 1) | R0.bit7) & 0x1F (C); S2/module = R1 >> 4 (B). If R2
4304  A707              ;              (high random byte) is non-zero the record is out of range -> abort with phase code 6.
4305  A707              ;              Otherwise compare target extent (C vs FCB+12) and S2 (B vs FCB+14): if both already
4306  A707              ;              match, fall through with no positioning; else reposition the directory to the target
4307  A707              ;              extent. Mirrors the standard CP/M 2.2 BDOS random seek. [RE]
4308  A707              ; ----------------------------------------------------------------------
4309  A707              BDOS_SEEK_COMPUTE:
4310  A707 C5                   PUSH BC
4311  A708                      ; HL = pointer to the active FCB (CURFCB).
4312  A708 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4313  A70B EB                   EX DE,HL
4314  A70C                      ; Offset 33 (0x21) = FCB random-record field R0; HL = FCB+33 after ADD HL,DE.
4315  A70C 21 21 00             LD HL,$0021
4316  A70F 19                   ADD HL,DE
4317  A710 7E                   LD A,(HL)
4318  A711                      ; Record-within-extent = R0 bits 0..6 (0..127).
4319  A711 E6 7F                AND $7F
4320  A713 F5                   PUSH AF
4321  A714 7E                   LD A,(HL)
4322  A715                      ; Rotate R0 bit7 into carry (combined with R1 below for the extent number).
4323  A715 17                   RLA
4324  A716 23                   INC HL
4325  A717 7E                   LD A,(HL)
4326  A718                      ; Rotate R1 left, picking up R0.bit7 from carry: forms (R1 << 1) | R0.bit7.
4327  A718 17                   RLA
4328  A719                      ; Low 5 bits = extent number within the directory entry.
4329  A719 E6 1F                AND $1F
4330  A71B                      ; C = target extent (low part).
4331  A71B 4F                   LD C,A
4332  A71C 7E                   LD A,(HL)
4333  A71D 1F                   RRA
4334  A71E 1F                   RRA
4335  A71F 1F                   RRA
4336  A720 1F                   RRA
4337  A721                      ; Keep R1's high nibble = S2 / extent-module count.
4338  A721 E6 0F                AND $0F
4339  A723                      ; B = target S2 (extent module) value (R1 >> 4).
4340  A723 47                   LD B,A
4341  A724 F1                   POP AF
4342  A725 23                   INC HL
4343  A726 6E                   LD L,(HL)
4344  A727 2C                   INC L
4345  A728 2D                   DEC L
4346  A729                      ; Preset L = seek phase code 6 (the random-record overflow result).
4347  A729 2E 06                LD L,$06
4348  A72B                      ; R2 (high random-record byte) non-zero -> record number out of range, abort the seek.
4349  A72B C2 8B A7             JP NZ,RANDREC_POS_RET
4350  A72E 21 20 00             LD HL,$0020
4351  A731 19                   ADD HL,DE
4352  A732 77                   LD (HL),A
4353  A733                      ; Offset 12 = FCB extent (EX) byte.
4354  A733 21 0C 00             LD HL,$000C
4355  A736 19                   ADD HL,DE
4356  A737 79                   LD A,C
4357  A738                      ; Compare target extent (C) against the FCB's current extent.
4358  A738 96                   SUB (HL)
4359  A739                      ; Extent differs -> must reposition the directory to the new extent.
4360  A739 C2 47 A7             JP NZ,BDOS_SEEK_REPOSITION
4361  A73C                      ; Offset 14 = FCB S2 (module) byte.
4362  A73C 21 0E 00             LD HL,$000E
4363  A73F 19                   ADD HL,DE
4364  A740 78                   LD A,B
4365  A741                      ; Compare target S2 (B) against the FCB's current S2.
4366  A741 96                   SUB (HL)
4367  A742 E6 7F                AND $7F
4368  A744                      ; Extent and S2 both already current -> nothing to seek, return OK.
4369  A744 CA 7F A7             JP Z,BDOS_SEEK_DONE
4370  A747              ; ----------------------------------------------------------------------
4371  A747              ; BDOS_SEEK_REPOSITION -- close the current extent and open/seek the directory to the requested
4372  A747              ; extent.
4373  A747              ;   In: B = target S2, C = target extent; DE -> FCB; BDOS_RETVAL = create/extend mode flag (0xFF =
4374  A747              ;       create on miss).
4375  A747              ;   Out: FCB extent (EX, +12) and S2 (+14) set to the target; directory positioned at the matching
4376  A747              ;        extent; a phase code is left in L (stored into BDOS_RETVAL at the seek tail); on success
4377  A747              ;        falls into BDOS_SEEK_DONE.
4378  A747              ;   Clobbers: A, BC, DE, HL, flags.
4379  A747              ;   Algorithm: close/flush the currently open extent (F_CLOSE_HND clears the host-buffer/seek cache).
4380  A747              ;              Set phase=3; if BDOS_RETVAL == 0xFF (create mode; INC A gives 0 / Z) take the
4381  A747              ;              extent-allocate path. Otherwise store the new EX (+12) and S2 (+14) into the FCB and
4382  A747              ;              open the matching directory entry (FCB_OPEN_SEARCH). Re-test BDOS_RETVAL (phase 4):
4383  A747              ;              on create, probe the next extent; read the directory record (DIR_MAKE_ENTRY); re-test
4384  A747              ;              (phase 5); then drop into BDOS_SEEK_DONE. [RE]
4385  A747              ; ----------------------------------------------------------------------
4386  A747              BDOS_SEEK_REPOSITION:
4387  A747 C5                   PUSH BC
4388  A748 D5                   PUSH DE
4389  A749                      ; Close the currently open extent (clears the host-buffer/seek cache cells) before
4390  A749                      ; repositioning.
4391  A749 CD A2 A4             CALL F_CLOSE_HND
4392  A74C D1                   POP DE
4393  A74D C1                   POP BC
4394  A74E                      ; Seek phase code 3 (extent-allocate path).
4395  A74E 2E 03                LD L,$03
4396  A750                      ; Load the create/extend mode flag.
4397  A750 3A 45 9F             LD A,(BDOS_RETVAL)
4398  A753                      ; Test for the 0xFF 'create/allocate on miss' value (INC -> 0 / sets Z).
4399  A753 3C                   INC A
4400  A754                      ; Create/allocate mode -> take the extent-allocate path.
4401  A754 CA 84 A7             JP Z,FCB_EXTENT_TO_TRKSEC_7
4402  A757                      ; Offset 12 = FCB extent (EX) byte.
4403  A757 21 0C 00             LD HL,$000C
4404  A75A 19                   ADD HL,DE
4405  A75B                      ; Store the new target extent into the FCB.
4406  A75B 71                   LD (HL),C
4407  A75C                      ; Offset 14 = FCB S2 byte.
4408  A75C 21 0E 00             LD HL,$000E
4409  A75F 19                   ADD HL,DE
4410  A760                      ; Store the new target S2 (module) into the FCB.
4411  A760 70                   LD (HL),B
4412  A761                      ; Search/open the directory entry for the new extent.
4413  A761 CD 51 A4             CALL FCB_OPEN_SEARCH
4414  A764 3A 45 9F             LD A,(BDOS_RETVAL)
4415  A767 3C                   INC A
4416  A768 C2 7F A7             JP NZ,BDOS_SEEK_DONE
4417  A76B C1                   POP BC
4418  A76C C5                   PUSH BC
4419  A76D                      ; Seek phase code 4.
4420  A76D 2E 04                LD L,$04
4421  A76F                      ; Bump the extent for the next-extent create probe.
4422  A76F 0C                   INC C
4423  A770                      ; Create path: allocate/init the new extent.
4424  A770 CA 84 A7             JP Z,FCB_EXTENT_TO_TRKSEC_7
4425  A773                      ; Read the directory record for the new extent into the scratch buffer.
4426  A773 CD 24 A5             CALL DIR_MAKE_ENTRY
4427  A776                      ; Seek phase code 5.
4428  A776 2E 05                LD L,$05
4429  A778 3A 45 9F             LD A,(BDOS_RETVAL)
4430  A77B 3C                   INC A
4431  A77C                      ; Create path: finalize the new extent.
4432  A77C CA 84 A7             JP Z,FCB_EXTENT_TO_TRKSEC_7
4433  A77F              ; ----------------------------------------------------------------------
4434  A77F              ; BDOS_SEEK_DONE -- successful SEEK exit: restore registers and return OK.
4435  A77F              ;   In: target extent/record now current in the FCB.
4436  A77F              ;   Out: A = 0 (seek OK) returned via BDOS_RET_RESULT; the BC saved at SEEK entry restored.
4437  A77F              ;   Clobbers: A, BC.
4438  A77F              ;   Algorithm: pop the saved BC, set A=0 and return the success status through the BDOS result tail.
4439  A77F              ;              [RE]
4440  A77F              ; ----------------------------------------------------------------------
4441  A77F              BDOS_SEEK_DONE:
4442  A77F                      ; Restore the caller's BC saved at SEEK entry.
4443  A77F C1                   POP BC
4444  A780                      ; A = 0: seek successful.
4445  A780 AF                   XOR A
4446  A781                      ; Return the seek result (0 = OK) to the caller.
4447  A781 C3 01 9F             JP BDOS_RET_RESULT
4448  A784              ; ----------------------------------------------------------------------
4449  A784              ; RANDREC_POS_FAIL -- error tail of the random-record positioning code (BDOS_SEEK_COMPUTE): mark the
4450  A784              ; extent invalid and report.
4451  A784              ;   In: L = error/return code to publish (set by the caller, e.g. 6 = 'random record out of range',
4452  A784              ;       3, 4, 5); one BC frame still pushed by BDOS_SEEK_COMPUTE; BDOS_PARAM_PTR = current FCB
4453  A784              ;       pointer.
4454  A784              ;   Out: FCB S2 byte (offset $0E) forced to $C0; BDOS_RETVAL result cell loaded with L; tail-jumps
4455  A784              ;        via RANDREC_POS_RET to MARK_FCB_S2_HIGHBIT, which then ORs $80 into S2 and returns.
4456  A784              ;   Clobbers: A, HL, BC (popped).
4457  A784              ;   Algorithm: PUSH HL; fetch &FCB.S2 via FCB_GET_S2 and store $C0 into it; POP HL; fall through
4458  A784              ;              into RANDREC_POS_RET, which POPs the BC frame, copies L into the result cell, and JPs
4459  A784              ;              MARK_FCB_S2_HIGHBIT.
4460  A784              ;   [RE] Reached from several points in BDOS_SEEK_COMPUTE when the random record cannot be
4461  A784              ;   positioned (out of range, or a read-mode request that would have to extend the file). Setting S2
4462  A784              ;   to $C0 marks the extent so the file is treated as unwritten/at-EOF; the published L code is the
4463  A784              ;   BDOS error returned to the caller.
4464  A784              ; ----------------------------------------------------------------------
4465  A784              FCB_EXTENT_TO_TRKSEC_7:
4466  A784 E5                   PUSH HL
4467  A785                      ; HL := &FCB.S2 (offset $0E of the current FCB)
4468  A785 CD 69 A1             CALL FCB_GET_S2
4469  A788                      ; S2 := $C0: high bit set (extent marked invalid/unwritten) + zero the module count [RE]
4470  A788 36 C0                LD (HL),$C0
4471  A78A E1                   POP HL
4472  A78B              ; ----------------------------------------------------------------------
4473  A78B              ; RANDREC_POS_RET -- common exit for BDOS_SEEK_COMPUTE: discard the saved BC frame, publish the L
4474  A78B              ; result code, finalize via MARK_FCB_S2_HIGHBIT.
4475  A78B              ;   In: L = result/return code; one BC frame still pushed on the stack from BDOS_SEEK_COMPUTE's
4476  A78B              ;       entry PUSH BC.
4477  A78B              ;   Out: BDOS_RETVAL result cell = L; control transfers to MARK_FCB_S2_HIGHBIT (sets FCB S2 high
4478  A78B              ;        bit, returns to the BDOS dispatcher).
4479  A78B              ;   Clobbers: A, BC (popped).
4480  A78B              ;   Algorithm: POP BC to discard the saved register pair; A := L; store A into the BDOS_RETVAL
4481  A78B              ;              result cell; JP MARK_FCB_S2_HIGHBIT.
4482  A78B              ;   [RE] Entered by fall-through from RANDREC_POS_FAIL and directly (JP NZ from $A72B) when the
4483  A78B              ;   addressed extent differs from the open one. MARK_FCB_S2_HIGHBIT ORs $80 into the FCB S2 byte
4484  A78B              ;   before returning.
4485  A78B              ; ----------------------------------------------------------------------
4486  A78B              RANDREC_POS_RET:
4487  A78B                      ; discard the BC frame pushed on entry to BDOS_SEEK_COMPUTE
4488  A78B C1                   POP BC
4489  A78C 7D                   LD A,L
4490  A78D                      ; publish the return/error code in the BDOS result cell
4491  A78D 32 45 9F             LD (BDOS_RETVAL),A
4492  A790                      ; set FCB S2 high bit, then return to caller
4493  A790 C3 78 A1             JP MARK_FCB_S2_HIGHBIT
4494  A793              ; ----------------------------------------------------------------------
4495  A793              ; F_READRAND_BODY -- BDOS function 33 (Read Random) worker: position the FCB from its random record,
4496  A793              ; then read that record.
4497  A793              ;   In: BDOS_PARAM_PTR = current FCB pointer (random-record field r0/r1/r2 set by the caller);
4498  A793              ;       reached from F_READRAND_H after FCB_AUTO_DRIVE_SELECT.
4499  A793              ;   Out: read result stored in the BDOS result cell (BDOS_RETVAL) by the called read routine; Z from
4500  A793              ;        positioning governs whether the read runs.
4501  A793              ;   Clobbers: A, BC, DE, HL.
4502  A793              ;   Algorithm: C := $FF (read mode = do NOT extend the file); CALL BDOS_SEEK_NOREAD
4503  A793              ;              (BDOS_SEEK_COMPUTE) to convert the random record into extent + current-record fields;
4504  A793              ;              if positioning succeeded (Z), CALL FILE_READ_RECORD to read the addressed record;
4505  A793              ;              RET.
4506  A793              ;   [RE][DOC CP/M 2.2 BDOS fn 33] C=$FF is consumed inside BDOS_SEEK_COMPUTE: when positioning would
4507  A793              ;   require extending the file, INC C on $FF sets Z and diverts to the error tail, so a read past
4508  A793              ;   EOF fails instead of allocating. The conditional CALL Z performs the sector read only when
4509  A793              ;   positioning succeeded (Z).
4510  A793              ; ----------------------------------------------------------------------
4511  A793              FCB_EXTENT_TO_TRKSEC_8:
4512  A793                      ; C := $FF: read mode -- positioning must NOT extend/allocate (INC C->Z triggers the fail
4513  A793                      ; path)
4514  A793 0E FF                LD C,$FF
4515  A795                      ; BDOS_SEEK_COMPUTE: convert random record (r0/r1/r2) into extent + cr; Z on success
4516  A795 CD 03 A7             CALL BDOS_SEEK_NOREAD
4517  A798                      ; if positioned OK, read the addressed record
4518  A798 CC C1 A5             CALL Z,FILE_READ_RECORD
4519  A79B C9                   RET
4520  A79C              ; ----------------------------------------------------------------------
4521  A79C              ; F_WRITERAND_BODY -- BDOS function 34 (Write Random) worker: position the FCB from its random
4522  A79C              ; record, then write that record.
4523  A79C              ;   In: BDOS_PARAM_PTR = current FCB pointer (random-record field set by the caller); reached from
4524  A79C              ;       F_WRITERAND_H after FCB_AUTO_DRIVE_SELECT.
4525  A79C              ;   Out: write result stored in the BDOS result cell (BDOS_RETVAL) by the called write routine; Z
4526  A79C              ;        from positioning governs whether the write runs.
4527  A79C              ;   Clobbers: A, BC, DE, HL.
4528  A79C              ;   Algorithm: C := $00 (write mode = allocate/extend as needed); CALL BDOS_SEEK_NOREAD
4529  A79C              ;              (BDOS_SEEK_COMPUTE) to set extent + current-record from the random record; if
4530  A79C              ;              positioning succeeded (Z), CALL BDOS_WRITE to write the record; RET.
4531  A79C              ;   [RE][DOC CP/M 2.2 BDOS fn 34] C=$00 is consumed inside BDOS_SEEK_COMPUTE: INC C on $00 yields
4532  A79C              ;   $01 (NZ), so the extend path is taken rather than the error tail, allowing a new extent/block to
4533  A79C              ;   be allocated. The conditional CALL Z writes the record only when positioning succeeded (Z).
4534  A79C              ; ----------------------------------------------------------------------
4535  A79C              FCB_EXTENT_TO_TRKSEC_9:
4536  A79C                      ; C := $00: write mode -- positioning may allocate/extend the file (INC C->$01 NZ, no fail)
4537  A79C 0E 00                LD C,$00
4538  A79E                      ; BDOS_SEEK_COMPUTE: convert random record into extent + cr; Z on success
4539  A79E CD 03 A7             CALL BDOS_SEEK_NOREAD
4540  A7A1                      ; if positioned OK, write the addressed record
4541  A7A1 CC 03 A6             CALL Z,BDOS_WRITE
4542  A7A4 C9                   RET
4543  A7A5              ; ----------------------------------------------------------------------
4544  A7A5              ; FCB_RECNUM_FROM_FIELDS -- compute the 24-bit absolute record number from an FCB's record byte plus
4545  A7A5              ; its extent (ex) and S2 fields.
4546  A7A5              ;   In: HL = base pointer to the FCB (or directory entry); DE = byte offset within it of the low
4547  A7A5              ;       record byte to read (e.g. $20 = cr for Set Random Record, $0F for the per-extent record
4548  A7A5              ;       count in Compute File Size).
4549  A7A5              ;   Out: C = low byte, B = mid byte, A = high byte of the record number; A AND $01 leaves Z/NZ on
4550  A7A5              ;        the result's low bit for callers; HL, DE clobbered.
4551  A7A5              ;   Clobbers: A, BC, HL, DE, flags.
4552  A7A5              ;   Algorithm: EX DE,HL so HL=offset, DE=FCB base; ADD HL,DE -> &FCB+offset; C := that byte, B := 0.
4553  A7A5              ;              Read the extent byte (offset $0C): RRCA then AND $80 puts its bit0 into bit7, add to
4554  A7A5              ;              C (carry into B) -- the *128 contribution; RRCA/AND $0F of the same extent byte adds
4555  A7A5              ;              the extent's high nibble into B. Read S2 (offset $0E): shift left 4 (ADD A,A x4), add
4556  A7A5              ;              into B to form the high bits; final AND $01 sets Z/NZ on the low bit of the
4557  A7A5              ;              accumulated value.
4558  A7A5              ;   [RE] Builds the linear absolute record index (record + ex*128 + S2*...) that CP/M 2.2 uses to
4559  A7A5              ;   map directory extents onto a flat record space; shared by Set Random Record (fn 36) and Compute
4560  A7A5              ;   File Size (fn 35).
4561  A7A5              ; ----------------------------------------------------------------------
4562  A7A5              FCB_ALLOC_PREP:
4563  A7A5                      ; HL := caller offset; DE := FCB base pointer
4564  A7A5 EB                   EX DE,HL
4565  A7A6                      ; HL := &FCB + offset (the low record byte)
4566  A7A6 19                   ADD HL,DE
4567  A7A7                      ; C := low record bits from that byte
4568  A7A7 4E                   LD C,(HL)
4569  A7A8 06 00                LD B,$00
4570  A7AA                      ; offset $0C = FCB extent (ex) byte
4571  A7AA 21 0C 00             LD HL,$000C
4572  A7AD 19                   ADD HL,DE
4573  A7AE 7E                   LD A,(HL)
4574  A7AF 0F                   RRCA
4575  A7B0                      ; extent bit0 -> record bit7 (the ex*128 contribution)
4576  A7B0 E6 80                AND $80
4577  A7B2 81                   ADD A,C
4578  A7B3 4F                   LD C,A
4579  A7B4 3E 00                LD A,$00
4580  A7B6 88                   ADC A,B
4581  A7B7 47                   LD B,A
4582  A7B8 7E                   LD A,(HL)
4583  A7B9 0F                   RRCA
4584  A7BA E6 0F                AND $0F
4585  A7BC 80                   ADD A,B
4586  A7BD 47                   LD B,A
4587  A7BE                      ; offset $0E = FCB S2 byte (extent-high / module)
4588  A7BE 21 0E 00             LD HL,$000E
4589  A7C1 19                   ADD HL,DE
4590  A7C2 7E                   LD A,(HL)
4591  A7C3                      ; first of four ADD A,A: shift S2 left to form the high record bits
4592  A7C3 87                   ADD A,A
4593  A7C4 87                   ADD A,A
4594  A7C5 87                   ADD A,A
4595  A7C6 87                   ADD A,A
4596  A7C7 F5                   PUSH AF
4597  A7C8 80                   ADD A,B
4598  A7C9 47                   LD B,A
4599  A7CA F5                   PUSH AF
4600  A7CB E1                   POP HL
4601  A7CC 7D                   LD A,L
4602  A7CD E1                   POP HL
4603  A7CE B5                   OR L
4604  A7CF                      ; set Z/NZ on the low bit of the result for callers
4605  A7CF E6 01                AND $01
4606  A7D1 C9                   RET
4607  A7D2              ; ----------------------------------------------------------------------
4608  A7D2              ; F_COMPSIZE_BODY -- BDOS function 35 (Compute File Size) worker: scan the directory and write the
4609  A7D2              ; max record number into r0/r1/r2.
4610  A7D2              ;   In: BDOS_PARAM_PTR = current FCB pointer; reached from F_SIZE_H after FCB_AUTO_DRIVE_SELECT.
4611  A7D2              ;   Out: FCB random-record bytes r0/r1/r2 (offsets $21-$23) set to the file's record count (one past
4612  A7D2              ;        the highest record across all matching directory extents).
4613  A7D2              ;   Clobbers: A, BC, DE, HL.
4614  A7D2              ;   Algorithm: C := $0C and CALL DIR_SEARCH_FIRST to begin a directory search masked over the first
4615  A7D2              ;              12 FCB bytes (drive+name+type; the extent byte is NOT matched). Point HL at FCB+$21
4616  A7D2              ;              and zero the three random-record bytes (D is 0 from LD DE,$0021). Then loop over
4617  A7D2              ;              every matching directory entry (falls into COMPSIZE_SCAN_LOOP): for each, compute its
4618  A7D2              ;              record number via FCB_RECNUM_FROM_FIELDS at offset $0F and keep the running maximum
4619  A7D2              ;              in r0/r1/r2; when the search exhausts, the largest record number remains stored.
4620  A7D2              ;   [RE][DOC CP/M 2.2 BDOS fn 35] Result is a record count (next free record), one past the highest
4621  A7D2              ;   used record; the loop mirrors the canonical 'scan directory, max(extent record number)'
4622  A7D2              ;   algorithm.
4623  A7D2              ; ----------------------------------------------------------------------
4624  A7D2              FCB_ALLOC_BLOCK_NUM_2:
4625  A7D2                      ; mask = first $0C (12) FCB bytes: drive+name+type (extent NOT compared) when scanning
4626  A7D2 0E 0C                LD C,$0C
4627  A7D4                      ; begin a masked directory search over those 12 bytes
4628  A7D4 CD 18 A3             CALL DIR_SEARCH_FIRST
4629  A7D7 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4630  A7DA                      ; offset $21 = FCB random-record field r0 (D=0 used to zero the bytes)
4631  A7DA 11 21 00             LD DE,$0021
4632  A7DD 19                   ADD HL,DE
4633  A7DE E5                   PUSH HL
4634  A7DF                      ; r0 := 0 (zero the 3-byte running maximum)
4635  A7DF 72                   LD (HL),D
4636  A7E0 23                   INC HL
4637  A7E1                      ; r1 := 0
4638  A7E1 72                   LD (HL),D
4639  A7E2 23                   INC HL
4640  A7E3                      ; r2 := 0
4641  A7E3 72                   LD (HL),D
4642  A7E4              ; ----------------------------------------------------------------------
4643  A7E4              ; COMPSIZE_SCAN_LOOP -- per-directory-entry step of Compute File Size: fold each extent's record
4644  A7E4              ; number into the running max.
4645  A7E4              ;   In: stack top = pointer to the FCB random-record max (r0/r1/r2); a masked directory search is in
4646  A7E4              ;       progress.
4647  A7E4              ;   Out: on directory exhaustion, exits via COMPSIZE_DONE (pop, return); otherwise updates the
4648  A7E4              ;        3-byte max in place and continues.
4649  A7E4              ;   Clobbers: A, BC, DE, HL.
4650  A7E4              ;   Algorithm: CALL CUR_RECORD_BYTES_EQUAL to test whether the search is exhausted; if so (Z) JP
4651  A7E4              ;              COMPSIZE_DONE. Else CALL FCB_BUF_PTR_ADD_OFFSET to point at this entry in the
4652  A7E4              ;              directory buffer, then FCB_ALLOC_PREP at offset $0F to get the candidate record
4653  A7E4              ;              number in C(lo)/B(mid)/A(hi). Reload &r0 (POP/PUSH HL), 24-bit subtract candidate -
4654  A7E4              ;              stored (SUB / SBC / SBC over r0,r1,r2); if candidate < stored (carry), JP
4655  A7E4              ;              COMPSIZE_NEXT keeping the stored max; otherwise overwrite r2,r1,r0 with the
4656  A7E4              ;              candidate; fall into COMPSIZE_NEXT.
4657  A7E4              ;   [RE] Implements a running max over directory extents; the 24-bit subtract decides whether this
4658  A7E4              ;   extent extends the file further than any seen so far.
4659  A7E4              ; ----------------------------------------------------------------------
4660  A7E4              COMPSIZE_SCAN_LOOP:
4661  A7E4                      ; test whether the directory search is exhausted; Z = no more entries
4662  A7E4 CD F5 A1             CALL CUR_RECORD_BYTES_EQUAL
4663  A7E7                      ; search exhausted -> finish (pop saved ptr and return)
4664  A7E7 CA 0C A8             JP Z,COMPSIZE_DONE
4665  A7EA                      ; HL := directory buffer + this entry's byte offset
4666  A7EA CD 5E A1             CALL FCB_BUF_PTR_ADD_OFFSET
4667  A7ED                      ; offset $0F = the entry's record-count byte for FCB_RECNUM_FROM_FIELDS
4668  A7ED 11 0F 00             LD DE,$000F
4669  A7F0                      ; candidate record number -> C(lo)/B(mid)/A(hi)
4670  A7F0 CD A5 A7             CALL FCB_ALLOC_PREP
4671  A7F3 E1                   POP HL
4672  A7F4 E5                   PUSH HL
4673  A7F5 5F                   LD E,A
4674  A7F6                      ; begin 24-bit compare: candidate - stored max over r0/r1/r2
4675  A7F6 79                   LD A,C
4676  A7F7 96                   SUB (HL)
4677  A7F8 23                   INC HL
4678  A7F9 78                   LD A,B
4679  A7FA 9E                   SBC A,(HL)
4680  A7FB 23                   INC HL
4681  A7FC 7B                   LD A,E
4682  A7FD 9E                   SBC A,(HL)
4683  A7FE                      ; candidate < stored max -> keep stored max, skip the store
4684  A7FE DA 06 A8             JP C,COMPSIZE_NEXT
4685  A801                      ; candidate >= max: store new high byte (r2)
4686  A801 73                   LD (HL),E
4687  A802 2B                   DEC HL
4688  A803                      ; store new mid byte (r1)
4689  A803 70                   LD (HL),B
4690  A804 2B                   DEC HL
4691  A805                      ; store new low byte (r0)
4692  A805 71                   LD (HL),C
4693  A806              ; ----------------------------------------------------------------------
4694  A806              ; COMPSIZE_NEXT -- Compute File Size loop continuation: advance the directory search and re-enter
4695  A806              ; the scan loop.
4696  A806              ;   In: directory search state live; stack top = pointer to the running r0/r1/r2 maximum.
4697  A806              ;   Out: re-enters COMPSIZE_SCAN_LOOP (COMPSIZE_SCAN_LOOP) after advancing to the next directory
4698  A806              ;        entry.
4699  A806              ;   Clobbers: A, BC, DE, HL.
4700  A806              ;   Algorithm: CALL BDOS_DIR_SCAN_NEXT to advance the masked directory search by one entry; JP
4701  A806              ;              COMPSIZE_SCAN_LOOP.
4702  A806              ;   [RE] Joined both from the 'candidate < max' early path and after a store; BDOS_DIR_SCAN_NEXT
4703  A806              ;   performs the next directory read/match.
4704  A806              ; ----------------------------------------------------------------------
4705  A806              COMPSIZE_NEXT:
4706  A806                      ; advance the masked directory search to the next matching entry
4707  A806 CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
4708  A809                      ; loop back to fold the next extent into the max
4709  A809 C3 E4 A7             JP COMPSIZE_SCAN_LOOP
4710  A80C              ; ----------------------------------------------------------------------
4711  A80C              ; COMPSIZE_DONE -- Compute File Size exit: discard the saved max pointer and return.
4712  A80C              ;   In: stack top = pointer to the FCB r0/r1/r2 max (already written in place).
4713  A80C              ;   Out: returns to the F_SIZE_H caller; FCB random-record field holds the computed file size.
4714  A80C              ;   Clobbers: HL.
4715  A80C              ;   Algorithm: POP HL to balance the PUSH HL done in FCB_ALLOC_BLOCK_NUM_2 before the scan; RET.
4716  A80C              ;   [RE] Sole loop exit, reached when the directory search is exhausted.
4717  A80C              ; ----------------------------------------------------------------------
4718  A80C              COMPSIZE_DONE:
4719  A80C                      ; balance the saved r0/r1/r2 pointer pushed before the scan loop
4720  A80C E1                   POP HL
4721  A80D C9                   RET
4722  A80E              ; ----------------------------------------------------------------------
4723  A80E              ; F_RANDREC_H -- BDOS function 36 (Set Random Record): compute the random-record field of the
4724  A80E              ; current FCB from its sequential position.
4725  A80E              ;   In: current FCB pointer in BDOS cell BDOS_PARAM_PTR (the FCB whose sequential extent/cr fields
4726  A80E              ;       are to be converted).
4727  A80E              ;   Out: bytes r0/r1/r2 (FCB offsets $21..$23) written with the 24-bit record number derived from
4728  A80E              ;        the FCB's extent and current-record fields.
4729  A80E              ;   Clobbers: A, BC, DE, HL.
4730  A80E              ;   Algorithm: call FCB_ALLOC_PREP with HL=FCB base and DE=$0020, which folds the cr (current-record
4731  A80E              ;              at FCB+$20), the extent number and the extent-high bit into a record count returned
4732  A80E              ;              in C (low) / B (high) / A (overflow), and leaves DE = the FCB base pointer; then form
4733  A80E              ;              HL = FCB+$0021 (DE + $0021) and store C,B,A into FCB[$21],[$22],[$23].
4734  A80E              ;   [RE] verified against canonical CP/M 2.2 Set Random Record (dispatch fn 36 at $9C8F);
4735  A80E              ;   FCB_ALLOC_PREP is the standard extent->record-count fold.
4736  A80E              ; ----------------------------------------------------------------------
4737  A80E              F_RANDREC_H:
4738  A80E                      ; HL = pointer to the current FCB (the file whose sequential position we are converting)
4739  A80E 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4740  A811                      ; DE = $20: FCB_ALLOC_PREP reads the cr/extent region at FCB+$20 and returns DE = the FCB
4741  A811                      ; base
4742  A811 11 20 00             LD DE,$0020
4743  A814                      ; fold cr + extent# + extent-high bit into a 24-bit record number -> C low, B high, A
4744  A814                      ; overflow; returns DE = FCB base
4745  A814 CD A5 A7             CALL FCB_ALLOC_PREP
4746  A817                      ; HL = $0021; the next ADD HL,DE makes HL = FCB + $21, the start of the 3-byte random-record
4747  A817                      ; field r0,r1,r2
4748  A817 21 21 00             LD HL,$0021
4749  A81A 19                   ADD HL,DE
4750  A81B                      ; store r0 (record number, low byte)
4751  A81B 71                   LD (HL),C
4752  A81C 23                   INC HL
4753  A81D                      ; store r1 (record number, high byte)
4754  A81D 70                   LD (HL),B
4755  A81E 23                   INC HL
4756  A81F                      ; store r2 (record number overflow / random-record overflow byte)
4757  A81F 77                   LD (HL),A
4758  A820 C9                   RET
4759  A821              ; ----------------------------------------------------------------------
4760  A821              ; DRV_INSTALL_RWTS_17 -- Select-disk / log-in worker: ensure the drive in BDOS_CUR_DRIVE is logged
4761  A821              ; in, and rebuild its allocation vector if it was not.
4762  A821              ;   In: BDOS_CUR_DRIVE = requested (current) drive number 0..15; DRV_SELECT_VECTOR = working login/select
4763  A821              ;       vector.
4764  A821              ;   Out: if the drive was newly logged in, its directory is scanned (BDOS_ERR_SELECT) and its
4765  A821              ;        allocation vector rebuilt (CMD_EXEC_65); DRV_SELECT_VECTOR updated with the drive's login bit.
4766  A821              ;   Clobbers: A, BC, DE, HL.
4767  A821              ;   Algorithm: load the working login vector DRV_SELECT_VECTOR; build a single-bit mask for the requested drive
4768  A821              ;              (DRV_INSTALL_RWTS_10 shifts); test (BDOS_RANDREC_3) whether the drive's DPB is
4769  A821              ;              already established; if not yet logged in (Z) call BDOS_ERR_SELECT to log it in /
4770  A821              ;              scan its directory; if the login bit was already set (RRA -> carry) just return;
4771  A821              ;              otherwise OR this drive's bit into DRV_SELECT_VECTOR (CMD_EXEC_12), store it, and fall into
4772  A821              ;              CMD_EXEC_65 to (re)build the allocation vector.
4773  A821              ;   [RE] the standard CP/M 2.2 select-disk login path reached from DRV_SET (fn 14) and DRV_ALLRESET
4774  A821              ;   (fn 13). [?] the A=L / RRA already-logged-in test is inferred from the surrounding flow, not
4775  A821              ;   proven from these bytes alone.
4776  A821              ; ----------------------------------------------------------------------
4777  A821              DRV_INSTALL_RWTS_17:
4778  A821                      ; HL = working login/select vector
4779  A821 2A AF A9             LD HL,(DRV_SELECT_VECTOR)
4780  A824                      ; A = requested drive number
4781  A824 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
4782  A827 4F                   LD C,A
4783  A828                      ; shift to form the single-bit drive mask for this drive
4784  A828 CD EA A0             CALL DRV_INSTALL_RWTS_10
4785  A82B E5                   PUSH HL
4786  A82C EB                   EX DE,HL
4787  A82D                      ; establish/test the drive's DPB; sets Z if the drive needs logging in
4788  A82D CD 59 9F             CALL BDOS_RANDREC_3
4789  A830 E1                   POP HL
4790  A831                      ; drive not yet logged in: run the disk log-in / directory scan
4791  A831 CC 47 9F             CALL Z,BDOS_ERR_SELECT
4792  A834 7D                   LD A,L
4793  A835                      ; rotate bit 0 of the drive mask into carry: carry set => this drive already had its login
4794  A835                      ; bit set
4795  A835 1F                   RRA
4796  A836                      ; already logged in: nothing more to do
4797  A836 D8                   RET C
4798  A837 2A AF A9             LD HL,(DRV_SELECT_VECTOR)
4799  A83A 4D                   LD C,L
4800  A83B 44                   LD B,H
4801  A83C                      ; OR this drive's bit into the working login vector
4802  A83C CD 0B A1             CALL CMD_EXEC_12
4803  A83F                      ; store the updated working login vector
4804  A83F 22 AF A9             LD (DRV_SELECT_VECTOR),HL
4805  A842                      ; tail into rebuild-allocation-vector for the freshly logged-in drive
4806  A842 C3 A3 A2             JP CMD_EXEC_65
4807  A845              ; ----------------------------------------------------------------------
4808  A845              ; DRV_SET_H -- BDOS function 14 (Select Disk): make the drive in DRV_SELECT_ARG the current drive.
4809  A845              ;   In: DRV_SELECT_ARG = desired drive number; BDOS_CUR_DRIVE = current drive number.
4810  A845              ;   Out: if the drive changed, BDOS_CUR_DRIVE is updated and the drive is logged in / allocation
4811  A845              ;        vector rebuilt (via DRV_INSTALL_RWTS_17); otherwise no-op.
4812  A845              ;   Clobbers: A, HL (and whatever DRV_INSTALL_RWTS_17 clobbers).
4813  A845              ;   Algorithm: compare desired drive (DRV_SELECT_ARG) with current (BDOS_CUR_DRIVE); if equal return; else
4814  A845              ;              store the new current drive and jump to the select/log-in worker.
4815  A845              ;   [RE] dispatch fn 14 at $9C63; matches canonical CP/M 2.2 Select Disk.
4816  A845              ; ----------------------------------------------------------------------
4817  A845              DRV_SET_H:
4818  A845                      ; A = requested drive number
4819  A845 3A D6 A9             LD A,(DRV_SELECT_ARG)
4820  A848                      ; HL -> current-drive cell
4821  A848 21 42 9F             LD HL,BDOS_CUR_DRIVE
4822  A84B                      ; already the current drive?
4823  A84B BE                   CP (HL)
4824  A84C                      ; yes: nothing to do
4825  A84C C8                   RET Z
4826  A84D                      ; set the new current drive
4827  A84D 77                   LD (HL),A
4828  A84E                      ; log it in / rebuild its allocation vector
4829  A84E C3 21 A8             JP DRV_INSTALL_RWTS_17
4830  A851              ; ----------------------------------------------------------------------
4831  A851              ; FCB_AUTO_DRIVE_SELECT -- common file-operation preamble: honor the drive prefix in the caller's
4832  A851              ; FCB, temporarily selecting that drive.
4833  A851              ;   In: BDOS_PARAM_PTR = pointer to the caller's FCB (byte 0 = drive prefix, 0=default else
4834  A851              ;       drive+1); BDOS_CUR_DRIVE = current drive; BDOS_STACK_TOP = current user number.
4835  A851              ;   Out: if the FCB names an explicit drive, that drive is selected (DRV_SELECT_ARG set, DRV_SET_H called)
4836  A851              ;        and the prior drive is saved in the restore cells (DRV_RESTORE_FLAG flag=$FF, DRV_SAVED_DRIVE=saved drive,
4837  A851              ;        DRV_SAVED_FCB_BYTE=saved FCB drive byte); the FCB's drive byte is rewritten to OR in the current user
4838  A851              ;        number.
4839  A851              ;   Clobbers: A, HL.
4840  A851              ;   Algorithm: set restore-pending flag DRV_RESTORE_FLAG=$FF; read FCB byte0, mask $1F and DEC to get drive
4841  A851              ;              index into DRV_SELECT_ARG; if >=$1E (no explicit drive / out of range) skip the switch; else
4842  A851              ;              save current drive (BDOS_CUR_DRIVE->DRV_SAVED_DRIVE) and original FCB byte (->DRV_SAVED_FCB_BYTE), strip
4843  A851              ;              the drive prefix bits ($E0 mask) from FCB byte0, and select the requested drive via
4844  A851              ;              DRV_SET_H; finally OR the current user number (BDOS_STACK_TOP) into FCB byte0.
4845  A851              ;   [RE] this is the auto-disk-select / FCB drive-prefix handler that nearly every file BDOS call
4846  A851              ;   funnels through; the matching restore is FCB_AUTO_DRIVE_RESTORE. The old auto-label
4847  A851              ;   'FCB_AUTO_DRIVE_SELECT' is a misnomer (it does not seek tracks).
4848  A851              ; ----------------------------------------------------------------------
4849  A851              FCB_AUTO_DRIVE_SELECT:
4850  A851                      ; mark 'a temporary drive switch is pending' so the epilogue restores it
4851  A851 3E FF                LD A,$FF
4852  A853                      ; store the restore-pending flag
4853  A853 32 DE A9             LD (DRV_RESTORE_FLAG),A
4854  A856                      ; HL -> caller's FCB; (HL) = drive-prefix byte
4855  A856 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4856  A859 7E                   LD A,(HL)
4857  A85A                      ; isolate the drive-prefix field of FCB byte 0
4858  A85A E6 1F                AND $1F
4859  A85C                      ; convert prefix (1..16) to drive index (0..15); $00 (default) wraps to $FF
4860  A85C 3D                   DEC A
4861  A85D                      ; record the drive this FCB asks for
4862  A85D 32 D6 A9             LD (DRV_SELECT_ARG),A
4863  A860                      ; no explicit drive (default => $FF) or out of range?
4864  A860 FE 1E                CP $1E
4865  A862                      ; yes: skip the drive switch, just merge the user number
4866  A862 D2 75 A8             JP NC,FCB_MERGE_USER
4867  A865 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
4868  A868                      ; save the current drive so the epilogue can restore it
4869  A868 32 DF A9             LD (DRV_SAVED_DRIVE),A
4870  A86B 7E                   LD A,(HL)
4871  A86C                      ; save the original FCB drive-prefix byte for restore
4872  A86C 32 E0 A9             LD (DRV_SAVED_FCB_BYTE),A
4873  A86F                      ; clear the drive-prefix bits, leaving the high flag bits of FCB byte0
4874  A86F E6 E0                AND $E0
4875  A871 77                   LD (HL),A
4876  A872                      ; temporarily select the drive named by the FCB
4877  A872 CD 45 A8             CALL DRV_SET_H
4878  A875              ; ----------------------------------------------------------------------
4879  A875              ; FCB_MERGE_USER -- tail of FCB_AUTO_DRIVE_SELECT: OR the current user number into the FCB's drive
4880  A875              ; byte.
4881  A875              ;   In: BDOS_STACK_TOP = current user number; BDOS_PARAM_PTR = pointer to the FCB.
4882  A875              ;   Out: FCB byte0 |= current user number.
4883  A875              ;   Clobbers: A, HL.
4884  A875              ;   Algorithm: load user number, OR with FCB byte0, store back.
4885  A875              ;   [RE] shared exit of the auto-disk-select preamble.
4886  A875              ; ----------------------------------------------------------------------
4887  A875              FCB_MERGE_USER:
4888  A875                      ; A = current user number
4889  A875 3A 41 9F             LD A,(BDOS_STACK_TOP)
4890  A878 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
4891  A87B                      ; merge the user number into the FCB's drive/flags byte
4892  A87B B6                   OR (HL)
4893  A87C                      ; write it back
4894  A87C 77                   LD (HL),A
4895  A87D C9                   RET
4896  A87E              ; ----------------------------------------------------------------------
4897  A87E              ; S_BDOSVER_H -- BDOS function 12 (Return Version Number): report CP/M 2.2.
4898  A87E              ;   In: none.
4899  A87E              ;   Out: low byte of the BDOS result set to $22 (= version 2.2) via BDOS_RET_RESULT, which writes
4900  A87E              ;        only BDOS_RETVAL (the result low byte / register A).
4901  A87E              ;   Clobbers: A.
4902  A87E              ;   Algorithm: load $22 and store it as the low byte of the BDOS return result. (The result high
4903  A87E              ;              byte is not written here; in canonical CP/M 2.2 the version word is $00$22, but this
4904  A87E              ;              routine sets only the low byte.)
4905  A87E              ;   [RE] dispatch fn 12 at $9C5F; $22 = CP/M 2.2 per the canonical version code.
4906  A87E              ; ----------------------------------------------------------------------
4907  A87E              S_BDOSVER_H:
4908  A87E                      ; version code $22 = CP/M 2.2
4909  A87E 3E 22                LD A,$22
4910  A880                      ; return it as the BDOS result low byte
4911  A880 C3 01 9F             JP BDOS_RET_RESULT
4912  A883              ; ----------------------------------------------------------------------
4913  A883              ; DRV_ALLRESET_H -- BDOS function 13 (Reset Disk System): return CP/M to its initial disk state.
4914  A883              ;   In: none.
4915  A883              ;   Out: login vector and working login/select vector cleared; current drive forced to A: (0); DMA
4916  A883              ;        address reset to TBUFF ($0080); drive A logged in fresh.
4917  A883              ;   Clobbers: A, HL (and DRV_INSTALL_RWTS_17 / RESTORE_USER_DMA clobbers).
4918  A883              ;   Algorithm: zero DRV_LOGIN_VECTOR and DRV_SELECT_VECTOR; set current drive BDOS_CUR_DRIVE=0; set
4919  A883              ;              DMA_ADDR=$0080 (TBUFF); call RESTORE_USER_DMA (set the live BIOS DMA / reset disk
4920  A883              ;              buffering); jump to DRV_INSTALL_RWTS_17 to log in drive A.
4921  A883              ;   [RE] dispatch fn 13 at $9C61; matches canonical CP/M 2.2 Reset Disk System.
4922  A883              ; ----------------------------------------------------------------------
4923  A883              DRV_ALLRESET_H:
4924  A883 21 00 00             LD HL,$0000
4925  A886                      ; clear the master logged-in drive bitmap
4926  A886 22 AD A9             LD (DRV_LOGIN_VECTOR),HL
4927  A889                      ; clear the working login/select vector
4928  A889 22 AF A9             LD (DRV_SELECT_VECTOR),HL
4929  A88C AF                   XOR A
4930  A88D                      ; force current drive back to A: (0)
4931  A88D 32 42 9F             LD (BDOS_CUR_DRIVE),A
4932  A890                      ; TBUFF ($0080) = default DMA address
4933  A890 21 80 00             LD HL,$0080
4934  A893                      ; reset the DMA address to TBUFF
4935  A893 22 B1 A9             LD (DMA_ADDR),HL
4936  A896                      ; push the reset DMA address through to disk buffering / BIOS
4937  A896 CD DA A1             CALL RESTORE_USER_DMA
4938  A899                      ; log in drive A from a clean state
4939  A899 C3 21 A8             JP DRV_INSTALL_RWTS_17
4940  A89C              ; ----------------------------------------------------------------------
4941  A89C              ; F_OPEN_H -- BDOS function 15 (Open File): open the file named by the FCB.
4942  A89C              ;   In: BDOS_PARAM_PTR = pointer to the caller's FCB.
4943  A89C              ;   Out: directory match result returned via FCB_OPEN_SEARCH (the search/open result path); FCB
4944  A89C              ;        filled in from the matching directory entry on success, $FF if not found.
4945  A89C              ;   Clobbers: A, BC, DE, HL.
4946  A89C              ;   Algorithm: CLEAR_FCB_S2 prepares/clears the open scratch state; FCB_AUTO_DRIVE_SELECT honors the
4947  A89C              ;              FCB drive prefix; jump into the open/search-and-fill path (FCB_OPEN_SEARCH).
4948  A89C              ;   [RE] dispatch fn 15 at $9C65; canonical CP/M 2.2 Open File.
4949  A89C              ; ----------------------------------------------------------------------
4950  A89C              F_OPEN_H:
4951  A89C                      ; prepare directory/open scratch state for this FCB
4952  A89C CD 72 A1             CALL CLEAR_FCB_S2
4953  A89F                      ; auto-select the FCB's drive prefix
4954  A89F CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4955  A8A2                      ; search the directory and fill the FCB (open path)
4956  A8A2 C3 51 A4             JP FCB_OPEN_SEARCH
4957  A8A5              ; ----------------------------------------------------------------------
4958  A8A5              ; F_CLOSE_H -- BDOS function 16 (Close File): write the FCB back to its directory entry.
4959  A8A5              ;   In: BDOS_PARAM_PTR = pointer to the caller's FCB (must be open).
4960  A8A5              ;   Out: directory entry updated; result returned via F_CLOSE_HND path ($FF / dir-code).
4961  A8A5              ;   Clobbers: A, BC, DE, HL.
4962  A8A5              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the FCB drive prefix; jump into the close
4963  A8A5              ;              (rewrite-directory) path.
4964  A8A5              ;   [RE] dispatch fn 16 at $9C67; canonical CP/M 2.2 Close File.
4965  A8A5              ; ----------------------------------------------------------------------
4966  A8A5              F_CLOSE_H:
4967  A8A5                      ; auto-select the FCB's drive prefix
4968  A8A5 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
4969  A8A8                      ; rewrite the directory entry and return the close result
4970  A8A8 C3 A2 A4             JP F_CLOSE_HND
4971  A8AB              ; ----------------------------------------------------------------------
4972  A8AB              ; F_SFIRST_H -- BDOS function 17 (Search for First): find the first directory entry matching the
4973  A8AB              ; FCB.
4974  A8AB              ;   In: DE = pointer to the search FCB (the BDOS dispatcher has also saved DE in BDOS_PARAM_PTR).
4975  A8AB              ;       FCB byte0 = $3F ('?') means 'match every entry' (ambiguous all-entries scan).
4976  A8AB              ;   Out: directory match copied to the DMA buffer; result (0..3 = dir position, or $FF none) via
4977  A8AB              ;        DISK_BUF_MOVE.
4978  A8AB              ;   Clobbers: A, BC, DE, HL.
4979  A8AB              ;   Algorithm: C=0 (default match length); fetch FCB byte0 (HL<-DE); if byte0==$3F do an unqualified
4980  A8AB              ;              all-entries scan (C left 0); else compute HL=FCB+$0C via DRV_INSTALL_RWTS_1 and test
4981  A8AB              ;              the extent byte FCB[$0C] -- if it is not '?' prepare scratch (CLEAR_FCB_S2) -- then
4982  A8AB              ;              auto-select drive and set C=$0F (15-byte name+type+extent match); fall into
4983  A8AB              ;              DIR_SEARCH_AND_COPY to run the directory search and copy the hit to the DMA buffer.
4984  A8AB              ;   [RE] dispatch fn 17 at $9C69; canonical CP/M 2.2 Search First; $3F is the '?' all-match marker.
4985  A8AB              ;   DRV_INSTALL_RWTS_1 only computes the FCB+$0C pointer (it does not save the search FCB).
4986  A8AB              ; ----------------------------------------------------------------------
4987  A8AB              F_SFIRST_H:
4988  A8AB                      ; search match length 0 (default name+type compare)
4989  A8AB 0E 00                LD C,$00
4990  A8AD EB                   EX DE,HL
4991  A8AE                      ; fetch FCB byte0 (drive/wildcard marker)
4992  A8AE 7E                   LD A,(HL)
4993  A8AF                      ; $3F ('?') in byte0 => match every directory entry
4994  A8AF FE 3F                CP $3F
4995  A8B1                      ; all-entries scan: go straight to the directory search
4996  A8B1 CA C2 A8             JP Z,DIR_SEARCH_AND_COPY
4997  A8B4                      ; HL = FCB + $0C (pointer to the extent byte); does NOT save the search FCB
4998  A8B4 CD A6 A0             CALL DRV_INSTALL_RWTS_1
4999  A8B7 7E                   LD A,(HL)
5000  A8B8                      ; is the extent byte FCB[$0C] the '?' wildcard (match all extents)?
5001  A8B8 FE 3F                CP $3F
5002  A8BA                      ; extent not wildcard: prepare directory scratch state
5003  A8BA C4 72 A1             CALL NZ,CLEAR_FCB_S2
5004  A8BD                      ; auto-select the FCB's drive prefix
5005  A8BD CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5006  A8C0                      ; match 15 bytes (name+type+extent) for a qualified search
5007  A8C0 0E 0F                LD C,$0F
5008  A8C2              ; ----------------------------------------------------------------------
5009  A8C2              ; DIR_SEARCH_AND_COPY -- run the directory scan and copy the matched entry to the DMA buffer.
5010  A8C2              ;   In: C = number of bytes to compare in the directory match; search FCB already established by
5011  A8C2              ;       F_SFIRST_H.
5012  A8C2              ;   Out: matching directory record moved to the DMA buffer; A = directory position (0..3) or $FF if
5013  A8C2              ;        none.
5014  A8C2              ;   Clobbers: A, BC, DE, HL.
5015  A8C2              ;   Algorithm: DIR_SEARCH_FIRST performs the directory search with the C-byte mask; tail into
5016  A8C2              ;              DISK_BUF_MOVE to copy the located directory entry into the user's DMA buffer and
5017  A8C2              ;              return the result code.
5018  A8C2              ;   [RE] shared search tail for fn 17 (Search First) and fn 18 (Search Next).
5019  A8C2              ; ----------------------------------------------------------------------
5020  A8C2              DIR_SEARCH_AND_COPY:
5021  A8C2                      ; scan the directory comparing C bytes against the search FCB
5022  A8C2 CD 18 A3             CALL DIR_SEARCH_FIRST
5023  A8C5                      ; copy the matched directory entry to the DMA buffer, return its position
5024  A8C5 C3 E9 A1             JP DISK_BUF_MOVE
5025  A8C8              ; ----------------------------------------------------------------------
5026  A8C8              ; F_SNEXT_H -- BDOS function 18 (Search for Next): continue a directory search begun by Search
5027  A8C8              ; First.
5028  A8C8              ;   In: search state saved in DIR_FCB_PTR (the search FCB pointer stored by the directory-search core
5029  A8C8              ;       DIR_SEARCH_FIRST at $A324).
5030  A8C8              ;   Out: next matching directory record copied to the DMA buffer; A = position (0..3) or $FF if no
5031  A8C8              ;        more.
5032  A8C8              ;   Clobbers: A, BC, DE, HL.
5033  A8C8              ;   Algorithm: restore the saved search FCB pointer (DIR_FCB_PTR -> BDOS_PARAM_PTR); auto-select its
5034  A8C8              ;              drive; BDOS_DIR_SCAN_NEXT advances the directory scan from the saved position; tail
5035  A8C8              ;              into DISK_BUF_MOVE to deliver the hit.
5036  A8C8              ;   [RE] dispatch fn 18 at $9C6B; canonical CP/M 2.2 Search Next; DIR_FCB_PTR holds the in-progress
5037  A8C8              ;   search FCB.
5038  A8C8              ; ----------------------------------------------------------------------
5039  A8C8              F_SNEXT_H:
5040  A8C8                      ; restore the saved Search-First FCB pointer
5041  A8C8 2A D9 A9             LD HL,(DIR_FCB_PTR)
5042  A8CB                      ; make it the active FCB for this scan step
5043  A8CB 22 43 9F             LD (BDOS_PARAM_PTR),HL
5044  A8CE                      ; auto-select the FCB's drive prefix
5045  A8CE CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5046  A8D1                      ; advance the directory search from the last matched entry
5047  A8D1 CD 2D A3             CALL BDOS_DIR_SCAN_NEXT
5048  A8D4                      ; copy the next matched entry to the DMA buffer, return its position
5049  A8D4 C3 E9 A1             JP DISK_BUF_MOVE
5050  A8D7              ; ----------------------------------------------------------------------
5051  A8D7              ; F_DELETE_H -- BDOS function 19 (Delete File): erase all directory entries matching the FCB.
5052  A8D7              ;   In: BDOS_PARAM_PTR = pointer to the (possibly ambiguous) FCB.
5053  A8D7              ;   Out: matching directory entries marked deleted ($E5) and their allocation freed; result via
5054  A8D7              ;        DIR_RETURN_MATCH_FLAG ($FF if none / dir code).
5055  A8D7              ;   Clobbers: A, BC, DE, HL.
5056  A8D7              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; F_DELETE_HND scans and erases each
5057  A8D7              ;              matching directory entry (releasing its blocks); tail into the
5058  A8D7              ;              directory-update/result path DIR_RETURN_MATCH_FLAG.
5059  A8D7              ;   [RE] dispatch fn 19 at $9C6D; canonical CP/M 2.2 Delete File.
5060  A8D7              ; ----------------------------------------------------------------------
5061  A8D7              F_DELETE_H:
5062  A8D7                      ; auto-select the FCB's drive prefix
5063  A8D7 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5064  A8DA                      ; erase every matching directory entry and free its blocks
5065  A8DA CD 9C A3             CALL F_DELETE_HND
5066  A8DD                      ; flush the directory and return the result code
5067  A8DD C3 01 A3             JP DIR_RETURN_MATCH_FLAG
5068  A8E0              ; ----------------------------------------------------------------------
5069  A8E0              ; F_READ_H -- BDOS function 20 (Read Sequential): read the next 128-byte record of the open file.
5070  A8E0              ;   In: BDOS_PARAM_PTR = pointer to an open FCB positioned at the next sequential record.
5071  A8E0              ;   Out: one record read into the DMA buffer; A = 0 on success or a nonzero read-error/EOF code; the
5072  A8E0              ;        FCB's sequential position advanced.
5073  A8E0              ;   Clobbers: A, BC, DE, HL.
5074  A8E0              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the sequential read core
5075  A8E0              ;              (FILE_READ_SEQ).
5076  A8E0              ;   [RE] dispatch fn 20 at $9C6F; canonical CP/M 2.2 Read Sequential.
5077  A8E0              ; ----------------------------------------------------------------------
5078  A8E0              F_READ_H:
5079  A8E0                      ; auto-select the FCB's drive prefix
5080  A8E0 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5081  A8E3                      ; read the next sequential record into the DMA buffer
5082  A8E3 C3 BC A5             JP FILE_READ_SEQ
5083  A8E6              ; ----------------------------------------------------------------------
5084  A8E6              ; F_WRITE_H -- BDOS function 21 (Write Sequential): write the next 128-byte record to the open file.
5085  A8E6              ;   In: BDOS_PARAM_PTR = pointer to an open FCB; DMA buffer holds the record to write.
5086  A8E6              ;   Out: one record written; A = 0 on success or a nonzero error code (disk full / R/O); FCB
5087  A8E6              ;        position advanced, allocation extended as needed.
5088  A8E6              ;   Clobbers: A, BC, DE, HL.
5089  A8E6              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the write core
5090  A8E6              ;              (FILE_WRITE_SEQ sets the write-mode flag for a normal sequential write).
5091  A8E6              ;   [RE] dispatch fn 21 at $9C71; canonical CP/M 2.2 Write Sequential; the write core distinguishes
5092  A8E6              ;   normal vs zero-fill write modes.
5093  A8E6              ; ----------------------------------------------------------------------
5094  A8E6              F_WRITE_H:
5095  A8E6                      ; auto-select the FCB's drive prefix
5096  A8E6 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5097  A8E9                      ; set the (normal) write mode and write the next sequential record
5098  A8E9 C3 FE A5             JP FILE_WRITE_SEQ
5099  A8EC              ; ----------------------------------------------------------------------
5100  A8EC              ; F_MAKE_H -- BDOS function 22 (Make File): create a new directory entry for the FCB.
5101  A8EC              ;   In: BDOS_PARAM_PTR = pointer to the FCB naming the file to create.
5102  A8EC              ;   Out: a fresh, empty directory entry allocated and the FCB opened against it; A = dir position or
5103  A8EC              ;        $FF if the directory is full.
5104  A8EC              ;   Clobbers: A, BC, DE, HL.
5105  A8EC              ;   Algorithm: CLEAR_FCB_S2 prepares the create scratch state; FCB_AUTO_DRIVE_SELECT honors the
5106  A8EC              ;              drive prefix; jump into the make-directory-entry core (DIR_MAKE_ENTRY).
5107  A8EC              ;   [RE] dispatch fn 22 at $9C73; canonical CP/M 2.2 Make File.
5108  A8EC              ; ----------------------------------------------------------------------
5109  A8EC              F_MAKE_H:
5110  A8EC                      ; prepare directory create scratch state
5111  A8EC CD 72 A1             CALL CLEAR_FCB_S2
5112  A8EF                      ; auto-select the FCB's drive prefix
5113  A8EF CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5114  A8F2                      ; allocate and initialize a new directory entry for the file
5115  A8F2 C3 24 A5             JP DIR_MAKE_ENTRY
5116  A8F5              ; ----------------------------------------------------------------------
5117  A8F5              ; F_RENAME_H -- BDOS function 23 (Rename File): change a file's name in its directory entries.
5118  A8F5              ;   In: BDOS_PARAM_PTR = pointer to an FCB whose first 12 bytes hold the old name and bytes $10..
5119  A8F5              ;       hold the new name.
5120  A8F5              ;   Out: every matching directory entry's name field rewritten to the new name; result via
5121  A8F5              ;        DIR_RETURN_MATCH_FLAG.
5122  A8F5              ;   Clobbers: A, BC, DE, HL.
5123  A8F5              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; F_RENAME_HND walks the directory rewriting
5124  A8F5              ;              matched entries to the new name; tail into the directory-update/result path
5125  A8F5              ;              DIR_RETURN_MATCH_FLAG.
5126  A8F5              ;   [RE] dispatch fn 23 at $9C75; canonical CP/M 2.2 Rename File.
5127  A8F5              ; ----------------------------------------------------------------------
5128  A8F5              F_RENAME_H:
5129  A8F5                      ; auto-select the FCB's drive prefix
5130  A8F5 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5131  A8F8                      ; rewrite every matching directory entry to the new name
5132  A8F8 CD 16 A4             CALL F_RENAME_HND
5133  A8FB                      ; flush the directory and return the result code
5134  A8FB C3 01 A3             JP DIR_RETURN_MATCH_FLAG
5135  A8FE              ; ----------------------------------------------------------------------
5136  A8FE              ; DRV_LOGINVEC_H -- BDOS function 24 (Return Login Vector): report which drives are logged in.
5137  A8FE              ;   In: DRV_SELECT_VECTOR = working login/select vector (bit d = drive d logged in).
5138  A8FE              ;   Out: BDOS result HL = the login vector (returned via the common result-store
5139  A8FE              ;        BDOS_RET_RESULT_HL).
5140  A8FE              ;   Clobbers: HL.
5141  A8FE              ;   Algorithm: load the working login vector and store it as the 16-bit BDOS result.
5142  A8FE              ;   [RE] dispatch fn 24 at $9C77; canonical CP/M 2.2 Return Login Vector.
5143  A8FE              ; ----------------------------------------------------------------------
5144  A8FE              DRV_LOGINVEC_H:
5145  A8FE                      ; HL = login vector (one bit per logged-in drive)
5146  A8FE 2A AF A9             LD HL,(DRV_SELECT_VECTOR)
5147  A901                      ; store HL as the 16-bit BDOS result
5148  A901 C3 29 A9             JP BDOS_RET_RESULT_HL
5149  A904              ; ----------------------------------------------------------------------
5150  A904              ; DRV_GET_H -- BDOS function 25 (Return Current Disk): report the current default drive.
5151  A904              ;   In: BDOS_CUR_DRIVE = current drive number.
5152  A904              ;   Out: BDOS result A = current drive (0=A:).
5153  A904              ;   Clobbers: A.
5154  A904              ;   Algorithm: load the current-drive cell and return it as the BDOS result.
5155  A904              ;   [RE] dispatch fn 25 at $9C79; canonical CP/M 2.2 Return Current Disk.
5156  A904              ; ----------------------------------------------------------------------
5157  A904              DRV_GET_H:
5158  A904                      ; A = current drive number
5159  A904 3A 42 9F             LD A,(BDOS_CUR_DRIVE)
5160  A907                      ; return it as the BDOS result
5161  A907 C3 01 9F             JP BDOS_RET_RESULT
5162  A90A              ; ----------------------------------------------------------------------
5163  A90A              ; F_DMAOFF_H -- BDOS function 26 (Set DMA Address): set the disk read/write buffer address.
5164  A90A              ;   In: DE = new DMA (disk transfer) address supplied by the caller.
5165  A90A              ;   Out: DMA_ADDR set to DE and pushed through to the BIOS disk-buffering layer.
5166  A90A              ;   Clobbers: A, HL (and RESTORE_USER_DMA clobbers).
5167  A90A              ;   Algorithm: move DE into HL, store at DMA_ADDR, jump to RESTORE_USER_DMA to apply it to the live
5168  A90A              ;              disk buffering / BIOS SETDMA.
5169  A90A              ;   [RE] dispatch fn 26 at $9C7B; canonical CP/M 2.2 Set DMA Address.
5170  A90A              ; ----------------------------------------------------------------------
5171  A90A              F_DMAOFF_H:
5172  A90A                      ; HL = caller's requested DMA address
5173  A90A EB                   EX DE,HL
5174  A90B                      ; record the new DMA address
5175  A90B 22 B1 A9             LD (DMA_ADDR),HL
5176  A90E                      ; apply the DMA address to disk buffering / BIOS
5177  A90E C3 DA A1             JP RESTORE_USER_DMA
5178  A911              ; ----------------------------------------------------------------------
5179  A911              ; DRV_ALLOCVEC_H -- BDOS function 27 (Return Allocation Vector address).
5180  A911              ;   In: ALLOC_VEC_PTR = base address of the current drive's allocation (block-in-use) bit vector.
5181  A911              ;   Out: BDOS result HL = the allocation vector address.
5182  A911              ;   Clobbers: HL.
5183  A911              ;   Algorithm: load the allocation-vector pointer and store it as the 16-bit BDOS result.
5184  A911              ;   [RE] dispatch fn 27 at $9C7D; canonical CP/M 2.2 Get Allocation Vector.
5185  A911              ; ----------------------------------------------------------------------
5186  A911              DRV_ALLOCVEC_H:
5187  A911                      ; HL = address of the current drive's allocation bit vector
5188  A911 2A BF A9             LD HL,(ALLOC_VEC_PTR)
5189  A914                      ; store HL as the 16-bit BDOS result
5190  A914 C3 29 A9             JP BDOS_RET_RESULT_HL
5191  A917              ; ----------------------------------------------------------------------
5192  A917              ; DRV_ROVEC_H -- BDOS function 29 (Return Read-Only Vector): report which drives are read-only.
5193  A917              ;   In: DRV_LOGIN_VECTOR -- here read as the read-only bit vector master copy.
5194  A917              ;   Out: BDOS result HL = the read-only drive vector (bit d set = drive d is R/O).
5195  A917              ;   Clobbers: HL.
5196  A917              ;   Algorithm: load the R/O vector and store it as the 16-bit BDOS result.
5197  A917              ;   [RE] dispatch fn 29 at $9C81; canonical CP/M 2.2 Get Read-Only Vector. [?] Source operand is the
5198  A917              ;   DRV_LOGIN_VECTOR cell; per CP/M 2.2 the R/O vector is a distinct mask -- the symbol name may be
5199  A917              ;   a misnomer for the R/O vector cell, or this build keeps the R/O bits in the same word.
5200  A917              ; ----------------------------------------------------------------------
5201  A917              DRV_ROVEC_H:
5202  A917                      ; HL = read-only drive vector (one bit per R/O drive)
5203  A917 2A AD A9             LD HL,(DRV_LOGIN_VECTOR)
5204  A91A                      ; store HL as the 16-bit BDOS result
5205  A91A C3 29 A9             JP BDOS_RET_RESULT_HL
5206  A91D              ; ----------------------------------------------------------------------
5207  A91D              ; F_ATTRIB_H -- BDOS function 30 (Set File Attributes): write the FCB's attribute bits into its
5208  A91D              ; directory entries.
5209  A91D              ;   In: BDOS_PARAM_PTR = pointer to the FCB carrying the desired attribute (high) bits in its
5210  A91D              ;       name/type bytes.
5211  A91D              ;   Out: matching directory entries updated with the new attributes; result via
5212  A91D              ;        DIR_RETURN_MATCH_FLAG.
5213  A91D              ;   Clobbers: A, BC, DE, HL.
5214  A91D              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; F_ATTRIB_HND walks the directory copying
5215  A91D              ;              the FCB's attribute bits into each matched entry; tail into the
5216  A91D              ;              directory-update/result path.
5217  A91D              ;   [RE] dispatch fn 30 at $9C83; canonical CP/M 2.2 Set File Attributes.
5218  A91D              ; ----------------------------------------------------------------------
5219  A91D              F_ATTRIB_H:
5220  A91D                      ; auto-select the FCB's drive prefix
5221  A91D CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5222  A920                      ; copy the FCB's attribute bits into every matching directory entry
5223  A920 CD 3B A4             CALL F_ATTRIB_HND
5224  A923                      ; flush the directory and return the result code
5225  A923 C3 01 A3             JP DIR_RETURN_MATCH_FLAG
5226  A926              ; ----------------------------------------------------------------------
5227  A926              ; DRV_DPB_H -- BDOS function 31 (Return Disk Parameter Block address).
5228  A926              ;   In: DPB_PTR = address of the current drive's DPB (set during disk select/log-in).
5229  A926              ;   Out: BDOS result HL = the DPB address.
5230  A926              ;   Clobbers: HL.
5231  A926              ;   Algorithm: load the DPB pointer and store it as the 16-bit BDOS result.
5232  A926              ;   [RE] dispatch fn 31 at $9C85; canonical CP/M 2.2 Get DPB; falls into the shared result-store
5233  A926              ;   BDOS_RET_RESULT_HL.
5234  A926              ; ----------------------------------------------------------------------
5235  A926              DRV_DPB_H:
5236  A926                      ; HL = address of the current drive's Disk Parameter Block
5237  A926 2A BB A9             LD HL,(DPB_PTR)
5238  A929              ; ----------------------------------------------------------------------
5239  A929              ; BDOS_RET_RESULT_HL -- common exit: store the 16-bit value in HL as the BDOS return result.
5240  A929              ;   In: HL = value to return to the caller.
5241  A929              ;   Out: BDOS result cell BDOS_RETVAL = HL.
5242  A929              ;   Clobbers: none (writes memory).
5243  A929              ;   Algorithm: store HL at the BDOS result cell and return.
5244  A929              ;   [RE] the HL-valued counterpart of BDOS_RET_RESULT (which returns A); used by the get-vector /
5245  A929              ;   get-pointer functions (login vector, alloc vector, R/O vector, DPB) and fallen into from
5246  A929              ;   DRV_DPB_H.
5247  A929              ; ----------------------------------------------------------------------
5248  A929              BDOS_RET_RESULT_HL:
5249  A929                      ; store HL as the 16-bit BDOS result
5250  A929 22 45 9F             LD (BDOS_RETVAL),HL
5251  A92C C9                   RET
5252  A92D              ; ----------------------------------------------------------------------
5253  A92D              ; F_USERNUM_H -- BDOS function 32 (Get/Set User Code).
5254  A92D              ;   In: DRV_SELECT_ARG = caller's argument byte ($FF = 'get', else the user number to set); BDOS_STACK_TOP =
5255  A92D              ;       current user number.
5256  A92D              ;   Out: if get: BDOS result A = current user number; if set: current user number BDOS_STACK_TOP
5257  A92D              ;        updated to (arg AND $1F).
5258  A92D              ;   Clobbers: A.
5259  A92D              ;   Algorithm: if the argument is $FF, return the current user number; otherwise mask the argument
5260  A92D              ;              to 0..31 and store it as the current user number.
5261  A92D              ;   [RE] dispatch fn 32 at $9C87; canonical CP/M 2.2 Get/Set User; $FF = query.
5262  A92D              ; ----------------------------------------------------------------------
5263  A92D              F_USERNUM_H:
5264  A92D                      ; A = caller's argument ($FF = query current user)
5265  A92D 3A D6 A9             LD A,(DRV_SELECT_ARG)
5266  A930                      ; is this a 'get current user' request?
5267  A930 FE FF                CP $FF
5268  A932                      ; no: it is a 'set user number' request
5269  A932 C2 3B A9             JP NZ,SET_USER_NUMBER
5270  A935                      ; get path: load the current user number
5271  A935 3A 41 9F             LD A,(BDOS_STACK_TOP)
5272  A938                      ; return it as the BDOS result
5273  A938 C3 01 9F             JP BDOS_RET_RESULT
5274  A93B              ; ----------------------------------------------------------------------
5275  A93B              ; SET_USER_NUMBER -- set path of BDOS function 32: change the current user number.
5276  A93B              ;   In: A = requested user number.
5277  A93B              ;   Out: current user number BDOS_STACK_TOP = A AND $1F (0..31).
5278  A93B              ;   Clobbers: A.
5279  A93B              ;   Algorithm: mask the requested user number to 5 bits and store it.
5280  A93B              ;   [RE] continuation of F_USERNUM_H (Get/Set User).
5281  A93B              ; ----------------------------------------------------------------------
5282  A93B              SET_USER_NUMBER:
5283  A93B                      ; clamp the user number to the range 0..31
5284  A93B E6 1F                AND $1F
5285  A93D                      ; store the new current user number
5286  A93D 32 41 9F             LD (BDOS_STACK_TOP),A
5287  A940 C9                   RET
5288  A941              ; ----------------------------------------------------------------------
5289  A941              ; F_READRAND_H -- BDOS function 33 (Read Random): read the record addressed by the FCB's
5290  A941              ; random-record field.
5291  A941              ;   In: BDOS_PARAM_PTR = pointer to an open FCB whose r0/r1/r2 ($21..$23) hold the target record
5292  A941              ;       number.
5293  A941              ;   Out: that record read into the DMA buffer; A = 0 on success or a random-read error code (e.g.
5294  A941              ;        1=reading unwritten data, 6=record number out of range); FCB positioned at that record.
5295  A941              ;   Clobbers: A, BC, DE, HL.
5296  A941              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the random-read core
5297  A941              ;              (FCB_EXTENT_TO_TRKSEC_8) which seeks to the random record and reads it.
5298  A941              ;   [RE] dispatch fn 33 at $9C89; canonical CP/M 2.2 Read Random.
5299  A941              ; ----------------------------------------------------------------------
5300  A941              F_READRAND_H:
5301  A941                      ; auto-select the FCB's drive prefix
5302  A941 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5303  A944                      ; position to the FCB's random record and read it
5304  A944 C3 93 A7             JP FCB_EXTENT_TO_TRKSEC_8
5305  A947              ; ----------------------------------------------------------------------
5306  A947              ; F_WRITERAND_H -- BDOS function 34 (Write Random): write the record addressed by the FCB's
5307  A947              ; random-record field.
5308  A947              ;   In: BDOS_PARAM_PTR = pointer to an open FCB whose r0/r1/r2 hold the target record number; DMA
5309  A947              ;       buffer holds the record.
5310  A947              ;   Out: that record written; A = 0 on success or a random-write error code; file extended/allocated
5311  A947              ;        as needed.
5312  A947              ;   Clobbers: A, BC, DE, HL.
5313  A947              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the random-write core
5314  A947              ;              (FCB_EXTENT_TO_TRKSEC_9).
5315  A947              ;   [RE] dispatch fn 34 at $9C8B; canonical CP/M 2.2 Write Random.
5316  A947              ; ----------------------------------------------------------------------
5317  A947              F_WRITERAND_H:
5318  A947                      ; auto-select the FCB's drive prefix
5319  A947 CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5320  A94A                      ; position to the FCB's random record and write it
5321  A94A C3 9C A7             JP FCB_EXTENT_TO_TRKSEC_9
5322  A94D              ; ----------------------------------------------------------------------
5323  A94D              ; F_SIZE_H -- BDOS function 35 (Compute File Size): set the FCB's random-record field to the file's
5324  A94D              ; record count.
5325  A94D              ;   In: BDOS_PARAM_PTR = pointer to the FCB naming the file.
5326  A94D              ;   Out: FCB r0/r1/r2 ($21..$23) set to the number of 128-byte records in the file (its 'virtual
5327  A94D              ;        size').
5328  A94D              ;   Clobbers: A, BC, DE, HL.
5329  A94D              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; jump into the size-compute core
5330  A94D              ;              (FCB_ALLOC_BLOCK_NUM_2) which scans the directory extents to find the highest record
5331  A94D              ;              and writes it into the FCB random-record field.
5332  A94D              ;   [RE] dispatch fn 35 at $9C8D; canonical CP/M 2.2 Compute File Size.
5333  A94D              ; ----------------------------------------------------------------------
5334  A94D              F_SIZE_H:
5335  A94D                      ; auto-select the FCB's drive prefix
5336  A94D CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5337  A950                      ; scan the file's extents and write its record count into the FCB
5338  A950 C3 D2 A7             JP FCB_ALLOC_BLOCK_NUM_2
5339  A953              ; ----------------------------------------------------------------------
5340  A953              ; DRV_RESET_H -- BDOS function 37 (Reset Drive): mark the drives named by the caller's bit mask as
5341  A953              ; no longer logged in.
5342  A953              ;   In: BDOS_PARAM_PTR = caller's reset bit-mask (one bit per drive to reset); DRV_SELECT_VECTOR = working
5343  A953              ;       login vector; DRV_LOGIN_VECTOR = master logged-in / R-O master vector.
5344  A953              ;   Out: for each drive bit set in the mask, that drive's bit is cleared in both DRV_SELECT_VECTOR and
5345  A953              ;        DRV_LOGIN_VECTOR, forcing a fresh log-in on next access.
5346  A953              ;   Clobbers: A, DE, HL.
5347  A953              ;   Algorithm: form the bitwise complement of the caller's reset mask (CPL of each byte of
5348  A953              ;              BDOS_PARAM_PTR); AND it into DRV_SELECT_VECTOR to clear those login bits and store back; then
5349  A953              ;              AND the now-masked login word with DRV_LOGIN_VECTOR (which also has the reset bits
5350  A953              ;              cleared) and store back, so the master vector loses the reset drives' bits too.
5351  A953              ;   [RE] dispatch fn 37 at $9C91; canonical CP/M 2.2 Reset Drive (selective reset). The auto-label
5352  A953              ;   'DIR_NAME_MASK' is unrelated to its real function.
5353  A953              ; ----------------------------------------------------------------------
5354  A953              DRV_RESET_H:
5355  A953                      ; HL = caller's reset bit-mask (one bit per drive to reset)
5356  A953 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
5357  A956 7D                   LD A,L
5358  A957                      ; complement the mask low byte (a 1 marks a drive to KEEP; 0 marks a drive being reset)
5359  A957 2F                   CPL
5360  A958 5F                   LD E,A
5361  A959 7C                   LD A,H
5362  A95A 2F                   CPL
5363  A95B                      ; HL = working login vector
5364  A95B 2A AF A9             LD HL,(DRV_SELECT_VECTOR)
5365  A95E                      ; clear the reset drives' bits in the login vector (high byte path)
5366  A95E A4                   AND H
5367  A95F 57                   LD D,A
5368  A960 7D                   LD A,L
5369  A961 A3                   AND E
5370  A962 5F                   LD E,A
5371  A963                      ; HL = master logged-in / R-O vector
5372  A963 2A AD A9             LD HL,(DRV_LOGIN_VECTOR)
5373  A966 EB                   EX DE,HL
5374  A967                      ; store the updated login vector
5375  A967 22 AF A9             LD (DRV_SELECT_VECTOR),HL
5376  A96A 7D                   LD A,L
5377  A96B A3                   AND E
5378  A96C 6F                   LD L,A
5379  A96D 7C                   LD A,H
5380  A96E A2                   AND D
5381  A96F 67                   LD H,A
5382  A970                      ; store the master vector with the reset drives cleared
5383  A970 22 AD A9             LD (DRV_LOGIN_VECTOR),HL
5384  A973 C9                   RET
5385  A974              ; ----------------------------------------------------------------------
5386  A974              ; FCB_AUTO_DRIVE_RESTORE -- file-operation epilogue: undo a temporary drive switch made by
5387  A974              ; FCB_AUTO_DRIVE_SELECT, then return the BDOS result.
5388  A974              ;   In: DRV_RESTORE_FLAG = restore-pending flag (0 = no switch was made); BDOS_PARAM_PTR = FCB pointer; DRV_SAVED_FCB_BYTE
5389  A974              ;       = saved FCB drive byte; DRV_SAVED_DRIVE = saved drive number; BDOS_SAVED_SP = saved BDOS stack
5390  A974              ;       pointer; BDOS_RETVAL = BDOS result.
5391  A974              ;   Out: if a switch was pending, the FCB's drive byte and the current drive are restored to their
5392  A974              ;        pre-call values (DRV_SET_H reselects the original drive); then control falls into
5393  A974              ;        BDOS_RETURN_RESULT to restore the BDOS stack and deliver A = result low byte (B = high
5394  A974              ;        byte).
5395  A974              ;   Clobbers: A, B, HL, SP.
5396  A974              ;   Algorithm: if no temporary switch was made (DRV_RESTORE_FLAG==0) skip to the result return; else clear the
5397  A974              ;              FCB drive byte ($00), and if the saved original byte (DRV_SAVED_FCB_BYTE) is nonzero restore it;
5398  A974              ;              restore the saved current drive (DRV_SAVED_DRIVE -> DRV_SELECT_ARG) and reselect it via DRV_SET_H;
5399  A974              ;              fall into BDOS_RETURN_RESULT.
5400  A974              ;   [RE] this is the universal file-op epilogue that pairs with FCB_AUTO_DRIVE_SELECT; the
5401  A974              ;   'DIR_NAME_MASK' auto-label is unrelated.
5402  A974              ; ----------------------------------------------------------------------
5403  A974              FCB_AUTO_DRIVE_RESTORE:
5404  A974                      ; was a temporary drive switch made by the preamble?
5405  A974 3A DE A9             LD A,(DRV_RESTORE_FLAG)
5406  A977 B7                   OR A
5407  A978                      ; no switch: skip restore, go straight to the result return
5408  A978 CA 91 A9             JP Z,BDOS_RETURN_RESULT
5409  A97B                      ; HL -> FCB whose drive byte was modified
5410  A97B 2A 43 9F             LD HL,(BDOS_PARAM_PTR)
5411  A97E                      ; clear the FCB drive byte before restoring it
5412  A97E 36 00                LD (HL),$00
5413  A980                      ; A = saved original FCB drive-prefix byte
5414  A980 3A E0 A9             LD A,(DRV_SAVED_FCB_BYTE)
5415  A983 B7                   OR A
5416  A984                      ; saved byte was 0 (no real prefix): nothing to put back, go to result return
5417  A984 CA 91 A9             JP Z,BDOS_RETURN_RESULT
5418  A987                      ; restore the original FCB drive-prefix byte
5419  A987 77                   LD (HL),A
5420  A988                      ; A = saved current drive number
5421  A988 3A DF A9             LD A,(DRV_SAVED_DRIVE)
5422  A98B                      ; set it as the drive to reselect
5423  A98B 32 D6 A9             LD (DRV_SELECT_ARG),A
5424  A98E                      ; reselect the drive that was current before the call
5425  A98E CD 45 A8             CALL DRV_SET_H
5426  A991              ; ----------------------------------------------------------------------
5427  A991              ; BDOS_RETURN_RESULT -- final BDOS exit: restore the entry stack and deliver the result to the
5428  A991              ; caller.
5429  A991              ;   In: BDOS_SAVED_SP = saved BDOS entry stack pointer; BDOS_RETVAL = 16-bit BDOS result.
5430  A991              ;   Out: SP restored to the BDOS entry stack; A = result low byte, B = result high byte (HL also =
5431  A991              ;        result).
5432  A991              ;   Clobbers: A, B, HL, SP.
5433  A991              ;   Algorithm: load the saved stack pointer into SP; load the 16-bit result into HL; copy L->A and
5434  A991              ;              H->B so both the 8-bit (A) and 16-bit (HL/BA) return conventions are satisfied;
5435  A991              ;              return to the BDOS dispatcher.
5436  A991              ;   [RE] the common tail every BDOS function returns through; pairs the saved-SP restore with the
5437  A991              ;   result hand-off.
5438  A991              ; ----------------------------------------------------------------------
5439  A991              BDOS_RETURN_RESULT:
5440  A991                      ; HL = saved BDOS entry stack pointer
5441  A991 2A 0F 9F             LD HL,(BDOS_SAVED_SP)
5442  A994                      ; restore the BDOS entry stack (drop any locals)
5443  A994 F9                   LD SP,HL
5444  A995                      ; HL = the 16-bit BDOS result value
5445  A995 2A 45 9F             LD HL,(BDOS_RETVAL)
5446  A998                      ; A = result low byte (8-bit return convention)
5447  A998 7D                   LD A,L
5448  A999                      ; B = result high byte (16-bit return convention)
5449  A999 44                   LD B,H
5450  A99A C9                   RET
5451  A99B              ; ----------------------------------------------------------------------
5452  A99B              ; F_WRITEZF_H -- BDOS function 40 (Write Random with Zero Fill): like Write Random, but newly
5453  A99B              ; allocated blocks are pre-filled with zeros.
5454  A99B              ;   In: BDOS_PARAM_PTR = pointer to an open FCB whose r0/r1/r2 hold the target record number; DMA
5455  A99B              ;       buffer holds the record.
5456  A99B              ;   Out: the record written at the random position; any block newly allocated to reach it is
5457  A99B              ;        zero-filled first; A = 0 or a random-write error code.
5458  A99B              ;   Clobbers: A, BC, DE, HL.
5459  A99B              ;   Algorithm: FCB_AUTO_DRIVE_SELECT honors the drive prefix; set write-mode WRITE_TYPE_FLAG=2 (zero-fill);
5460  A99B              ;              C=0; call the random-record extract/seek core (BDOS_SEEK_COMPUTE) and, on success
5461  A99B              ;              (Z), perform the write (BDOS_WRITE).
5462  A99B              ;   [RE] dispatch fn 40 at $9C97; canonical CP/M 2.2 Write Random with Zero Fill; WRITE_TYPE_FLAG=2
5463  A99B              ;   distinguishes it from normal Write Random.
5464  A99B              ; ----------------------------------------------------------------------
5465  A99B              F_WRITEZF_H:
5466  A99B                      ; auto-select the FCB's drive prefix
5467  A99B CD 51 A8             CALL FCB_AUTO_DRIVE_SELECT
5468  A99E                      ; write-mode 2 = write random with zero fill of new blocks
5469  A99E 3E 02                LD A,$02
5470  A9A0                      ; select zero-fill write mode
5471  A9A0 32 D5 A9             LD (WRITE_TYPE_FLAG),A
5472  A9A3                      ; C=0 parameter to the random-record extract core
5473  A9A3 0E 00                LD C,$00
5474  A9A5                      ; decode the FCB random record and seek/allocate to it
5475  A9A5 CD 07 A7             CALL BDOS_SEEK_COMPUTE
5476  A9A8                      ; on success, write the record (with zero-filled new blocks)
5477  A9A8 CC 03 A6             CALL Z,BDOS_WRITE
5478  A9AB C9                   RET
5479  A9AC              EMPTY_DIR_FCB:
5480  A9AC E5                   DEFB    $E5

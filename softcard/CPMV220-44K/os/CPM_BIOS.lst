1466  AF4A              ; ----------------------------------------------------------------------
1467  AF4A              ; DEV_HANDLER_PTRS -- DEFW table of disk read/write handler addresses (primary group),
1468  AF4A              ;   indexed by DEV_HANDLER_LOOKUP. Continues as DEV_HANDLER_PTRS_B (+6). DATA.
1469  AF4A              ;   Each entry should relocate from a literal address to the named target:
1470  AF4A              ;     [0] $ACDF -> DISK_RD_HANDLER_A  (CALL SLOT_IO_ADDR sector-bit read handler in the
1471  AF4A              ;         CTRL_HANDLER_OFFSET_TBL data/code region)
1472  AF4A              ;     [1] $AD04 -> PLOT_CHAR_AT_COL        (named handler just below)
1473  AF4A              ;     [2] $AD31 -> DISK_WR_HANDLER_B (handler tail in the $AD22 data/code region)
1474  AF4A              ;   and DEV_HANDLER_PTRS_B holds:
1475  AF4A              ;     [0] $AD12 -> DISK_RD_HANDLER_B (RRA bit-test read handler at the $AD12 block)
1476  AF4A              ;     [1] $AD1C -> DISK_WR_HANDLER_A (CALL SET_SCREEN_BASE write handler in the $AD22 block)
1477  AF4A              ;   See flags: these targets currently sit inside DEFB blocks (CTRL_HANDLER_OFFSET_TBL / $AD12 /
1478  AF4A              ;   $AD22)
1479  AF4A              ;   that are really handler CODE, so the relocations need those blocks named first.
1480  AF4A              ; ----------------------------------------------------------------------
1481  AF4A              DEV_HANDLER_PTRS:
1482  AF4A                      ; table of device-handler addresses (DEFW). DEV_HANDLER_LOOKUP indexes from
1483  AF4A                      ; here; DEV_HANDLER_LOOKUP_B indexes from DEV_HANDLER_PTRS_B (+6). Selected per config
1484  AF4A                      ; by DISK_WRITE_HOST to install the right console/disk handler into the vector slots.
1485  AF4A DF AC                DEFW    DEV_STROBE_RD            ; [0]
1486  AF4C 04 AD                DEFW    PLOT_CHAR_AT_COL         ; [1]
1487  AF4E 31 AD                DEFW    DEV_WR_BIT               ; [2]
1488  AF50              DEV_HANDLER_PTRS_B:
1489  AF50 12 AD                DEFW    DEV_READ_BIT             ; DEV_HANDLER_LOOKUP_B base
1490  AF52 1C AD                DEFW    DEV_OUT_RPC
1491  AF54              ; ----------------------------------------------------------------------
1492  AF54              ; DEV_HANDLER_LOOKUP_B -- fetch a disk-handler address from DEV_HANDLER_PTRS_B[A].
1493  AF54              ;   In:  A = entry index (0-based). Out: HL = handler address. Clobbers: A,HL.
1494  AF54              ;   Algorithm: point HL at DEV_HANDLER_PTRS_B then fall into the shared index loader
1495  AF54              ;   (HL += A*2; HL = word at that slot). Used by DISK_WRITE_HOST to install the per-config
1496  AF54              ;   read/write handler addresses. [RE]
1497  AF54              ; ----------------------------------------------------------------------
1498  AF54              DEV_HANDLER_LOOKUP_B:
1499  AF54                      ; select the secondary handler-pointer table
1500  AF54 21 50 AF             LD HL,DEV_HANDLER_PTRS_B
1501  AF57 18 03                JR DISK_RTN_LOOKUP_IDX
1502  AF59              ; ----------------------------------------------------------------------
1503  AF59              ; DEV_HANDLER_LOOKUP -- fetch a disk-handler address from DEV_HANDLER_PTRS[A].
1504  AF59              ;   In:  A = entry index (0-based). Out: HL = handler address. Clobbers: A,HL.
1505  AF59              ;   Algorithm: HL = base; HL += A*2 (ADD A,A; ADD A,L; LD L,A); HL = the 16-bit word
1506  AF59              ;   at that slot (low then high). Shared tail of DEV_HANDLER_LOOKUP_B. [RE]
1507  AF59              ; ----------------------------------------------------------------------
1508  AF59              DEV_HANDLER_LOOKUP:
1509  AF59                      ; select the primary handler-pointer table
1510  AF59 21 4A AF             LD HL,DEV_HANDLER_PTRS
1511  AF5C              DISK_RTN_LOOKUP_IDX:
1512  AF5C                      ; index*2 for 16-bit (word) table entries
1513  AF5C 87                   ADD A,A
1514  AF5D 85                   ADD A,L
1515  AF5E 6F                   LD L,A
1516  AF5F                      ; load handler address low byte
1517  AF5F 7E                   LD A,(HL)
1518  AF60 2C                   INC L
1519  AF61                      ; load handler address high byte -> HL = handler entry
1520  AF61 66                   LD H,(HL)
1521  AF62 6F                   LD L,A
1522  AF63 C9                   RET
1523  AF64              ; ----------------------------------------------------------------------
1524  AF64              ; SIGNON_EMIT -- emit one sign-on byte, optionally preceded by a fixed prefix char.
1525  AF64              ;   In:  A = byte/flag. Out: none (prints via CONOUT_DISPATCH=CONOUT-class writer).
1526  AF64              ;   Algorithm: if A is positive (bit7 clear) just print it; if negative, first print
1527  AF64              ;   the prefix char from the config block (Apple $0397) then print A. Called twice from
1528  AF64              ;   the boot path to emit two config-derived sign-on chars before the banner. [RE]
1529  AF64              ; ----------------------------------------------------------------------
1530  AF64              SIGNON_EMIT:
1531  AF64 B7                   OR A
1532  AF65                      ; bit7 clear -> emit the char directly
1533  AF65 F2 70 AF             JP P,SIGNON_EMIT_CHAR
1534  AF68 F5                   PUSH AF
1535  AF69                      ; negative flag: fetch the prefix char from the config block (Apple $0397)
1536  AF69 3A 97 F3             LD A,($F397)
1537  AF6C                      ; emit the prefix char
1538  AF6C CD 42 AB             CALL CONOUT_DISPATCH
1539  AF6F F1                   POP AF
1540  AF70              SIGNON_EMIT_CHAR:
1541  AF70                      ; tail-call to emit the original char
1542  AF70 C3 42 AB             JP CONOUT_DISPATCH
1543  AF73              ; ----------------------------------------------------------------------
1544  AF73              ; SIGNON_BANNER -- the cold-boot sign-on string, printed char-by-char by the boot path
1545  AF73              ;   (loop at DEV_INSTALL_7) until the $00 terminator. Reads:
1546  AF73              ;   'Apple ][ CP/M' / '44K Ver. 2.20' / '(C) 1980 Microsoft', CR/LF separated. DATA.
1547  AF73              ; ----------------------------------------------------------------------
1548  AF73              SIGNON_BANNER:
1549  AF73 0D 0A 0D 0A          DEFB    "\r\n\r\n\r\n"
1549  AF77 0D 0A
1550  AF79 41 70 70 6C          DEFB    "Apple ][ CP/M"          ; string
1550  AF7D 65 20 5D 5B
1550  AF81 20 43 50 2F
1550  AF85 4D
1551  AF86 0D                   DEFB    $0D                      ; terminator
1552  AF87 0A                   DEFB    "\n"
1553  AF88 34 34 4B 20          DEFB    "44K Ver. 2.20"          ; string
1553  AF8C 56 65 72 2E
1553  AF90 20 32 2E 32
1553  AF94 30
1554  AF95 0D                   DEFB    $0D                      ; terminator
1555  AF96 0A                   DEFB    "\n"
1556  AF97 28 43 29 20          DEFB    "(C) 1980 Microsoft"     ; string
1556  AF9B 31 39 38 30
1556  AF9F 20 4D 69 63
1556  AFA3 72 6F 73 6F
1556  AFA7 66 74
1557  AFA9 0D                   DEFB    $0D                      ; terminator
1558  AFAA 0A 0D 0A 00          DEFB    "\n\r\n\0"
1559  AFAE              ; ----------------------------------------------------------------------
1560  AFAE              ; IO_VECTOR_DEFAULTS -- 22-byte (BC=$0016) DATA table of default I/O handler pointers,
1561  AFAE              ;   copied by the boot path (LDIR) into the SoftCard config/vector page at $F380=Apple
1562  AFAE              ;   $0380 when that page is uninitialized ($F381==0). The first 22 bytes are eleven
1563  AFAE              ;   little-endian addresses ($AB0C,$AB12,$AB12,$AC3E,$AC3E,$AD45,$AD45,$AD3F,$AD3F,
1564  AFAE              ;   $AD2B,$AD2B) mirroring console/list/punch/reader/disk handler entry points; only
1565  AFAE              ;   those 22 bytes are copied. This is a DATA pointer table, not relocated code. The
1566  AFAE              ;   bytes past offset 22 ($AFC4 onward) coincidentally re-mirror nearby handler code
1567  AFAE              ;   but are NOT executed from here. [RE] -- see flags.
1568  AFAE              ; ----------------------------------------------------------------------
1569  AFAE              IO_VECTOR_DEFAULTS:
1570  AFAE 0C AB                DEFW    KBD_STATUS_40COL         ; CONST (40-col keyboard status)
1571  AFB0 12 AB                DEFW    CONSOLE_IN_40COL         ; CONIN
1572  AFB2 12 AB                DEFW    CONSOLE_IN_40COL
1573  AFB4 3E AC                DEFW    PUT_CHAR_DE3             ; CONOUT
1574  AFB6 3E AC                DEFW    PUT_CHAR_DE3
1575  AFB8 45 AD                DEFW    DEV_OUT_3                ; LIST/PUNCH/READER stubs
1576  AFBA 45 AD                DEFW    DEV_OUT_3
1577  AFBC 3F AD                DEFW    DEV_OUT_2
1578  AFBE 3F AD                DEFW    DEV_OUT_2
1579  AFC0 2B AD                DEFW    DEV_OUT_1
1580  AFC2 2B AD                DEFW    DEV_OUT_1
1581  AFC4                      ; $AFC4-$AFEF: an in-image second copy of the DEV_HANDLER_PTRS table + the
1582  AFC4                      ; DEV_HANDLER_LOOKUP / SIGNON_EMIT routines (byte-identical to $AF4A-$AF6F);
1583  AFC4                      ; not referenced or executed from here. [RE]
1584  AFC4 42 AB E1 23          DEFB    $42,$AB,$E1,$23,$18,$F3,$DF,$AC,$04,$AD,$31,$AD,$12,$AD,$1C,$AD
1584  AFC8 18 F3 DF AC
1584  AFCC 04 AD 31 AD
1584  AFD0 12 AD 1C AD
1585  AFD4 21 50 AF 18          DEFB    $21,$50,$AF,$18,$03,$21,$4A,$AF,$87,$85,$6F,$7E,$2C,$66,$6F,$C9
1585  AFD8 03 21 4A AF
1585  AFDC 87 85 6F 7E
1585  AFE0 2C 66 6F C9
1586  AFE4 B7 F2 70 AF          DEFB    $B7,$F2,$70,$AF,$F5,$3A,$97,$F3,$CD,$42,$AB,$F1
1586  AFE8 F5 3A 97 F3
1586  AFEC CD 42 AB F1
1587  AFF0              ; ----------------------------------------------------------------------
1588  AFF0              ; READ_SEKSEC -- load the current deblock sector and set flags.
1589  AFF0              ;   In:  none. Out: A = current sector (from BOOT+1=seksec); Z set if sector==0.
1590  AFF0              ;   Clobbers: A. Called by the READ/WRITE deblock path to test/translate the sector.
1591  AFF0              ;   Note BOOT+1 is the post-boot reuse of the BOOT 'LD SP,$0100' operand byte. [RE]
1592  AFF0              ; ----------------------------------------------------------------------
1593  AFF0              READ_SEKSEC:
1594  AFF0                      ; read the current deblock sector (BOOT+1 reused as seksec)
1595  AFF0 3A A9 AE             LD A,(BOOT+1)
1596  AFF3                      ; set Z/sign flags on the sector value for the caller
1597  AFF3 B7                   OR A
1598  AFF4 C9                   RET
1599  AFF5 0D 0A 0D 0A          DEFB    "\r\n\r\nApple ]"
1599  AFF9 41 70 70 6C
1599  AFFD 65 20 5D
1600  B000
1601  B000                  IFNDEF CPM_LINK
1602  B000                  SAVEBIN "{out_bin}", $AA00, $0600
1603  B000                  ENDIF
1604  B000
# file closed: CPM_BIOS.asm

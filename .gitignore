# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# Script output directory
apple-ii/apple-panic/output/

# Rebuilt disk images from the decompiled distributions (regenerable)
softcard/*/rebuilt/

# Emulator-produced 60K disk (regenerable by running CPM60.COM in softcard_emu)
softcard/CPMV223-60K/CPMV223-60K-EMU.DSK

# Large generated images (reproducible via nibbler flux)
**/*_flux.png
**/flux_image.png

# Large emulation artifacts (reproducible via nibbler)
boot_trace.log
decoded_sectors/
emu_*.bin
**/game_*.bin
**/lowmem_*.bin
**/rwts_*.bin
**/title_*.bin
# cross-CPU INCBIN build artifacts: the .asm/.s sources are tracked, the .bin is
# sub-assembled at build time (see chunk_map incbin_deps) and must not be tracked
**/CPM_BootLoader_*.bin
**/CPM_RPC6502.bin

# IDE / editor
.vscode/
.idea/
*.swp
*~

# Claude Code project config
.claude/

# OS
Thumbs.db
.DS_Store

# Local toolchain (per-developer; reinstall via shared/toolchain/README.md)
shared/toolchain/cc65/
shared/toolchain/sjasmplus/
shared/toolchain/*.zip
shared/toolchain/smoke_*.o
shared/toolchain/smoke_*.bin

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/

# Script output directory
apple-ii/apple-panic/output/

# Rebuilt disk images from the decompiled distributions (regenerable)
softcard/*/rebuilt/

# Emulator-produced 60K disk (regenerable by running CPM60.COM in softcard_emu)
softcard/CPMV223-60K/CPMV223-60K-EMU.DSK

# Large generated images (reproducible via nibbler flux)
**/*_flux.png
**/flux_image.png

# Large emulation artifacts (reproducible via nibbler)
boot_trace.log
decoded_sectors/
emu_*.bin
**/game_*.bin
**/lowmem_*.bin
**/rwts_*.bin
**/title_*.bin
**/installfragments_*.bin
# cross-CPU INCBIN build artifacts: the .asm/.s sources are tracked, the .bin is
# sub-assembled at build time (see chunk_map incbin_deps) and must not be tracked
**/CPM_BootLoader_*.bin
**/CPM_RPC6502.bin
# stray build artifacts an assemble/verify step may leave in an os/ source dir:
# the per-chunk .bin output and any include copy staged beside the source. The
# canonical includes live in softcard/include/; the build stages its own copies.
**/os/*.bin
**/os/apple_softcard.inc
**/os/cpm22.inc

# BASIC fold listings: GBASIC.lst / MBASIC.lst are the per-build address+machine-code
# reference, emitted by `python -m cpm_pipeline.basic.fold_build` (the master BASIC.asm
# no longer carries inline `; $XXXX <bytes>` comments). Regenerated, not tracked.
**/utilities/*.lst
# CP/M OS listings (CPM_BIOS.lst, CPM_CCP.lst, ...) -- the per-file address+machine-code
# reference emitted by cpm_pipeline.os_listing; the os/ .asm carries no inline `$addr`
# comments either. Regenerated, not tracked.
**/os/*.lst

# IDE / editor
.vscode/
.idea/
*.swp
*~

# Claude Code project config
.claude/

# OS
Thumbs.db
.DS_Store

# Local toolchain (per-developer; reinstall via shared/toolchain/README.md)
shared/toolchain/cc65/
shared/toolchain/sjasmplus/
shared/toolchain/*.zip
shared/toolchain/smoke_*.o
shared/toolchain/smoke_*.bin
